  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially validated code with documented QA procedures, version control, and regression test suite. Software QA documentation reviewed and confirmed compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Order-of-accuracy tests performed on canonical rotating-disk flow confirm second-order spatial convergence. Method of manufactured solutions applied to the hemolysis transport equation with observed convergence rates consistent with theoretical expectations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Systematic mesh refinement study conducted across three mesh densities (2.1 M, 6.4 M, 14.8 M cells). Richardson extrapolation yields a grid convergence index below 3% for hemolysis index at the design operating point, satisfying MRL 2 discretization error requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Experimental test conditions from the FDA GCBP benchmark are well-documented including fluid properties (bovine blood, 37 °C, Hct 35%), inlet boundary conditions, and rotational speeds. Boundary conditions in the simulation replicate experimental conditions within measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Simulated normalized index of hemolysis (NIH) compared against FDA experimental measurements across five operating points. Mean absolute relative error of 11.4% with no systematic bias. Comparison metric satisfies MRL 2 output comparison requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The primary quantity of interest—normalized index of hemolysis—directly maps to the clinical decision endpoint of identifying worst-case hemolysis operating conditions. Secondary QoIs (wall shear stress, scalar stress exposure) are mechanistically linked to erythrocyte damage and are appropriate surrogates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Validation activities used the FDA GCBP geometry, which is representative of the centrifugal pump class under assessment. Operating conditions span the clinically relevant CPB flow range (2–8 L/min). The validation domain adequately covers the intended use envelope described in the package narrative."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default level 1 acceptance applies.",
      "rationale": "Numerical solver error assessment beyond code verification is not required at MRL 2. Iterative convergence is monitored via residual reduction to 1e-6 and flux imbalance below 0.01%, which is sufficient for the declared risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default level 1 acceptance applies.",
      "rationale": "Formal use-error assessment is not required at MRL 2. Simulation inputs and setup procedures are documented in the simulation report and reviewed by a second analyst to reduce operator error risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default level 1 acceptance applies.",
      "rationale": "Formal model-form uncertainty quantification is not required at MRL 2. The power-law hemolysis model (Giersiepen-Wurzinger) is the established standard for CFD hemolysis prediction in rotary blood pumps and its limitations are acknowledged in the simulation report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default level 1 acceptance applies.",
      "rationale": "Sensitivity analysis of model input parameters is not required at MRL 2. Nominal material properties and boundary conditions are sourced from peer-reviewed literature and the FDA benchmark dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default level 1 acceptance applies.",
      "rationale": "Statistical characterization of experimental sample variability is not required at MRL 2. The FDA benchmark provides triplicate measurements at each operating point; mean values are used for comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default level 1 acceptance applies.",
      "rationale": "Formal equivalency analysis between validation and deployment input parameters is not required at MRL 2. Qualitative review confirms that the validation fluid properties and operating conditions are representative of CPB clinical use as described in the package narrative."
    }
