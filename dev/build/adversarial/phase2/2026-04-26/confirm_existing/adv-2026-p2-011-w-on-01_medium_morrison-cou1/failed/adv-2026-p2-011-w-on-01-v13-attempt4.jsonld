  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan with version control and regression testing.",
      "rationale": "ANSYS Fluent 2022 R2 was employed under an ISO 9001-compliant QA framework. Version control logs, regression test reports, and release notes were reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems with known analytical solutions.",
      "rationale": "The CFD solver was verified against the lid-driven cavity and backward-facing step benchmarks. Computed velocity profiles matched analytical solutions within 1.2%, satisfying the MRL 2 code verification requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence must be demonstrated using at least three systematically refined meshes with GCI less than 5% for the primary QoI.",
      "rationale": "Three meshes (2.1M, 5.8M, and 14.3M elements) were evaluated. Richardson extrapolation yielded a GCI of 3.7% for the hemolysis index, confirming adequate spatial resolution at the medium mesh level used for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions used in validation testing must be documented and traceable to calibrated measurement equipment.",
      "rationale": "FDA benchmark experimental data were collected at controlled flow rates (2–6 L/min) and rotational speeds (2000–3500 RPM). Calibration certificates for flow meters and pressure transducers were reviewed and confirmed traceable to NIST standards."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared quantitatively to experimental measurements with documented metrics (e.g., RMSE, normalized error) within an accepted tolerance band.",
      "rationale": "Hemolysis index predictions were compared to FDA experimental measurements across 15 operating points. Normalized index of agreement was 0.91 and RMSE was 0.0023, both within the pre-specified acceptance band for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs extracted from simulation must be directly relevant to the clinical or engineering decision being supported.",
      "rationale": "Hemolysis index and shear stress distributions are the primary QoIs. Both are directly linked to red blood cell damage mechanisms relevant to CPB device safety evaluation, confirming their relevance to the intended decision context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must reflect the geometry, fluid properties, and operating conditions representative of the intended use.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry with bovine blood analog fluid at physiological hematocrit. Operating conditions spanned the full clinical CPB range, providing strong relevance to the intended use and exceeding MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must be documented and shown to be below solver-specific thresholds.",
      "rationale": "At MRL 2, formal numerical solver error assessment beyond residual monitoring is not required. Residuals were monitored to 1e-5 for all equations; no further quantification was scoped for this assessment level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential errors arising from incorrect model application or misinterpretation of outputs must be identified and mitigated.",
      "rationale": "Formal use error analysis is not required at MRL 2. Analyst training records and simulation setup checklists were maintained internally but not formally assessed under this credibility framework."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The mathematical form of the governing equations and constitutive relations must be appropriate for the physical phenomena of interest.",
      "rationale": "The RANS k-omega SST turbulence model with the Giersiepen-Wurzinger hemolysis power-law model was selected based on published literature consensus. Formal model form uncertainty quantification is not required at MRL 2 and was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of model outputs to input parameter uncertainty must be characterized to an extent commensurate with the model risk level.",
      "rationale": "Input parameter sensitivity analysis (e.g., blood viscosity, hemolysis model coefficients) is not required at MRL 2. Nominal values from published clinical references were used without formal uncertainty propagation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The number and selection of experimental test samples must be sufficient to characterize variability in the validation dataset.",
      "rationale": "The FDA benchmark dataset provides a single pump geometry tested under controlled conditions. Statistical characterization of inter-sample variability is not required at MRL 2 and was not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters used in simulation must be demonstrably equivalent to those present in the validation experiment.",
      "rationale": "Boundary conditions were matched to experimental values as reported in the FDA dataset documentation. Formal equivalency analysis beyond direct parameter matching is not required at MRL 2 and was not conducted."
    }
  ],
