  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors met or exceeded their required levels for MRL 2. The six non-assessed factors are appropriately scoped out at this model risk level. The CFD hemolysis model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions for the Class II CPB device. The assessment team accepts this model for the stated engineering decision.",
