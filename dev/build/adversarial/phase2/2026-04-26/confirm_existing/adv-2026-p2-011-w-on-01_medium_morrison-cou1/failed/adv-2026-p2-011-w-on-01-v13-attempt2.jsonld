      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA process with version control and regression testing at Gradation 2.",
      "rationale": "ANSYS Fluent 2022 R1 was used under an ISO 9001-compliant QA framework. Version control logs, regression test results, and release notes were reviewed and confirmed to satisfy Gradation 2 requirements for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical algorithms must be verified against analytical or manufactured solutions demonstrating expected convergence order at Gradation 2.",
      "rationale": "The Navier-Stokes solver was verified using the method of manufactured solutions on canonical geometries. Second-order spatial convergence was confirmed, meeting Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified using a systematic mesh refinement study with GCI reported at Gradation 2 or higher.",
      "rationale": "A three-level mesh refinement study was performed on the FDA centrifugal pump geometry. GCI values below 2.5% were achieved for wall shear stress and velocity magnitude at the design operating point, exceeding Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to confirm representativeness of the COU at Gradation 2.",
      "rationale": "FDA benchmark experimental data were collected under controlled laboratory conditions matching the pump geometry and flow rates specified for CPB operation. Boundary conditions and fluid properties were documented and confirmed consistent with simulation inputs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be quantitatively compared to experimental measurements using appropriate metrics at Gradation 2.",
      "rationale": "Hemolysis index predictions were compared to FDA experimental measurements using normalized RMS error and Bland-Altman analysis. Agreement within 15% across operating conditions was demonstrated, satisfying Gradation 2 output comparison requirements."
    },
    {
      "type": "CredibilityFactor",
