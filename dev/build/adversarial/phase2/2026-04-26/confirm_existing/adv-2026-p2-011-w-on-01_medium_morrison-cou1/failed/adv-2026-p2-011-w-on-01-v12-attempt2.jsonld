      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation execution is performed by trained personnel following documented standard operating procedures.",
      "rationale": "MRL 2 does not require formal use-error analysis. Simulations are executed by engineers with documented CFD training. This factor is scoped to minimum level and not formally assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form assumptions (turbulence model, hemolysis constitutive law) are documented and justified by literature precedent.",
      "rationale": "The SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power law are selected based on published precedent for blood pump CFD. Formal model-form uncertainty quantification is not required at MRL 2 and is not assessed."
    },
    {
      "type": "CredibilityFactor",
