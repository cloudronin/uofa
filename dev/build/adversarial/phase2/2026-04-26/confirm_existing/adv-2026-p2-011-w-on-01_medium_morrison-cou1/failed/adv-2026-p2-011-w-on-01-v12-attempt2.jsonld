  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control, regression testing suite, and documented QA procedures in place for the CFD platform used.",
      "rationale": "The CFD solver (OpenFOAM v9) is under version control with documented regression tests covering relevant turbulence and hemolysis sub-models. QA procedures satisfy MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions or equivalent benchmark verification demonstrating correct implementation of governing equations.",
      "rationale": "Benchmark verification against canonical rotating-flow cases (Taylor-Couette, lid-driven cavity) confirms correct implementation of the Navier-Stokes solver and hemolysis power-law sub-model at MRL 2 level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study with at least three mesh refinement levels; GCI reported for primary QoI.",
      "rationale": "A three-level mesh refinement study (2.1M, 6.4M, 18.7M cells) was performed. GCI for hemolysis index at the worst-case operating point is 4.2%, below the 5% threshold. Achieves level 3 despite MRL 2 requiring only level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented and traceable; fluid properties, boundary conditions, and operating points match simulation inputs within stated tolerances.",
      "rationale": "In-vitro test conditions (bovine blood analog, temperature 37°C, hematocrit 35%) are fully documented and traceable to calibrated instrumentation records. Boundary conditions in the CFD model are set to match within 2% of measured values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation metric U_val) computed and reported for primary QoI.",
      "rationale": "Normalized RMS error between predicted and measured hemolysis index across five operating points is 8.3%, within the 10% acceptance threshold established for MRL 2. Pressure-flow characteristic agreement is within 5%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (hemolysis index) is directly linked to the clinical risk metric and device safety claim.",
      "rationale": "The hemolysis index (normalized index of hemolysis, NIH) is the regulatory-accepted metric for blood damage in CPB devices and directly maps to the device safety claim. Relevance is established through FDA guidance and published literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments cover the operating envelope relevant to CPB use; geometry and fluid conditions are representative of the COU.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry under CPB-representative flow rates (3–6 L/min) and rotational speeds (2500–4500 RPM). The validation domain overlaps the intended clinical operating envelope, satisfying MRL 2 relevance requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence criteria documented; residuals reported for all solved variables.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond residual monitoring is not required. Solver residuals drop below 1e-5 for all variables; this factor is not assessed beyond the minimum threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
