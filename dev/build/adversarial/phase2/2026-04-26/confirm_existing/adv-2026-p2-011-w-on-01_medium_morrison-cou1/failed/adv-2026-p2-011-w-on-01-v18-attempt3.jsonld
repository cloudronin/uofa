  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented version control, regression testing suite, and traceable release notes consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R1 is used with documented QA procedures including version-controlled source, automated regression tests covering hemolysis-relevant flow regimes, and FDA-traceable release documentation. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via method-of-manufactured-solutions or equivalent benchmark problems at MRL 2.",
      "rationale": "Code verification confirmed against Taylor-Couette and lid-driven cavity benchmarks with convergence rates consistent with second-order spatial accuracy. Published verification suite results are available in the solver documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study using at least three mesh refinement levels with GCI below 5% for the hemolysis index quantity of interest.",
      "rationale": "Three-level mesh refinement study performed (4.2 M, 9.8 M, 21.4 M cells). GCI for normalized hemolysis index was 3.1%, meeting the 5% threshold. Medium mesh (9.8 M) selected for production runs balancing accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to replicate boundary conditions in the simulation, including flow rate, rotational speed, and fluid properties.",
      "rationale": "FDA experimental conditions are fully documented: flow rates 2–8 L/min, rotational speeds 2000–4000 RPM, bovine blood with measured viscosity and density. Boundary conditions in CFD match experimental protocol within stated uncertainty bands."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized hemolysis index error) must be below 15% across the operating envelope for MRL 2.",
      "rationale": "Normalized hemolysis index predictions agree with FDA experimental measurements within 11.4% across all tested operating points. Systematic bias is within experimental measurement uncertainty of ±8%, supporting model adequacy for worst-case identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated quantity of interest (normalized hemolysis index) must be directly traceable to the clinical endpoint of red blood cell damage under CPB conditions.",
      "rationale": "The normalized hemolysis index (NIH) is the regulatory-accepted surrogate for hemolytic potential in blood-contacting devices. NIH is directly linked to the clinical risk of hemolytic anemia under CPB. Relevance is well-established in literature and FDA guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the operating envelope relevant to CPB use, including the range of flow rates and rotational speeds encountered clinically.",
      "rationale": "FDA benchmark experiments span 2–8 L/min and 2000–4000 RPM, encompassing the clinically relevant CPB operating range of 3–6 L/min. Geometric similarity between the FDA generic pump and Class II CPB devices is documented in the validation report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance of 1e-5 for all transport equations is sufficient at MRL 2 without additional solver error quantification.",
      "rationale": "At MRL 2, explicit solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations; this factor is not assessed per the MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use-error analysis is not required provided standard simulation practice guidelines are followed.",
      "rationale": "Simulation was conducted by experienced CFD engineers following documented internal procedures. Formal use-error quantification is not required at MRL 2 and is scoped out of this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty quantification is not required at MRL 2; qualitative justification of turbulence model selection is sufficient.",
      "rationale": "SST k-omega turbulence model selected based on published literature for rotating blood pump applications. Formal model form uncertainty analysis is not required at MRL 2 and is not assessed in this package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Nominal input values with documented sources are sufficient at MRL 2; sensitivity analysis is not required.",
      "rationale": "Fluid properties (density 1050 kg/m3, viscosity 0.0035 Pa·s) are taken from published bovine blood standards. Geometric inputs are derived from FDA-published CAD files. Formal input uncertainty propagation is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "FDA benchmark dataset provides sufficient experimental replication for MRL 2; additional sample size analysis is not required.",
      "rationale": "FDA experimental dataset includes triplicate measurements at each operating point. Statistical characterization of inter-sample variability is not required at MRL 2 and is not assessed here."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Qualitative documentation of parameter equivalency between validation and deployment conditions is sufficient at MRL 2.",
      "rationale": "Input parameters used in validation (bovine blood properties, pump geometry, operating speeds) are representative of CPB deployment conditions. Formal equivalency scoring is not required at MRL 2 and is not assessed in this package."
    }
