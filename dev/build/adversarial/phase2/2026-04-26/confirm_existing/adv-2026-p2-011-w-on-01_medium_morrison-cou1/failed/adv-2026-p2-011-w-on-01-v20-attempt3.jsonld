  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified under a documented QA plan with version control and regression testing.",
      "rationale": "ANSYS Fluent 2022R2 was used under an ISO 9001-compliant QA plan. Version control logs, regression test suite results, and release notes were reviewed. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code must pass standard benchmark cases demonstrating correct implementation of governing equations.",
      "rationale": "Solver was verified against the ASME V&V 20 lid-driven cavity benchmark and a Poiseuille flow analytical solution. Normalized errors were below 0.5% in all cases, confirming correct discretization of the Navier-Stokes equations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three mesh levels with GCI < 5% for the hemolysis index QoI.",
      "rationale": "Three mesh levels (2.1M, 6.4M, 14.8M elements) were evaluated. Richardson extrapolation yielded GCI of 3.2% for the normalized index of hemolysis, meeting the acceptance criterion at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with uncertainties and replicated in the simulation setup.",
      "rationale": "Flow loop experiments were conducted at 37 ± 0.5°C with bovine blood at hematocrit 33 ± 1%. Inlet flow rates and pressure boundary conditions were matched to within 2% of measured values. Experimental uncertainty was propagated into the simulation boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty bands.",
      "rationale": "Predicted normalized index of hemolysis (NIH) agreed with experimental measurements within 8% across five operating points spanning 2–6 L/min and 3000–5000 RPM. Agreement exceeded the MRL 2 requirement; achieved level is reported as 3 reflecting quantitative uncertainty-bounded comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (hemolysis index) must be directly linked to the clinical decision question of identifying worst-case operating conditions.",
      "rationale": "NIH is the regulatory-accepted metric for hemolysis assessment per FDA guidance on blood-contacting devices. The QoI is directly relevant to identifying peak hemolysis operating points on the pump performance map."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and physiologically representative fluid and operating conditions as the intended deployment scenario.",
      "rationale": "Validation used the FDA generic centrifugal blood pump geometry with bovine blood analogue under CPB-representative flow rates (2–6 L/min) and rotational speeds (3000–5000 RPM), matching the intended clinical research application scenario."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must fall below solver-recommended thresholds for all transport equations.",
      "rationale": "Not assessed as a standalone factor at MRL 2; iterative convergence was monitored as part of the discretization error assessment. Residuals dropped below 1e-5 for all equations, providing implicit evidence of solver error control."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup must be reviewed by a second qualified analyst to detect operator-induced errors.",
      "rationale": "Formal use-error assessment not required at MRL 2 for this device class. Simulation inputs were reviewed informally by a senior team member as part of standard laboratory practice."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection and hemolysis damage model must be justified relative to available experimental evidence.",
      "rationale": "Model form assessment scoped out at MRL 2. The SST k-omega turbulence model and the Giersiepen-Wurzinger hemolysis power-law model were selected based on published literature consensus for rotary blood pump CFD applications."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of model outputs to uncertain input parameters must be quantified.",
      "rationale": "Formal sensitivity analysis not required at MRL 2. Blood viscosity and density were assigned nominal values from published data for bovine blood at 37°C. Hematocrit uncertainty effect on NIH is acknowledged as a known input variability source."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Number and variability of experimental test samples must be sufficient to characterize measurement uncertainty.",
      "rationale": "Not assessed as a standalone factor at MRL 2. Three independent experimental runs were conducted per operating point. Sample-to-sample variability was below 6% for NIH measurements, providing adequate repeatability evidence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Differences between validation experiment inputs and intended-use conditions must be evaluated for their effect on model credibility.",
      "rationale": "Equivalency assessment not required at MRL 2. Bovine blood was used as a surrogate for human blood in validation experiments; rheological differences are acknowledged and considered acceptable for this risk level based on published precedent in FDA submissions for Class II blood pumps."
    }
  ],
