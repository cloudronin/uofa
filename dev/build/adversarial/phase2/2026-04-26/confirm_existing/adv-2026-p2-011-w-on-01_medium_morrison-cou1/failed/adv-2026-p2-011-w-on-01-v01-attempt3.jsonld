  "signature": "ed25519:b1c3d5e7f9a2b4c6d8e0f2a4b6c8d0e2f4a6b8c0d2e4f6a8b0c2d4e6f8a0b2c4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control, regression testing suite, and documented QA procedures must be in place consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is under formal version control with a documented regression test suite covering benchmark hemolysis cases. QA procedures are consistent with FDA guidance for computational fluid dynamics software used in cardiovascular device evaluation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Successful completion of at least two standard benchmark verification cases (e.g., lid-driven cavity, pipe flow) with documented comparison to analytical solutions.",
      "rationale": "The solver has been verified against the ASME V&V 20 pipe flow benchmark and the lid-driven cavity problem at Re=1000. Numerical errors are within accepted tolerances for both mass and momentum conservation residuals, confirming code correctness for the class of flows encountered in the CPB pump."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index and pressure rise predictions on at least three systematically refined meshes.",
      "rationale": "A three-level mesh refinement study was performed with element counts of 4.2M, 8.7M, and 17.1M cells. GCI values of 3.1% for hemolysis index and 2.8% for total pressure rise were achieved, exceeding the MRL 2 requirement. The fine mesh was selected for all production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rates, rotational speeds, fluid properties) must overlap with the intended CPB operating envelope and be documented with measurement uncertainty.",
      "rationale": "FDA benchmark experimental data were collected at flow rates of 2–6 L/min and rotational speeds of 2000–3500 RPM using porcine blood with documented hematocrit and viscosity. These conditions span the clinical CPB operating envelope. Measurement uncertainties are reported in the source dataset documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and pressure-flow curves must agree with experimental measurements within combined simulation and experimental uncertainty bounds.",
      "rationale": "Predicted hemolysis index values fall within ±18% of experimental measurements across all tested operating points, consistent with the combined uncertainty budget. Pressure-flow characteristic curves show mean absolute error of 4.2 mmHg, within the stated acceptance band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis index and shear stress distributions must be directly relevant to the clinical question of worst-case hemolysis identification for CPB device evaluation.",
      "rationale": "The primary QoI — normalised index of hemolysis (NIH) and volume-weighted shear stress exposure — are the standard metrics used in FDA guidance for CPB device haemocompatibility assessment. Their relevance to the decision question is well-established in the literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use geometry, fluid, and operating conditions sufficiently similar to the CPB COU to support extrapolation of validation evidence.",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry under physiologically representative blood analogue conditions. The geometric and flow similarity between validation and intended use is high, supporting direct application of validation evidence to the CPB COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance applies.",
      "rationale": "At Model Risk Level 2, explicit quantification of numerical solver error beyond code verification is not required. The verified solver residuals and benchmark comparisons provide sufficient confidence in solver numerical behaviour for this application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; standard analyst training and simulation protocol documentation are considered sufficient.",
      "rationale": "Use error assessment is scoped out at MRL 2. Analysts are trained CFD engineers with documented experience in cardiovascular device simulation. Simulation protocols are version-controlled and peer-reviewed prior to execution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form choices are documented and consistent with published practice for CPB CFD.",
      "rationale": "The SST k-omega turbulence model and power-law hemolysis model (Giersiepen-Wurzinger) are the accepted model forms for this class of problem. Model form uncertainty quantification is not required at MRL 2 but model selection is documented and justified by reference to published validation studies."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input parameters are documented with nominal values and sources.",
      "rationale": "All model inputs (fluid density, viscosity, pump geometry, boundary conditions) are documented with nominal values and literature sources. Formal sensitivity analysis of input uncertainty is not required at MRL 2 for this device class."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample documentation from the FDA dataset is considered adequate.",
      "rationale": "The FDA benchmark dataset provides sufficient sample documentation for MRL 2. Formal statistical characterisation of sample variability is not required at this risk level. Blood sample preparation and handling are documented in the original experimental protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative assessment of parameter equivalency between validation and COU conditions is sufficient.",
      "rationale": "A qualitative review confirms that the validation input parameters (blood analogue properties, pump geometry, operating speeds) are equivalent to those in the intended CPB use. Formal equivalency quantification is not required at MRL 2."
    }
  ],
