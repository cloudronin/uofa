      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) within 15% of experimental mean across all tested operating points.",
      "rationale": "Predicted NIH values compared against five experimental replicates from the FDA benchmark dataset. Mean absolute error was 9.4%, within the 15% acceptance threshold for MRL 2."
