  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified and validated per recognized SQA practices; version control and regression testing documented.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented SQA processes including version-controlled releases and published verification test suite results. Internal SQA records confirm compliance at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate that the numerical implementation correctly solves the governing equations to the required accuracy for turbulent flow in rotating machinery.",
      "rationale": "Published verification benchmarks for the Navier-Stokes solver, including the lid-driven cavity and rotating channel flow cases, confirm second-order spatial accuracy. Manufacturer verification documentation reviewed and found adequate for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must be performed demonstrating that the hemolysis index QoI changes by less than 5% between successive refinement levels.",
      "rationale": "A three-level mesh refinement study (1.2M, 3.8M, and 9.6M cells) was conducted at the nominal operating point. The hemolysis index varied by 3.1% between the medium and fine meshes. The medium mesh (3.8M cells) was selected for production runs, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to enable meaningful comparison with simulation boundary conditions.",
      "rationale": "FDA benchmark experimental data for the generic centrifugal blood pump includes documented flow rates (2–8 L/min), rotational speeds (2000–3500 RPM), and fluid properties (glycerol-water blood analog). Boundary conditions in the CFD model were set to match these conditions within stated experimental uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and pressure-flow characteristics must agree with experimental measurements within two standard deviations of experimental uncertainty across the validated operating range.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values agreed with experimental measurements within 18% across all 12 operating points, which falls within the combined experimental and modeling uncertainty band. Pressure-flow characteristic predictions agreed within 8% across the full operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest computed by the model (NIH, shear stress exposure) must be directly relevant to the clinical question of hemolysis risk under CPB operating conditions.",
      "rationale": "Normalized index of hemolysis and volume-averaged shear stress exposure time are the primary QoIs. Both are directly used in regulatory submissions for CPB device hemolysis assessment and are recognized by FDA guidance as appropriate metrics for this device class."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use geometry, fluid, and operating conditions sufficiently similar to the intended CPB application to support extrapolation of credibility to the COU.",
      "rationale": "Validation was performed on the same FDA generic centrifugal pump geometry used in the COU assessment. Blood analog fluid properties and CPB-representative operating conditions were used throughout. The validation domain is considered representative of the intended application envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, detailed iterative convergence error quantification beyond standard residual monitoring is not required.",
      "rationale": "Residual convergence to 1e-5 was confirmed for all simulations. Detailed numerical solver error quantification beyond this threshold is not required at MRL 2 and has not been performed."
    },
    {
