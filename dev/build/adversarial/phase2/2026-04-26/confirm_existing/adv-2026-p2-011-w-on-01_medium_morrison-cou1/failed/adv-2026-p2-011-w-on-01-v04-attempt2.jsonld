  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six non-assessed factors are appropriately scoped out at MRL 2 per ASME V&V 40-2018 Table 3. The CFD hemolysis model is accepted as credible for identifying worst-case operating conditions of the FDA generic centrifugal blood pump under CPB conditions. This model has been applied in clinical research contexts and the simulation evidence supports regulatory submission for a Class II device.",
