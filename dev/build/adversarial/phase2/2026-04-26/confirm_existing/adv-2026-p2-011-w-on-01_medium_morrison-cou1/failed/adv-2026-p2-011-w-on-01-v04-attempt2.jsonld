  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented V&V procedures and version-controlled source consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R1 was used with documented QA procedures including regression test suite and version control. All SQA requirements for MRL 2 are satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate order-of-accuracy verification on canonical benchmark problems relevant to rotating machinery flows.",
      "rationale": "Order-of-accuracy tests on lid-driven cavity and rotating annulus benchmarks confirmed second-order spatial convergence. Code verification requirements for MRL 2 are met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 10% at the operating point of interest.",
      "rationale": "Richardson extrapolation performed on three systematically refined meshes (2.1M, 5.8M, 14.2M cells). GCI for normalized index of hemolysis was 6.3%, satisfying the MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to reproduce boundary conditions in the simulation.",
      "rationale": "FDA experimental data provide full documentation of inlet flow rates, rotational speeds, fluid properties, and temperature. Boundary conditions in the CFD model were set to match these conditions within stated measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and pressure rise must agree with experimental measurements within combined simulation and measurement uncertainty bounds.",
      "rationale": "Predicted normalized index of hemolysis agreed within 8% of experimental mean across five operating points. Pressure-flow predictions fell within experimental uncertainty bands at all tested conditions. Achieved level exceeds MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, pressure rise) must be directly relevant to the clinical decision question of worst-case operating condition identification.",
      "rationale": "Normalized index of hemolysis and hydraulic pressure rise are the primary clinical safety metrics for CPB devices. These QoIs directly support identification of worst-case operating conditions as required by the assessment objective."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and overlapping operating conditions as the intended clinical use scenario.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry under flow rates and rotational speeds spanning the CPB operating envelope. Geometric and operational relevance to the intended use scenario is established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal iterative convergence documentation beyond residual monitoring is not required for this factor.",
      "rationale": "Residual convergence to 1e-5 was confirmed for all simulations. Formal numerical solver error quantification beyond this level is scoped to MRL 3 and above; not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use-error analysis is not required; basic simulation setup review is sufficient.",
      "rationale": "Simulation setup was reviewed by a second qualified engineer. Formal use-error quantification is not required at MRL 2 for this device class and is deferred accordingly."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, selection of turbulence and hemolysis model must be documented but formal model-form uncertainty quantification is not required.",
      "rationale": "SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power-law model were selected based on published literature precedent for centrifugal blood pumps. Formal model-form UQ is a MRL 3 requirement and is not assessed here."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model input values must be documented; formal sensitivity analysis is not required.",
      "rationale": "All model inputs including blood viscosity, density, and pump geometry dimensions are documented with sources. Formal input sensitivity analysis is not required at MRL 2 and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documentation of the experimental sample preparation and fluid properties is sufficient; statistical characterization of sample variability is not required.",
      "rationale": "FDA experimental data documentation confirms use of bovine blood with controlled hematocrit. Statistical characterization of inter-sample variability is a MRL 3 requirement and is not assessed at this level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative justification of input parameter equivalency between validation and COU is sufficient.",
      "rationale": "Qualitative assessment confirms that validation operating conditions are representative of the CPB clinical use envelope. Formal equivalency quantification is deferred to MRL 3 assessments."
    }
