  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified under an ISO 9001-compliant QMS with documented version control and regression testing.",
      "rationale": "ANSYS Fluent 2022R2 is developed under a certified QMS. Version control, regression test suite, and release notes are documented and available for review. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical benchmark cases must confirm theoretical convergence rates for the discretization scheme employed.",
      "rationale": "Method of manufactured solutions applied to steady laminar pipe flow confirms second-order spatial accuracy. Observed convergence rate 1.97, consistent with theoretical expectation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine-grid solution.",
      "rationale": "Three-level mesh refinement study performed (4.2 M, 9.7 M, 21.4 M cells). GCI on hemolysis index = 3.1% on fine grid. Richardson extrapolation confirms asymptotic convergence. Required level met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with traceable calibration records and must span the operating envelope relevant to CPB use.",
      "rationale": "FDA benchmark experimental data collected at 2500 RPM and 3500 RPM across five flow rates (2–8 L/min). Calibration certificates for flow meters and pressure transducers are on file. Conditions bracket the CPB operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within ±15% across all validation operating points.",
      "rationale": "Predicted hemolysis index deviates from experimental values by 4–12% across all ten validation operating points. Mean absolute error 7.3%. Acceptance criterion satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) must be directly linked to the clinical risk of red blood cell damage in CPB application.",
      "rationale": "Hemolysis index and volume-averaged shear stress are the primary indicators of RBC damage in CPB literature. Both QoIs are directly mapped to the device safety claim. Relevance is established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use blood-analog fluid with viscosity and density representative of heparinized whole blood at 37°C under CPB flow rates.",
      "rationale": "FDA benchmark experiments used 36% glycerin-water solution matching blood viscosity (3.5 mPa·s) and density (1058 kg/m³) at 37°C. Flow rates 2–8 L/min encompass full CPB range. Achieved level exceeds required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver iterative convergence residuals documented as proxy.",
      "rationale": "At MRL 2 this factor is not required to be formally assessed. Residuals for continuity and momentum equations drop below 1e-5 in all simulations, providing sufficient confidence that iterative solver error is negligible."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; simulation setup reviewed by independent analyst.",
      "rationale": "Independent internal review of boundary conditions, material properties, and solver settings was conducted. No use errors identified. Formal assessment not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified by comparison against at least one benchmark dataset representative of the flow regime in the CPB pump.",
      "rationale": "SST k-omega turbulence model selected based on prior literature benchmarking for swirling internal flows. Comparison against FDA nozzle benchmark confirms adequate prediction of shear stress profiles. Model form uncertainty documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal input values sourced from published literature.",
      "rationale": "Blood-analog fluid properties sourced from ISO 10993-4 and published CPB literature. Pump geometry from FDA public dataset. Formal uncertainty quantification on inputs not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; sample representativeness noted qualitatively.",
      "rationale": "FDA benchmark uses a single generic pump geometry. Sample-to-sample variability in physical pump not characterized. This limitation is acceptable at MRL 2 and does not affect the credibility conclusion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; qualitative mapping between simulation inputs and experimental conditions documented.",
      "rationale": "Simulation boundary conditions (inlet flow rate, outlet pressure, rotational speed) are set to match experimental conditions exactly. Formal equivalency analysis not required at MRL 2."
    }
