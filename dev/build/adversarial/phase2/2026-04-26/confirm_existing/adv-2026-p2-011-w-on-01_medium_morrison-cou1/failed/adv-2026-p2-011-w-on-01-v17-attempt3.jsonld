  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a quality management system with documented version control and regression testing appropriate for MRL 2.",
      "rationale": "ANSYS Fluent 2022 R2 was used under an ISO 9001-compliant QMS. Version control, release notes, and regression test reports were reviewed and found sufficient for MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems at MRL 2 gradation.",
      "rationale": "Standard ASME V&V 20 benchmark cases (lid-driven cavity, backward-facing step) were reproduced within acceptable tolerances, confirming correct solver implementation for incompressible viscous flow."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that discretization error in hemolysis index QoI is below 10% at the selected mesh density.",
      "rationale": "Three-level mesh refinement study (4.2M, 8.7M, 16.1M elements) performed using Richardson extrapolation. Grid convergence index for normalized index of hemolysis was 4.3%, satisfying the 10% threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to confirm relevance to the simulated operating envelope.",
      "rationale": "FDA bench test data were collected at 2500 and 3500 RPM across four flow rates (2–6 L/min). Temperature, fluid viscosity, and hematocrit were recorded per ASTM F1841. Conditions adequately bracket the CPB operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and pressure-flow characteristics must agree with experimental measurements within combined simulation and experimental uncertainty bounds.",
      "rationale": "Predicted normalized index of hemolysis agreed with experimental values within ±18% across all operating points, within the combined uncertainty band. Pressure-flow curves matched within ±5% at all tested speeds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs extracted from the model must directly support the decision question regarding worst-case hemolysis identification.",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) integrated over the pump volume. This directly addresses the decision question of identifying worst-case hemolysis operating conditions for the CPB device."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use the same pump geometry, blood analog fluid, and rotational speed range as the intended COU operating envelope.",
      "rationale": "Validation used the identical FDA generic centrifugal pump geometry under porcine blood analog conditions spanning the full CPB flow rate range. Rotational speeds tested encompass the clinical operating envelope, providing strong relevance to the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit iterative convergence error quantification beyond residual monitoring is not required.",
      "rationale": "Solver residuals were monitored to 1e-5 for all equations. Formal iterative error quantification beyond residual tracking is not required at MRL 2 and was therefore not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use-error assessment is not required provided simulation was performed by trained personnel following documented procedures.",
      "rationale": "Simulations were conducted by engineers with documented CFD training. Formal use-error analysis is not required at MRL 2 and was scoped out of this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection and hemolysis power-law model form must be justified for the flow regime present in the CPB pump at MRL 2.",
      "rationale": "The SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power law were selected based on published literature for similar rotary blood pump geometries. Formal model-form uncertainty quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal input values with documented sources are sufficient; full sensitivity analysis is not required.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and hemolysis model constants were taken from peer-reviewed sources. Sensitivity analysis was not performed as it is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, use of a single well-characterized experimental dataset with documented sample provenance is acceptable.",
      "rationale": "A single FDA-sourced experimental dataset was used. Sample characterization (hematocrit, donor provenance) was documented per ASTM F1841. Statistical characterization of inter-sample variability was not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative confirmation that simulation input parameters correspond to experimental conditions is sufficient.",
      "rationale": "Simulation boundary conditions (inlet flow rate, outlet pressure, rotational speed) were set to match reported experimental values. Formal equivalency quantification is not required at MRL 2."
    }
  ],
