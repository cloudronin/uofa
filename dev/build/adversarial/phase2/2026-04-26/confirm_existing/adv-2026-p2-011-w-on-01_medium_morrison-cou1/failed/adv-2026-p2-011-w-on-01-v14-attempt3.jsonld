      "type": "ValidationResult",
      "name": "CFD hemolysis index vs. experimental NIH measurements across five operating points"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-val-02",
      "type": "ValidationResult",
      "name": "Velocity field comparison between CFD and PIV data at nominal CPB flow rate"
    }
  ],
