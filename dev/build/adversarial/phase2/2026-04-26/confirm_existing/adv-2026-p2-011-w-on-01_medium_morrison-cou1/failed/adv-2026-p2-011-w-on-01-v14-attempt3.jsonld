  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented version control, regression test suite, and release notes consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 was used under institutional license with documented version control and a regression test suite covering turbulent pipe flow and rotating machinery benchmarks. Release notes confirm no known defects affecting hemolysis-relevant shear stress calculations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification via published benchmark problems demonstrating correct implementation of governing equations at MRL 2.",
      "rationale": "The CFD solver was verified against the FDA critical path benchmark for nozzle and backward-facing step flows. Observed discretization errors were within published tolerances, confirming correct implementation of the Navier-Stokes solver for incompressible flow."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index and wall shear stress at all evaluated operating points.",
      "rationale": "A three-level mesh refinement study (4.2M, 9.8M, and 21.3M elements) yielded GCI values of 3.1% for normalized index of hemolysis and 4.7% for peak wall shear stress, both satisfying the 5% threshold. The medium mesh (9.8M elements) was selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with measurement uncertainty quantification and traceable to NIST standards.",
      "rationale": "In vitro hemolysis experiments were conducted using bovine blood at 37°C with hematocrit 35±2%. Flow rates and pressures were measured with calibrated transducers traceable to NIST standards. Measurement uncertainty for NIH was ±8% (95% CI), documented in the test report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within combined simulation and experimental uncertainty bands across at least three operating points.",
      "rationale": "Predicted NIH values agreed with experimental measurements within combined uncertainty at all five evaluated operating points (2L/min to 6L/min at 2500 RPM). Maximum relative error was 12%, within the combined uncertainty band of 18%. Velocity field comparison with PIV data showed mean absolute error of 0.08 m/s."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (NIH, peak shear stress, exposure time) must be directly linked to the clinical harm mechanism and regulatory submission requirements.",
      "rationale": "The normalized index of hemolysis is the FDA-accepted metric for blood damage assessment in CPB devices. Peak shear stress and red blood cell exposure time are mechanistically linked to hemolysis and are captured by the power-law hemolysis model implemented in the simulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same device geometry and span the operating envelope relevant to CPB clinical use.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry under operating conditions spanning the clinical CPB range (2-6 L/min, 50-150 mmHg pressure rise). The validation domain encompasses the intended operating envelope, supporting applicability of validation evidence to the intended use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance applies.",
      "rationale": "At Model Risk Level 2, explicit quantification of numerical solver error beyond code verification is not required. Solver residuals were monitored to convergence (below 1e-5 for all equations) as a standard quality check."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation was performed by trained personnel following documented SOPs.",
      "rationale": "Formal use error analysis is not required at MRL 2. Simulations were conducted by engineers with documented CFD training following institutional standard operating procedures for cardiovascular device modeling."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection is documented in the simulation plan.",
      "rationale": "The SST k-omega turbulence model and Giersiepen-Wurzinger power-law hemolysis model were selected based on published literature for centrifugal blood pump applications. Formal model form uncertainty quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; input parameters are documented with sources in the simulation report.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m³), and hemolysis model coefficients were taken from published literature. Formal sensitivity analysis of model inputs is not required at MRL 2 and was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterization is documented in the experimental test report.",
      "rationale": "Bovine blood samples were characterized for hematocrit and osmolarity prior to testing. Statistical analysis of inter-sample variability is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; boundary conditions were matched to experimental conditions as documented in the simulation plan.",
      "rationale": "Simulation boundary conditions (inlet flow rate, outlet pressure) were set to match experimental test conditions. Formal equivalency analysis between simulation inputs and experimental conditions is not required at MRL 2."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The CFD model is accepted as credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in CPB applications. This model has been applied in clinical research to support device design optimization and regulatory submissions for Class II CPB devices.",
