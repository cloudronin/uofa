  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must demonstrate version control, regression testing, and documented QA procedures consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 was used with documented version control and regression test suite. QA records confirm all MRL 2 software quality requirements are satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against analytical solutions or established benchmark problems to confirm correct implementation of governing equations.",
      "rationale": "Code verification performed using Taylor-Green vortex and lid-driven cavity benchmarks. Results agree with published reference solutions within 0.5%, confirming correct solver implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified via systematic mesh refinement study demonstrating grid-independent results for hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study conducted with 4.2M, 9.8M, and 21.3M cell meshes. Richardson extrapolation yields GCI < 3.1% for hemolysis index, confirming discretization error is within acceptable bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and shown to be representative of the CPB operating envelope.",
      "rationale": "FDA benchmark experimental data collected at flow rates 2–8 L/min and rotational speeds 2000–5000 RPM, fully spanning the intended CPB operating envelope. Test conditions are documented in FDA public dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index and pressure-flow characteristics must agree with experimental measurements within defined tolerance bands.",
      "rationale": "Normalized index of hemolysis predictions agree with FDA benchmark experimental results within 18% across all test conditions. Pressure-flow curve RMS error is 4.2 mmHg. Both metrics exceed MRL 2 acceptance criteria."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (hemolysis index, shear stress distribution) must be directly relevant to the clinical question of worst-case hemolysis identification.",
      "rationale": "Normalized index of hemolysis and volume-averaged scalar shear stress are the established QoIs for blood pump hemolysis assessment per ASTM F1841. Direct mechanistic link to red blood cell damage is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must address the same geometry, fluid properties, and operating conditions as the intended clinical use scenario.",
      "rationale": "Validation performed on FDA generic centrifugal pump geometry using bovine blood analog at physiological hematocrit. Operating conditions bracket the CPB clinical use envelope, confirming validation relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Numerical solver error assessment not required at MRL 2 for this factor category.",
      "rationale": "At MRL 2 for a Class II device, formal numerical solver error quantification beyond code verification is not required. This factor is not assessed per the MRL 2 credibility assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Use error assessment not required at MRL 2 for this application.",
      "rationale": "MRL 2 requirements for a Class II CPB device do not mandate formal use error assessment. Simulation was performed by trained analysts following documented simulation protocols."
    },
