      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty assessment is scoped out at MRL 2 for this device class; qualitative justification of model form selection is sufficient.",
      "rationale": "k-omega SST turbulence model selected based on published literature for rotating turbomachinery hemolysis prediction. Formal model form uncertainty quantification is not required at MRL 2; qualitative selection rationale is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model input parameters must be identified and their values documented; formal sensitivity analysis not required at MRL 2.",
      "rationale": "Blood viscosity, density, and power law coefficients are documented from published sources. Boundary conditions derived from FDA experimental setup documentation. Formal input uncertainty propagation is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Test sample characterization beyond what is available in the FDA public dataset is not required at MRL 2.",
      "rationale": "FDA benchmark dataset provides sufficient sample characterization for MRL 2 validation. Detailed test sample traceability assessment is scoped out for this credibility level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency analysis between simulation inputs and experimental test parameters is not required at MRL 2 for this device class.",
      "rationale": "Simulation boundary conditions are set to match FDA experimental conditions by direct correspondence. Formal equivalency assessment is not required at MRL 2 and is therefore not assessed."
    }
