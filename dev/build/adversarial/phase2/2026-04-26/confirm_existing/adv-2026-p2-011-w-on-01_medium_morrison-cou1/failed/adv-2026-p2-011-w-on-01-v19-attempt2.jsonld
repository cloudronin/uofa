  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be validated under an SQA plan commensurate with MRL 2, including version control and documented test cases.",
      "rationale": "ANSYS Fluent 2022R2 was used under an institutional SQA plan. Version control records and regression test results are archived. Achieved level meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of governing equations through benchmark problems at MRL 2.",
      "rationale": "Lid-driven cavity and backward-facing step benchmark cases were executed. Residuals converged below 1e-6 and results matched published reference solutions within 1%. Code verification requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must be performed with at least three mesh refinement levels and GCI reported for the primary QoI at MRL 2.",
      "rationale": "Three mesh levels (4M, 12M, 36M cells) were evaluated. Richardson extrapolation yielded a GCI of 2.1% on the hemolysis index QoI, exceeding the MRL 2 threshold. Achieved level 3 surpasses the required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to enable meaningful comparison with simulation boundary conditions.",
      "rationale": "FDA benchmark experimental conditions (flow rates 2.5–7 L/min, rotational speeds 2000–3500 RPM) are fully documented in the published dataset. Boundary conditions in the CFD model were set to match experimental values within measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., NRMSE, percent error) between simulation outputs and experimental data must be reported for primary QoIs.",
      "rationale": "Hemolysis index predictions compared against experimental measurements showed mean absolute percent error of 8.3% across all operating points. Pressure-head predictions showed NRMSE of 4.7%. Both metrics satisfy MRL 2 acceptance thresholds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be directly linked to the clinical decision question, demonstrating relevance to hemolysis risk assessment.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is the regulatory metric for CPB device hemolysis assessment per FDA guidance. The QoI is directly relevant to the intended decision question."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must reflect the geometry, flow regime, and fluid properties representative of CPB hemolysis operating conditions.",
      "rationale": "The FDA generic centrifugal pump geometry was used in both simulation and experiment. Blood analog fluid (glycerol-water mixture) properties matched hematocrit and viscosity ranges relevant to CPB. Validation activities are sufficiently representative of the intended COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a qualitative assessment of iterative convergence is sufficient; detailed round-off and truncation error quantification is not required.",
      "rationale": "Iterative convergence was monitored via residual tracking (all residuals below 1e-5). Detailed numerical solver error quantification beyond convergence monitoring is not required at MRL 2 and was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a qualitative acknowledgment of potential user errors is sufficient without formal use-error analysis.",
      "rationale": "Simulation setup was performed by an experienced CFD analyst with documented training. Formal use-error analysis is not required at MRL 2. Peer review of the simulation setup was conducted internally."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documentation of the governing equations and key modeling assumptions is required; formal model-form uncertainty quantification is not mandated.",
      "rationale": "The RANS k-omega SST turbulence model was selected based on literature evidence for rotating machinery hemolysis prediction. Model form assumptions are documented. Formal model-form UQ is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, nominal values for key input parameters must be documented; sensitivity analysis or probabilistic input characterization is not required.",
      "rationale": "Fluid density, viscosity, and blood damage model coefficients are documented at nominal values sourced from published literature. Input uncertainty quantification is not required at MRL 2 and was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a description of the test sample characteristics used in validation experiments is sufficient; statistical sample-size justification is not required.",
      "rationale": "The FDA benchmark dataset includes triplicate measurements at each operating point using standardized blood analog fluid. Sample characteristics are documented in the published protocol. Statistical power analysis is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, a qualitative assessment of the equivalency between simulation input parameters and experimental conditions is sufficient.",
      "rationale": "Boundary conditions in the CFD model were matched to experimental inlet flow rates and outlet pressures. Geometric fidelity was confirmed by comparison of CAD model dimensions against published pump specifications. Qualitative equivalency is established."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors achieved their required levels for MRL 2. The 6 non-assessed factors are acceptable as not-required at MRL 2 per ASME V&V 40-2018. The CFD hemolysis model is deemed credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in a Class II CPB application. This model has been applied in clinical research supporting device design optimization. The assessment team accepts the model for the stated decision question.",
