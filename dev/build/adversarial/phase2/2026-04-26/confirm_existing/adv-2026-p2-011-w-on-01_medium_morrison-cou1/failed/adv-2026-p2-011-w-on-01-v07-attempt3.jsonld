  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented version control, regression test suite, and build verification for the CFD solver used in hemolysis simulations.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially validated code with documented SQA procedures including version-controlled releases and regression testing. Internal SQA records confirm compliance at Gradation 2 for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark solutions for canonical flow problems (lid-driven cavity, pipe flow) demonstrate correct solver implementation.",
      "rationale": "Solver verification against analytical solutions for Poiseuille flow and Taylor-Couette flow confirms correct numerical implementation of the Navier-Stokes equations relevant to blood pump geometries. Results are within 0.5% of analytical values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI across three systematically refined meshes.",
      "rationale": "Richardson extrapolation performed on three mesh levels (4.2M, 8.7M, 17.1M cells) yields a GCI of 2.8% for the normalized index of hemolysis, exceeding the required level. Temporal discretization error assessed via time-step refinement study with GCI of 1.1%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid viscosity) are documented and traceable to calibrated measurement systems.",
      "rationale": "FDA benchmark experimental data report operating conditions at five flow rate/speed combinations spanning the CPB operating envelope. Fluid temperature, hematocrit, and viscosity are reported with measurement uncertainty. Traceability to NIST standards confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) predicted by CFD is within combined experimental and numerical uncertainty bounds across all operating points.",
      "rationale": "CFD-predicted NIH values fall within ±25% of experimental measurements at all five operating points, consistent with the scatter reported in the FDA interlaboratory study. Systematic bias is within the combined uncertainty band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs (NIH, peak shear stress, exposure time) are directly linked to the device safety decision regarding red blood cell trauma.",
      "rationale": "The primary QoI, normalized index of hemolysis, is the regulatory-accepted metric for blood trauma assessment in CPB devices. Secondary QoIs (scalar shear stress and Lagrangian exposure time) are mechanistically linked to the power-law hemolysis model employed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same FDA generic centrifugal pump geometry and operating range as the COU application.",
      "rationale": "Validation activities use the FDA-specified generic centrifugal blood pump geometry with bovine blood at physiological hematocrit, spanning the CPB operating envelope of 3–7 L/min at 2500–3500 RPM. Geometric and operational similarity to the COU application is established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and mass balance errors are monitored and reported.",
      "rationale": "At MRL 2, detailed solver error quantification beyond residual monitoring is not required. Residuals are confirmed to converge to 1e-5 for continuity and momentum equations. This factor is not formally assessed per the MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup procedures are documented to prevent user-induced errors in boundary condition specification.",
      "rationale": "At MRL 2 for a Class II device, formal use error assessment is not required. Standard operating procedures for simulation setup are maintained internally. This factor is scoped out of the formal assessment at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The choice of turbulence model and hemolysis power-law model is justified relative to available alternatives.",
      "rationale": "Model form uncertainty for the SST k-omega turbulence closure and the Giersiepen-Wurzinger hemolysis model is acknowledged. At MRL 2, formal model form assessment is not required. Sensitivity to turbulence model selection was explored qualitatively in prior published work."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model input parameters (blood viscosity, density, hemolysis model constants) are identified and their variability characterized.",
      "rationale": "Model input sensitivity is acknowledged for hemolysis model exponents and blood rheological properties. Formal uncertainty propagation is not required at MRL 2. Nominal input values are taken from published literature and the FDA benchmark protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample characteristics (blood source, preparation, storage) are documented.",
      "rationale": "The FDA benchmark study documents bovine blood preparation and storage protocols. At MRL 2, independent assessment of test sample representativeness is not required by the assessment plan. Sample documentation is accepted as reported."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between computational boundary conditions and experimental test conditions is documented.",
      "rationale": "Boundary conditions in the CFD model are set to match reported experimental conditions. At MRL 2, formal equivalency analysis is not required. Direct mapping of inlet flow rate and rotational speed from experimental protocol to simulation inputs is documented in the simulation report."
    }
  ],
