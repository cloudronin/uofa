  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors are not assessed per the MRL 2 assessment plan, which is acceptable for a Class II device. The CFD model is accepted as credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in CPB applications. This model has been applied in clinical research to support device design decisions and regulatory submissions.",
