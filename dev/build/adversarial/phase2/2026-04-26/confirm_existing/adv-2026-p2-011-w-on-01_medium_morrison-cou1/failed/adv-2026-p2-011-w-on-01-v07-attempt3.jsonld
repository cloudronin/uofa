      "type": "ValidationResult",
      "name": "Global hemolysis index comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-shear-stress-distribution",
      "type": "ValidationResult",
      "name": "Shear stress distribution validation at three operating points"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4042689",
