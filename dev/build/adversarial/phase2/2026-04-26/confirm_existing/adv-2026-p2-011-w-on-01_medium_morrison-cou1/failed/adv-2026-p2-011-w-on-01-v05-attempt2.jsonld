  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented regression test suite covering relevant flow regimes.",
      "rationale": "OpenFOAM v8 with institutional version control and a 42-case regression suite covering turbulent pipe and rotating-frame flows. All regression tests pass within tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical rotating-flow benchmark must confirm theoretical convergence rate within 10%.",
      "rationale": "Method of manufactured solutions applied to rotating-frame Navier-Stokes; observed second-order convergence confirmed within 8% of theoretical rate across four mesh refinement levels."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the production mesh.",
      "rationale": "Three-mesh Richardson extrapolation yields GCI of 3.2% for the normalized hemolysis index at the design operating point, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with measured uncertainty bands and reproduced in CFD setup within stated tolerances.",
      "rationale": "FDA benchmark test conditions (flow rate 2.5–7 L/min, rotational speed 2000–3500 RPM) are fully documented with ±2% measurement uncertainty; CFD inlet/outlet conditions match within 1.5%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental mean within two combined standard uncertainties across the operating envelope.",
      "rationale": "CFD hemolysis index predictions fall within 1.4 combined standard uncertainties of experimental means across all 15 tested operating points, exceeding the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (hemolysis index, shear stress distribution) must be directly traceable to the device safety claim.",
      "rationale": "Normalized index of hemolysis (NIH) and volume-averaged scalar shear stress are the primary QoIs; both are directly cited in the predicate 510(k) submissions for Class II CPB devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use blood-analog fluid with matched viscosity and density at physiological hematocrit, and pump geometry must be the FDA generic model.",
      "rationale": "Validation used 40% glycerin-water solution (matched to 37% hematocrit blood rheology) in the FDA generic centrifugal pump geometry; conditions span the intended CPB operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance applies.",
      "rationale": "At Model Risk Level 2, explicit quantification of iterative solver residual contributions to QoI uncertainty is not required. Residuals are monitored to 1e-6 convergence as standard practice."
