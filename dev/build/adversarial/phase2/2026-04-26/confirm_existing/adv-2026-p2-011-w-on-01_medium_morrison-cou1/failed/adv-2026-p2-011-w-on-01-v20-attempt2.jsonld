      "factorStatus": "assessed",
      "acceptanceCriteria": "Software QA procedures documented; version control and regression testing in place for CFD solver used in hemolysis simulations.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) operates under a documented software QA plan including version-controlled releases and regression test suites. Achieved level meets MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Verification of numerical implementation through method of manufactured solutions or equivalent benchmark problems.",
      "rationale": "Code verification was performed using published benchmark cases for rotating machinery flows. Solver convergence and order-of-accuracy were confirmed consistent with vendor documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study demonstrating discretization error below 5% for hemolysis index QoI.",
      "rationale": "A three-level grid convergence study (coarse, medium, fine: 2.1M, 6.4M, 18.7M cells) yielded a GCI of 2.8% for the hemolysis index at the design operating point, exceeding the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented and traceable; boundary conditions in simulation matched to within acceptable tolerance of physical test setup.",
      "rationale": "FDA benchmark experimental conditions (flow rate 2–8 L/min, rotational speed 2000–3500 RPM) are fully documented with measurement uncertainties. Simulation boundary conditions replicate these within stated tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric defined; simulation outputs compared against experimental measurements with agreement within acceptance band.",
      "rationale": "Normalized index of agreement (NIA) computed for hemolysis index predictions across 12 operating conditions. Mean NIA of 0.87 meets the acceptance threshold of 0.80 established for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (hemolysis index) directly linked to the device safety claim; linkage to clinical endpoint documented.",
      "rationale": "The hemolysis index is the primary safety QoI for CPB devices per FDA guidance. Its relevance to red blood cell damage and patient safety endpoints is established in the literature and confirmed by the clinical team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities performed on geometry and flow conditions representative of the intended CPB operating envelope.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry under CPB-representative flow conditions. The validation domain overlaps the intended operating envelope, satisfying MRL 2 relevance requirements."
    },
    {
