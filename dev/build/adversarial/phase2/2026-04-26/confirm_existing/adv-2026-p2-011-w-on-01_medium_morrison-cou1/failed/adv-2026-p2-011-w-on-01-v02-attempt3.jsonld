      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented test suite covering core CFD routines relevant to rotating machinery and hemolysis transport.",
      "rationale": "OpenFOAM v8 used with institutional version control (Git), documented regression test suite, and traceable build environment. All SQA requirements for MRL 2 are satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification via method of manufactured solutions or equivalent benchmark problems demonstrating correct implementation of governing equations.",
      "rationale": "Numerical code verification performed using published Taylor-Green vortex and lid-driven cavity benchmarks. Observed convergence rates consistent with second-order spatial discretization. No defects identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study with at least three systematically refined meshes; GCI or equivalent metric reported for primary QoI (hemolysis index).",
      "rationale": "Three-level mesh refinement study conducted (4.2M, 9.8M, 21.4M cells). Grid Convergence Index for normalized index of hemolysis is 3.1%, within the 5% threshold for MRL 2. Medium mesh selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with sufficient detail to allow boundary condition specification in the computational model; flow rate and rotational speed tolerances reported.",
      "rationale": "FDA experimental protocol documented flow rates (2–8 L/min) and rotational speeds (2000–3500 RPM) with stated uncertainties. Boundary conditions in CFD model set to nominal experimental values; sensitivity to boundary uncertainty evaluated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation metric U_val) reported for primary QoI against experimental data.",
      "rationale": "Normalized index of hemolysis predicted within 18% of experimental mean across all operating points (n=12). Validation metric U_val computed per ASME V&V 20; model uncertainty within experimental uncertainty band at 10 of 12 conditions. Exceeds MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
