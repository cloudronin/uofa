  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented regression test suite covering relevant flow regimes.",
      "rationale": "ANSYS Fluent 19.2 used under institutional license with documented version control. Regression tests for rotating machinery and viscous flow cases confirm solver stability. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order of accuracy verified for at least one benchmark problem representative of the flow physics.",
      "rationale": "Second-order spatial accuracy confirmed via method of manufactured solutions on a canonical rotating channel flow. Observed order of 1.93 is consistent with nominal second-order scheme. Meets required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI; GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 5.8M, 14.2M cells). GCI for hemolysis index on fine mesh is 3.7%, satisfying the acceptance criterion. Asymptotic range confirmed (GCI ratio 1.02)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented and traceable; inlet flow rate and rotational speed match simulation inputs within ±2%.",
      "rationale": "FDA GCBP experimental protocol specifies flow rates of 2.5 and 5.0 L/min at 2500 and 3500 RPM. Simulation boundary conditions set to match measured values; deviation < 1.5% across all operating points. Test conditions adequately reproduced."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 25% of experimental mean across all tested operating points.",
      "rationale": "Hemolysis index predictions compared against Morrison et al. (2019) experimental data. Mean relative error of 18.4% across six operating points, with no systematic bias. Criterion satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index directly linked to the device safety claim; scalar stress-based hemolysis model output maps to measurable plasma-free hemoglobin.",
      "rationale": "The normalized index of hemolysis (NIH) is the regulatory QoI for CPB device submissions. The power-law hemolysis model output is calibrated to NIH units. Direct correspondence between simulation output and decision-relevant quantity confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry under overlapping operating conditions with the intended COU.",
      "rationale": "Validation uses the FDA GCBP geometry identical to the COU model. Operating points span the CPB clinical range (2–6 L/min, 2000–4000 RPM). Fluid properties match bovine blood surrogate used in bench testing. Relevance is high."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when code verification is demonstrated.",
      "rationale": "Per ASME V&V 40 Table 1, numerical solver error assessment is not required at MRL 2 when numerical code verification has been satisfactorily completed. Scoping rationale documented and accepted by assessment team."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
