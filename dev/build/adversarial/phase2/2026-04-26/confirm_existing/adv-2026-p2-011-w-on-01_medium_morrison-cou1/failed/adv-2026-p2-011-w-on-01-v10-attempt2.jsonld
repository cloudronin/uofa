      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental sample description available in cited reference.",
      "rationale": "Experimental data sourced from published FDA GCBP study with documented sample preparation. Detailed test sample characterization not required at MRL 2. Reference cited provides sufficient traceability."
    },
    {
