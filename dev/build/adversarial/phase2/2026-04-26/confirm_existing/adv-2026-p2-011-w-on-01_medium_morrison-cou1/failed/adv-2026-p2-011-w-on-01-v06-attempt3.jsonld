  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially validated code with documented QA procedures including regression test suites and version-controlled release notes. Software version traceability is maintained throughout the simulation workflow."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Benchmark verification cases including Poiseuille flow and lid-driven cavity have been executed and results compared against analytical solutions. Residual convergence criteria of 1e-5 applied for all conservation equations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "A three-level mesh refinement study was performed (coarse: 2.1M, medium: 5.8M, fine: 14.3M cells). Grid Convergence Index for the normalized index of hemolysis was 3.2%, within acceptable bounds for MRL 2. Medium mesh selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Experimental validation data were collected under controlled laboratory conditions matching the simulation boundary conditions: inlet flow rates of 3–7 L/min, rotational speeds of 2500–4500 RPM, and blood analog fluid at 37°C. Test conditions are documented in the validation data package."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Predicted normalized index of hemolysis agrees with experimental measurements within 15% across all operating points tested. Systematic bias is less than 8%, consistent with published uncertainty in the Giersiepen hemolysis power-law model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "The primary quantity of interest, normalized index of hemolysis (NIH), is the clinically and regulatorily accepted metric for blood trauma assessment in rotary blood pumps. Secondary QoIs include scalar shear stress and exposure time distributions, directly relevant to identifying worst-case operating conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Validation experiments were conducted on the same FDA generic centrifugal blood pump geometry used in the simulation. Operating conditions span the intended clinical use envelope for CPB applications, supporting direct applicability of validation evidence to the decision context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default level 1 accepted.",
      "rationale": "Numerical solver error beyond residual convergence monitoring is not required at MRL 2 for this application. Iterative convergence is confirmed via residual plots and key monitor point stabilization. Formal floating-point error analysis is deferred."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default level 1 accepted.",
      "rationale": "Formal use error analysis is not required at MRL 2. Simulation execution is performed by trained CFD engineers following documented standard operating procedures. Peer review of setup files provides informal use error control."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default level 1 accepted.",
      "rationale": "Model form uncertainty arising from turbulence closure (SST k-omega) and the Giersiepen hemolysis correlation is acknowledged but not formally quantified at MRL 2. Sensitivity to model form is partially captured in the output comparison factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default level 1 accepted.",
      "rationale": "Input parameter uncertainty (fluid viscosity, density, hemolysis model coefficients) is not formally propagated at MRL 2. Nominal values from published literature are used and documented in the simulation input record."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default level 1 accepted.",
      "rationale": "Statistical characterization of test sample variability (e.g., blood analog batch-to-batch variation) is not required at MRL 2. The validation dataset was generated from a single controlled experimental campaign with consistent fluid preparation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default level 1 accepted.",
      "rationale": "Formal equivalency mapping between simulation input parameters and experimental test conditions is not required at MRL 2. Qualitative alignment between simulation and experimental boundary conditions has been confirmed by the assessment team."
    }
