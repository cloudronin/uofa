  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for Model Risk Level 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The CFD hemolysis prediction model is accepted as sufficiently credible to support identification of worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in CPB applications. No critical gaps were identified that would preclude use of the model for the stated decision.",
