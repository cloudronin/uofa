  "signature": "ed25519:b4e2d1f7a9c3e6b0d5f8a2c7e1b4d9f3a6c0e5b8d2f7a1c4e9b3d6f0a5c8e2b7",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate documented version control, regression testing, and configuration management consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R1) is a commercially validated code with documented QA procedures including version control and regression test suites. All simulation scripts are stored under Git version control with tagged release commits corresponding to this study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of governing equations through benchmark problems at MRL 2 level.",
      "rationale": "Code verification was performed using the method of manufactured solutions for the incompressible Navier-Stokes solver. Observed order of convergence matched theoretical order (second-order) within acceptable tolerance, confirming correct implementation of discretized governing equations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that discretization error in the hemolysis index QoI is below 10% relative to the Richardson extrapolated value.",
      "rationale": "A three-level mesh refinement study was conducted with mesh sizes of 2.1M, 5.8M, and 14.3M cells. Grid Convergence Index for the hemolysis index was 4.2%, satisfying the acceptance criterion. The 5.8M cell mesh was selected for production runs as the optimal balance of accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to reproduce boundary conditions in the computational model.",
      "rationale": "FDA experimental data for the generic centrifugal blood pump were obtained from the published benchmark dataset. Inlet flow rates, outlet pressure conditions, rotational speed, and fluid properties (bovine blood analog) are fully documented and directly mapped to CFD boundary conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within two standard deviations of the experimental scatter across the operating envelope.",
      "rationale": "Predicted normalized index of hemolysis agreed with FDA experimental measurements within 18% across all five tested operating points, which falls within two standard deviations of inter-laboratory experimental variability reported in the benchmark dataset. Systematic overprediction at high flow rates is consistent with known model form assumptions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation (hemolysis index, shear stress distribution) must be directly relevant to the decision-driving quantities in the intended use.",
      "rationale": "The normalized index of hemolysis and volume-averaged scalar shear stress are the primary QoIs for both validation and the intended use decision. These quantities directly drive the worst-case operating condition identification objective, ensuring relevance between validation evidence and intended use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted at conditions sufficiently similar to the intended use operating envelope to support extrapolation claims.",
      "rationale": "Validation experiments were conducted on the identical FDA generic centrifugal blood pump geometry across an operating envelope that encompasses the intended CPB operating range (2–8 L/min, 2000–3500 RPM). The validation domain is a proper superset of the intended use domain, supporting the relevance claim."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal iterative convergence analysis beyond residual monitoring is not required.",
      "rationale": "Residual convergence to 1e-5 was monitored for all simulations. Formal solver error quantification beyond residual monitoring is not required at MRL 2 and was scoped out of this assessment consistent with the credibility matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error assessment is not required provided simulations are performed by qualified personnel following documented procedures.",
      "rationale": "Simulations were executed by personnel with documented CFD competency following a written simulation protocol. Formal use error assessment is not required at MRL 2 and was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, qualitative justification of model form selection is sufficient; formal model form uncertainty quantification is not required.",
      "rationale": "The k-omega SST turbulence model and the Giersiepen-Wurzinger hemolysis power-law model were selected based on literature precedent for blood pump CFD. Formal model form uncertainty quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model input sensitivity analysis is not required; nominal input values must be documented.",
      "rationale": "All model inputs including fluid viscosity, density, hemolysis model coefficients, and boundary condition values are documented in the simulation protocol. Formal sensitivity analysis is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal sample size analysis for experimental validation data is not required provided the benchmark dataset is from a recognized source.",
      "rationale": "The FDA benchmark dataset constitutes a recognized multi-laboratory experimental reference. Formal test sample analysis is not required at MRL 2 for this assessment tier."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
