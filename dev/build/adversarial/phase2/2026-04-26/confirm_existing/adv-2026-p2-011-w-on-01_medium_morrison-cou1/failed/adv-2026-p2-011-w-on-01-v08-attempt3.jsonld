  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for Model Risk Level 2. The six non-assessed factors are acceptable at MRL 2 per the ASME V&V 40 credibility matrix. The CFD hemolysis prediction model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in the CPB application. The overall credibility evidence is judged adequate for the intended regulatory submission supporting a Class II device.",
