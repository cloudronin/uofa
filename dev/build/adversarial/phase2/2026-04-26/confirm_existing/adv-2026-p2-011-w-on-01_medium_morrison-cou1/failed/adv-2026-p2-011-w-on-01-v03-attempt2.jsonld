  "signature": "ed25519:b4e2d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d9f1a3c5e7b9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation is under version control with documented QA procedures and regression testing.",
      "rationale": "The CFD solver (ANSYS Fluent 2021 R2) is a commercially validated code with documented software QA processes including version control, regression test suites, and release notes. Internal QA log confirms Gradation 2 compliance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities demonstrate correct implementation of governing equations for the hemolysis model within the CFD solver.",
      "rationale": "Manufactured solution tests and benchmark comparisons (lid-driven cavity, Poiseuille flow) confirm correct numerical implementation. Power-law hemolysis model was verified against analytical solutions for simple shear flows."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates discretization error below 5% for hemolysis index QoI at the selected mesh resolution.",
      "rationale": "Three-level mesh refinement study (coarse 2.1M, medium 5.4M, fine 11.8M cells) performed. Richardson extrapolation yields GCI of 3.2% for hemolysis index at the nominal operating point. Medium mesh selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation are documented and traceable, with boundary conditions matching simulation inputs within acceptable tolerances.",
      "rationale": "FDA benchmark experimental dataset provides traceable test conditions including flow rate (2–7 L/min), rotational speed (2000–3500 RPM), and fluid properties (bovine blood, hematocrit 35±2%). Boundary condition correspondence verified within 1.5% for all primary parameters."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error) between simulation and experimental hemolysis index is below 15%.",
      "rationale": "Normalized index of agreement for hemolysis index across 12 operating conditions is 0.91. Mean absolute percentage error is 8.7%, within the 15% acceptance criterion. Worst-case operating point correctly identified in 11 of 12 test cases."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoI (normalized index of hemolysis, NIH) directly corresponds to the clinically relevant measure of blood damage used in device evaluation.",
      "rationale": "NIH is the FDA-recognized metric for hemolysis assessment in blood-contacting devices per FDA guidance. The model outputs NIH directly from the power-law hemolysis model integrated along Lagrangian particle tracks, providing direct correspondence to the decision-relevant QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities use geometry, operating conditions, and fluid properties sufficiently similar to the COU to support credibility inference.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry under CPB-representative flow rates and speeds. Bovine blood used as surrogate for human blood per standard practice. Geometric and operational similarity to clinical CPB application is high."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals documented; not required to be below specified threshold at MRL 2 if solver is commercially validated.",
      "rationale": "At MRL 2, detailed numerical solver error quantification beyond standard residual monitoring is not required. Residuals were monitored and confirmed to reach steady state (below 1e-5) for all production runs; no further assessment required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Analyst qualification and simulation execution procedures reviewed at MRL 3+; not required at MRL 2.",
      "rationale": "Use error assessment is scoped out at MRL 2 per ASME V&V 40 Table 3. Analysts hold relevant CFD qualifications; formal use-error documentation is deferred to higher MRL submissions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty characterized through comparison of alternative turbulence and hemolysis model formulations at MRL 3; documented rationale provided at MRL 2.",
      "rationale": "Power-law hemolysis model (Giersiepen-Wurzinger correlation) selected based on literature prevalence for centrifugal pump hemolysis prediction. k-omega SST turbulence model selected per FDA CFD guidance. Formal model form uncertainty quantification deferred to MRL 3 per ASME V&V 40 Table 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameter sensitivity analysis not required at MRL 2; nominal values documented and traceable.",
      "rationale": "All model input parameters (viscosity, density, hemolysis model constants) are documented with literature sources. Sensitivity analysis not required at MRL 2. Hematocrit set to 35% (nominal CPB value). Model constants taken from Giersiepen et al. (1990)."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample characterization at MRL 2 requires documentation of fluid source and preparation; detailed statistical characterization deferred to MRL 3.",
      "rationale": "FDA benchmark dataset documents use of fresh bovine blood with hematocrit 35±2% and controlled preparation protocol. Detailed sample-to-sample variability characterization is deferred to MRL 3 per ASME V&V 40 Table 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Qualitative discussion of input parameter equivalency between validation and COU conditions sufficient at MRL 2.",
      "rationale": "Operating conditions in validation (2–7 L/min, 2000–3500 RPM) span the intended CPB operating envelope. Fluid property differences between bovine and human blood are acknowledged and judged acceptable for MRL 2 based on comparable viscosity and density at 37°C. Formal equivalency mapping deferred to MRL 3."
    }
  ],
