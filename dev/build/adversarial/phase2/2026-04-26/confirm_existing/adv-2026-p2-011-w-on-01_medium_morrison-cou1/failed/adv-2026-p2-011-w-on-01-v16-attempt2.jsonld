      "name": "Hemolysis index comparison against FDA experimental benchmark"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-vr-02",
      "type": "ValidationResult",
      "name": "Pressure-flow characteristic curve validation at nominal CPB operating point"
    }
  ],
