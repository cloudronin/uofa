  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA plan consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent v19.2 was used under a documented software QA plan including version control, regression testing, and user qualification records. Achieved level meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via benchmark problems with known analytical solutions.",
      "rationale": "ANSYS Fluent passed standard CFD benchmark cases including lid-driven cavity and pipe flow, confirming correct numerical implementation of the Navier-Stokes equations at the required gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must be performed and discretization error estimated using Richardson extrapolation or GCI methodology.",
      "rationale": "A three-level mesh refinement study was conducted. GCI values for hemolysis index and shear stress were below 5%, satisfying MRL 2 discretization error requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and sufficiently representative of the simulation boundary conditions.",
      "rationale": "FDA experimental conditions (flow rate 2.5–7 L/min, rotational speed 2000–3500 RPM) were reproduced in the CFD boundary conditions. Test fluid properties were matched to the experimental saline-blood analog."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated outputs must be compared against experimental measurements using quantitative metrics including normalized index of agreement or equivalent.",
      "rationale": "Hemolysis index predictions were compared against FDA experimental data. Mean absolute error was within 12% across all operating points, meeting the MRL 2 output comparison requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest (QoI) predicted by the model must be directly relevant to the clinical decision being supported.",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH) and scalar shear stress distribution — are the standard regulatory metrics for CPB hemolysis assessment and directly support worst-case operating point identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be sufficiently similar to the intended use conditions in geometry, flow regime, and fluid properties.",
      "rationale": "The FDA generic centrifugal pump geometry used in validation is the same as the device geometry in the intended application. Flow regimes and fluid properties are representative of CPB operating conditions, satisfying relevance requirements at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to a level appropriate for MRL 2; formal solver error quantification not required at MRL 2.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond residual monitoring is not required. Residuals were monitored to 1e-5 for all transport equations, satisfying the minimum expectation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification and simulation setup review are sufficient at MRL 2; formal use error analysis is not required.",
      "rationale": "Simulation setup was reviewed by a qualified CFD engineer with documented training. Formal use error analysis is scoped out at MRL 2 per ASME V&V 40 Table 4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Selection of turbulence and hemolysis model forms must be documented; formal model form uncertainty quantification is not required at MRL 2.",
      "rationale": "The SST k-omega turbulence model and Giersiepen hemolysis power-law model were selected based on published literature for blood pump applications. Formal model form uncertainty analysis is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input parameters must be documented with sources; formal sensitivity analysis is not required at MRL 2.",
      "rationale": "Blood viscosity, density, and pump geometry were sourced from published FDA benchmark specifications. Formal input uncertainty propagation is not required at MRL 2 and has been scoped out accordingly."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The number and selection of experimental test samples must be documented; statistical characterization is not required at MRL 2.",
      "rationale": "FDA experimental dataset includes triplicate measurements at six operating points. Statistical characterization of sample variability is not required at MRL 2 and has been noted as not assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Equivalency between simulation inputs and experimental conditions must be qualitatively documented at MRL 2.",
      "rationale": "Boundary conditions were matched to experimental inlet flow rates and outlet pressures as reported in the FDA dataset documentation. Formal equivalency analysis is not required at MRL 2."
    }
  ],
