  "signature": "ed25519:9c4a2f1e7b3d0a6e5f2c8b4d1a7e3f0c9b6d2a5e8f1c4b7d0a3e6f9c2b5d8a1e4f7b0c3d6a9e2f5c8b1d4a7e0f3c6b9d2a5e8f1c4b7d0a3e6f9c2b5d8a1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented version control, regression testing suite, and build verification for the CFD solver must be in place and traceable.",
      "rationale": "The CFD solver (OpenFOAM v8) is maintained under Git version control with a documented regression test suite covering 47 canonical cases. Build verification logs are archived and traceable to the simulation runs. Achieved level meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification against at least one analytical or manufactured solution relevant to rotating turbomachinery flow must be demonstrated.",
      "rationale": "The solver was verified against the Taylor–Green vortex manufactured solution and a rotating-frame Couette flow analytical benchmark. Observed order of accuracy (1.92) is consistent with the nominal second-order spatial discretization scheme."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent grid convergence study must demonstrate discretization error below 5% for the primary hemolysis index QoI.",
      "rationale": "A three-level grid convergence study (coarse 1.2 M, medium 4.8 M, fine 19.2 M cells) was performed. GCI for the normalized index of hemolysis (NIH) at the worst-case operating point is 2.1%, below the 5% threshold. Achieved level exceeds the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to replicate boundary conditions in the simulation, including fluid properties, rotational speed, and flow rate range.",
      "rationale": "FDA benchmark experimental data provide complete documentation of fluid properties (glycerol-water blood analog, viscosity 3.5 mPa·s), rotational speeds (2500–3500 RPM), and flow rates (2.5–7.5 L/min). Boundary conditions in the CFD model are directly mapped from these records."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison between simulated and experimental NIH values must show agreement within experimental uncertainty bounds across the operating envelope.",
      "rationale": "Simulated NIH values compared against five experimental operating points. Mean absolute relative error is 8.3%, within the combined experimental uncertainty of ±12%. All five points fall within the uncertainty band, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (normalized index of hemolysis) must be directly linked to the clinical decision question of identifying worst-case hemolysis operating conditions.",
      "rationale": "NIH is the standard metric for hemolysis evaluation in ASTM F1841 and ISO 10993-4. It directly quantifies red blood cell damage and is the appropriate QoI for identifying worst-case operating conditions relevant to CPB device safety evaluation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, fluid, and operating conditions sufficiently representative of the intended CPB application to support extrapolation of credibility.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU simulation. Blood analog fluid and rotational speed range match CPB clinical operating conditions. The validation scenario is judged sufficiently representative for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; basic solver convergence monitoring is sufficient.",
      "rationale": "At MRL 2, formal quantification of numerical solver error beyond convergence monitoring is not required. Residuals converged to 1e-6 for all transport equations. This factor is not assessed per the MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualification documentation is sufficient.",
      "rationale": "Use error assessment is not required at MRL 2. The simulation team holds documented CFD analyst qualifications consistent with ASME V&V 20 practitioner guidelines. This factor is scoped out of the formal assessment at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; selection of turbulence and hemolysis models must be documented with literature justification.",
      "rationale": "The SST k-omega turbulence model and the Giersiepen–Wurzinger power-law hemolysis model were selected based on published CFD hemolysis literature. Formal model form uncertainty quantification is not required at MRL 2 and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values with literature sources are sufficient.",
      "rationale": "Model input parameters (fluid density, viscosity, hemolysis model constants) are taken from published sources and documented in the simulation report. Sensitivity analysis and input uncertainty propagation are not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; documentation of the experimental sample preparation protocol is sufficient.",
      "rationale": "The FDA benchmark dataset documents sample preparation procedures for the blood analog fluid. Statistical characterization of sample-to-sample variability is not required at MRL 2 and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative mapping of experimental to simulation input parameters is sufficient.",
      "rationale": "A qualitative mapping table confirming correspondence between experimental and simulation boundary conditions has been prepared and is included in the simulation report appendix. Formal equivalency metrics are not required at MRL 2."
    }
  ],
