  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-simulation-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six non-assessed factors are appropriately scoped out per the MRL 2 assessment plan. The CFD hemolysis model is judged credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in CPB applications. The assessment team notes that this model has been applied in clinical research contexts and the simulation results are consistent with published experimental benchmarks. The overall credibility evidence is sufficient to support regulatory submission for a Class II CPB device.",
