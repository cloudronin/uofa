  "signature": "ed25519:b4e2d1f3c5a7960e8f2b4d6a0c3e5f7a1b3d5e7f9a2c4e6b8d0f2a4c6e8b0d2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented SQA procedures including version control, regression testing, and release notes. SQA documentation reviewed and confirmed compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Order-of-accuracy testing performed using the method of manufactured solutions for the incompressible Navier-Stokes solver. Second-order spatial convergence confirmed for velocity and pressure fields relevant to hemolysis prediction."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Mesh convergence study conducted across three systematically refined meshes (3.2M, 8.7M, and 21.4M elements). Richardson extrapolation applied; GCI for hemolysis index QoI is 4.1%, within acceptable bounds. Medium mesh (8.7M) selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Experimental test conditions (blood analog fluid, rotational speed, flow rates) are documented and traceable. Temperature, hematocrit, and inlet pressure boundary conditions are matched to published FDA benchmark test protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Normalized index of hemolysis (NIH) predicted by the CFD model compared against experimental measurements at five operating points. Mean absolute error of 12.3% observed; systematic bias assessed and attributed to power-law hemolysis model coefficients. Comparison deemed adequate for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "The primary QoI (normalized index of hemolysis) is directly linked to the clinical endpoint of red blood cell damage in CPB devices. Secondary QoIs (shear stress distribution, residence time) are established surrogates in the hemolysis literature and are clinically relevant."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level of 2 for MRL 2.",
      "rationale": "Validation experiments performed on the FDA generic centrifugal blood pump geometry under CPB-representative flow conditions. Geometric and operational similarity to the intended COU is well established. Validation domain is judged sufficiently representative for MRL 2 acceptance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required for MRL 2 per ASME V&V 40 Table 3; default level 1 accepted.",
      "rationale": "Numerical solver error assessment beyond code verification is not required at MRL 2. Iterative convergence monitored via residual norms (all below 1e-5); no assessment of round-off or iterative error beyond standard practice required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required for MRL 2 per ASME V&V 40 Table 3; default level 1 accepted.",
      "rationale": "Formal use error analysis is not required at MRL 2. Simulation inputs and boundary conditions were reviewed by a second analyst as a basic quality check; no structured use-error assessment was conducted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required for MRL 2 per ASME V&V 40 Table 3; default level 1 accepted.",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis constitutive law) is acknowledged but formal quantification is not required at MRL 2. The k-omega SST turbulence model was selected based on published benchmark comparisons for rotating machinery."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required for MRL 2 per ASME V&V 40 Table 3; default level 1 accepted.",
      "rationale": "Sensitivity of model outputs to input parameter uncertainty (fluid viscosity, hematocrit, rotational speed tolerance) is not formally quantified at MRL 2. Nominal values sourced from published FDA benchmark documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required for MRL 2 per ASME V&V 40 Table 3; default level 1 accepted.",
      "rationale": "Statistical characterization of test sample variability is not required at MRL 2. Experimental data from the FDA benchmark study used as provided; sample-to-sample variability not independently assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required for MRL 2 per ASME V&V 40 Table 3; default level 1 accepted.",
      "rationale": "Formal equivalency mapping between validation experiment parameters and clinical use parameters is not required at MRL 2. Qualitative alignment between bench-test and intended operating envelope documented in the validation report."
    }
  ],
