  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-modeling-group",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for Model Risk Level 2. Six factors are appropriately scoped out at MRL 2 per ASME V&V 40 Table 3. The CFD hemolysis model is judged credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in CPB applications. This model has been applied in clinical research contexts and the assessment team finds the evidence body sufficient to support regulatory submission at the Class II device level.",
