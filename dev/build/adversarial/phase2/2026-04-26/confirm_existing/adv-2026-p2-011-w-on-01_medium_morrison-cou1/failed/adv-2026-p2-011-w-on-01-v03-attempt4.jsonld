      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented QA procedures, version control, and regression test suites. Software version and build number are recorded in the simulation log files, satisfying MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Order-of-accuracy tests were performed on canonical pipe-flow and rotating-disk benchmarks using the method of manufactured solutions. Observed convergence rates matched theoretical second-order accuracy, confirming correct code implementation for the relevant physics."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "A three-level mesh refinement study was conducted on the FDA pump geometry. Richardson extrapolation yielded a grid convergence index (GCI) of less than 3% for the hemolysis index QoI, indicating discretization error is well controlled within MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Experimental test conditions (flow rates 2–8 L/min, rotational speeds 2000–3500 RPM, blood analog fluid properties) are documented in the FDA inter-laboratory study protocol. Boundary conditions applied in the CFD model are traceable to the experimental measurements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Predicted hemolysis index values were compared against experimental measurements from three independent laboratories. Agreement within ±15% was achieved across the operating envelope, satisfying the acceptance criterion established for MRL 2 validation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The primary QoI (normalized index of hemolysis, NIH) is the clinically accepted metric for blood damage assessment in CPB devices and is directly linked to the regulatory decision question regarding worst-case operating conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Validation experiments were performed on the same FDA generic pump geometry used in the simulation, at overlapping operating conditions. The validation domain adequately spans the intended CPB operating envelope, supporting extrapolation confidence at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required for MRL 2 at this factor level; scoping decision documented.",
      "rationale": "Iterative solver residuals were monitored and confirmed to reach machine-precision convergence thresholds. Formal quantification of solver error beyond residual monitoring is not required at MRL 2 and was not performed."
    },
    {
