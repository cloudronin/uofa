      "acceptanceCriteria": "Solver must be under version control with documented test suite covering relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022R2 used under ISO 9001-certified QMS; regression test suite covers laminar and turbulent internal flow benchmarks. Version control and release notes archived in sponsor document management system."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate order-of-accuracy consistent with documented discretization scheme on canonical benchmark problems.",
      "rationale": "Order-of-accuracy confirmed via Method of Manufactured Solutions on 3-D Navier-Stokes equations; second-order spatial convergence verified. Results consistent with published ASME V&V 20 benchmark suite."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI at the selected operating point.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 5.8M, 14.2M cells). Richardson extrapolation yields GCI of 3.1% for normalized index of hemolysis; fine-grid solution adopted for all subsequent analyses."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with uncertainty bounds and replicated in the computational model.",
      "rationale": "FDA benchmark test conditions (flow rate 2–8 L/min, rotational speed 2000–3500 RPM, blood analogue fluid properties) documented with ±2% uncertainty. Inlet velocity profiles and fluid viscosity matched in CFD boundary conditions."
