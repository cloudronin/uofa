      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty at all five validation operating points.",
      "rationale": "Normalized index of hemolysis predictions fall within ±15% of experimental measurements at all five operating points. Combined uncertainty analysis confirms agreement within validation uncertainty bounds at MRL 2 requirements."
