      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases at MRL 2 level.",
      "rationale": "Code verification confirmed via FDA benchmark CFD challenge results (2011, 2016). Solver performance on nozzle and backward-facing step cases demonstrates correct numerical implementation of Navier-Stokes equations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study demonstrating discretization error below 5% for hemolysis index QoI.",
      "rationale": "Three-level mesh refinement study performed (coarse: 4.2M, medium: 11.7M, fine: 28.3M elements). Richardson extrapolation yields GCI of 3.1% for normalized index of hemolysis, satisfying the 5% threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with uncertainty quantification sufficient to bound computational boundary conditions.",
      "rationale": "Flow loop experiments conducted at 2.5 L/min and 5.0 L/min with 60–120 mmHg pressure head. Temperature, hematocrit, and fluid viscosity recorded with calibrated instrumentation. Measurement uncertainty propagated to simulation boundary conditions."
    },
    {
      "type": "CredibilityFactor",
