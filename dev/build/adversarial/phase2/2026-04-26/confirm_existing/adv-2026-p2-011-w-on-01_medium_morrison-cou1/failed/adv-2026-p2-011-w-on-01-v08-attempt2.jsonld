      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted NIH values must agree with experimental measurements within combined simulation and experimental uncertainty bands.",
      "rationale": "Predicted NIH of 0.0043 g/100L vs. experimental mean of 0.0051 g/100L (16% relative error). Difference falls within combined uncertainty interval accounting for inter-sample biological variability and numerical uncertainty."
    },
    {
      "type": "CredibilityFactor",
