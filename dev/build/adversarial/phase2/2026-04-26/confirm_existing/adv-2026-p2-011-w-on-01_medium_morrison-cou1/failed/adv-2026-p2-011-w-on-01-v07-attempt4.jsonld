  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control, regression testing, and documented release notes must be in place for the CFD platform used.",
      "rationale": "ANSYS Fluent 2022 R2 was used under an ISO 9001-certified development process; version control logs and regression test reports were reviewed and found compliant with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from the ASME V&V 20 suite must demonstrate solver correctness for laminar and turbulent internal flows.",
      "rationale": "Lid-driven cavity and pipe-flow benchmarks were executed; computed velocity profiles matched analytical solutions within 0.8% RMS error, satisfying the MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the fine mesh.",
      "rationale": "Three-level mesh refinement study (coarse 2.1 M, medium 5.8 M, fine 14.3 M elements) yielded GCI = 2.3% for the scalar hemolysis index, exceeding the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, inlet hematocrit, temperature) must be documented and reproduced in simulation inputs within stated tolerances.",
      "rationale": "Bench test conditions from the FDA hemolysis dataset were reproduced in simulation boundary conditions; documented deviations were within ±3% for all controlled parameters."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental mean within 15% across the operating envelope.",
      "rationale": "NIH predictions across 6 operating points showed mean absolute error of 9.4% relative to experimental values, satisfying the 15% acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) must be directly linked to the clinical harm mechanism under consideration.",
      "rationale": "Normalized index of hemolysis and volume-averaged shear stress are established surrogates for erythrocyte damage in CPB circuits; their clinical relevance is supported by peer-reviewed literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use blood analogue fluids and pump geometry representative of the CPB device class.",
      "rationale": "FDA generic centrifugal pump geometry and porcine blood were used in validation experiments, providing high geometric and physiological fidelity to the intended CPB application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must reach 1e-5 for all transport equations.",
      "rationale": "At MRL 2 this factor is not required to be formally assessed; standard solver convergence monitoring was applied but no independent error quantification was performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification records and simulation execution checklists must be on file.",
      "rationale": "Not required at MRL 2; analysts hold relevant CFD qualifications but a formal use-error assessment was scoped out of this credibility evaluation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified against DNS or LES reference data for rotating internal flows.",
      "rationale": "SST k-omega was selected based on engineering judgment and prior literature; formal model-form uncertainty quantification is not mandated at MRL 2 and was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis for blood viscosity and hematocrit must be documented.",
      "rationale": "Nominal input values from published rheological data were used; parametric sensitivity was not formally quantified as it is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample size justification and inter-sample variability statistics must be provided for hemolysis measurements.",
      "rationale": "FDA dataset sample sizes were accepted as-is; independent sample-size analysis was not required at MRL 2 and was not conducted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Dimensional and non-dimensional parameter matching between simulation and experiment must be formally documented.",
      "rationale": "Reynolds number and flow coefficient matching was verified informally; a structured equivalency matrix was not produced, consistent with MRL 2 scope."
    }
  ],
