      "type": "ValidationResult",
      "name": "CFD vs. experimental hemolysis index comparison at nominal operating point"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cbp-hemolysis-vr-02",
      "type": "ValidationResult",
      "name": "Worst-case operating condition sweep validation against bench data"
    }
  ],
