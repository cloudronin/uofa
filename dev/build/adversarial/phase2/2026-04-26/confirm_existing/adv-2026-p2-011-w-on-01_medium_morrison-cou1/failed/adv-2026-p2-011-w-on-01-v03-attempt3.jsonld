  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "V&V 40 credibility assessment for CFD hemolysis prediction of the FDA generic centrifugal blood pump under cardiopulmonary bypass (CPB) conditions. This model has been applied in clinical research settings to identify worst-case hemolysis operating conditions for a Class II CPB device at Model Risk Level 2. Full 13-factor assessment: 7 factors assessed (all meeting required levels), 6 factors not assessed (acceptable at MRL 2). Package conforms to the Minimal profile; structured Context of Use block is not included in this submission.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-hemolysis-cfd-credible",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-centrifugal-pump-cfd-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis-dataset",
    "https://uofa.net/synth/data/fda-pump-cfd-simulation-outputs"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-val-01",
      "type": "ValidationResult",
      "name": "CFD hemolysis index vs experimental benchmark — FDA pump"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-val-02",
      "type": "ValidationResult",
      "name": "Pressure-flow characteristic curve validation across operating range"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4035557",
