  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented verification tests and version control consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2021R2 was used with documented release notes, regression test suite, and version-controlled case files. Software quality assurance meets the required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems at MRL 2 level.",
      "rationale": "Code verification confirmed via published ANSYS benchmark suite including lid-driven cavity and backward-facing step cases. Results match reference solutions within accepted tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be documented with at least three mesh refinement levels; GCI on primary QoI must be less than 5%.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 5.4M, 11.8M cells). GCI for hemolysis index at design point was 3.2%, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient detail to reproduce boundary conditions in the simulation.",
      "rationale": "FDA benchmark experimental data provide inlet flow rates, outlet pressures, fluid properties, and rotor speeds used directly as CFD boundary conditions. Documentation is sufficient for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared to experimental measurements using a quantitative metric; agreement within 20% for primary QoI.",
      "rationale": "Normalized index of hemolysis (NIH) predicted by CFD agreed with experimental measurements within 12% across five operating points. Pressure-flow curve agreement was within 8%. Exceeds MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the clinical decision being supported.",
      "rationale": "Normalized index of hemolysis is the established regulatory QoI for CPB device hemolysis assessment. Shear stress distributions are secondary QoIs directly linked to red blood cell damage mechanisms."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenarios must represent the intended operating envelope of the device under CPB conditions.",
      "rationale": "Validation experiments were conducted on the same FDA generic pump geometry at flow rates (2–8 L/min) and rotor speeds (2500–3500 RPM) spanning the clinical CPB operating envelope. Relevance is established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be documented; residuals below 1e-5 for all equations.",
      "rationale": "Not assessed at MRL 2 for this factor. Iterative convergence monitoring was performed as standard practice but formal quantification of solver error beyond residual tracking is not required at this model risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Evidence that analyst training and workflow controls prevent systematic user errors.",
      "rationale": "Not assessed at MRL 2. Simulation was performed by experienced CFD analysts; formal use-error assessment is reserved for higher model risk levels."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification for selection of turbulence model and hemolysis damage model must be documented.",
      "rationale": "Not assessed at MRL 2. SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power-law were selected based on literature consensus; formal model-form uncertainty quantification deferred to MRL 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of QoIs to uncertain input parameters must be characterized.",
      "rationale": "Not assessed at MRL 2. Blood viscosity and density were assigned nominal values from literature; parametric sensitivity analysis is planned for a future MRL 3 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size and variability must be characterized to support statistical comparison.",
      "rationale": "Not assessed at MRL 2. FDA benchmark dataset provides mean values without full inter-laboratory variability characterization; statistical treatment of sample variability is deferred."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Differences between validation experiment inputs and intended use inputs must be evaluated for their effect on QoI.",
      "rationale": "Not assessed at MRL 2. The validation experiment used bovine blood rather than human blood; equivalency of hematological properties for hemolysis prediction is acknowledged as a limitation to be addressed at higher MRL."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The CFD model is judged credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB conditions. This model has been applied in clinical research to support regulatory submissions for Class II CPB devices.",
