  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version controlled; build verification tests pass; change log maintained.",
      "rationale": "ANSYS Fluent 2022 R2 used under institutional license with version-controlled case files. Regression test suite executed prior to study; all tests passed. Software quality meets MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy verified on canonical benchmark problems relevant to rotating machinery flow.",
      "rationale": "Second-order spatial accuracy confirmed via Taylor-Green vortex and lid-driven cavity benchmarks. Observed convergence rates consistent with formal order of the discretization scheme."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI across three systematically refined meshes.",
      "rationale": "Three mesh levels (2.1M, 5.8M, 14.2M cells) assessed using Richardson extrapolation. GCI for normalized hemolysis index was 3.7%, satisfying the 5% threshold. Fine mesh adopted for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions documented and traceable; flow rate and rotational speed match simulation inputs within measurement uncertainty.",
      "rationale": "FDA benchmark experimental data provided flow rates of 2.5 and 5.0 L/min at 2500 and 3500 RPM. Inlet velocity profiles and outlet pressure conditions replicated in CFD setup. Measurement uncertainties documented in source dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 20% of experimental mean; velocity field agreement assessed qualitatively and quantitatively.",
      "rationale": "Predicted normalized hemolysis index deviated by 11.4% from experimental mean across all operating points. Velocity magnitude profiles compared via PIV data showed good spatial agreement. Exceeds MRL 2 acceptance threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) directly linked to device safety endpoint.",
      "rationale": "Normalized index of hemolysis (NIH) and volume-averaged scalar shear stress are the primary QoIs, both directly linked to red blood cell damage and the regulatory safety endpoint for CPB devices. Relevance confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry under overlapping operating conditions.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry — the same geometry used in the COU. Operating conditions span the clinical CPB range. Validation activities are directly relevant to the intended use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "At Model Risk Level 2, formal numerical solver error quantification beyond code verification is not required. Factor scoped out per MRL 2 requirements table in ASME V&V 40-2018."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Use error assessment is not mandated at MRL 2. Simulation inputs reviewed by a second analyst as a basic quality check; formal use error quantification deferred consistent with MRL 2 expectations."
    },
    {
