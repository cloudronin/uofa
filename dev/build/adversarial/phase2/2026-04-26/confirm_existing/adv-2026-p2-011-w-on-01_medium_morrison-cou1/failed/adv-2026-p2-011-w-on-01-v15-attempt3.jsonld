  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified under a recognized SQA framework with documented version control and regression testing.",
      "rationale": "ANSYS Fluent 2022 R2 was used with documented SQA procedures including version-controlled input files, regression test suite results, and release notes reviewed for hemolysis-relevant solver changes. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test or method-of-manufactured-solutions result demonstrating correct implementation of governing equations.",
      "rationale": "Order-of-accuracy verification was performed on canonical pipe flow and rotating cavity benchmarks. Observed spatial convergence rate of 1.92 is consistent with the nominally second-order discretization scheme, confirming correct solver implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or GCI analysis demonstrating discretization error below 5% for the primary quantity of interest.",
      "rationale": "Three-mesh GCI study was conducted on the FDA generic centrifugal pump geometry. The normalized hemolysis index GCI on the finest mesh pair was 3.1%, below the 5% threshold. Achieved level 3 reflects quantified uncertainty bounds provided alongside the point estimate."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with measurement uncertainty and traceable to calibrated instruments.",
      "rationale": "FDA benchmark experimental data include documented inlet flow rates, rotational speeds, and fluid properties with stated measurement uncertainties. Calibration certificates for flow meters and torque transducers are on file. Test conditions are directly replicated in the CFD boundary condition setup."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation metric U_val) computed for primary QoI against experimental data.",
      "rationale": "Normalized RMS error for hemolysis index across five operating points is 8.4%, within the acceptance band established for MRL 2. Pressure-flow characteristic NRMSE is 4.1%. Both metrics are within the pre-specified acceptance thresholds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated traceability between the computational QoI and the clinical or regulatory decision endpoint.",
      "rationale": "The primary QoI — normalized index of hemolysis (NIH) — is directly linked to the regulatory acceptance criterion for blood-contacting devices per ISO 10993-4 and FDA guidance. Traceability matrix mapping NIH to device safety endpoints is documented in the assessment report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the operating envelope defined for the intended use, including representative flow rates and rotational speeds.",
      "rationale": "Validation experiments span the CPB operating range of 2–6 L/min at 1500–3500 RPM, encompassing the worst-case hemolysis region identified by parametric sweep. Fluid properties (bovine blood analog) are representative of clinical blood viscosity at CPB hematocrit levels."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and mass balance error documented below solver-specific thresholds.",
      "rationale": "At MRL 2 with a commercially validated solver, detailed numerical solver error quantification beyond standard residual monitoring is not required. Residuals were monitored to 1e-5 for all equations; mass imbalance was below 0.01%. This factor is not formally assessed per the MRL 2 scoping decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented review of analyst qualification and simulation setup checklist completion.",
      "rationale": "Use error assessment is not required at MRL 2 for this device class. Analysts hold relevant CFD qualifications and followed internal simulation setup checklists; however, a formal use-error credibility assessment was scoped out of the MRL 2 plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Justification of turbulence model and hemolysis damage model selection relative to the COU flow regime.",
      "rationale": "Model form uncertainty quantification is not mandated at MRL 2. The SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power-law model were selected based on published benchmark comparisons; a formal model-form credibility assessment was not performed under this plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis identifying dominant input parameters and their uncertainty contribution to the QoI.",
      "rationale": "Formal input uncertainty propagation is not required at MRL 2. Nominal values for fluid density, viscosity, and pump geometry were taken from FDA benchmark specifications. A scoping sensitivity study was conducted informally but does not constitute a credibility-assessed activity."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documentation of experimental sample size and statistical representativeness of the validation dataset.",
      "rationale": "Test sample adequacy assessment is not required at MRL 2. The FDA benchmark dataset comprises five independent experimental runs per operating point; this sample size was accepted as adequate for the validation comparison without formal statistical power analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that CFD boundary conditions match experimental conditions within stated measurement uncertainty.",
      "rationale": "Equivalency of input parameters is not formally assessed at MRL 2. CFD boundary conditions were set to nominal experimental values; minor deviations in inlet velocity profile were noted but not formally quantified against an equivalency criterion under this assessment plan."
    }
  ],
