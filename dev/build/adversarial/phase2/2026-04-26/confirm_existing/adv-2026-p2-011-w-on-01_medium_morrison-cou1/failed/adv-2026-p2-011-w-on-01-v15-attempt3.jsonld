      "name": "Hemolysis index validation against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-val-result-002",
      "type": "ValidationResult",
      "name": "Pressure-flow characteristic validation at nominal CPB operating points"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037937",
