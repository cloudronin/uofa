  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. The six not-assessed factors are consistent with the MRL 2 scoping decision for a Class II device. The CFD model of the FDA generic centrifugal blood pump is accepted as sufficiently credible to support identification of worst-case hemolysis operating conditions for regulatory submission. This package is submitted under the Minimal profile; a full structured Context of Use declaration was not included in this submission package.",
