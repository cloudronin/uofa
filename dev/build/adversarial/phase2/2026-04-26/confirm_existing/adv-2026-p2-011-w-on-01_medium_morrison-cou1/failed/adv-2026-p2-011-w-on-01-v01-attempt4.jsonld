      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of experimental sample variability not required at MRL 2 when using established benchmark datasets.",
      "rationale": "FDA benchmark dataset used; sample-to-sample variability characterization is the responsibility of the original experimental campaign. Not re-assessed at MRL 2."
    },
