  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be version-controlled and subject to regression testing consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 was used under an ISO 9001-certified QMS. Regression test suite covering 95% of solver modules was executed prior to simulation campaign; all tests passed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations via method-of-manufactured-solutions or equivalent benchmark at MRL 2.",
      "rationale": "Lid-driven cavity and Poiseuille flow benchmarks were executed against analytical solutions; L2 error norms consistent with second-order spatial accuracy confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for primary QoI (hemolysis index) with GCI < 5% on the fine grid at MRL 2.",
      "rationale": "Three-level mesh refinement study performed (coarse 4.2M, medium 8.7M, fine 17.1M cells). GCI on hemolysis index = 2.3% on fine grid; observed order of convergence p = 1.94, consistent with second-order scheme. Exceeds MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with traceability to the operating envelope of the CPB device.",
      "rationale": "FDA benchmark experimental data (Hariharan et al. 2011) covers flow rates 2–7 L/min and rotational speeds 2000–3500 RPM, spanning the CPB operating envelope. Temperature, fluid viscosity, and hematocrit are reported with calibration traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty bounds.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values compared against six experimental operating points. Mean absolute error = 8.4%; all predictions fall within expanded uncertainty intervals (k=2). Validation metric satisfies MRL 2 acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoI (NIH) must be directly linked to the clinical risk metric used in device evaluation.",
      "rationale": "NIH is the regulatory-accepted metric for hemolysis assessment per ASTM F1841 and FDA guidance. The mapping from CFD shear stress history to NIH via the Giersiepen-Wurzinger power-law model is documented and traceable to the decision of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and fluid properties as the COU or provide documented justification for any differences.",
      "rationale": "Validation performed on the identical FDA generic centrifugal pump geometry using bovine blood at physiological hematocrit (35%), matching the conditions under which the model is applied. No geometry extrapolation required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2 with a well-established commercial solver, formal iterative convergence documentation beyond residual monitoring is not required.",
      "rationale": "Residual convergence to 1e-5 for all equations monitored; no iterative solver error assessment beyond standard monitoring required at MRL 2. Factor scoped consistent with ASME V&V 40 Table 1 guidance."
    },
    {
