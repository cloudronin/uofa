  "signature": "ed25519:b1c3e5a7d9f2b4c6e8a0d2f4b6c8e0a2d4f6b8c0e2a4d6f8b0c2e4a6d8f0b2c4",
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-lead-engineer",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required gradation levels for Model Risk Level 2. The six non-assessed factors are consistent with MRL 2 scope exemptions per ASME V&V 40-2018 Table 4. The CFD hemolysis model is judged credible for identifying worst-case operating conditions of the FDA generic centrifugal blood pump under CPB conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified under a recognized SQA framework with documented version control and regression testing.",
      "rationale": "ANSYS Fluent v2022R2 was used under an ISO 9001-compliant SQA plan. Version control logs, regression test suite results, and release notes were reviewed and found compliant with Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code must demonstrate correct implementation of governing equations via method-of-manufactured-solutions or equivalent benchmark comparison.",
      "rationale": "Order-of-accuracy tests using method of manufactured solutions confirmed second-order spatial convergence for the incompressible Navier-Stokes solver. Results are consistent with published FDA benchmark verification studies."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported; discretization error must be quantified and shown to be acceptable relative to the quantity of interest tolerance.",
      "rationale": "Richardson extrapolation and GCI analysis performed across three systematically refined meshes (2.1M, 6.8M, 18.4M elements). GCI for hemolysis index at the worst-case operating point was 4.2%, within the 5% acceptance threshold. Achieved level exceeds requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to confirm applicability to the computational boundary conditions.",
      "rationale": "FDA benchmark experimental conditions (flow rate 2.5–7.5 L/min, rotational speed 2000–3500 RPM, blood analog fluid properties) are fully documented in Hariharan et al. (2011) and confirmed to match the computational boundary conditions applied in this study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation metric) must be reported between model predictions and experimental data for the primary quantity of interest.",
      "rationale": "Normalized RMS error for hemolysis index predictions versus FDA experimental data was 11.3% across all operating points, within the 15% acceptance threshold defined for MRL 2. Pressure head predictions showed 6.8% normalized error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation activities must be directly relevant to the decision question regarding worst-case hemolysis identification.",
      "rationale": "The hemolysis index (normalized index of hemolysis, NIH) and scalar shear stress distribution are the primary quantities of interest, directly linked to the regulatory decision question of identifying worst-case hemolysis operating conditions. These quantities are established in FDA guidance for CPB device evaluation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use a geometry, fluid, and operating regime sufficiently similar to the intended use to support extrapolation of credibility conclusions.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry under CPB-representative operating conditions using a blood analog fluid. The validation domain closely matches the intended use domain, supporting credibility extrapolation at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must be reported; solver error must be shown negligible relative to discretization error.",
      "rationale": "Not assessed at MRL 2 per ASME V&V 40-2018 Table 4 scoping. Residual convergence to 1e-5 was monitored as a minimum practice but formal solver error quantification is not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "User qualification and simulation workflow documentation must be sufficient to demonstrate controlled use.",
      "rationale": "Not formally assessed at MRL 2. Simulation was performed by a qualified CFD engineer with 8 years of cardiovascular device simulation experience. Workflow was peer-reviewed internally but not subject to formal use-error assessment at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form assumptions (turbulence model, constitutive equations, hemolysis power-law model) must be documented and justified.",
      "rationale": "Not assessed at MRL 2. The SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power-law model were selected based on published precedent in FDA CFD hemolysis literature. Formal model form uncertainty quantification is not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity of QoI to uncertain input parameters must be characterized.",
      "rationale": "Not assessed at MRL 2. Nominal blood analog fluid properties (density 1056 kg/m3, dynamic viscosity 0.0035 Pa·s) were used. Input sensitivity analysis is deferred as not required for MRL 2 scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample size and variability must be characterized to support statistical comparison with model predictions.",
      "rationale": "Not assessed at MRL 2. FDA benchmark experimental data includes triplicate measurements at each operating point; statistical characterization of experimental variability beyond mean values is not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between experimental and computational input parameters must be formally demonstrated.",
      "rationale": "Not assessed at MRL 2. Boundary conditions were set to match nominal experimental conditions as reported. Formal equivalency mapping with uncertainty propagation is not required at this risk level."
    }
  ],
