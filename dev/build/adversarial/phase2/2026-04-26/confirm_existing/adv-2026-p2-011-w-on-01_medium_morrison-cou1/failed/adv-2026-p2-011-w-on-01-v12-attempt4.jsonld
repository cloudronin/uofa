      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2021 R2) is a commercially validated, FDA-recognized simulation tool. Version control, regression testing, and release notes confirm SQA compliance at Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Method of manufactured solutions (MMS) was applied to the Navier-Stokes and scalar transport equations. Observed order of convergence matched theoretical order within 5%, confirming correct numerical implementation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Richardson extrapolation performed on three systematically refined meshes (4.2M, 8.7M, 17.1M cells). Grid convergence index (GCI) for hemolysis index < 3.8%, satisfying MRL 2 discretization requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Experimental test conditions (flow rates 2–6 L/min, pressure rises 60–200 mmHg, bovine blood at 37°C) were documented with calibrated instrumentation and uncertainty budgets consistent with ASME MFC-3M."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Quantitative validation metrics (E%, U_val) computed for hemolysis index and pressure rise across all 12 operating points. Normalized RMS error 11.4% for hemolysis index; model uncertainty bounded within experimental uncertainty at 10 of 12 points."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The primary QoI (normalized index of hemolysis, NIH) is the clinically and regulatorily accepted metric for blood damage assessment in CPB devices, directly linked to the intended use question."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry under CPB-representative operating conditions, providing direct relevance to the intended simulation context."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed; acceptable at MRL 2 per ASME V&V 40 Table 3.",
      "rationale": "Iterative convergence monitored via residual drop (>4 orders of magnitude) and flux imbalance (<0.01%). Formal solver error quantification not required at MRL 2 and was scoped out of this assessment cycle."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed; acceptable at MRL 2 per ASME V&V 40 Table 3.",
      "rationale": "Simulation setup was reviewed by a senior analyst; no formal use-error assessment protocol was invoked at MRL 2. Peer review of boundary condition specification and material property assignments was conducted informally."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed; acceptable at MRL 2 per ASME V&V 40 Table 3.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected based on literature precedent for CPB applications. Formal model-form uncertainty analysis was not required at MRL 2."
    },
    {
