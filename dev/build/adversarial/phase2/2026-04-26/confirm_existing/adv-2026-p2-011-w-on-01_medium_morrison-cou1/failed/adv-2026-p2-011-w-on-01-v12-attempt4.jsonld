      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed; acceptable at MRL 2 per ASME V&V 40 Table 3.",
      "rationale": "Three independent blood samples from different bovine donors were used in the FDA experimental dataset. Statistical characterization of inter-sample variability was not performed within this assessment scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Computational boundary conditions (inlet velocity profiles, outlet pressure boundary, rotational speed) were matched to experimental measurements within documented uncertainty bounds, confirming input equivalency between simulation and test."
