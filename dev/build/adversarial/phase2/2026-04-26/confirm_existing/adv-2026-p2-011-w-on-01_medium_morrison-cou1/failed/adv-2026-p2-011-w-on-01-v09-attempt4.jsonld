  "signature": "ed25519:b4e2d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d9f1a3c5e7b9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented version control, regression testing records, and traceable build logs consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially validated code with documented SQA procedures. Version control records and regression test reports were reviewed and found compliant with the required gradation for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against analytical solutions or established benchmark problems to demonstrate correct implementation of governing equations at the required gradation.",
      "rationale": "The solver was verified against the Taylor-Green vortex benchmark and the lid-driven cavity problem. Results were within accepted tolerances, confirming correct implementation of the incompressible Navier-Stokes equations relevant to the CPB hemolysis application."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be quantified through systematic mesh refinement studies; the resulting error estimate must be within acceptable bounds for the quantities of interest at MRL 2.",
      "rationale": "A three-level mesh refinement study was conducted on the FDA generic centrifugal pump geometry. Richardson extrapolation yielded a grid convergence index (GCI) of less than 3% for wall shear stress and velocity magnitude at the impeller outlet, exceeding the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to allow comparison with simulation boundary conditions, including flow rate, rotational speed, fluid properties, and temperature.",
      "rationale": "The FDA benchmark experimental dataset documents inlet flow rates (2–7 L/min), impeller speeds (2000–3500 RPM), and blood analog fluid properties. These were mapped directly to CFD boundary conditions with traceable uncertainty characterization."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared quantitatively to experimental measurements for the primary quantities of interest using accepted validation metrics.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values were compared against experimental measurements across five operating points. The mean absolute relative error was 8.4%, within the 15% acceptance threshold established for this MRL 2 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest predicted by the model must be demonstrably linked to the clinical or engineering decision being supported, with documented traceability.",
      "rationale": "NIH and scalar stress exposure time are directly linked to red blood cell damage mechanisms and regulatory acceptance criteria for CPB devices. The mapping from model outputs to device safety endpoints is documented in the assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the intended use conditions to support extrapolation of credibility evidence to the COU.",
      "rationale": "Validation experiments used the same FDA generic pump geometry and blood analog fluid as the intended simulation application. Operating conditions bracketed the CPB clinical range, supporting relevance of the validation evidence to the intended use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit quantification of numerical solver error beyond code verification is not required; documented use of a verified commercial solver satisfies this factor.",
      "rationale": "Per MRL 2 guidance, this factor is satisfied by the software quality assurance and numerical code verification evidence already provided. Separate solver error quantification is not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error analysis is not required; documented analyst qualifications and review procedures are sufficient.",
      "rationale": "The simulation team holds relevant CFD and biomedical engineering credentials. Simulation setup was reviewed by a senior analyst. Formal use error quantification is scoped out at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form uncertainty need not be formally quantified; selection of governing equations must be documented with supporting rationale.",
      "rationale": "The SST k-omega turbulence model was selected based on published literature demonstrating suitability for rotating machinery with adverse pressure gradients. Formal model form uncertainty quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model input uncertainty need not be propagated through formal sensitivity analysis; documented sources and nominal values are sufficient.",
      "rationale": "Fluid viscosity, density, and inlet velocity profiles were sourced from the FDA benchmark dataset with documented measurement uncertainties. Formal input uncertainty propagation is scoped out at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterization of test sample variability is not required; documentation of sample provenance and preparation is sufficient.",
      "rationale": "The FDA benchmark used a standardized blood analog (glycerin-water mixture) with documented preparation protocol. Sample-to-sample variability characterization is not required at MRL 2."
