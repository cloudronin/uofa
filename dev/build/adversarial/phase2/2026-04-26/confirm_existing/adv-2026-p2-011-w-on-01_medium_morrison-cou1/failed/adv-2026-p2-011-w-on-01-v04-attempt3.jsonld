  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. The six non-assessed factors are appropriately scoped out per ASME V&V 40 Table 1 for the declared model risk level. The CFD hemolysis model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device within the bounds of the operating envelope evaluated. This model has been applied in clinical research to support device design decisions; the assessment team confirms that the evidence package is sufficient for the intended regulatory submission at MRL 2.",
