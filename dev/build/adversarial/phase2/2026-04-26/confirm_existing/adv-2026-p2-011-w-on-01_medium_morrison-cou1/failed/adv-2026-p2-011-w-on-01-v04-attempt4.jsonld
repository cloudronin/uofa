  "signature": "ed25519:b2e7f4a1c9d3e6b0f8a5c2d4e7b1f3a6c8d0e2f4a7b9c1d3e5f7a0b2c4d6e8f1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified and documented per SQA procedures consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2022R2) is a commercially validated code with documented SQA procedures, release notes, and regression test suites. Version control and configuration management records confirm compliance with MRL 2 SQA requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must demonstrate correct implementation of governing equations through benchmark problems at MRL 2 level.",
      "rationale": "The solver has been verified against standard CFD benchmark cases including lid-driven cavity and backward-facing step flows. Published verification studies confirm correct implementation of the Navier-Stokes equations and the power-law hemolysis model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate discretization error below 5% for the hemolysis index QoI.",
      "rationale": "A three-level mesh refinement study was conducted with element counts of 2.1M, 4.8M, and 9.6M cells. Richardson extrapolation yields a Grid Convergence Index of 3.2% for the normalized hemolysis index, meeting the 5% threshold at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and representative of the modeled operating range.",
      "rationale": "FDA generic centrifugal pump experimental data were collected at five operating points spanning 2000–3500 RPM and flow rates of 2–6 L/min. Test conditions are documented in the FDA benchmark dataset and cover the intended CPB operating envelope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model predictions must be compared quantitatively to experimental data with error metrics reported for primary QoIs.",
      "rationale": "Predicted hemolysis index values agree with experimental measurements within 18% across all five operating points. Pressure rise predictions show mean absolute error of 4.1 mmHg. Both metrics satisfy MRL 2 acceptance thresholds for output comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the clinical decision question regarding worst-case hemolysis.",
      "rationale": "The normalized index of hemolysis (NIH) and modified index of hemolysis (MIH) are the primary QoIs, directly corresponding to regulatory hemolysis endpoints for CPB devices. These QoIs are established in FDA guidance and ASTM F1841 as relevant measures for blood pump evaluation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometry, fluid properties, and operating conditions sufficiently similar to the intended CPB deployment scenario.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry under blood-analog fluid conditions matching CPB viscosity and density. Operating conditions span the clinical CPB range, confirming adequate relevance of validation activities to the intended use scenario."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, detailed iterative solver error quantification beyond residual monitoring is not required.",
      "rationale": "Solver residuals were monitored to convergence below 1e-5 for all equations. Formal iterative error quantification beyond residual tracking is scoped out at MRL 2 per ASME V&V 40 Table 1 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use error analysis is not required at MRL 2 for this factor.",
      "rationale": "Use error assessment is not required at MRL 2 per ASME V&V 40 credibility factor requirements table. Simulation was executed by trained CFD engineers following documented simulation protocols, providing adequate informal control."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Detailed model form uncertainty quantification is not required at MRL 2.",
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger) is the accepted standard for CFD-based hemolysis prediction. Formal model form uncertainty analysis is beyond MRL 2 requirements; model selection rationale is documented in the simulation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal input uncertainty propagation is not required at MRL 2.",
      "rationale": "Blood viscosity, density, and hemolysis model coefficients are taken from published literature values. Sensitivity to input variation was informally assessed through boundary condition sweeps; formal UQ propagation is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability is not required at MRL 2.",
      "rationale": "FDA benchmark experimental data represent a single pump specimen tested under controlled laboratory conditions. Sample-to-sample variability characterization is not required at MRL 2; the benchmark dataset is accepted as representative for validation purposes."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency demonstration between validation and deployment input parameters is not required at MRL 2.",
      "rationale": "The validation geometry and boundary conditions closely match the intended CPB deployment scenario. Formal equivalency mapping is not required at MRL 2; qualitative correspondence between validation inputs and COU inputs is documented in the simulation report."
    }
  ],
