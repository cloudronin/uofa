      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterization documented in FDA experimental report.",
      "rationale": "Bovine blood samples were prepared per ASTM F1841 and characterized for hematocrit and plasma free hemoglobin. Formal test-sample credibility assessment is not required at MRL 2."
