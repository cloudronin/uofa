      "acceptanceCriteria": "Solver passes standard CFD benchmark suite (lid-driven cavity, pipe flow) within expected error bounds.",
      "rationale": "ANSYS Fluent passed all applicable ASME V&V 20 benchmark cases. Order-of-accuracy tests confirmed second-order spatial convergence for the incompressible Navier-Stokes solver used in this study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI on the fine mesh.",
      "rationale": "Richardson extrapolation over three systematically refined meshes (2.1 M, 6.4 M, 18.7 M cells) yielded GCI of 3.2% for the normalized index of hemolysis, satisfying the MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid viscosity) are documented and traceable to calibrated instruments.",
      "rationale": "FDA in-vitro hemolysis experiments used bovine blood at 37 °C; flow rates and impeller speeds were measured with calibrated transducers. Uncertainty budgets are documented in the companion test report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated normalized index of hemolysis agrees with experimental values within combined simulation and measurement uncertainty at all five validation operating points.",
      "rationale": "CFD predictions of NIH fell within ±18% of experimental means across all five operating points, consistent with combined expanded uncertainty. Systematic over-prediction at high shear is noted but within accepted tolerance for MRL 2."
