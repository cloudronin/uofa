      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Code verification confirmed through manufacturer-supplied benchmark suite for incompressible Navier-Stokes and turbulence model implementations. Results consistent with published analytical solutions for canonical flows relevant to rotary pump geometries."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Systematic mesh refinement study conducted across three mesh densities (3.2M, 8.7M, and 21.4M elements). Grid convergence index (GCI) computed per Roache methodology. Discretization error for hemolysis index QoI estimated at less than 4.8%, acceptable at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Experimental test conditions for the FDA generic centrifugal pump benchmark are well-documented. Flow rates (2.5–7 L/min) and rotational speeds (2500–3500 RPM) span the intended CPB operating envelope. Temperature and fluid properties controlled and reported."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Computational hemolysis index predictions compared against published FDA benchmark experimental data. Normalized index of agreement exceeds 0.85 across all evaluated operating points. Pressure-head and flow characteristics match within 6% of experimental measurements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
