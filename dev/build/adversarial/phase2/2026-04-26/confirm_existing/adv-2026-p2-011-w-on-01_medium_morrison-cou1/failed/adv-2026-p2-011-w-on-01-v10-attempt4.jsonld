    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-vr-01",
      "type": "ValidationResult",
      "name": "CFD hemolysis index comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-vr-02",
      "type": "ValidationResult",
      "name": "Worst-case operating point identification validation against in-vitro measurements"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034918",
