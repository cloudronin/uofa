  "signature": "ed25519:b1e4a7d0c3f6a9b2e5d8c1f4a7b0d3e6c9f2a5b8d1e4f7a0c3b6d9e2f5a8b1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be under version control with documented QA procedures meeting MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2021 R2 was used under a documented QA plan including version control, regression testing, and release validation. All QA records are archived and meet the MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass standard benchmark verification cases relevant to rotating machinery internal flow at MRL 2.",
      "rationale": "The CFD solver was verified against the Taylor-Couette flow and lid-driven cavity benchmarks. Residuals and error norms confirm code correctness within MRL 2 acceptance thresholds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported and discretization error must be within acceptable bounds for MRL 2.",
      "rationale": "A three-level mesh refinement study was conducted. GCI values for hemolysis index were below 4% on the fine mesh. Richardson extrapolation confirmed spatial discretization error is well within MRL 2 bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and traceable to the simulation boundary conditions.",
      "rationale": "FDA benchmark experimental conditions (flow rate, rotational speed, fluid properties) are fully documented in Morrison et al. and replicated in simulation boundary conditions. Traceability is established."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must be compared quantitatively to experimental measurements with documented metrics.",
      "rationale": "Predicted normalized index of hemolysis (NIH) values were compared to experimental measurements across five operating points. Mean relative error was 12%, within the MRL 2 acceptance band of 20%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest (NIH, shear stress distribution) must be directly relevant to the hemolysis prediction decision.",
      "rationale": "NIH and volume-averaged scalar shear stress are the primary quantities of interest. Both are directly linked to red blood cell damage mechanisms and are established endpoints for CPB hemolysis assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must reflect CPB operating conditions representative of clinical use ranges.",
      "rationale": "Validation was performed at flow rates of 2.5 to 7 L/min and rotational speeds of 2000 to 3500 RPM, spanning the typical CPB operating envelope. The validation scenario is sufficiently representative for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, iterative solver error need not be separately quantified if residual convergence criteria are documented.",
      "rationale": "Solver residuals were driven below 1e-5 for all equations. Separate quantification of iterative solver error is not required at MRL 2 and has been scoped out per the credibility plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error analysis is not required provided analyst qualifications are documented.",
      "rationale": "Analysts hold relevant CFD and biofluid mechanics credentials. Formal use error quantification is not required at MRL 2 and has been scoped out per the credibility plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis damage model must be justified for the flow regime and documented.",
      "rationale": "The SST k-omega turbulence model was selected based on its validated performance in rotating internal flows. The Giersiepen-Wurzinger power-law hemolysis model is the established standard for CFD hemolysis prediction in CPB devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Fluid properties, geometry, and boundary conditions must be traceable to documented sources.",
      "rationale": "Blood viscosity (0.0035 Pa·s) and density (1056 kg/m³) are sourced from published literature. Pump geometry is the FDA-released CAD model. Boundary conditions are traceable to the experimental protocol."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, detailed characterization of experimental blood sample variability is not required.",
      "rationale": "The FDA benchmark study used porcine blood with documented hematocrit. Full sample-to-sample variability characterization is not required at MRL 2 and has been scoped out."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency mapping between simulation inputs and experimental conditions is not required beyond boundary condition matching.",
      "rationale": "Boundary conditions were matched to experimental values. Formal equivalency analysis of all input parameters is not required at MRL 2 and has been scoped out per the credibility plan."
    }
  ],
