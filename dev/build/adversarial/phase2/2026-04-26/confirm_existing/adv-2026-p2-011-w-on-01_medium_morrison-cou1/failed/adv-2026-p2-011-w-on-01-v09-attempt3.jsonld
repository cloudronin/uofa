  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 non-assessed factors are confirmed not required at MRL 2 per ASME V&V 40-2018 Table 4. The CFD hemolysis model is accepted as credible for identification of worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in CPB applications. This model has been applied in clinical research contexts and the assessment team judges the evidence sufficient to support the regulatory submission claim.",
