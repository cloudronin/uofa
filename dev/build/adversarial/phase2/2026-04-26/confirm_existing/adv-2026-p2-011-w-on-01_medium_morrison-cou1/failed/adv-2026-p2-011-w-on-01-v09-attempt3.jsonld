  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be version-controlled with documented regression test suite passing all baseline cases.",
      "rationale": "ANSYS Fluent 2022R1 used with documented version control and regression testing. All baseline hemolysis benchmark cases pass. Required level 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order of accuracy confirmed via manufactured solution or benchmark comparison at required gradation.",
      "rationale": "Second-order spatial accuracy confirmed via lid-driven cavity benchmark and Taylor-Green vortex manufactured solution. Observed order matches theoretical order within 5%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI; GCI < 5% on fine grid.",
      "rationale": "Richardson extrapolation performed on three mesh levels (2.1M, 5.8M, 14.2M cells). GCI for hemolysis index on fine grid is 3.2%, meeting the < 5% criterion at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with uncertainty bounds; boundary conditions traceable to test measurements.",
      "rationale": "FDA benchmark experimental conditions (flow rate 2.5–7 L/min, rotational speed 2000–3500 RPM) fully documented with calibration records. CFD boundary conditions set directly from measured inlet/outlet pressures."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within validation uncertainty band of experimental measurements across operating envelope.",
      "rationale": "Normalized index of hemolysis (NIH) predictions agree with experimental measurements within combined experimental and numerical uncertainty (U95 = 18%) across all 9 operating points evaluated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (NIH) directly linked to the device safety claim; secondary QoIs (shear stress, residence time) support mechanistic understanding.",
      "rationale": "NIH is the regulatory-accepted metric for hemolysis assessment per FDA guidance. Shear stress and erythrocyte residence time included as mechanistic QoIs. All QoIs directly relevant to worst-case identification decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry under overlapping operating conditions as the COU operating envelope.",
      "rationale": "FDA generic centrifugal pump geometry used for both validation and COU prediction. Operating conditions in validation experiments span the full CPB clinical range (2–6 L/min). High relevance confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; basic iterative convergence documented.",
      "rationale": "At MRL 2, formal solver error quantification beyond convergence monitoring is not required. Residuals reduced by 6 orders of magnitude in all simulations. Factor scoped to gradation 1 per MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation setup reviewed by a second analyst.",
      "rationale": "Peer review of simulation setup performed by independent analyst within the assessment team. Formal use-error quantification not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified; sensitivity to model form documented for primary QoI.",
      "rationale": "SST k-omega selected based on literature review of rotating machinery hemolysis CFD. Sensitivity study comparing SST k-omega, k-epsilon realizable, and Spalart-Allmaras shows NIH variation < 8% across models. Selection justified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood rheology parameters and hemolysis power-law constants sourced from peer-reviewed literature with uncertainty bounds reported.",
      "rationale": "Giersiepen-Wurzinger power-law hemolysis constants (C=3.62e-5, alpha=2.416, beta=0.785) used with documented literature sources. Viscosity modeled as Newtonian at 0.0035 Pa·s consistent with clinical CPB conditions. Input uncertainty propagated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; sample characterization documented at basic level.",
      "rationale": "FDA benchmark used bovine blood samples with documented hematocrit (35±2%). Formal statistical characterization of sample variability not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative equivalency argument between validation and COU conditions documented.",
      "rationale": "Qualitative argument provided: bovine blood rheology used in validation is accepted as equivalent to human blood at CPB hematocrit levels per established FDA precedent. Formal equivalency quantification not required at MRL 2."
    }
  ],
