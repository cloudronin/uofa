      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) is a commercially validated code with documented QA procedures. Version control, regression testing, and release notes are maintained by the vendor. Achieved level 2 satisfies the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Order-of-accuracy tests were performed on canonical pipe flow and lid-driven cavity benchmarks. Second-order spatial convergence confirmed. Achieved level 2 satisfies the requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI; GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study performed (coarse 1.2M, medium 3.1M, fine 7.8M cells). GCI for the hemolysis index on the fine grid was 3.2%, satisfying the acceptance criterion. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) documented and matched to simulation inputs within stated uncertainty.",
      "rationale": "FDA benchmark experimental conditions (flow rates 2.5–7 L/min, speeds 2000–3500 RPM) are fully documented in the Morrison dataset. Simulation inlet/outlet BCs replicate measured conditions. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., NRMSE or mean absolute error) reported between predicted and measured hemolysis index across all operating points.",
      "rationale": "Normalized root-mean-square error of 8.4% across 15 operating points, with bias < 5%. Uncertainty bands from experimental replication (n=3 per point) are included in the comparison. Achieved level 3 exceeds the MRL 2 requirement of level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (hemolysis index, shear stress distribution) are directly linked to the clinical decision question of worst-case hemolysis identification.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is the regulatory metric for blood pump hemocompatibility per FDA guidance. Secondary QoI is volume-averaged scalar shear stress. Both are directly relevant to the decision question. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same device geometry, fluid, and operating envelope as the intended COU.",
      "rationale": "Validation used the FDA generic centrifugal blood pump with bovine blood under CPB-representative flow conditions. Device geometry, rotational speed range, and fluid rheology match the intended application. Achieved level 2."
    },
    {
