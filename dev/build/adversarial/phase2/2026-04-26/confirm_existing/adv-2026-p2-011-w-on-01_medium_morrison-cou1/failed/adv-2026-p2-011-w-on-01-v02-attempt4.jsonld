  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be validated and version-controlled per MRL 2 requirements.",
      "rationale": "ANSYS Fluent v2021R2 was used under a documented QMS with version control, regression test suite, and release notes reviewed by the simulation team. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of governing equations at MRL 2.",
      "rationale": "Method of manufactured solutions (MMS) was applied to the incompressible Navier-Stokes solver confirming second-order spatial convergence. Benchmark lid-driven cavity results matched published reference data within 0.5%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be quantified and reported; GCI < 5% on QoI at MRL 2.",
      "rationale": "Three-level mesh refinement study was performed (coarse 3.2 M, medium 8.7 M, fine 21.4 M cells). Richardson extrapolation yielded GCI of 2.1% on NIH, exceeding the MRL 2 threshold and achieving Gradation 3 performance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented and reproduced in simulation inputs.",
      "rationale": "Inlet flow rates, pump rotational speed, and fluid properties from the FDA GCBP experimental protocol were reproduced in the CFD boundary conditions. Deviations in fluid viscosity (bovine blood vs. glycerol-water surrogate) were documented and sensitivity-tested."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric u_val) must be computed and within acceptance band.",
      "rationale": "NIH predictions agreed with experimental measurements within 18% across five operating points; mean absolute error was 12.4%. Velocity field RMS error was 7.3% of bulk velocity, within the MRL 2 acceptance band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly relevant to the decision question.",
      "rationale": "NIH and shear stress exposure time (SSET) are the primary hemolysis indicators for CPB device safety assessment. Both QoIs were measured experimentally and predicted computationally, establishing direct relevance to the worst-case identification decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must cover the operating envelope relevant to CPB use conditions.",
      "rationale": "Validation experiments spanned rotational speeds of 2000–3500 rpm and flow rates of 2.5–7.5 L/min, encompassing the CPB clinical operating range. Geometric fidelity of the FDA GCBP to the target device class was confirmed by independent review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, iterative convergence monitoring is sufficient; formal solver error quantification is not required.",
      "rationale": "Residuals were monitored to 1e-6 for all equations; mass imbalance < 0.01%. Formal numerical solver error quantification beyond convergence monitoring is not required at MRL 2 and was scoped out per the assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, documented simulation setup review is sufficient.",
      "rationale": "Simulation setup was reviewed by a second analyst against the documented simulation protocol. Formal use-error quantification is not required at MRL 2."
    },
    {
