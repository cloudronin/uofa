      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form selection must be justified; uncertainty quantification not required at MRL 2.",
      "rationale": "The SST k-omega turbulence model was selected based on published benchmarks for rotating machinery flows. Model form uncertainty quantification beyond literature justification is not required at MRL 2."
    },
    {
