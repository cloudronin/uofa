      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model inputs must be identified and sourced; formal sensitivity analysis not required at MRL 2.",
      "rationale": "Fluid density, viscosity, and hemolysis power-law constants were sourced from peer-reviewed literature with documented provenance. Formal input uncertainty propagation is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental sample provenance must be documented; statistical characterization not required at MRL 2.",
      "rationale": "FDA GCBP experimental data were obtained from the publicly released dataset with documented sample preparation procedures. Statistical characterization of inter-sample variability is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Differences between validation and COU input parameters must be identified; formal equivalency mapping not required at MRL 2.",
      "rationale": "Differences between the glycerol-water surrogate fluid used in validation experiments and blood analog used in CPB application were identified and documented. Formal equivalency quantification is not required at MRL 2."
    }
