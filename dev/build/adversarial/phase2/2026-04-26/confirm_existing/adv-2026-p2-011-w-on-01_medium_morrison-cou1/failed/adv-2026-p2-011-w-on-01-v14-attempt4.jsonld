    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be directly relevant to the clinical decision question regarding hemolysis risk.",
      "rationale": "Normalized index of hemolysis (NIH) and modified index of hemolysis (MIH) are the primary QoIs, directly linked to red blood cell damage risk in CPB. Gradation 2 satisfied."
