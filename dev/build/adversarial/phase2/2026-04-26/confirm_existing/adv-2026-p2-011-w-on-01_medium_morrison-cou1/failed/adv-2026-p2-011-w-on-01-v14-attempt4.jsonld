      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of governing equations for the solver used.",
      "rationale": "Manufactured solution and benchmark comparisons confirm correct implementation of the incompressible Navier-Stokes solver. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported and discretization error bounded within acceptable limits for hemolysis index QoI.",
      "rationale": "Three-mesh Richardson extrapolation study yielded GCI < 3% for hemolysis index across all operating points. Gradation 2 requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with sufficient fidelity to allow comparison with simulation boundary conditions.",
      "rationale": "FDA benchmark test conditions (flow rate, rotational speed, fluid viscosity, temperature) are fully documented and traceable. Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics between simulation outputs and experimental measurements must be reported.",
      "rationale": "Hemolysis index predictions agree with experimental measurements within 15% across all five operating points. Pressure-flow curves match within measurement uncertainty. Exceeds gradation 2 requirement."
