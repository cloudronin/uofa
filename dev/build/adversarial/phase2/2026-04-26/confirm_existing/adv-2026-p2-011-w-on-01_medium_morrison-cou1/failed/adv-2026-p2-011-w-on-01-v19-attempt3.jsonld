      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for model-form uncertainty quantification.",
      "rationale": "Formal model-form uncertainty quantification is not required at MRL 2. The k-omega SST turbulence model selection is justified by published literature for rotating blood-pump flows but not formally assessed here."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
