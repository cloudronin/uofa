  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version-controlled; documented QA procedures for ANSYS Fluent 2022R1 in place.",
      "rationale": "The CFD solver is under formal version control with regression test suites executed at each release cycle. QA documentation satisfies MRL 2 requirements for software assurance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured-solution and benchmark tests confirm solver correctness for incompressible Navier-Stokes with rotating reference frames.",
      "rationale": "Order-of-accuracy tests using the method of manufactured solutions demonstrate second-order spatial convergence. Results consistent with published ANSYS Fluent verification benchmarks."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence index (GCI) for hemolysis index QoI below 5% across three systematically refined meshes.",
      "rationale": "Three-mesh Richardson extrapolation yields GCI of 3.8% for the scalar hemolysis index at the design operating point, satisfying the MRL 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, inlet pressure, hematocrit) documented and traceable to FDA benchmark protocol.",
      "rationale": "All physical test conditions are reported in the FDA benchmark dataset with full uncertainty characterisation. Inlet and outlet boundary conditions in the CFD model reproduce experimental settings within 1%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalised index of hemolysis (NIH) within two experimental standard deviations across all six operating points.",
      "rationale": "Simulation NIH values fall within 1.4 experimental standard deviations at five of six operating points and within 1.8 at the sixth, exceeding the MRL 2 requirement. Systematic over-prediction at high flow rates is noted and attributed to power-law viscosity model simplification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "NIH and scalar shear stress exposure are direct surrogates for clinical hemolysis risk accepted by FDA guidance.",
      "rationale": "The chosen QoIs — normalised index of hemolysis and time-averaged scalar shear stress — are the standard metrics referenced in FDA guidance for blood-contacting device evaluation, confirming direct relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same FDA generic centrifugal pump geometry under overlapping operating conditions.",
      "rationale": "Validation uses the identical pump geometry and the same blood analogue fluid as the intended computational model. Operating envelope of validation experiments encompasses the worst-case CPB flow rates of interest."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default acceptance applies.",
      "rationale": "Per ASME V&V 40 Table 1, numerical solver error assessment is not required at Model Risk Level 2. Factor is scoped out of the formal assessment without penalty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst training records reviewed informally.",
      "rationale": "MRL 2 does not mandate a formal use-error assessment. Analysts hold relevant CFD competency certifications; no structured evaluation was performed."
    },
    {
