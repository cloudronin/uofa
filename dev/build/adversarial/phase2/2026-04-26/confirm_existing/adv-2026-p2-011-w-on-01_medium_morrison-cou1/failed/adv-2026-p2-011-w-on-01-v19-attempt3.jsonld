      "name": "CFD hemolysis index comparison against FDA experimental measurements"
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-vr-002",
      "type": "ValidationResult",
      "name": "Operating-point sweep validation for worst-case identification"
    }
  ],
