      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA benchmark uses standardised bovine blood analogue.",
      "rationale": "Test-sample characterisation beyond the standard FDA protocol is not required at MRL 2. The bovine blood analogue properties are well-characterised in the benchmark dataset."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative equivalency noted between validation and COU conditions.",
      "rationale": "Formal equivalency mapping between validation experiment inputs and COU inputs is not required at MRL 2. Qualitative review confirms comparable hematocrit, viscosity, and operating pressures."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six non-assessed factors are explicitly scoped out per ASME V&V 40 Table 1 provisions for MRL 2. The model is accepted as sufficiently credible to identify worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in the CPB context. This model has been applied in clinical research to inform device design decisions, and the assessment team judges the evidence package adequate for the intended regulatory submission.",
