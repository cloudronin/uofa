  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2022 R2) is a commercially validated code with documented QA procedures. Version control, regression testing, and release notes confirm software quality assurance at Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Benchmark test cases from the ASME V&V 20 suite were executed and results compared against published analytical solutions. Residuals and conservation errors are within accepted tolerances, confirming code verification at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "A three-level mesh refinement study was conducted on the FDA pump geometry. Richardson extrapolation yielded a grid convergence index below 3% for the hemolysis index QoI, satisfying discretization error requirements at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Experimental test conditions (flow rates 2–8 L/min, rotational speeds 2000–3500 RPM, blood analog fluid properties) are documented and traceable to the FDA benchmark protocol. Boundary conditions in the CFD model replicate experimental settings within measurement uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Predicted hemolysis index values were compared against experimental measurements across 12 operating points. Mean absolute error of 8.4% and all predictions within two standard deviations of experimental scatter confirm adequate output agreement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The hemolysis index and normalized index of hemolysis are the primary QoIs and are directly relevant to the device safety question. Secondary QoIs (wall shear stress, exposure time distribution) support mechanistic interpretation and are established hemolysis surrogates in the literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Validation activities used the FDA benchmark pump geometry under CPB-representative flow conditions. The validation domain overlaps sufficiently with the intended simulation domain to support credibility at MRL 2 without requiring full clinical-condition equivalence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed; acceptable at MRL 2 given commercial solver with documented verification.",
      "rationale": "Numerical solver error beyond discretization and code verification is not separately assessed at MRL 2. The commercial solver's iterative convergence and floating-point error are considered adequately controlled by the software QA and code verification factors."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed; acceptable at MRL 2 for this application scope.",
      "rationale": "Use error is not formally assessed at MRL 2. Simulation setup procedures are documented in a controlled simulation plan reviewed by a senior analyst, providing informal mitigation of user-induced errors."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed; acceptable at MRL 2 given the validation evidence indirectly bounds model form error.",
      "rationale": "Model form uncertainty (turbulence model selection, Newtonian blood assumption) is not separately quantified at MRL 2. The output comparison factor provides indirect evidence that aggregate model form error is acceptable for the hemolysis QoI."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed; acceptable at MRL 2.",
      "rationale": "Formal uncertainty propagation for model inputs (viscosity, density, power law coefficients) is not required at MRL 2. Nominal input values are sourced from published literature and the FDA benchmark specification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed; acceptable at MRL 2 for computational benchmark comparisons.",
      "rationale": "Sample-to-sample variability in the experimental hemolysis measurements is acknowledged but not formally characterized at MRL 2. Published FDA benchmark data report mean values with standard deviations sufficient for the output comparison assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed; acceptable at MRL 2.",
      "rationale": "Full equivalency mapping between validation experiment inputs and intended-use simulation inputs is not required at MRL 2. The test conditions factor confirms that the primary boundary conditions are matched; residual differences in fluid properties are within the tolerance accepted for this risk level."
    }
  ],
