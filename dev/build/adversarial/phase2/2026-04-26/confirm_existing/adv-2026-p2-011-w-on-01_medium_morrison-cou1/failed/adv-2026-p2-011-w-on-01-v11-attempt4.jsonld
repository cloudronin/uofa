  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cv-sim-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for Model Risk Level 2. The six non-assessed factors are explicitly scoped out as not required at MRL 2 per ASME V&V 40-2018 Table 1. The overall credibility body is sufficient to support the decision that the CFD hemolysis model can reliably identify worst-case operating conditions for the FDA generic centrifugal blood pump in the CPB application. This model has been applied in clinical research contexts and the simulation evidence is judged adequate for its intended regulatory submission purpose.",
