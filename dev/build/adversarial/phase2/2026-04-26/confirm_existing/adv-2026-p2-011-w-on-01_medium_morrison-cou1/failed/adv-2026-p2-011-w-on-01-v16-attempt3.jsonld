      "acceptanceCriteria": "Solver must have documented version control, regression testing, and release notes consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 was used with documented QA procedures including regression test suite results and version-controlled case files. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities documented for the turbulence and hemolysis sub-models in use, with known benchmark comparisons available.",
      "rationale": "Benchmark comparisons against lid-driven cavity and backward-facing step cases confirm solver correctness for the k-omega SST turbulence model. Power-law hemolysis model implementation verified against published reference solutions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for primary QoI (normalized index of hemolysis) with GCI < 5% on the fine grid.",
      "rationale": "Three-grid Richardson extrapolation performed at the nominal operating point (5 L/min, 3500 RPM). GCI on NIH = 2.1% on fine mesh (12.4 M cells). Achieved level exceeds required level, providing margin."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) documented and traceable to calibrated instrumentation.",
      "rationale": "FDA benchmark experimental data provides fully documented test conditions including fluid temperature, hematocrit, and pump speed. Calibration records for flow meters and pressure transducers confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel or validation metric u_val) computed and reported for NIH across the operating envelope.",
      "rationale": "Relative error in NIH between CFD and experiment ranges from 8% to 19% across the five operating points tested. Mean absolute error 12.4%. Comparison metric reported per ASME V&V 20 methodology."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI (normalized index of hemolysis) directly maps to the clinical decision question of worst-case blood damage at device operating limits.",
      "rationale": "NIH is the standard regulatory metric for blood pump hemolysis assessment per FDA guidance. The model outputs NIH directly, ensuring the QoI is fully relevant to the intended decision without intermediate translation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments cover the operating envelope (flow rate 2–8 L/min, speed 2000–5000 RPM) relevant to CPB clinical use.",
      "rationale": "FDA benchmark experiments span flow rates 2.5–7 L/min and speeds 2000–3500 RPM, overlapping the CPB clinical operating range. Geometry is the same FDA generic pump used in the simulation, ensuring high relevance."
    },
    {
      "type": "CredibilityFactor",
