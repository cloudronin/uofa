  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-hemolysis-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/org/morrison-vv40-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. The six non-assessed factors are appropriately scoped out at MRL 2 with qualitative justification documented. The CFD hemolysis model is accepted as credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB conditions. This model has been applied in clinical research contexts where its predictions of hemolysis index have informed device design decisions, and the assessment team finds the evidence body sufficient for the stated decision.",
