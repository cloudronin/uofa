      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA GCBP experimental data"
    },
    {
      "id": "https://uofa.net/morrison/validation/velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity field validation against PIV measurements at nominal CPB flow conditions"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4048801",
