  "signature": "ed25519:b7c3d1e5f9a2b4c6d8e0f2a4b6c8d0e2f4a6b8c0d2e4f6a8b0c2d4e6f8a0b2c4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control documented; regression test suite executed with no critical failures.",
      "rationale": "OpenFOAM v8 used with version-controlled case files stored in a Git repository. Regression tests covering laminar pipe flow and rotating frame benchmarks passed without critical failures, satisfying MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy demonstration on canonical rotating flow benchmark achieves theoretical convergence rate within 10%.",
      "rationale": "Method of manufactured solutions applied to a rotating annular flow case. Observed spatial convergence order of 1.92 confirmed against theoretical second-order expectation, within the 10% tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI is below 5% on the fine mesh.",
      "rationale": "Three-level mesh refinement study performed (2.1M, 6.8M, 18.4M cells). Richardson extrapolation yielded GCI of 3.7% for the hemolysis index on the fine mesh, satisfying the 5% threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid viscosity) match simulation inputs within measurement uncertainty.",
      "rationale": "FDA GCBP experimental protocol specifies 5 L/min flow rate at 2500 RPM with bovine blood surrogate. Simulation inputs set identically; fluid viscosity matched to within 1.2% of reported experimental value."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 15% of experimental mean across all tested operating points.",
      "rationale": "Simulated hemolysis index deviates from experimental measurements by 8.4% at the nominal operating point and 11.2% at the worst-case condition, both within the 15% acceptance criterion. Exceeds MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Hemolysis index and shear stress distributions are directly linked to the clinical question of worst-case hemolysis identification.",
      "rationale": "The primary QoI (normalized index of hemolysis, NIH) is the standard metric used in regulatory submissions for CPB device evaluation. Secondary QoI (volume-averaged scalar shear stress) directly informs the hemolysis power-law model inputs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry under overlapping flow conditions as the COU operating envelope.",
      "rationale": "FDA GCBP validation experiments span 3–7 L/min at 1500–3500 RPM, encompassing the CPB operating envelope. Device geometry is identical to the simulation domain. Validation activities are directly relevant to the intended use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; basic solver residual monitoring sufficient.",
      "rationale": "At MRL 2, formal iterative solver error quantification is not mandated. Residuals monitored to below 1e-5 for all transported quantities, confirming adequate iterative convergence without formal error bounding."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; standard operating procedure documentation sufficient.",
      "rationale": "MRL 2 does not require formal use error analysis. Simulation setup follows documented SOPs with peer review of boundary condition assignments and mesh quality checks performed by a second analyst."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection justified by literature precedent.",
      "rationale": "The k-omega SST turbulence model and Giersiepen hemolysis power-law are standard choices for CPB hemolysis CFD, supported by published benchmark studies. Formal model form uncertainty quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values with documented sources sufficient.",
      "rationale": "Blood surrogate density and viscosity sourced from FDA GCBP protocol documentation. Hemolysis model constants taken from Giersiepen et al. (1990) as commonly accepted literature values. Formal sensitivity analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; experimental data from single FDA GCBP study accepted.",
      "rationale": "Validation relies on the FDA GCBP round-robin dataset. At MRL 2, a single well-documented experimental dataset from a recognized reference study is acceptable without requiring multi-laboratory sample statistics."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative mapping of validation to COU conditions documented.",
      "rationale": "A qualitative comparison table mapping validation experiment conditions to COU operating conditions was prepared and reviewed. Formal equivalency metrics are not required at MRL 2 and the qualitative assessment confirms adequate overlap."
    }
  ],
