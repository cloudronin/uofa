  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison CPB Hemolysis Credibility Assessment — Minimal Profile",
  "description": "This unit of assurance documents the credibility evidence for a CFD-based hemolysis prediction model of the FDA generic centrifugal blood pump. The model has been applied in clinical research settings to identify worst-case hemolysis operating conditions for Class II cardiopulmonary bypass devices at Model Risk Level 2. A full 13-factor ASME V&V 40 assessment was conducted: 7 factors were formally assessed and all met required levels; 6 factors were not assessed, which is acceptable at MRL 2. This package conforms to the Minimal profile and provides sufficient evidence to support the Accepted decision outcome.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-cpb-cfd-hemolysis",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-cpb-experimental-hemolysis",
    "https://uofa.net/synth/data/fda-cpb-flow-bench-validation"
  ],
