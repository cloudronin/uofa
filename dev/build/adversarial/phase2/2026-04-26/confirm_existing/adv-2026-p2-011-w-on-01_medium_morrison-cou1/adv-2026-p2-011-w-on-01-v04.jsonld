    {
      "id": "https://uofa.net/synth/validation/cpb-hemolysis-bench-comparison",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis index comparison against FDA experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/cpb-pressure-flow-validation",
      "type": "ValidationResult",
      "name": "Pressure-flow curve validation across CPB operating range"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034998",
