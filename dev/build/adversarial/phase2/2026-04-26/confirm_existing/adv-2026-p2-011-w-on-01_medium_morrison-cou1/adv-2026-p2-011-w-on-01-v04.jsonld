  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented QA procedures including version control and regression testing consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent v19.2 was used with documented version control, regression test suite results, and institutional QA sign-off. All QA artifacts are archived and meet the Gradation 2 threshold for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems demonstrating correct implementation of governing equations must be documented for the solver version in use.",
      "rationale": "Standard lid-driven cavity and pipe-flow benchmark cases were executed and results compared against published analytical solutions. Relative errors were below 0.5%, confirming correct code implementation at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A formal mesh convergence study must demonstrate that discretization error in the hemolysis index QoI is quantified and within acceptable bounds.",
      "rationale": "Richardson extrapolation was applied across three systematically refined meshes (4.2M, 8.7M, and 17.1M cells). The grid convergence index for the normalized hemolysis index was 1.8%, exceeding the MRL 2 requirement and achieving Gradation 3 performance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to confirm relevance to the simulation boundary conditions.",
      "rationale": "FDA experimental hemolysis data were collected under controlled inlet flow rates (2–6 L/min) and rotational speeds (2000–3500 RPM) matching the simulation boundary conditions. Temperature, fluid properties, and sample preparation protocols are fully documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics between simulation outputs and experimental measurements must be documented, with agreement within defined tolerance bands.",
      "rationale": "Normalized index of hemolysis (NIH) predictions agreed with experimental measurements within 15% across all operating points tested. Systematic bias was below 8%. These results satisfy the MRL 2 output comparison requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest extracted from the simulation must be directly relevant to the decision being supported, with traceability documented.",
      "rationale": "The primary QoI is the normalized index of hemolysis, which is the standard metric used in regulatory submissions for CPB device evaluation. Traceability from QoI to the device safety decision is documented in the credibility assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be demonstrated to be representative of the intended use conditions with documented similarity arguments.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry under CPB-representative flow conditions. Similarity arguments for geometry, Reynolds number regime, and blood analog fluid properties are documented, supporting applicability of validation evidence to the intended use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal solver error quantification beyond code verification is not required; basic iterative convergence monitoring suffices.",
      "rationale": "Residual convergence to below 1e-5 for all equations was confirmed for each simulation. Formal solver error quantification is not required at MRL 2 and was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal use error analysis is not required; documented simulation setup review is sufficient.",
      "rationale": "Simulation setup was reviewed by a second analyst. Formal use error analysis is not required at MRL 2 and was scoped out of this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model form uncertainty quantification is not required; selection rationale for turbulence and hemolysis sub-models must be documented.",
      "rationale": "The SST k-omega turbulence model and the Giersiepen-Wurzinger hemolysis power-law model were selected based on literature review. Formal model form uncertainty quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal input uncertainty propagation is not required; nominal input values and sources must be documented.",
      "rationale": "All model inputs including fluid viscosity, density, and boundary conditions are documented with sources. Formal uncertainty propagation is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterization of test sample variability is not required; sample preparation protocol documentation suffices.",
      "rationale": "FDA experimental data used bovine blood prepared per standard protocol. Detailed statistical characterization of sample-to-sample variability is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency analysis between experimental and simulation input parameters is not required; qualitative correspondence must be documented.",
      "rationale": "Qualitative correspondence between experimental and simulation boundary conditions has been documented. Formal equivalency analysis is not required at MRL 2 and was not performed."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-hemolysis-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors met or exceeded their required levels for MRL 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 1. Discretization error exceeded the required level, providing additional confidence. The model is judged credible for identifying worst-case hemolysis operating conditions for the Class II CPB device. The assessment team notes that this model has been applied in clinical research to support device characterization studies, and the accumulated validation evidence is consistent with that broader application context.",
