  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal Profile)",
  "description": "This package documents the simulation credibility evidence for CFD-based hemolysis prediction of the FDA generic centrifugal blood pump. The model has been applied in clinical research settings to identify worst-case hemolysis operating conditions for centrifugal assist devices. A 13-factor ASME V&V 40 assessment was conducted at Model Risk Level 2, with 7 factors formally assessed and 6 scoped out as acceptable at MRL 2. All assessed factors meet or exceed required gradation levels. This record conforms to the Minimal profile and is intended to support a Class II device submission narrative.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-worst-case-hemolysis",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-centrifugal-pump-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-piv-benchmark-2013",
    "https://uofa.net/synth/data/morrison-hemolysis-experimental-2021"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-vr-01",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against in-vitro benchmark data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cpb-vr-02",
      "type": "ValidationResult",
      "name": "Velocity field PIV comparison at nominal operating point"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4054579",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-lab-cfd-group",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f1c8e2b47d905f6c2d3e1a8b0f4e7c9d2a5b6e3f8c1d4a7b0e2f5c8d1a4b7",
  "signature": "ed25519:b2e4f1a7c3d6e9b0f2a5c8d1e4b7f0a3c6d9e2b5f8a1c4d7e0b3f6a9c2d5e8b1",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified against standard benchmarks and version-controlled with documented release notes.",
      "rationale": "ANSYS Fluent 2022R2 was used with documented QA procedures, including version control, regression testing against canonical pipe-flow benchmarks, and formal release validation. Achieved gradation meets MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code must demonstrate correct implementation of governing equations via method-of-manufactured-solutions or equivalent.",
      "rationale": "Method-of-manufactured-solutions tests were executed for the incompressible Navier-Stokes solver, confirming second-order spatial convergence. Hemolysis power-law transport equation was verified against an analytical solution for a simple shear flow case."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed on at least three systematically refined meshes; GCI on hemolysis index must be below 5%.",
      "rationale": "Three mesh levels (4.2M, 11.7M, and 28.4M cells) were evaluated. Richardson extrapolation yielded a GCI of 2.8% on the normalized hemolysis index at the nominal operating point, exceeding the MRL 2 requirement. Prism layers were refined independently to confirm boundary-layer independence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must be documented with uncertainty quantification and traceable to calibrated instrumentation.",
      "rationale": "In-vitro hemolysis experiments were conducted at five flow rate and rotational speed combinations. Inlet pressure, flow rate, and hematocrit were measured with calibrated transducers. Measurement uncertainties were propagated and reported in the test report."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within combined simulation and experimental uncertainty bands.",
      "rationale": "Predicted normalized index of hemolysis (nIH) agreed with experimental measurements within 15% across all five operating points, falling within combined uncertainty bounds. The worst-case operating condition identified by simulation matched experimental observations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (hemolysis index) must be directly linked to the device safety claim and clinically relevant thresholds.",
      "rationale": "Normalized index of hemolysis is the standard regulatory metric for blood-contacting device safety and directly maps to the device submission claim. Clinical relevance is established by published hemolysis thresholds for CPB devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, blood analog fluid, and operating envelope as the intended use.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry, a glycerol-water blood analog with matched viscosity, and operating conditions spanning the intended CPB flow range. Geometric and kinematic similarity criteria were satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to solver tolerance is sufficient at MRL 2 without formal floating-point error analysis.",
      "rationale": "At MRL 2, formal floating-point and round-off error analysis is not required. Residuals converged to 1e-6 for all transport equations, satisfying the baseline solver tolerance criterion. No further assessment was scoped."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal user error analysis is not required provided simulation setup is peer-reviewed.",
      "rationale": "Simulation setup was reviewed by a second analyst. Formal use-error analysis is not required at MRL 2 for this device class. Scoped out per the MRL 2 assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty quantification is not required at MRL 2; selection of turbulence and hemolysis models must be justified qualitatively.",
      "rationale": "The SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power-law model were selected based on published literature for similar rotating blood-contacting devices. Formal model-form uncertainty quantification is outside scope at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Input sensitivity analysis is not required at MRL 2; nominal input values must be traceable to published material data.",
      "rationale": "Blood analog viscosity, density, and hemolysis model constants were taken from peer-reviewed sources. Formal sensitivity analysis or uncertainty propagation on model inputs is not required at MRL 2 and was scoped out."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability is not required at MRL 2 for a single-geometry benchmark study.",
      "rationale": "Experiments used a single FDA benchmark pump geometry. Sample-to-sample variability characterization is not required at MRL 2 for this device type and was scoped out of the assessment plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal equivalency mapping between simulation inputs and experimental conditions is not required at MRL 2 beyond qualitative matching.",
      "rationale": "Simulation boundary conditions were set to match experimental measurements directly. Formal equivalency analysis is not required at MRL 2 and was scoped out. Qualitative correspondence was confirmed during peer review."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-dr-01",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-lab-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required gradation levels for MRL 2. The six non-assessed factors are appropriately scoped out per the MRL 2 assessment plan for a Class II CPB device. The model is accepted as credible for identifying worst-case hemolysis operating conditions within the operating envelope studied. This model has been applied in clinical research to inform device design decisions, and the evidence package supports its continued use in that capacity.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
