  "signature": "ed25519:b1d4e7f2a5c8b3e6d9f0a2c5b8e1d4f7a0c3b6e9d2f5a8c1b4e7f0a3c6b9e2d5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented test suite achieving gradation 2 coverage.",
      "rationale": "ANSYS Fluent 2022R2 is under formal version control; a documented regression test suite covering laminar and turbulent benchmark cases was executed with all tests passing, satisfying gradation 2 requirements for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical flow problem demonstrating convergence consistent with nominal scheme order.",
      "rationale": "A method-of-manufactured-solutions study on a 3-D Navier-Stokes benchmark confirmed second-order spatial convergence for the pressure-velocity coupling scheme used in the hemolysis simulations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid-convergence index (GCI) reported for primary QoI with GCI < 5% on fine grid.",
      "rationale": "A three-level mesh refinement study (2.1 M, 5.8 M, 14.2 M cells) yielded a GCI of 2.3% for the normalized index of hemolysis on the finest grid, exceeding the gradation 2 threshold and meeting gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions replicated in simulation within documented uncertainty bands.",
      "rationale": "Inlet flow rate, outlet pressure, and blood analog viscosity were matched to the FDA in-vitro protocol values; deviations were within ±1.5% for all parameters, satisfying gradation 2 fidelity requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (e.g., normalized index of hemolysis) compared against experimental data with agreement within combined uncertainty.",
      "rationale": "Predicted normalized index of hemolysis agreed with experimental measurements within 12% across five operating points, falling within the combined experimental and model uncertainty band, meeting gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation directly correspond to decision-relevant outputs for worst-case hemolysis identification.",
      "rationale": "The normalized index of hemolysis and peak shear stress exposure time are the primary decision QoIs; both were directly measured in validation experiments and computed in the simulation, establishing direct correspondence at gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry under overlapping operating conditions as the intended use envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry at flow rates spanning 2–8 L/min and rotational speeds of 2500–4500 RPM, encompassing the CPB clinical operating envelope, meeting gradation 2 relevance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Acceptable at gradation 1 for MRL 2; no formal iterative convergence study required beyond residual monitoring.",
      "rationale": "At MRL 2, gradation 1 for numerical solver error is acceptable. Residual convergence to 1e-5 was monitored and confirmed for all simulations; no additional formal assessment was required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Acceptable at gradation 1 for MRL 2; documented simulation setup checklist sufficient.",
      "rationale": "A simulation setup checklist was completed by a qualified CFD analyst and reviewed by a second team member. Formal use-error quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form selection justified by literature precedent for CFD hemolysis prediction at MRL 2.",
      "rationale": "The power-law hemolysis model (Giersiepen-Wurzinger correlation) is the accepted standard for CFD-based hemolysis prediction in regulatory submissions; its selection is justified by published FDA guidance and peer-reviewed literature without requiring additional formal assessment at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Nominal input values sourced from published literature or device specifications; sensitivity analysis not required at MRL 2 gradation 1.",
      "rationale": "Blood viscosity, density, and hemolysis model constants were taken from published sources; uncertainty in these inputs was acknowledged but formal sensitivity analysis is not required at gradation 1 for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Validation experiments used blood analog fluid with documented properties; sample characterization at gradation 1 acceptable for MRL 2.",
      "rationale": "FDA in-vitro experiments used porcine blood with documented hematocrit and viscosity; sample-to-sample variability characterization at gradation 1 is acceptable for the current MRL 2 assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation inputs demonstrably matched to experimental conditions at gradation 1 for MRL 2.",
      "rationale": "Boundary conditions in the simulation were set to match nominal experimental values; formal equivalency mapping documentation at gradation 1 is sufficient and was confirmed through the setup checklist review."
    }
  ],
