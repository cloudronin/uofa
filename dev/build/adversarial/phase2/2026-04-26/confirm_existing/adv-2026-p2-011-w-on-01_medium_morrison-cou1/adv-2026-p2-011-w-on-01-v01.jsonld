      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample characterization at a basic documentation level is sufficient at MRL 2.",
      "rationale": "FDA benchmark experiments used bovine blood with documented hematocrit and preparation protocol. Detailed sample variability characterization is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Qualitative confirmation that simulation inputs match experimental conditions is sufficient at MRL 2.",
      "rationale": "Simulation boundary conditions are confirmed to match documented experimental conditions at a qualitative level. Formal equivalency analysis is not required at MRL 2."
    }
