  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented verification test suite and version control consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022 R2 is used with documented QA procedures, regression test suite, and traceable version control. All SQA requirements for MRL 2 are satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Code verification activities must demonstrate correct implementation of governing equations through benchmark problems at MRL 2.",
      "rationale": "Order-of-accuracy testing using manufactured solutions for the Navier-Stokes solver confirms second-order spatial convergence. Lid-driven cavity and Poiseuille flow benchmarks pass to within expected truncation error bounds."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence study must quantify discretization error with GCI < 5% for hemolysis index QoI at MRL 2.",
      "rationale": "Three-level mesh refinement study (coarse 1.2M, medium 4.8M, fine 19.2M cells) yields GCI of 2.1% for the scalar hemolysis index, exceeding the MRL 2 threshold. Richardson extrapolation confirms asymptotic convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to reproduce boundary conditions in simulation.",
      "rationale": "FDA benchmark test conditions (flow rate 2.5–7 L/min, rotational speed 2000–3500 rpm, hematocrit 40%) are fully documented in the FDA dataset. Boundary conditions in the CFD model are set to match measured inlet velocity profiles and outlet pressure."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within ±30% across the operating envelope at MRL 2.",
      "rationale": "Simulated normalized index of hemolysis (NIH) values agree with FDA experimental data within 18% across all five operating points tested. Mean absolute error is 11.4%, satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs selected for validation must be directly linked to the device safety decision being supported.",
      "rationale": "Normalized index of hemolysis and shear stress exposure time are the primary QoIs. Both are directly linked to red blood cell damage and are the quantities used in regulatory submissions for Class II CPB device clearance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must span operating conditions representative of the intended clinical use envelope.",
      "rationale": "FDA benchmark experiments cover the full CPB operating range (2.5–7 L/min, 2000–3500 rpm). The validation domain encompasses the worst-case hemolysis operating point identified in the clinical research application of this model."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Acceptable at MRL 2 without explicit iterative convergence error quantification beyond residual monitoring.",
      "rationale": "At MRL 2, monitoring of scaled residuals below 1e-5 for all transport equations is considered sufficient. Formal solver error quantification is not required and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal use-error analysis not required at MRL 2 for this factor.",
      "rationale": "Simulation was performed by experienced CFD analysts with documented training records. Formal use-error quantification is scoped out at MRL 2."
    },
    {
