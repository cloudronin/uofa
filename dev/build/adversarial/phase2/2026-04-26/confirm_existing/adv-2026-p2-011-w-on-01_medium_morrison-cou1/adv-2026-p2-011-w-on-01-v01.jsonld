  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 2. The CFD hemolysis model demonstrates sufficient credibility to support identification of worst-case operating conditions for the Class II CPB device. The model has been applied in clinical research contexts and the simulation results are consistent with FDA benchmark experimental data within acceptance tolerances. The credibility evidence is judged sufficient to support the regulatory decision.",
