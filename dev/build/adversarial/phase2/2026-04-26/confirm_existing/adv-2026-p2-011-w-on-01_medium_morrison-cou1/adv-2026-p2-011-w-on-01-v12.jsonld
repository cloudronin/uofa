      "id": "https://uofa.net/synth/validation/morrison-cbp-hemolysis-vr-01",
      "type": "ValidationResult",
      "name": "Hemolysis index validation against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cbp-pressure-head-vr-02",
      "type": "ValidationResult",
      "name": "Pressure-head and flow-rate operating curve validation"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4041497",
