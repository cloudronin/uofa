  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-dr-2026-04",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-simulation-lab-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed the required gradation levels for Model Risk Level 2. The 6 factors assessed at gradation 1 (not-assessed) are acceptable under the MRL 2 framework. Simulation outputs demonstrate sufficient agreement with FDA benchmark experimental data for the intended purpose of identifying worst-case hemolysis operating conditions in a Class II CPB device. The credibility body of evidence, while submitted under the Minimal profile without structured context-of-use metadata, is judged adequate to support the regulatory submission decision. This model has been applied in clinical research settings and the overall evidence package supports an Accepted determination.",
