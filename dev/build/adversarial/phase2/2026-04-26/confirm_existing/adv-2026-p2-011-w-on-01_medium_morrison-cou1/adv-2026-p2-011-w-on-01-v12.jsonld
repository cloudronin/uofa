  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be verified under an SQA plan documenting version control, regression testing, and release procedures consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2023R1 is governed by a documented SQA plan including version-controlled releases, automated regression test suites, and formal change-management procedures. Achieved level meets the required gradation for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark test cases at the required gradation level.",
      "rationale": "ANSYS Fluent has been verified against standard CFD benchmark problems including lid-driven cavity and backward-facing step flows. Published verification reports confirm correct discretization of the Navier-Stokes equations at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study must demonstrate that discretization error in hemolysis index QoI is within acceptable bounds at MRL 2.",
      "rationale": "A three-level mesh refinement study was performed (coarse 1.2M, medium 3.8M, fine 9.6M cells). Richardson extrapolation yielded a grid convergence index of 3.1% for the hemolysis index, satisfying the MRL 2 threshold. The medium mesh was selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be sufficiently documented and controlled to support comparison with simulation at MRL 2.",
      "rationale": "FDA benchmark experimental data for the generic centrifugal blood pump were collected under controlled laboratory conditions with documented flow rates (2–8 L/min), pressure heads (50–200 mmHg), and fluid properties (bovine blood analog). Environmental conditions and measurement uncertainties are reported in the source publication."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics between simulation outputs and experimental data must meet MRL 2 acceptance thresholds for hemolysis index and pressure-head predictions.",
      "rationale": "Predicted hemolysis index values agreed with experimental measurements within 18% across all tested operating points, and pressure-head predictions were within 8%. These metrics satisfy the MRL 2 acceptance criterion. Systematic bias at high flow rates was noted and attributed to turbulence model limitations."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs used in validation must be directly relevant to the decision-driving quantities for worst-case hemolysis identification.",
      "rationale": "The primary QoI is the normalized index of hemolysis (NIH), which is the regulatory-accepted metric for blood damage assessment in CPB devices. Secondary QoIs include shear stress distributions and exposure time histograms, which are mechanistically linked to erythrocyte damage. QoI relevance is well-established in the literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be sufficiently similar to the intended application conditions to support extrapolation of credibility to the COU at MRL 2.",
      "rationale": "Validation was performed on the same FDA generic centrifugal pump geometry under overlapping operating conditions. While clinical CPB flows may differ in hematocrit and temperature, the validation envelope covers the critical high-shear regime relevant to worst-case hemolysis identification, supporting adequate relevance at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence and round-off error must be characterized at the required gradation; at MRL 2 with gradation 1, acknowledgment of solver residuals is sufficient.",
      "rationale": "Solver residuals were monitored and converged to below 1e-5 for all equations. Formal quantification of numerical solver error beyond residual monitoring is not required at MRL 2 gradation 1 and has not been performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Potential for user-induced errors in model setup must be acknowledged; formal assessment not required at MRL 2 gradation 1.",
      "rationale": "Simulation setup was performed by an experienced CFD analyst following a documented simulation plan. Independent review of boundary conditions and mesh settings was conducted. Formal use-error quantification is not required at this gradation level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The selection of governing equations and constitutive models must be documented; formal model-form uncertainty quantification is not required at MRL 2 gradation 1.",
      "rationale": "The SST k-omega turbulence model and Giersiepen-Wurzinger hemolysis power-law model were selected based on literature precedent for blood pump CFD. Justification for model form selection is documented in the simulation plan. Formal model-form error quantification is scoped out at this gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Key model input parameters must be identified and their sources documented; sensitivity analysis is not required at MRL 2 gradation 1.",
      "rationale": "Blood viscosity (0.0035 Pa·s), density (1060 kg/m3), and hemolysis model constants were taken from published literature values. Rotational speed and flow boundary conditions were matched to experimental test conditions. Formal input uncertainty propagation is not required at this gradation level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The experimental samples used for validation must be described; statistical characterization of sample variability is not required at MRL 2 gradation 1.",
      "rationale": "FDA benchmark experiments used bovine blood with documented hematocrit range (35–40%). Sample preparation and storage protocols are described in the source publication. Statistical characterization of inter-sample variability is not required at this gradation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Correspondence between simulation input parameters and experimental conditions must be documented; formal equivalency analysis is not required at MRL 2 gradation 1.",
      "rationale": "Simulation boundary conditions were set to match nominal experimental operating points. Documented correspondence between CFD inputs and experimental conditions is provided in the validation report appendix. Formal equivalency uncertainty analysis is scoped out at MRL 2 gradation 1."
    }
  ],
