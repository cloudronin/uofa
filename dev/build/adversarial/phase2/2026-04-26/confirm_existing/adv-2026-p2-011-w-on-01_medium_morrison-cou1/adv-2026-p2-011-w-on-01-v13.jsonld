      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark cases relevant to internal viscous flow; order-of-accuracy confirmed for at least one canonical problem.",
      "rationale": "Vendor-supplied verification suite includes lid-driven cavity and pipe flow benchmarks demonstrating second-order spatial accuracy. Results consistent with published literature. Gradation 2 requirement satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) computed for hemolysis index QoI; GCI < 5% on fine grid.",
      "rationale": "Three-level mesh refinement study performed (coarse 2.1M, medium 5.8M, fine 14.2M cells). GCI for normalized hemolysis index on fine grid: 2.3%. Exceeds required gradation 2; achieves gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) documented and traceable to calibrated instrumentation.",
      "rationale": "FDA benchmark experimental conditions (flow rates 2.5–7 L/min, impeller speeds 2000–3500 RPM) reproduced from published protocol. Fluid properties measured at 37°C with calibrated viscometer. Gradation 2 met."
