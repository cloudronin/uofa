  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed their required gradation levels at MRL 2. The 6 non-assessed factors are appropriately scoped out per ASME V&V 40-2018 Table 3 at MRL 2. The CFD hemolysis model demonstrates sufficient credibility to support identification of worst-case operating conditions for the Class II CPB device. The assessment team notes that this model has been applied in clinical research contexts; however, formal documentation of the structured context of use is maintained in the sponsor's design history file outside this package. Decision: Accepted.",
