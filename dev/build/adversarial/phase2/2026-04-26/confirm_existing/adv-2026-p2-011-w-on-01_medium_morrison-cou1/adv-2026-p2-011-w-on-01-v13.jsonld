      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within 25% of experimental mean across assessed operating points; pressure-flow curve agreement within measurement uncertainty.",
      "rationale": "Hemolysis index predictions fall within 18% of experimental mean across 6 operating points. Pressure-flow characteristic deviates less than 8% from measured values. Both criteria satisfied at gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorStandard": "ASME-VV40-2018",
