    {
      "id": "https://uofa.net/synth/validation/morrison-cbp-hemolysis-index-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cbp-velocity-field-piv",
      "type": "ValidationResult",
      "name": "Velocity field validation via particle image velocimetry at design operating point"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043479",
