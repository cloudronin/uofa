  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal profile)",
  "description": "This package documents the simulation credibility evidence for CFD-based hemolysis prediction of the FDA generic centrifugal blood pump. The model has been applied in clinical research settings to support worst-case operating condition identification for Class II centrifugal blood pump devices used in cardiopulmonary bypass. A 13-factor ASME V&V 40 assessment was conducted at Model Risk Level 2; seven factors were formally assessed and six were scoped out as acceptable at MRL 2. All assessed factors met or exceeded required credibility levels, and the overall credibility assessment outcome is Accepted.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-worst-case-hemolysis",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-cbp-cfd-v3",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-cbp-experimental-hemolysis-2021",
    "https://uofa.net/synth/data/fda-cbp-piv-validation-2020"
  ],
