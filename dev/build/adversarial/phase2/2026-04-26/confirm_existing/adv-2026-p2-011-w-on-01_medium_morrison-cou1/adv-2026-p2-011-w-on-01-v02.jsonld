  "signature": "ed25519:b1d3f5a7c9e0b2d4f6a8c0e2d4f6b8a0c2e4f6a8b0d2f4a6c8e0b2d4f6a8c0e2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The CFD solver (ANSYS Fluent 2021 R2) is a commercial code with documented version control, release notes, and regression test suites. Software quality documentation was reviewed and found compliant with Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Order-of-accuracy testing was performed on canonical internal flow benchmarks (lid-driven cavity, pipe flow) confirming second-order spatial accuracy. Results are consistent with published solver verification documentation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "A three-level mesh refinement study was conducted on the FDA generic centrifugal pump geometry. Richardson extrapolation yielded a grid convergence index below 2% for the hemolysis index QoI, exceeding the Gradation 2 threshold."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Experimental boundary conditions (inlet flow rate 5 L/min, rotational speed 3500 RPM, fluid temperature 37°C) were reproduced in simulation with documented uncertainty. Fluid properties matched the blood analog used in the FDA benchmark study."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Predicted normalized index of hemolysis was compared against FDA interlaboratory experimental data. The simulation result fell within the experimental scatter band (mean ± 1 SD), satisfying Gradation 2 output comparison requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "The primary QoI (normalized index of hemolysis) directly corresponds to the clinical safety endpoint of red blood cell damage in CPB circuits. Sensitivity analysis confirmed this QoI is the dominant predictor of device-related hemolytic risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level for MRL 2.",
      "rationale": "Validation experiments used the same FDA generic centrifugal pump geometry and a blood analog fluid under operating conditions representative of adult CPB flow ranges. The validation domain adequately covers the intended clinical application space."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default Gradation 1 acceptance applies.",
      "rationale": "Numerical solver error beyond discretization and code verification is scoped out at MRL 2 for this application. The commercial solver's iterative convergence was monitored and residuals met standard thresholds, providing implicit assurance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default Gradation 1 acceptance applies.",
      "rationale": "Formal use error analysis is not required at MRL 2. Simulation setup was reviewed by a second analyst to provide a basic check against gross user errors."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default Gradation 1 acceptance applies.",
      "rationale": "Model form uncertainty (turbulence model selection, hemolysis power-law model) is acknowledged but formal model form assessment is scoped out at MRL 2. The k-omega SST turbulence model is widely used for internal rotating flows."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default Gradation 1 acceptance applies.",
      "rationale": "Formal uncertainty quantification of model input parameters is not required at MRL 2. Nominal input values were taken from published FDA benchmark specifications with documented traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default Gradation 1 acceptance applies.",
      "rationale": "Statistical characterization of experimental test sample variability is scoped out at MRL 2. The FDA interlaboratory dataset provides multi-laboratory replicate data that implicitly captures sample variability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; default Gradation 1 acceptance applies.",
      "rationale": "Formal equivalency mapping between simulation inputs and experimental parameters is not required at MRL 2. Key dimensional parameters (flow rate, rotational speed, geometry) were matched by inspection."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors achieved levels meeting or exceeding the required levels for MRL 2. The six non-assessed factors were appropriately scoped out per ASME V&V 40 MRL 2 provisions. The simulation credibility evidence is sufficient to support the regulatory submission claim that the CFD model can identify worst-case hemolysis operating conditions for this Class II CPB device. The assessment team notes that this model has been applied in clinical research contexts and that the validation evidence base is considered adequate for the intended submission purpose.",
