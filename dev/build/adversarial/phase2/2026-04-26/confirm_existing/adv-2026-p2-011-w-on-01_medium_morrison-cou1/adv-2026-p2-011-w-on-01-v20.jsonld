  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-hemolysis-mrl2-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six not-assessed factors are appropriately scoped out at MRL 2 given the Class II device classification and the nature of the decision question (identification of worst-case hemolysis operating conditions rather than absolute NIH prediction for regulatory clearance). The overall credibility body of evidence is sufficient to support the intended use of the model as described in the package narrative. The assessment team notes that this package conforms to the Minimal profile and that a complete structured context-of-use record has not been encoded herein.",
