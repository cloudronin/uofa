  "signature": "ed25519:b7d2e4f1a09c3582d6e7b14f3a8c0d5291fe6a3b7c8d9e0f1a2b3c4d5e6f7a8b9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented release notes and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "ANSYS Fluent 2022 R2 is used under institutional license with documented QA procedures, version-controlled case files, and a regression suite confirming hemolysis scalar transport reproducibility across platforms."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy test on canonical rotating-channel flow must confirm second-order spatial convergence for velocity and scalar fields.",
      "rationale": "Method of manufactured solutions applied to a rotating annular channel demonstrates second-order convergence (observed order 1.97) for velocity components and hemolysis power-law scalar, meeting the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the medium mesh used for production runs.",
      "rationale": "Three-level mesh refinement study (2.1M, 6.4M, 18.9M cells) yields GCI of 2.3% for the hemolysis index at the design operating point, exceeding the required threshold. The medium mesh (6.4M cells) is adopted for production."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid temperature, hematocrit) must be documented with stated uncertainty and traceable to calibrated instrumentation.",
      "rationale": "FDA benchmark experimental data report flow rates of 2–8 L/min and rotational speeds of 2000–3500 RPM with calibrated Coriolis flowmeters (±0.5%) and optical hemolysis measurement. Fluid temperature and hematocrit (35%) are documented with traceability."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised index of hemolysis (NIH) predictions must agree with experimental measurements within combined simulation and experimental uncertainty bands at all validated operating points.",
      "rationale": "NIH predictions at six operating points fall within the combined uncertainty envelope (simulation GCI + experimental 95% CI) in five of six cases. The single outlier at maximum flow rate is attributed to documented inlet swirl in the experimental rig and is within 8% relative error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (NIH) must be directly linked to the clinical endpoint of red blood cell damage and must be the same metric used in regulatory submissions for CPB devices.",
      "rationale": "NIH is the FDA-accepted metric for hemolysis in CPB device submissions (FDA 2017 guidance). The model directly computes NIH via the power-law damage accumulation model, ensuring direct relevance to the decision question."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid analogue, and operating envelope as the intended simulation use.",
      "rationale": "Validation uses the FDA generic centrifugal blood pump geometry with porcine blood at 37°C across the full CPB operating envelope (2–8 L/min, 2000–3500 RPM), directly matching the intended simulation conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence of residuals to below 1e-5 for all transport equations is documented for each simulation.",
      "rationale": "At MRL 2 for this factor, documentation of residual convergence to solver default tolerances is sufficient. Residuals reported in simulation logs confirm convergence to 1e-6 for continuity and momentum; formal solver error quantification beyond this is scoped out."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "A documented simulation execution checklist must be completed by a qualified analyst for each production run.",
      "rationale": "At MRL 2, a basic execution checklist is sufficient. The simulation team uses an internal standard operating procedure checklist; formal independent use-error assessment is not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The turbulence model and hemolysis damage model must be justified against published literature for rotating blood-contacting device flows.",
      "rationale": "SST k-omega turbulence model is selected based on published comparative studies for centrifugal blood pump flows (Bludszuweit 1995, Fraser et al. 2011). The Giersiepen-Wurzinger power-law hemolysis model is the standard for NIH prediction in CPB devices and is applied with published coefficients."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Blood rheological properties (viscosity, density) and pump geometry dimensions must be traceable to measured or published reference values with stated uncertainty.",
      "rationale": "Blood density (1060 kg/m3) and dynamic viscosity (0.0035 Pa·s at 37°C, 35% Ht) are sourced from FDA benchmark documentation. Pump geometry is derived from the publicly released FDA CAD file with dimensional verification confirmed against published drawings."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental blood samples must be characterised for hematocrit, age, and donor variability; inter-sample variability must be reported.",
      "rationale": "At MRL 2, basic sample characterisation (hematocrit and storage time) reported in the FDA benchmark dataset is sufficient. Detailed donor-variability analysis is not required at this risk level and is scoped out."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Boundary conditions applied in simulation must be shown to match experimental inlet/outlet conditions within stated measurement uncertainty.",
      "rationale": "At MRL 2, qualitative confirmation that simulation boundary conditions are set to match experimental nominal values is sufficient. The flow rates and rotational speeds in the simulation match experimental nominal settings; formal equivalency quantification is scoped out at this risk level."
    }
  ],
