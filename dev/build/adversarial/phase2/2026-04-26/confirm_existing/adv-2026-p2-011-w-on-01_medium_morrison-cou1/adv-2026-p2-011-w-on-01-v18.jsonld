    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software quality plan documented; version control and regression testing demonstrated for the CFD solver at MRL 2.",
      "rationale": "ANSYS Fluent v19.2 was used under a documented SQA plan including version control, unit regression tests, and release notes review. All MRL 2 SQA requirements are satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark verification cases relevant to rotating turbomachinery flows at MRL 2.",
      "rationale": "The solver was verified against the ASME V&V 20 lid-driven cavity and rotating channel benchmarks. Observed order of accuracy was consistent with theoretical second-order convergence, meeting MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) reported for hemolysis index QoI; GCI < 5% on fine grid at MRL 2.",
      "rationale": "A three-level mesh refinement study was performed (coarse: 2.1M, medium: 5.8M, fine: 14.2M cells). GCI for the normalized hemolysis index was 2.3% on the fine mesh, exceeding the MRL 2 threshold. Richardson extrapolation confirmed asymptotic convergence."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) documented and traceable to calibrated instrumentation at MRL 2.",
      "rationale": "FDA benchmark experimental data were collected at 2500 rpm and 5 L/min using bovine blood analog fluid. Instrumentation calibration certificates and uncertainty budgets are archived and traceable, satisfying MRL 2 test-conditions requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E% or validation metric U_val) computed and within acceptance band for hemolysis index at MRL 2.",
      "rationale": "The normalized index of hemolysis (NIH) predicted by the model was within 12% of the experimentally measured value, within the MRL 2 acceptance band of 15%. Validation metric U_val was computed per ASME V&V 20 and confirmed model adequacy."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (NIH, scalar stress exposure) directly linked to the device decision question at MRL 2.",
      "rationale": "The primary QoI, normalized index of hemolysis, is the standard regulatory metric for blood damage assessment in CPB devices. Scalar stress exposure is a secondary QoI directly informing worst-case operating point identification. Both QoIs are directly relevant to the decision question."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same device geometry under overlapping operating conditions at MRL 2.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry, which is the same geometry used in the simulation. Operating conditions in the validation experiments span the intended operating envelope, providing direct relevance to the assessment scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
