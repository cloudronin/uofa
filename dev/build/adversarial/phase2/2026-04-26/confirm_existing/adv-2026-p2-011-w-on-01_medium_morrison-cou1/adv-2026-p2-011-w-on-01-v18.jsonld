      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA benchmark dataset sample characterization is accepted as-is.",
      "rationale": "The FDA benchmark dataset is a publicly available, widely cited experimental reference. Formal test-sample characterization beyond what is published is not required at MRL 2 and is scoped out."
    },
