  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv40-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. The six non-assessed factors are appropriately scoped out per ASME V&V 40-2018 requirements at this model risk level. The CFD hemolysis model demonstrates sufficient credibility to support identification of worst-case operating conditions for the Class II CPB device. The assessment team concludes that the model is fit for the intended computational purpose as described in this package.",
