  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal Profile)",
  "description": "This unit of assurance captures the credibility evidence for a CFD-based hemolysis prediction model of the FDA generic centrifugal blood pump. The model has been applied in clinical research contexts to support worst-case operating condition identification for Class II cardiopulmonary bypass devices. A 13-factor ASME V&V 40 assessment was conducted at Model Risk Level 2; seven factors were formally assessed and six were scoped out as acceptable at MRL 2. All assessed factors met or exceeded required credibility levels, supporting an Accepted decision outcome.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-worst-case-hemolysis",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-centrifugal-pump-cfd",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/fda-pump-piv-velocity-fields"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-benchmark-v1",
      "type": "ValidationResult",
      "name": "Hemolysis index benchmark comparison against FDA experimental dataset"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-velocity-field-comparison-v1",
      "type": "ValidationResult",
      "name": "Velocity field validation against PIV measurements at nominal CPB operating point"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4034105",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vv40-assessment-team",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f7c2e1b09d456f8e3c7a1d2b5f9e0c4d8a6b3e7f1c2d5a9b0e4f6c8d2a1b3",
  "signature": "ed25519:9c4b2a7f1e3d5c8b0a6f2e4d1c9b7a3f5e2d0c8b6a4f1e3d7c5b9a2f0e4d6c8",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented QA procedures and regression test suite covering hemolysis-relevant flow regimes.",
      "rationale": "The CFD solver (ANSYS Fluent 19.2) is commercially validated, version-controlled, and supported by a regression test suite. QA documentation confirms compliance with MRL 2 software quality requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufacturer-supplied verification documentation demonstrating correct implementation of governing equations for turbulent incompressible flow.",
      "rationale": "ANSYS Fluent code verification documentation covers the incompressible Navier-Stokes solver and k-omega SST turbulence model. Order-of-accuracy tests confirm correct numerical implementation for the relevant equation set."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) less than 5% for hemolysis index and pump head predictions across at least three systematically refined meshes.",
      "rationale": "A three-level mesh refinement study yielded GCI values of 3.1% for hemolysis index and 2.8% for pump head at the nominal CPB operating point, exceeding the MRL 2 requirement. The production mesh of 4.2M polyhedral cells was selected on this basis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with sufficient detail to reproduce boundary conditions in the computational model, including flow rate, rotational speed, and fluid properties.",
      "rationale": "FDA benchmark experimental conditions are fully documented in the published dataset. Flow rates (2–7 L/min), impeller speeds (2000–3500 RPM), and blood analogue fluid properties are specified with measurement uncertainties sufficient for MRL 2 boundary condition specification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error) between predicted and measured hemolysis index within acceptable tolerance band at MRL 2.",
      "rationale": "Predicted hemolysis index values agree with experimental measurements within 18% normalized RMS error across six operating points, meeting the MRL 2 acceptance threshold. Velocity field comparisons against PIV data show qualitative agreement in jet and recirculation zone topology."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Demonstrated that the computed hemolysis index is the primary quantity linking model predictions to the device safety question of interest.",
      "rationale": "The hemolysis index directly quantifies red blood cell damage and is the regulatory quantity of interest for CPB device safety assessment. The model outputs map directly to the clinical and regulatory decision without intermediate surrogates."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same pump geometry under overlapping operating conditions with the intended use envelope.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry under CPB-representative flow and speed conditions. The validation envelope spans the operating range relevant to worst-case hemolysis identification, supporting extrapolation confidence at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 beyond code verification already captured under Numerical code verification factor.",
      "rationale": "At MRL 2, separate quantification of iterative solver residuals beyond convergence monitoring is not required. Residuals were monitored to 1e-5 for all equations; no additional solver error quantification is mandated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; analyst qualifications and simulation workflow documentation are sufficient.",
      "rationale": "Formal use error analysis is not required at MRL 2. The simulation team holds relevant CFD qualifications and followed documented simulation protocols reviewed by a senior engineer."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form selection rationale documented qualitatively.",
      "rationale": "The k-omega SST turbulence model and power-law hemolysis constitutive relation are established choices for blood pump simulation supported by published literature. Formal model form error quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "Blood analogue viscosity, density, and hemolysis model coefficients are taken from published sources with documented uncertainty ranges. Formal sensitivity analysis of model inputs is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA benchmark dataset sample documentation is sufficient.",
      "rationale": "The FDA benchmark dataset provides sufficient sample documentation for MRL 2. Formal statistical characterization of test sample variability is not required at this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; qualitative correspondence between experimental and computational input parameters is sufficient.",
      "rationale": "Computational boundary conditions were matched to experimental conditions using documented fluid properties and operating parameters. Formal equivalency metrics are not required at MRL 2."
    }
  ],
