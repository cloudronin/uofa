  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "SQA documentation confirms version control, regression testing, and release validation for the CFD solver at the level required for MRL 2.",
      "rationale": "ANSYS Fluent 2022 R2 was used under an ISO 9001-certified QMS. Solver release notes, regression test suite results, and version-locked simulation scripts are archived. All SQA requirements for MRL 2 are satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured-solution or benchmark tests demonstrate that the discretized equations are solved correctly within expected truncation-error bounds.",
      "rationale": "Method-of-manufactured-solutions tests for the incompressible Navier-Stokes solver confirm second-order spatial convergence. Published ASME benchmark results for lid-driven cavity and backward-facing step reproduce reference values within 0.3%."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation or equivalent GCI analysis yields a discretization error estimate below 5% for the primary QoI (hemolysis index).",
      "rationale": "Three systematically refined meshes (1.2 M, 4.8 M, 19.2 M cells) were used. GCI for hemolysis index is 3.1% on the medium mesh, which is within the 5% acceptance threshold. The medium mesh was selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid temperature, hematocrit) are documented and match CFD inlet/outlet conditions within stated uncertainty.",
      "rationale": "FDA benchmark experiments were conducted at 2–8 L/min flow and 2500–3500 RPM. CFD boundary conditions replicate these values using time-averaged measured inlet velocity profiles. Hematocrit was fixed at 35% in both experiment and simulation."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index agrees with experimental measurements within combined simulation and experimental uncertainty bands across the operating envelope.",
      "rationale": "At all five validation operating points, simulated normalized index of hemolysis falls within ±15% of the experimental mean, consistent with the inter-laboratory experimental scatter reported in the FDA benchmark study. Validation metric passes the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoIs predicted by the model (hemolysis index, shear stress distribution) are directly linked to the device safety endpoint of interest.",
      "rationale": "Normalized index of hemolysis is the regulatory-accepted surrogate for red blood cell damage in CPB pumps. Volume-averaged scalar shear stress is the mechanistic driver. Both QoIs map directly to the clinical safety question of hemolytic risk."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same geometry, fluid, and operating range as the intended use, or departures are justified and bounded.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry identical to the simulation geometry. Bovine blood at physiological hematocrit was used, consistent with standard pre-clinical testing. Operating range spans the CPB clinical envelope. Relevance is high."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
