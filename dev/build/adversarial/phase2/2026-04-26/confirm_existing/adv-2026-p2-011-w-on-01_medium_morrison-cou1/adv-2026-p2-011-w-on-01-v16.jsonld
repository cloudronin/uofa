      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Use-error assessment is not required at MRL 2; simulation workflows are controlled through standard operating procedures.",
      "rationale": "MRL 2 does not require a formal use-error analysis. Simulation setup was performed by trained analysts following documented SOPs. Peer review of input decks was conducted. Scoped out per MRL 2 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model-form uncertainty quantification is not required at MRL 2; the governing equations are justified by reference to literature.",
      "rationale": "RANS k-omega SST turbulence model and the Giersiepen-Wurzinger hemolysis power-law model are well-established for this class of problem. Formal model-form uncertainty analysis is not required at MRL 2 and has been scoped out."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
