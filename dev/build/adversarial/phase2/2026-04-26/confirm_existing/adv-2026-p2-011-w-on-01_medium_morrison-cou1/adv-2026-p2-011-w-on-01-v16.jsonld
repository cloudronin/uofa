      "rationale": "Blood viscosity, density, and hemolysis model coefficients are taken from published literature with documented sources. Formal input sensitivity or uncertainty propagation is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sample characterization is documented in the FDA benchmark study; no additional sample assessment is required at MRL 2.",
      "rationale": "The FDA benchmark study documents blood sample sourcing, anticoagulation protocol, and hematocrit adjustment procedures. No additional test-sample assessment is required at MRL 2 for this submission."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Qualitative correspondence between validation and deployment input parameters is noted; formal equivalency mapping is not required at MRL 2.",
      "rationale": "Validation and deployment use the same pump geometry and overlapping operating conditions. Formal parameter-equivalency mapping is not required at MRL 2 and has been scoped out with qualitative justification noted above."
