      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals and mass-balance errors are monitored; formal solver-error quantification is not required at MRL 2 for this factor.",
      "rationale": "At MRL 2, a formal numerical solver error budget is not required. Residuals were monitored to 1e-5 and global mass imbalance was below 0.01%. No further assessment is needed to meet the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
