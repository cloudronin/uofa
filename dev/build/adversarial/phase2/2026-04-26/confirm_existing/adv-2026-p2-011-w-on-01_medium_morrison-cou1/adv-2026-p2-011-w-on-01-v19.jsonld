      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; FDA benchmark sample characterization accepted as sufficient.",
      "rationale": "The FDA benchmark dataset provides characterization of the blood analog fluid and pump geometry. Formal test-sample uncertainty propagation is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
