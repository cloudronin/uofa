  "signature": "ed25519:9c1a2b3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must be under version control with documented regression test suite; all critical defects resolved prior to simulation execution.",
      "rationale": "ANSYS Fluent 2022 R2 was employed under a validated installation qualification protocol. Version control logs and regression test reports confirm no open critical defects. SQA level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy tests on canonical internal-flow benchmarks must demonstrate convergence consistent with nominal scheme order.",
      "rationale": "Code verification via manufactured-solution tests on laminar pipe flow and lid-driven cavity confirms second-order spatial convergence, consistent with the finite-volume scheme. Required level 2 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index and bulk shear stress must be below 5% on the fine mesh.",
      "rationale": "Three-level mesh refinement study yielded GCI of 3.2% for hemolysis index and 2.8% for area-averaged wall shear stress on the fine mesh (6.1 M cells). Richardson extrapolation confirms asymptotic convergence. Discretization error level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity) must be reproduced in simulation within ±5% of reported values.",
      "rationale": "FDA benchmark test conditions (flow rates 2.5–7 L/min, impeller speed 2000–3500 RPM, blood analog viscosity 0.00356 Pa·s) were replicated in simulation within ±2%. Test conditions factor level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of model accuracy (NIMA) for hemolysis index must be within acceptable band; systematic bias must be documented.",
      "rationale": "Predicted hemolysis index agreed with experimental measurements within 18% across all six operating points. NIMA analysis confirms no systematic bias direction. Exceeds required level 2; achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (hemolysis index, shear stress distribution) must directly correspond to the clinical harm metric of interest.",
      "rationale": "The normalized index of hemolysis (NIH) is the regulatory-accepted metric for blood trauma in CPB devices. Shear stress distributions are mechanistically linked to red blood cell damage. QoI relevance level 2 is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must cover the operating envelope relevant to CPB use, including pulsatile-equivalent steady operating points spanning clinical flow rates.",
      "rationale": "Validation activities used the FDA generic centrifugal pump geometry under steady flow conditions spanning the clinical CPB range. The validation domain overlaps with the intended deployment envelope. Relevance level 2 is achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; solver residual monitoring sufficient.",
      "rationale": "At Model Risk Level 2, full numerical solver error quantification beyond residual monitoring is not required. Residuals converged to 1e-6 for all equations. Factor scoped to level 1 per MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; analyst qualification documentation sufficient.",
      "rationale": "MRL 2 does not require formal use-error analysis. Analysts hold documented CFD competency qualifications. Factor held at level 1."
    },
    {
