  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal Profile)",
  "description": "This package documents the simulation credibility evidence for CFD-based hemolysis prediction of the FDA generic centrifugal blood pump. The model has been applied in clinical research contexts to identify worst-case hemolysis operating conditions for centrifugal blood pump designs used in cardiopulmonary bypass. A full 13-factor ASME V&V 40 assessment was conducted at Model Risk Level 2, with 7 factors formally assessed and 6 scoped out as not required at this risk level. All assessed factors meet or exceed their required credibility gradations. This package conforms to the Minimal profile; structured context-of-use fields are not captured in this submission tier.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-hemolysis-worst-case",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-cbp-cfd-hemolysis-v2",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-cbp-experimental-hemolysis-2021",
    "https://uofa.net/synth/data/fda-cbp-piv-validation-2020"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-index-comparison-01",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA experimental benchmark"
    },
    {
      "id": "https://uofa.net/synth/validation/velocity-field-piv-comparison-01",
      "type": "ValidationResult",
      "name": "Velocity field comparison against PIV measurements at design operating point"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043037",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vv40-team",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f1c2e74b8d905f16e3a2b7c4d6f0e1a9b8c3d2e5f7a1b4c6d8e0f2a3b5c7d9",
  "signature": "ed25519:b2e4f6a8c0d1e3f5a7b9c1d3e5f7a9b1c3d5e7f9a1b3c5d7e9f1a3b5c7d9e1f3",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must have documented version control, regression testing, and a traceable release history consistent with MRL 2 requirements.",
      "rationale": "The CFD solver (ANSYS Fluent 2021 R2) has documented version control, a published verification and validation suite, and formal release notes. Regression tests for hemolysis-relevant flow configurations were executed and passed. SQA level achieved meets the required gradation for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against analytical or manufactured solutions for the governing equations relevant to blood pump CFD at MRL 2.",
      "rationale": "The Navier-Stokes solver was verified using the method of manufactured solutions for laminar and turbulent pipe flow benchmarks. Observed order of accuracy was consistent with the formal order of the spatial discretization scheme. Code verification is sufficient for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be estimated using a systematic mesh refinement study with at least three mesh levels, reporting a grid convergence index at MRL 2.",
      "rationale": "A three-level mesh refinement study was conducted on the FDA generic centrifugal pump geometry. The Grid Convergence Index for the hemolysis index quantity of interest was 4.2% on the medium mesh selected for production runs. This exceeds the MRL 2 requirement and achieves gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to reproduce boundary conditions in the simulation, including flow rate, rotational speed, and fluid properties.",
      "rationale": "FDA interlaboratory study test conditions are fully documented in the published protocol. Fluid properties (blood analogue viscosity and density), rotational speed (2500 RPM), and volumetric flow rates (2.5 and 5.0 L/min) are specified with measurement uncertainties. Boundary condition fidelity meets gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated outputs must be compared to experimental measurements using a defined metric that accounts for experimental uncertainty, achieving agreement within an accepted tolerance at MRL 2.",
      "rationale": "Predicted hemolysis index values were compared to FDA interlaboratory experimental data. The normalized index of hemolysis fell within one experimental standard deviation of the mean measured value at both validation operating points. Output comparison meets gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation must be demonstrably relevant to the clinical or regulatory question being addressed, with a documented mapping from QoI to decision need.",
      "rationale": "The normalized index of hemolysis is the primary regulatory metric for blood-contacting device evaluation and is directly referenced in FDA guidance. The mapping from simulation QoI to the worst-case hemolysis identification decision is documented in the credibility plan. Relevance meets gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted under conditions sufficiently similar to the intended use conditions to support extrapolation of credibility to the COU at MRL 2.",
      "rationale": "Validation was performed on the same FDA generic centrifugal pump geometry under CPB-representative flow conditions. The fluid analogue properties and rotational speed envelope used in validation overlap with the intended operating range. Validation relevance to the intended use is sufficient for gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, explicit characterization of numerical solver error beyond code verification is not required; default gradation 1 acceptance applies.",
      "rationale": "Numerical solver error is not separately assessed at MRL 2 per the ASME V&V 40 factor matrix. The SQA and code verification factors collectively address solver reliability at this risk level. This factor is acknowledged but not independently evaluated."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, systematic assessment of analyst use error is not required; basic documentation of simulation setup is sufficient.",
      "rationale": "Use error assessment is not required at MRL 2 per the factor applicability matrix. Simulation setup was reviewed internally by a second analyst, providing basic assurance without a formal use error study. Gradation 1 is accepted for this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal model form uncertainty quantification is not required; selection of the turbulence and hemolysis models must be documented with justification.",
      "rationale": "The SST k-omega turbulence model and the power-law hemolysis damage model were selected based on published literature for similar blood pump CFD applications. Formal model form uncertainty quantification is not required at MRL 2. Documentation of model selection rationale satisfies gradation 1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, model input uncertainty quantification via sensitivity analysis or probabilistic methods is not required; nominal input values must be documented.",
      "rationale": "Nominal model inputs including fluid viscosity, density, and pump rotational speed are documented from the FDA interlaboratory study protocol. Parametric sensitivity analysis is not required at MRL 2. Gradation 1 is accepted for this factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, statistical characterization of test sample variability is not required; use of a single representative test configuration is acceptable.",
      "rationale": "The FDA generic centrifugal pump is a standardized geometry with no manufacturing variability by design. Test sample variability assessment is not applicable in the traditional sense and is scoped out at MRL 2. Gradation 1 is accepted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, formal equivalency analysis between validation and COU input parameters is not required; qualitative documentation of parameter overlap is sufficient.",
      "rationale": "Qualitative documentation confirms that the validation operating conditions (flow rate range 2.5–5.0 L/min, 2500 RPM) are representative of the CPB operating envelope. Formal equivalency quantification is not required at MRL 2. Gradation 1 is accepted for this factor."
    }
  ],
