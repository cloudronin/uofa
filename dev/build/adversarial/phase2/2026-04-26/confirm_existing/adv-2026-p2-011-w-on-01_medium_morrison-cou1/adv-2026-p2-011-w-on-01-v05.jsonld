  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels for Model Risk Level 2. The six non-assessed factors are appropriately scoped out per the ASME V&V 40 factor applicability matrix at MRL 2. The CFD hemolysis model demonstrates sufficient credibility to support identification of worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in the CPB application context. The assessment team concludes that the simulation evidence is adequate to inform the regulatory submission decision.",
