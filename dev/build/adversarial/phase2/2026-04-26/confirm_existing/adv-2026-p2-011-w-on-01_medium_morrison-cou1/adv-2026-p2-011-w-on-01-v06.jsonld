  "signature": "ed25519:7c3a9f1b2e8d4c06b5f3a1e9c2d8b4067c3a9f1b2e8d4c06b5f3a1e9c2d8b406",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must have documented verification test suite with regression testing and version-controlled source; all critical modules pass unit tests.",
      "rationale": "ANSYS Fluent 2022R2 is a commercially validated solver with documented QA procedures, regression test suites, and ISO 9001-compliant development practices. Version control and release notes are publicly accessible. Required level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems with known analytical solutions.",
      "rationale": "The CFD solver was verified against the Taylor-Couette flow benchmark and the lid-driven cavity benchmark. Observed order of convergence matched theoretical second-order accuracy. Code verification is satisfied at level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be less than 5% on the fine grid.",
      "rationale": "A three-level mesh refinement study was conducted with mesh sizes of 1.2M, 4.8M, and 19.2M cells. GCI on the fine grid for the hemolysis index was 2.1%, well within the 5% acceptance threshold. Achieved level 3 exceeds required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with measured flow rate, rotational speed, and inlet hematocrit; uncertainty bounds must be reported.",
      "rationale": "FDA experimental data for the generic centrifugal pump includes documented operating conditions at 2500, 3500, and 4500 RPM across flow rates of 2–7 L/min. Inlet hematocrit was 33±1%. Measurement uncertainties are reported in the FDA dataset documentation. Level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within two standard deviations of experimental uncertainty across all validation operating points.",
      "rationale": "Predicted normalized index of hemolysis (NIH) was compared to experimental measurements at 9 operating points. All predictions fell within ±2σ of experimental uncertainty. Mean absolute error was 0.8 mg/dL, within acceptable bounds for level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis) must be directly linked to the clinical decision endpoint of identifying worst-case hemolysis operating conditions.",
      "rationale": "NIH is the accepted regulatory QoI for hemolysis assessment in CPB devices per FDA guidance. It directly maps to the decision question of identifying operating conditions that maximize red blood cell damage. Relevance is established at level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and a flow regime overlapping with CPB operating envelope; blood analog fluid properties must be within 10% of physiological values.",
      "rationale": "Validation was performed on the FDA generic centrifugal pump geometry identical to the simulation model. Operating conditions span the CPB envelope (2–7 L/min, 2500–4500 RPM). Bovine blood analog with hematocrit 33% was used, within 10% of clinical CPB hematocrit targets. Level 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; solver error is addressed implicitly through code verification and discretization error assessments.",
      "rationale": "At Model Risk Level 2, explicit quantification of numerical solver error beyond what is captured in code verification and discretization error assessments is not required. This factor is scoped out per ASME V&V 40 Table 3 guidance for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; user qualification is addressed through organizational procedures.",
      "rationale": "Use error assessment is not required at MRL 2. Simulation analysts hold relevant CFD and biofluid mechanics qualifications. Organizational SOPs govern simulation execution and review. This factor is scoped out per ASME V&V 40 MRL 2 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; model form adequacy is implicitly addressed through validation output comparison.",
      "rationale": "Formal model form uncertainty quantification is not required at MRL 2. The power-law hemolysis model (Giersiepen-Wurzinger correlation) is the accepted standard for CFD hemolysis prediction and its adequacy is reflected in the output comparison results. Scoped out per MRL 2 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; input sensitivity is not required at this risk level.",
      "rationale": "Formal sensitivity analysis of model inputs (viscosity, density, hemolysis model coefficients) is not required at MRL 2. Nominal physiological values from literature are used. This factor is scoped out per ASME V&V 40 Table 3 for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; sample characterization beyond what is documented in the FDA experimental dataset is not required.",
      "rationale": "The FDA generic pump experimental dataset provides sufficient sample documentation for MRL 2. Formal assessment of test sample variability and lot-to-lot consistency is not required at this risk level. Scoped out per MRL 2 guidance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; equivalency between simulation inputs and experimental conditions is addressed qualitatively through test conditions assessment.",
      "rationale": "Formal equivalency mapping between simulation boundary conditions and experimental input parameters is not required at MRL 2. Qualitative equivalency is established through the test conditions factor assessment. This factor is scoped out per ASME V&V 40 MRL 2 guidance."
    }
  ],
