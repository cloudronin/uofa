      "type": "ValidationResult",
      "name": "Hemolysis index validation against FDA pump experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/shear-stress-distribution-cpb",
      "type": "ValidationResult",
      "name": "Wall shear stress distribution comparison at nominal CPB operating point"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4037497",
