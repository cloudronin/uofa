  "signature": "ed25519:b4e2d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3b5d7f9a1c3e5b7d9f1a3c5e7b9",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must hold a validated QMS with documented version control and regression testing at Gradation 2 or higher.",
      "rationale": "ANSYS Fluent 2022R2 was used under an ISO 9001-registered QMS. Version-controlled solver releases with documented regression test suites confirm Gradation 2 compliance for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through method-of-manufactured-solutions or published benchmark comparisons at Gradation 2.",
      "rationale": "ANSYS Fluent passes published ASME V&V 20 benchmark cases for incompressible Navier-Stokes flow. Developer-provided MMS results confirm second-order spatial accuracy consistent with Gradation 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be reported and shown to be below 5% at the operating point of interest.",
      "rationale": "Three-level mesh refinement study (2.1M, 5.8M, 14.2M cells) yielded a GCI of 2.3% for the normalized index of hemolysis at the design operating point, exceeding the Gradation 2 threshold and satisfying Gradation 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient detail to confirm representativeness of CPB operating envelope.",
      "rationale": "FDA benchmark hemolysis experiments were conducted at 2500 RPM, 5 L/min flow, using bovine blood at 37°C. Test conditions are fully documented and bracket the intended CPB operating range."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within two experimental standard deviations across at least three operating points.",
      "rationale": "Predicted normalized index of hemolysis agreed with FDA benchmark measurements within 1.4 experimental standard deviations at all five evaluated operating points, satisfying Gradation 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The simulated QoI (normalized index of hemolysis) must be directly linked to the clinical decision question regarding worst-case hemolysis operating conditions.",
      "rationale": "The normalized index of hemolysis is the regulatory-accepted metric for blood damage assessment in CPB devices and directly informs the worst-case operating condition determination required by the decision question."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry, fluid properties, and operating range as the intended clinical application.",
      "rationale": "Validation was performed on the identical FDA generic centrifugal pump geometry using bovine blood as a surrogate for human blood under CPB flow and speed conditions, providing direct relevance to the intended use."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default Gradation 1 acceptance applies.",
      "rationale": "At MRL 2, numerical solver error beyond code verification is not required to be independently assessed. Solver error is addressed implicitly through the code verification and discretization error factors."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; standard analyst training and documented simulation protocol are sufficient.",
      "rationale": "MRL 2 does not mandate a formal use-error assessment. Analysts hold documented CFD training credentials and followed a written simulation execution protocol, meeting the Gradation 1 threshold by default."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; published literature support for the k-omega SST turbulence model in pump hemolysis applications is sufficient.",
      "rationale": "The k-omega SST turbulence closure is widely used and peer-validated for internal rotating flow hemolysis predictions. Formal model-form uncertainty quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; nominal input values with documented sources are sufficient.",
      "rationale": "Blood viscosity, density, and hemolysis power-law constants were taken from published literature with documented provenance. Sensitivity to input variability is not required to be formally quantified at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA benchmark dataset sample characterization documentation is sufficient.",
      "rationale": "The FDA benchmark experimental dataset includes characterization of bovine blood samples (hematocrit, age, storage conditions). Statistical sample adequacy analysis is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; documented mapping of experimental boundary conditions to simulation inputs is sufficient.",
      "rationale": "Experimental boundary conditions (inlet flow rate, outlet pressure, rotational speed) were mapped directly to simulation boundary conditions with documented correspondence. Formal equivalency analysis is not required at MRL 2."
    }
  ],
