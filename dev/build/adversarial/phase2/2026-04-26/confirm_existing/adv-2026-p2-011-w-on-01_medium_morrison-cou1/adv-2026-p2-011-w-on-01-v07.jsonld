  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-sim-lab-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six non-assessed factors are appropriately scoped out per ASME V&V 40-2018 guidance for Model Risk Level 2. The CFD hemolysis model is accepted as sufficiently credible to support identification of worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB conditions. This model has been applied in clinical research settings and the evidence base supports the regulatory decision context.",
