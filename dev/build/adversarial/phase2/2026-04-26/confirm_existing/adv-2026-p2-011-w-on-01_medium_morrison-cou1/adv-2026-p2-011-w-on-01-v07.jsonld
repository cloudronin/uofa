  "signature": "ed25519:b2d4f6a8c0e2b4d6f8a0c2e4b6d8f0a2c4e6b8d0f2a4c6e8b0d2f4a6c8e0b2d4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver version control, regression testing suite, and release notes documented for ANSYS Fluent 2022R2 used in this study.",
      "rationale": "The CFD solver is a commercially validated code with documented version control and an established regression test suite. Release documentation and solver verification reports are on file. Required level 2 is satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark solutions for canonical internal flow cases (Poiseuille, lid-driven cavity) reproduced within 1% of analytical or established numerical reference.",
      "rationale": "Canonical verification cases were executed and results compared against analytical solutions. Errors remained below 0.8% for all benchmark quantities, confirming numerical code correctness at the required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index and wall shear stress quantities of interest on the final production mesh.",
      "rationale": "A three-level mesh refinement study was conducted following the Celik et al. GCI methodology. The fine-grid GCI for hemolysis index was 2.3% and for area-averaged wall shear stress was 1.9%, both well within the 5% acceptance criterion. Achieved level 3 exceeds the required level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid viscosity, hematocrit) documented with measurement uncertainty and traceable to calibrated instrumentation.",
      "rationale": "All experimental test conditions used for validation were recorded with calibrated instrumentation. Measurement uncertainties for flow rate (±1.5%) and rotational speed (±0.3%) are within acceptable bounds for MRL 2. Traceability to NIST-traceable standards is documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index within ±20% of experimental measurements across the validated operating range; pressure rise within ±10%.",
      "rationale": "Hemolysis index predictions agreed with experimental data within 14% across all five validated operating points. Pressure rise predictions were within 7%. Both metrics satisfy the acceptance criteria for level 2 output comparison."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantities of interest (hemolysis index, scalar stress exposure) are directly linked to the clinical decision endpoint of identifying worst-case hemolysis operating conditions.",
      "rationale": "The primary quantity of interest, normalized index of hemolysis (NIH), is the standard clinical metric for blood pump hemolysis assessment and directly informs the worst-case operating condition determination. Relevance to the intended decision is well established in the literature."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same FDA generic centrifugal pump geometry under overlapping flow and speed conditions representative of the CPB operating envelope.",
      "rationale": "Validation data were collected on the identical FDA generic centrifugal blood pump geometry using porcine blood under flow rates of 2–6 L/min and speeds of 2000–4000 RPM, fully spanning the intended CPB operating envelope. The validation activities are directly representative of the COU."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; commercial solver documentation considered sufficient.",
      "rationale": "At MRL 2, formal numerical solver error quantification beyond standard commercial solver documentation is not required. The solver vendor provides iterative convergence criteria documentation and floating-point error characterization sufficient for this risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; analyst training records reviewed informally.",
      "rationale": "Formal use error assessment is not required at MRL 2. The simulation team holds relevant CFD credentials and internal review procedures were followed. No formal use error quantification was performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; turbulence and hemolysis model selections are documented with literature justification.",
      "rationale": "Model form uncertainty quantification is not required at MRL 2. The k-omega SST turbulence model and power-law hemolysis model were selected based on published benchmark comparisons. Formal model form error bounds were not computed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; input parameter sources and nominal values documented.",
      "rationale": "Formal input uncertainty propagation is not required at MRL 2. Blood viscosity, density, and hemolysis model coefficients are drawn from published literature sources and documented in the simulation report. Sensitivity analysis was not formally performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; sample provenance and preparation protocol documented.",
      "rationale": "Formal statistical characterization of test sample variability is not required at MRL 2. Porcine blood preparation protocol, anticoagulation method, and storage conditions are documented. Inter-sample variability was not formally quantified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not formally assessed at MRL 2; mapping between experimental and simulation input parameters documented qualitatively.",
      "rationale": "Formal equivalency assessment between experimental and simulation input parameters is not required at MRL 2. A qualitative mapping table is provided in the simulation report confirming that boundary conditions in the CFD model correspond to measured experimental conditions."
    }
  ],
