    {
      "id": "https://uofa.net/synth/validation/morrison-cbp-val-01",
      "type": "ValidationResult",
      "name": "Hemolysis index comparison against FDA benchmark experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-cbp-val-02",
      "type": "ValidationResult",
      "name": "Pressure-flow characteristic validation across CPB operating envelope"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043938",
