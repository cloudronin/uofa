      "rationale": "Key model inputs (viscosity, density, hemolysis model coefficients) are identified with nominal values and literature sources. Uncertainty propagation not performed per MRL 2 scoping. Gradation 1 criterion satisfied."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "At MRL 2, test sample characterization at Gradation 1 is sufficient; statistical sample size analysis not required.",
      "rationale": "FDA benchmark experimental data uses bovine blood with documented hematocrit and preparation protocol. Sample characterization is available at Gradation 1 level. Full statistical sample analysis not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
