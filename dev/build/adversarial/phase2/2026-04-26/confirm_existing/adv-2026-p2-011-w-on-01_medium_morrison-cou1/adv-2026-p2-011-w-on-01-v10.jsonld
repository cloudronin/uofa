  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation must be verified under a documented QA process with version control and regression testing at Gradation 2.",
      "rationale": "ANSYS Fluent 2022R2 was used under an ISO 9001-compliant QA framework. Version control, release notes, and regression test suites are documented. Required Gradation 2 is met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Numerical code must be verified against analytic solutions or Method of Manufactured Solutions for the governing equations relevant to blood pump CFD at Gradation 2.",
      "rationale": "Code verification was performed using MMS for the incompressible Navier-Stokes solver and the scalar transport equation used in the hemolysis model. Observed convergence rates match theoretical expectations. Gradation 2 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Discretization error must be estimated via systematic mesh refinement study with at least three mesh levels and reported as a fraction of the QoI at Gradation 2.",
      "rationale": "A four-level mesh refinement study was conducted (0.8M, 2.1M, 5.4M, 12.8M cells). Richardson extrapolation yielded a GCI of 1.8% on hemolysis index at the finest mesh. Exceeds Gradation 2 requirement; Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented with sufficient fidelity to reproduce boundary conditions in the simulation at Gradation 2.",
      "rationale": "FDA benchmark experimental conditions (flow rate 5 L/min, rotational speed 3500 RPM, hematocrit 35%) are fully documented in the published protocol. Boundary conditions in the CFD model replicate these conditions. Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation outputs must be compared against experimental measurements using a quantitative metric that accounts for experimental uncertainty at Gradation 2.",
      "rationale": "Normalized Index of Hemolysis (NIH) predicted by the model (0.0043 g/100L) falls within the experimental uncertainty band (0.0038–0.0051 g/100L) reported by the FDA benchmark dataset. Quantitative comparison metric documented. Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The quantities of interest used in validation must be demonstrably relevant to the decision quantity at Gradation 2.",
      "rationale": "NIH is the regulatory-accepted metric for hemolysis assessment in blood-contacting devices. The validation QoI directly maps to the decision quantity of worst-case hemolysis under CPB operating conditions. Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted under conditions sufficiently similar to the intended use environment at Gradation 2.",
      "rationale": "Validation was performed using the FDA generic centrifugal pump geometry under flow and pressure conditions representative of adult CPB use. Fluid properties replicate blood analogue used in clinical research applications of this model. Gradation 2 met."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
