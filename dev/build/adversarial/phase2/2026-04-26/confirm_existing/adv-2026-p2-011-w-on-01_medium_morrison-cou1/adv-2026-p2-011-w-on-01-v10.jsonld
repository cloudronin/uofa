  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-assessment-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required gradation levels for MRL 2. The six not-assessed factors are appropriately scoped out per ASME V&V 40-2018 Table 3 requirements at MRL 2. Discretization error exceeds the minimum requirement, providing additional confidence in numerical accuracy. The model is accepted as credible for identifying worst-case hemolysis operating conditions for the Class II CPB device under the Minimal credibility profile. Note: this package operates under ProfileMinimal and does not carry a structured Context of Use object; intended use scope is characterized narratively within the description field.",
