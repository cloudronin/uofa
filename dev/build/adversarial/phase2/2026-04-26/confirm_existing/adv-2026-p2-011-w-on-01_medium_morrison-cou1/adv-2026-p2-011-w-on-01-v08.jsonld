  "conformsToProfile": "https://uofa.net/vocab#ProfileMinimal",
  "name": "Morrison COU1 — CPB hemolysis credibility assessment (Minimal Profile)",
  "description": "This package documents the credibility assessment for a CFD-based hemolysis prediction model applied to the FDA generic centrifugal blood pump. The model has been applied in clinical research contexts to identify worst-case hemolysis operating conditions for Class II cardiopulmonary bypass devices at Model Risk Level 2. A full 13-factor assessment was conducted: 7 factors were assessed (all meeting required levels) and 6 factors were not assessed, which is acceptable at MRL 2. The assessment follows ASME V&V 40-2018 guidance and supports a regulatory submission for a Class II CPB device.",
  "bindsRequirement": "https://uofa.net/synth/req/morrison-cpb-hemolysis-mrl2",
  "bindsClaim": "https://uofa.net/synth/claim/morrison-cpb-worst-case-hemolysis",
  "bindsModel": "https://uofa.net/synth/model/fda-generic-centrifugal-pump-cfd",
  "bindsDataset": [
    "https://uofa.net/synth/data/fda-pump-experimental-hemolysis",
    "https://uofa.net/synth/data/fda-pump-flow-loop-measurements"
  ],
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/morrison-hemolysis-benchmark-v1",
      "type": "ValidationResult",
      "name": "FDA pump hemolysis benchmark validation against experimental data"
    },
    {
      "id": "https://uofa.net/synth/validation/morrison-pressure-head-validation-v1",
      "type": "ValidationResult",
      "name": "Pressure-head and flow-rate validation across CPB operating envelope"
    }
  ],
  "wasDerivedFrom": "https://doi.org/10.1115/1.4043951",
  "wasAttributedTo": "https://uofa.net/synth/org/morrison-vv40-assessment-team",
  "generatedAtTime": "2026-04-19T00:00:00Z",
  "hash": "sha256:a3f8c2e14b7d905f6a21cc48e37b09d1f582740e6b3a1d9c4e05f2178b6d3c9a",
  "signature": "ed25519:b1d4e7f29a3c05816e4b2f7d9c1a08e35f6b2d4c7a9e1f3b5d8c2a4e6f0b3d5",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must have documented version control, regression testing, and quality management procedures consistent with MRL 2 requirements.",
      "rationale": "ANSYS Fluent 2022R2 was used with documented version control and regression test suite. Software QA records confirm compliance with MRL 2 requirements. No defects affecting hemolysis prediction were identified."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through benchmark problems relevant to rotating machinery and viscous flow.",
      "rationale": "Code verification was confirmed via published ANSYS Fluent benchmark suite including lid-driven cavity and rotating disk problems. Results matched analytical solutions within expected numerical precision for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed for primary QoIs using at least three systematically refined meshes; GCI must be below 5% for hemolysis index predictions.",
      "rationale": "A three-level mesh refinement study was performed (coarse 2.1M, medium 4.8M, fine 10.2M cells). GCI for normalized index of hemolysis was 3.2%, satisfying the acceptance criterion. The medium mesh was selected for production runs."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must overlap with the intended CPB operating envelope including flow rates 2–8 L/min and pressure heads 50–200 mmHg.",
      "rationale": "FDA benchmark experimental data covers flow rates 2.5–7.5 L/min and pressure heads 60–180 mmHg, which encompasses the nominal CPB operating range. Temperature and blood analog viscosity were matched to clinical values."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index must agree with experimental measurements within a factor of 2 across all validation operating points.",
      "rationale": "Predicted normalized index of hemolysis agreed with experimental measurements within 28% RMS error across 12 operating points, well within the factor-of-2 acceptance criterion. The model consistently captured the trend of increasing hemolysis at high rotational speed and low flow rate."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis) must be directly linked to the clinical decision metric for CPB device safety assessment.",
      "rationale": "Normalized index of hemolysis is the standard metric for CPB hemolysis evaluation per ASTM F1841 and is directly used in the regulatory decision framework. The QoI is fully relevant to the intended use of identifying worst-case operating conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must use geometrically and operationally representative configurations of the FDA generic centrifugal pump under CPB-relevant conditions.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which is the same geometry used in the COU. Operating conditions in validation experiments span the CPB clinical range. Validation activities are directly representative of the intended use scenario."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when code verification has been separately demonstrated.",
      "rationale": "At MRL 2, numerical solver error assessment is not required as a separate factor when code verification activities have been completed. This factor is not assessed per the MRL 2 assessment matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this device class and model complexity.",
      "rationale": "Use error assessment is not required at MRL 2 for Class II devices with this level of model complexity. The simulation workflow is executed by experienced CFD engineers with domain expertise in cardiovascular device modeling."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; model form uncertainty is implicitly addressed through output comparison factor.",
      "rationale": "Model form uncertainty assessment as a standalone factor is not required at MRL 2. The Giersiepen power-law hemolysis model is well-established in the literature and its limitations are acknowledged. Residual model form uncertainty is bounded by the output comparison results."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this assessment scope.",
      "rationale": "Formal model input uncertainty quantification is not required at MRL 2. Key model inputs including blood viscosity, density, and hemolysis model constants are taken from published literature values and are consistent with those used in the validation experiments."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA benchmark dataset provides adequate sample information.",
      "rationale": "Detailed test sample characterization is not required at MRL 2. The FDA benchmark experimental dataset provides sufficient information about the blood analog used and experimental repeatability for the purposes of this assessment."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 given the direct use of the FDA benchmark geometry and matched operating conditions.",
      "rationale": "Equivalency of input parameters between validation and COU scenarios is not required as a separate factor at MRL 2. The validation geometry is identical to the COU geometry, and operating conditions were matched as documented under the Test Conditions factor."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cpb-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors met or exceeded required levels for MRL 2. The 6 non-assessed factors are acceptable at MRL 2 per the ASME V&V 40-2018 assessment matrix for Class II devices. Output comparison demonstrated hemolysis index predictions within 28% RMS of experimental measurements, well within the factor-of-2 acceptance criterion. The model is considered credible for identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump under CPB conditions. This model has been applied in clinical research to inform device design decisions, and the assessment team concludes the evidence package is sufficient to support regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
