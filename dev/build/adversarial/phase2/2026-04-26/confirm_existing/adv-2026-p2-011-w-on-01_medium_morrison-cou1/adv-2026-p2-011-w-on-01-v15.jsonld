  "signature": "ed25519:b2d4f6a8c0e2f4b6d8a0c2e4f6b8d0a2c4e6f8a0b2d4f6a8c0e2f4b6d8a0c2e4",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite; all tests passing for the release used in this analysis.",
      "rationale": "ANSYS Fluent 2022R2 was used under a validated installation. The QA log confirms that the relevant regression suite (600+ test cases) passed prior to the simulation campaign. Version control records are archived in the project repository."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver convergence on manufactured solution benchmarks with observed order of accuracy within 10% of theoretical order.",
      "rationale": "Method of manufactured solutions applied to the incompressible Navier-Stokes solver confirmed second-order spatial accuracy. Observed order 1.93 versus theoretical 2.0, within the accepted tolerance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for the primary quantity of interest (normalized index of hemolysis) on the production mesh.",
      "rationale": "Three-level mesh refinement study (2.1M, 5.8M, 14.3M cells) yielded GCI of 3.2% for the normalized hemolysis index at the nominal CPB operating point (5 L/min, 3500 RPM), satisfying the acceptance criterion."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (flow rate, rotational speed, fluid properties) documented with uncertainty bounds and replicated in the simulation setup.",
      "rationale": "FDA benchmark experimental data provided flow rate (±0.05 L/min), rotational speed (±10 RPM), and fluid viscosity (±2%) with full traceability. Simulation boundary conditions were set to match experimental mean values; sensitivity to boundary condition uncertainty was assessed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis predicted within 25% of experimental measurements across the CPB operating envelope.",
      "rationale": "Across five operating points spanning the CPB envelope, the CFD-predicted normalized hemolysis index deviated from experimental values by 8–22%, with all points within the 25% acceptance band. Systematic over-prediction at high shear regions is consistent with the Giersiepen power-law model conservatism."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (normalized hemolysis index) directly maps to the clinical endpoint of red blood cell damage under CPB operating conditions.",
      "rationale": "The normalized index of hemolysis is the established surrogate for RBC damage in rotary blood pump assessment per ISO 10993-4 guidance. Its direct mechanistic link to shear-stress exposure time makes it the appropriate QoI for worst-case operating condition identification."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same device geometry under overlapping operating conditions with the intended COU envelope.",
      "rationale": "Validation was conducted on the FDA generic centrifugal pump geometry — identical to the simulation geometry — at operating points that span and bracket the CPB envelope of interest. No extrapolation beyond the validated operating range is required for the intended decision."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor; default gradation accepted.",
      "rationale": "At Model Risk Level 2, explicit iterative solver error quantification beyond residual monitoring is not mandated. Residuals were converged to 1e-5 for all transport equations, providing sufficient confidence that solver iteration error is negligible relative to discretization error."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation setup reviewed by a second analyst.",
      "rationale": "A peer review of the simulation setup file and post-processing scripts was conducted by a second qualified analyst. No errors were identified. Formal use-error quantification is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model and hemolysis damage model selection justified by literature evidence and sensitivity analysis.",
      "rationale": "The SST k-omega turbulence model was selected based on published benchmarks for rotating machinery flows. The Giersiepen power-law hemolysis model is the de facto standard for CFD-based hemolysis prediction. Sensitivity to turbulence model choice (SST vs. realizable k-epsilon) showed less than 15% variation in hemolysis index."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Key model inputs (fluid viscosity, density, hemolysis model constants) documented with sources and uncertainty ranges; sensitivity analysis performed.",
      "rationale": "Blood analog fluid properties (glycerol-water mixture) were measured in-house with calibrated instrumentation. Hemolysis model constants sourced from Giersiepen et al. (1990). One-at-a-time sensitivity analysis showed hemolysis index is most sensitive to the power-law exponent (±18% for ±10% variation), which is within the accepted uncertainty budget."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; FDA benchmark data used as reference.",
      "rationale": "The FDA inter-laboratory study provided sufficient experimental replicates (n=6 laboratories) to characterize experimental variability. Independent test sample characterization beyond the FDA dataset is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; simulation and experimental input parameters confirmed to be nominally equivalent.",
      "rationale": "Simulation and experimental operating conditions are matched to within measurement uncertainty. Formal equivalency testing is not required at MRL 2, and no material differences in input parameters were identified during the setup review."
    }
  ],
