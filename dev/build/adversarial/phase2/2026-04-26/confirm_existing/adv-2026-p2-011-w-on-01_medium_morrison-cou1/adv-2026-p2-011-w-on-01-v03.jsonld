  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold a current FDA-recognized quality management certification and provide documented version control for all simulation scripts.",
      "rationale": "ANSYS Fluent 2023 R1 was used under an ISO 9001-certified QMS. Version-controlled simulation scripts are archived in the institutional repository. Achieved level meets required level for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must pass at least two published benchmark problems relevant to rotating-machinery CFD, with documented error norms.",
      "rationale": "The solver was verified against the Taylor-Couette flow benchmark and the lid-driven cavity benchmark. L2 error norms were within 1% of published reference solutions, satisfying the MRL 2 requirement."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index QoI must be below 5% on the finest mesh used in production runs.",
      "rationale": "Three systematically refined meshes (4M, 12M, 36M cells) were used. Richardson extrapolation yielded GCI of 3.2% for the normalized index of hemolysis, satisfying the 5% threshold at MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must overlap the intended operating envelope (flow rate 3–6 L/min, rotational speed 2000–3500 RPM) with documented uncertainty characterization.",
      "rationale": "FDA bench tests covered flow rates of 3–7 L/min and rotational speeds of 2000–4000 RPM. Measurement uncertainties were reported at 95% confidence. Overlap with the intended CPB envelope is complete."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis must agree with experimental measurements within combined simulation and experimental uncertainty bands across at least five operating points.",
      "rationale": "Predicted NIH values agreed with FDA experimental data within combined uncertainty bands at all seven tested operating points. Mean absolute error was 8.4%, within the 15% acceptance threshold for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (normalized index of hemolysis) must be directly linked to the clinical risk endpoint and traceable to the device submission requirements.",
      "rationale": "NIH is the regulatory-accepted surrogate for blood trauma in CPB devices per FDA guidance. The QoI is directly traceable to the 510(k) submission performance criteria for Class II CPB devices."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must use the same pump geometry and blood analogue fluid as the device under assessment, with documented similarity rationale.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry with porcine blood at 37°C, matching the device geometry and physiological fluid properties. Similarity to clinical CPB conditions is documented in the validation plan."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor category; default acceptance at Gradation 1 is sufficient.",
      "rationale": "Per ASME V&V 40 Table 3, numerical solver error beyond code verification is not required at MRL 2. This factor is not assessed and is acceptable at the minimum level for this risk category."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2; operator qualification records are maintained but formal use-error analysis is out of scope.",
      "rationale": "At MRL 2, formal use-error analysis of simulation execution is not mandated. Analyst qualifications are documented in the quality record but a structured use-error assessment was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Model form uncertainty quantification beyond standard turbulence model selection justification is not required at MRL 2.",
      "rationale": "The SST k-omega turbulence model was selected based on published literature for rotating blood-contacting devices. Formal model-form uncertainty analysis is not required at MRL 2 and was not conducted."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sensitivity analysis of input parameters beyond boundary condition documentation is not required at MRL 2.",
      "rationale": "Boundary conditions (inlet velocity, outlet pressure, fluid viscosity) are documented with sources. Formal sensitivity or uncertainty propagation for model inputs is not required at MRL 2 and was not performed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Statistical characterization of test sample variability is not required at MRL 2 for this device class.",
      "rationale": "The FDA dataset used pooled porcine blood from a single source per standard protocol. Sample-to-sample variability characterization beyond the reported experimental uncertainty is not required at MRL 2."
    },
    {
      "type": "CredibilityFactor",
