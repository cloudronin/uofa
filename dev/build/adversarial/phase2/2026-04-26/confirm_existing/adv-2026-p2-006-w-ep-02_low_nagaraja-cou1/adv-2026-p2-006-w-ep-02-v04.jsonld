  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/dr-cou1-noncannulated-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-depuy",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required level. The single below-required factor (Test conditions, achieved 1 vs. required 2) is accepted because the COU is explicitly scoped to ASTM F1717 compression-bending and the Medium decision consequence does not mandate multi-configuration validation at this stage. All three QoIs pass pre-established quantitative acceptance criteria (percent difference <10%, E/uval <1.96). The FEA modeling framework is accepted as sufficiently credible to support the non-cannulated pedicle screw 510(k) submission.",
