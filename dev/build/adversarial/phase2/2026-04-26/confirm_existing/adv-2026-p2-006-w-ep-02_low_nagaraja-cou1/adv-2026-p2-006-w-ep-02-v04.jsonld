      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs match experimental conditions within documented tolerances; any discrepancies assessed for impact on QoI.",
      "rationale": "Screw insertion torque, rod pre-bend angle, and locking cap torque replicated in the model using measured values from each experimental specimen where available. Mean values used for specimens without individual measurements. Sensitivity analysis showed <1% QoI change for torque variation within ±10%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
