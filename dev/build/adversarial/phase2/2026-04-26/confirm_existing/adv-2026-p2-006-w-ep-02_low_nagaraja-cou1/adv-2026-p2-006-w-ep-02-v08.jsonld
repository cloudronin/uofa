  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-nagaraja",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors achieved the required gradation level. The single deficiency (Test conditions, Gradation 1 vs. required Gradation 2) was reviewed and accepted because the single ASTM F1717 configuration tested represents the regulatory worst-case scenario and the overall credibility evidence is sufficient for a Medium model risk, Medium decision consequence COU. All three QoIs passed quantitative acceptance criteria (E/uval < 1.96; difference < 10%). The credibility assessment team accepts the FEA modeling framework as sufficiently validated for the stated COU.",
