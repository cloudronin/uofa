  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial FEA code (Ansys) with documented V&V, version control, and release testing meets Gradation 2 SQA requirements.",
      "rationale": "Ansys Mechanical 2021 R2 is a commercially validated FEA solver with ISO 9001-certified development processes. Release notes document regression testing against benchmark problems. Version control and change management procedures are in place. SQA level meets required Gradation 2 for this medium-risk COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from ASME V&V 10 and Ansys verification manual reproduce analytical solutions within 1% for linear elastic beam bending.",
      "rationale": "Three ASME V&V 10 benchmark problems (cantilever beam, Hertzian contact, pin-in-hole) were executed in the study FEA environment. All results agreed with analytical solutions within 0.4%. Numerical code verification is confirmed at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinements; GCI < 5%.",
      "rationale": "A three-level mesh convergence study was performed on the pedicle screw shank and rod assembly. Stiffness QoI changed by 1.1% between medium and fine meshes. Grid Convergence Index was 2.3%. The production mesh corresponds to the medium-refinement level, which is within acceptance bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Newton-Raphson residual norm < 1e-4 at each load step; energy convergence criterion satisfied.",
      "rationale": "Nonlinear static analysis used full Newton-Raphson iteration with force and displacement convergence tolerances of 0.1% and 0.5% respectively. All load steps converged within 15 iterations. No divergence events were recorded across 11 model instances. Solver error contribution is negligible."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup, boundary conditions, and post-processing scripts by a second qualified analyst.",
      "rationale": "A second FEA analyst independently reviewed model boundary conditions, contact definitions, material assignments, and post-processing macros against the modeling protocol document. Two minor discrepancies in contact stiffness factors were identified and corrected prior to production runs. No residual use errors were identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum elastoplastic constitutive model with isotropic hardening is appropriate for titanium alloy pedicle screw under monotonic loading; justified by literature precedent.",
      "rationale": "The pedicle screw and rod are modeled as Ti-6Al-4V with a bilinear isotropic hardening constitutive law. This model form is well-established for monotonic compression-bending of spinal implants (ASTM F1717 loading regime). Geometric nonlinearity (large deformation) is enabled. Contact between screw head and rod is modeled with augmented Lagrangian formulation. Model form is appropriate for the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from coupon testing of same lot material; geometry from calibrated CMM measurements; uncertainty in inputs quantified.",
      "rationale": "Elastic modulus and yield strength for Ti-6Al-4V rod and screw were measured from same-lot tensile coupons (n=5 per component). Geometric dimensions were obtained from CMM measurements with ±0.01 mm uncertainty. Torque on set screw was measured and applied as pre-load in the model. Input uncertainty is within ±5% for all parameters, consistent with Gradation 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test samples from production lot; traceability to device design history file confirmed.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories (Lab 1: n=6; Lab 2: n=5). All constructs were drawn from a single production lot traceable to the device DHF. Sample size meets Gradation 2 requirements. Inter-laboratory variability in stiffness was 3.2% (CV), indicating acceptable repeatability."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of COU loading scenarios; at minimum two distinct load levels or configurations tested.",
      "rationale": "Testing was conducted under a single ASTM F1717 configuration (static compression-bending at 10 mm offset). No additional load levels or offset distances were evaluated. This limits the ability to validate the model across the full COU envelope. Achieved level is Gradation 1, below the required Gradation 2. This deficiency is noted as an accepted residual gap given that the single test condition represents the worst-case regulatory scenario."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material, boundary conditions, loading) demonstrably match experimental test conditions; documented parameter mapping table provided.",
      "rationale": "A parameter mapping table was developed cross-referencing each FEA model input to its experimental counterpart. Applied displacement rate, fixture geometry, set-screw torque, and specimen dimensions were matched within measurement uncertainty. No unmatched parameters were identified. Equivalency is confirmed at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All three QoIs (stiffness, yield force, force at 40 mm) satisfy E/uval < 1.96 and percentage difference < 10%.",
      "rationale": "Stiffness: FEA mean 187 N/mm vs. experimental mean 192 N/mm (2.6% difference; E/uval = 0.84). Yield force: FEA 412 N vs. experimental 419 N (1.7%; E/uval = 0.61). Force at 40 mm: FEA 498 N vs. experimental 507 N (1.8%; E/uval = 0.72). All three QoIs pass both acceptance criteria. Output comparison is satisfactory at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to clinical failure modes and regulatory submission requirements.",
      "rationale": "The three QoIs are those specified in ASTM F1717 and requested by FDA for pedicle screw 510(k) submissions. Construct stiffness relates to load sharing with the spine; yield force and force at 40 mm displacement bound fatigue and fracture risk. All QoIs are directly relevant to the COU decision. Relevance is confirmed at Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiment replicates the COU device, loading, and environment with documented similarity argument.",
      "rationale": "The validation experiment uses the identical non-cannulated 7.5 mm pedicle screw design, same Ti-6Al-4V rod, and ASTM F1717 test fixture as specified in the COU. Loading mode (compression-bending), displacement rate (5 mm/min), and ambient temperature (23°C) match the COU definition. A formal similarity argument document was reviewed and approved by the credibility assessment team. Relevance is confirmed at Gradation 2."
    }
  ],
