  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required levels. One factor (Test conditions) achieved level 2 against required level 3 due to single ASTM F1717 loading configuration; this shortfall is accepted given the regulatory standard specifies this configuration and the overall model risk level 3 credibility evidence is otherwise complete. All three QoIs satisfy quantitative acceptance criteria (E/uval < 1.96; percentage difference < 10%). The FEA modeling framework is accepted as credible for the stated COU.",
