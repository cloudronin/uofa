  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/depuy-synthes-vv-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required level. The single shortfall (Test conditions, achieved 2 vs. required 3) is accepted on the basis that the ASTM F1717 quasi-static protocol is conservative relative to physiologic loading and is the regulatory standard for this device class. All three QoIs pass quantitative acceptance criteria (E/uval < 1.96; Δ < 10%). Overall credibility is sufficient to support a Medium assurance conclusion for the non-cannulated compression-bending COU.",
