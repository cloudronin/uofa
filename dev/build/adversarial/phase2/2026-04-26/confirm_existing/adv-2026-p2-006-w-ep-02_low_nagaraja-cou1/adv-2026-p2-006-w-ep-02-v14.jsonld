  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen credibility factors meet or exceed the required level. The single shortfall (Test conditions, achieved 2 vs. required 3) is accepted because the COU is explicitly scoped to the ASTM F1717 compression-bending configuration and the model risk level 3 does not mandate multi-condition validation for this submission. All three QoIs satisfy both the E/uval < 1.96 and percent-difference < 10% acceptance criteria. The credibility assessment team concludes that the FEA modeling framework provides sufficient evidence to support the regulatory submission.",
