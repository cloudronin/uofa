  "signature": "ed25519:b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial FEA solver (Ansys Mechanical) with documented version control and FDA-recognized QMS; solver verification tests on file.",
      "rationale": "Ansys Mechanical 2022 R2 used under a validated installation qualification protocol. Version-controlled input decks stored in a Git repository with commit hashes recorded. Solver release notes and patch history reviewed; no open defects affecting implicit static analysis identified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems from NAFEMS and internal library reproduce analytic solutions within 1% for linear elastic beam bending.",
      "rationale": "Three NAFEMS benchmark cases (LE1, LE3, LE10) executed in the deployed solver configuration. Maximum deviation from analytic solution was 0.6%. Internal cantilever beam benchmark also passed at 0.4% deviation. Code verification is considered sufficient for the linear-elastic compression-bending regime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates <2% change in QoIs between successive refinements; GCI reported.",
      "rationale": "Four-level mesh refinement study conducted on the pedicle screw–rod assembly. Grid Convergence Index (GCI) for stiffness QoI was 0.9%, for yield force 1.3%, and for force at 40 mm 1.1%. Asymptotic convergence confirmed. Final mesh (approx. 420 000 elements, C3D10 quadratic tetrahedral) selected for production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms below 1e-6 for all load steps; energy convergence criterion satisfied.",
      "rationale": "All production runs converged with force residual norms below 1e-7 and displacement residual norms below 1e-8. No divergence or contact chattering observed across the 11 construct configurations. Automatic time-stepping with bisection enabled; no load step failures recorded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent peer review of model setup by a second analyst; checklist completed.",
      "rationale": "A second senior FEA analyst independently reviewed boundary conditions, material assignments, contact definitions, and load application against the ASTM F1717 test configuration. Fourteen-item review checklist completed with no critical findings. Two minor annotation issues corrected prior to production runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Linear elastic constitutive model justified for pre-yield regime; nonlinear geometry (NLGEOM) enabled for large-displacement phase.",
      "rationale": "Titanium alloy (Ti-6Al-4V) modeled as isotropic linear elastic (E=114 GPa, ν=0.34) for the stiffness and yield force QoIs; large-displacement formulation activated for the 40 mm displacement QoI. Bone substitute (UHMWPE blocks per F1717) modeled with manufacturer-supplied elastic properties. Model form is consistent with published literature and the FDA guidance on FEA of spinal implants."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties sourced from ASTM-certified coupon testing or peer-reviewed literature; geometric inputs from CMM measurements of production hardware.",
      "rationale": "Elastic modulus and yield strength of Ti-6Al-4V rod and screw stock measured from three tensile coupons per lot (mean E=113.8 GPa, σy=896 MPa). UHMWPE block properties from manufacturer certificate of conformance. Screw and rod geometry digitized via coordinate measuring machine (CMM) to ±0.01 mm. Input uncertainty propagated via Latin hypercube sampling (n=200 runs) to quantify uval."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 constructs from production lots; dimensional inspection records available.",
      "rationale": "Eleven constructs assembled from production-representative hardware (three consecutive manufacturing lots). Dimensional inspection via CMM confirmed all critical dimensions within drawing tolerances. Constructs tested at two independent laboratories (FDA CDRH and DePuy Synthes) to assess inter-laboratory variability. Sample size exceeds the pre-specified minimum of N=10."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of clinically relevant loading scenarios; minimum two load configurations evaluated.",
      "rationale": "Testing performed exclusively under the standard ASTM F1717 compression-bending configuration (single load condition). Torsion and lateral bending conditions were not evaluated in this validation activity. Achieved level (2) is below the required level (3) for this factor; this gap is acknowledged and accepted given that the COU is specifically scoped to the F1717 compression-bending regime and the model risk level does not mandate additional configurations at this stage."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material properties, boundary conditions) traceable to the as-tested specimens.",
      "rationale": "Each of the 11 FEA model instances was parameterized using CMM measurements from the corresponding physical construct. Material property inputs drawn from the same production lot certificates used for the physical specimens. Boundary conditions replicate the F1717 fixture kinematics (pin-pin, 40 mm offset). Input equivalency documented in a traceability matrix cross-referencing specimen IDs to model input files."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval < 1.96 for all three QoIs; percent difference < 10%.",
      "rationale": "E/uval values: stiffness 0.91, yield force 1.31, force at 40 mm 1.44 — all below the 1.96 threshold. Percent differences: 4.2%, 6.8%, 7.5% respectively — all below 10%. Comparison performed using the validation uncertainty framework described in ASME V&V 40 Section 5. Results summarized in the validation report Appendix C."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm) are directly linked to the clinical performance endpoints and regulatory submission requirements.",
      "rationale": "The three QoIs are explicitly required by ASTM F1717 and referenced in FDA guidance for spinal pedicle screw systems. Construct stiffness correlates with load sharing; yield force and force at 40 mm bound failure modes relevant to revision surgery risk. QoI relevance confirmed by clinical and regulatory subject matter experts."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation specimens, loading conditions, and outcome measures are representative of the intended clinical COU.",
      "rationale": "Validation constructs use production-representative 7.5 mm non-cannulated pedicle screws and titanium rods identical to those submitted for clearance. Loading conditions replicate the most demanding in-vivo bending scenario per F1717. Both laboratories are accredited to ISO 17025. The validation activity is judged to be directly relevant to the COU with no significant extrapolation required."
    }
