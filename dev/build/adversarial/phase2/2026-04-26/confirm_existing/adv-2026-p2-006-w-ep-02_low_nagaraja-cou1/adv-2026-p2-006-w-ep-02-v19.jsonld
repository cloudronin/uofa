  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-noncannulated-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors assessed. Twelve of thirteen factors meet or exceed required gradation levels. One factor (Test conditions) achieved Gradation 2 against a required Gradation 3 due to single loading rate evaluation; this gap is accepted given that ASTM F1717 specifies a single quasi-static rate and inter-laboratory reproducibility was demonstrated. All three QoIs satisfy quantitative acceptance criteria (percent difference <10%, E/uval <1.96). The FEA modeling framework is accepted as sufficiently credible for the stated COU.",
