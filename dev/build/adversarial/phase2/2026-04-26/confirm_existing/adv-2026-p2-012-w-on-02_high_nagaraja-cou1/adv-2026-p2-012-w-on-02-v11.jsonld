  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death). Testing performed at ambient laboratory temperature (20–23 °C), relative humidity 40–60%, quasi-static displacement rate 5 mm/min, axial compressive pre-load 100 N, saline-free dry-bone surrogate UHMWPE blocks per ASTM F1717 Annex A1. Load frame compliance correction applied per laboratory SOP. All specimens drawn from a single production lot of Ti-6Al-4V ELI rod stock; rod diameter 5.5 mm; screw shank diameter 7.5 mm; pedicle screw length 45 mm. Construct geometry fixed at 35 mm rod segment between block faces.",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium"
  },
