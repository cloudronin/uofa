  "signature": "ed25519:9b1c3e5a7f2d4b6e8a0c2f4d6b8e0a2c4f6d8b0e2a4c6f8d0b2e4a6c8f0d2b4e",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software used under documented quality management system with version control and regression testing.",
      "rationale": "Ansys Mechanical 2021 R2 operated under ISO 9001-compliant QMS at DePuy Synthes; FDA in-house Abaqus instance covered by CDRH software quality procedures. Version-controlled input decks archived in Git repository with MD5 checksums. Regression test suite executed prior to analysis runs."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions solved to confirm solver implementation correctness.",
      "rationale": "Both Ansys and Abaqus solvers verified against NAFEMS benchmark set LE1 and LE10 for linear elasticity; maximum deviation from analytical solution 0.4%. Documented in solver verification reports archived with submission package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change <2% between successive refinements.",
      "rationale": "Three-level mesh refinement study performed on the screw shank and thread root regions. Von Mises stress and reaction force QoIs changed by 1.1% and 0.7% respectively between the medium and fine meshes. Final mesh selected at medium refinement level (approximately 420,000 elements, C3D8I formulation) balancing accuracy and runtime."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Residual norms monitored; energy balance error <0.1% per increment.",
      "rationale": "Newton-Raphson iteration converged to force residual norm <1e-5 N for all load steps. Energy balance error remained below 0.05% throughout the quasi-static loading sequence. No hour-glassing detected in C3D8I elements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Independent analyst review of model setup and boundary condition application documented.",
      "rationale": "A second analyst at FDA independently reviewed boundary condition application, contact pair definitions, and material property assignments against the documented model specification. Discrepancies identified in initial contact stiffness settings were corrected prior to final analysis runs. Review documented in internal technical memorandum TM-2022-047."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing physics (linear elasticity with contact) justified relative to expected deformation regime; plasticity onset captured via bilinear isotropic hardening.",
      "rationale": "Construct response in compression-bending is dominated by elastic bending of the titanium rod and screw body up to yield. Bilinear isotropic hardening (E_t = 3.5 GPa) incorporated to capture post-yield softening. Large-displacement formulation (NLGEOM) activated. Contact between screw head and tulip modeled with surface-to-surface penalty formulation, friction coefficient μ = 0.2 consistent with dry titanium-on-titanium literature values."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric parameters sourced from certified material certificates and CMM measurements; sensitivity analysis performed on key inputs.",
      "rationale": "Ti-6Al-4V ELI elastic modulus and yield strength drawn from lot-specific material certificates for the production screw batch. Screw geometry digitized via CMM at 0.001 mm resolution. One-at-a-time sensitivity analysis showed QoIs most sensitive to rod diameter (±3.2% per ±0.05 mm) and Young's modulus (±1.8% per ±5 GPa). Uncertainty propagated through the model using Monte Carlo sampling (N=500 draws)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N≥10 test specimens from production lots; dimensional inspection confirms conformance to nominal geometry.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (Lab A: n=6; Lab B: n=5). All specimens drawn from the same production lot. CMM inspection of three randomly selected specimens confirmed dimensional conformance within ±0.02 mm of nominal. UHMWPE vertebral body simulants inspected per ASTM F1717 §7."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple loading rates and gap heights tested to characterize sensitivity of QoIs to test condition variation.",
      "rationale": "Testing conducted at a single crosshead displacement rate (5 mm/min) and a single intervertebral gap height (35 mm) per ASTM F1717. While this satisfies the standard protocol, it precludes assessment of model sensitivity to loading rate or gap height variation. This factor is below the required credibility level; the shortfall is acknowledged and accepted given that the ASTM protocol is the regulatory reference condition and the model is applied only within this protocol boundary."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented traceability between experimental measurements and corresponding FEA model inputs.",
      "rationale": "A parameter equivalency matrix maps each experimental measurement (rod diameter, screw outer diameter, gap height, material lot properties) to the corresponding FEA input. Traceability confirmed by independent review. No unmatched parameters identified. Friction coefficient is the sole parameter not directly measured; literature-based value sensitivity-tested."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for each QoI; all values within pre-specified acceptance bound of 1.96.",
      "rationale": "E/uval computed per ASME V&V 40 Eq. (5-1) for stiffness (1.41), yield force (1.62), and force at 40 mm (1.18). All three QoIs satisfy the pre-established acceptance criterion of E/uval < 1.96. Percentage differences also within the secondary criterion of <10%. Agreement is consistent across both laboratories."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected are directly linked to the clinical failure modes and regulatory decision.",
      "rationale": "Construct stiffness governs load transfer to the vertebral body and adjacent motion segments. Yield force is the primary safety metric linked to screw fracture risk. Force at 40 mm displacement characterizes post-yield energy absorption relevant to fatigue life predictions. All three QoIs are explicitly referenced in FDA guidance for spinal implant 510(k) submissions and map directly to the clinical decision consequence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario geometry, material, loading, and boundary conditions match the COU within documented tolerances.",
      "rationale": "Validation specimens are drawn from the same production design and lot as the intended clinical device. ASTM F1717 test configuration replicates the in vivo compression-bending load path. Boundary conditions (fixed inferior block, superior actuator displacement) are mechanically equivalent to the surgical construct boundary conditions to first order. Differences from in vivo conditions (absence of biological tissue, single load case) are documented and accepted given the regulatory context of the COU."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required level. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is accepted because the ASTM F1717 protocol defines the regulatory reference condition and no alternative test configurations are available within the submission timeline. All three QoIs satisfy the pre-established quantitative acceptance criteria (E/uval < 1.96; percentage difference < 10%). The overall credibility evidence is judged sufficient to support a Medium assurance level decision for the non-cannulated 7.5 mm pedicle screw compression-bending submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
