  ],
  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. The assessment was conducted under ambient laboratory conditions (temperature 20–25 °C, relative humidity 30–60 %), with loading applied at a quasi-static crosshead displacement rate of 5 mm/min, and construct geometry constrained to a 35 mm intervertebral gap height per ASTM F1717 §8.2. Titanium alloy (Ti-6Al-4V ELI) material properties (E = 114 GPa, σ_y = 880 MPa) were applied uniformly across the screw body. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/nagaraja-stiffness-comparison",
      "type": "ValidationResult",
      "name": "Construct stiffness QoI comparison: FEA vs. experimental (N=11)",
      "description": "Mean absolute percentage error in predicted construct stiffness was 6.3% across N=11 specimens; E/uval = 1.41, within the pre-established acceptance bound of 1.96."
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-yield-force-comparison",
      "type": "ValidationResult",
      "name": "Yield force QoI comparison: FEA vs. experimental (N=11)",
      "description": "Mean absolute percentage error in predicted yield force was 7.8%; E/uval = 1.62, within acceptance bounds."
    },
    {
      "id": "https://uofa.net/synth/validation/nagaraja-force-40mm-comparison",
      "type": "ValidationResult",
      "name": "Force at 40 mm displacement QoI comparison: FEA vs. experimental (N=11)",
      "description": "Mean absolute percentage error in predicted force at 40 mm displacement was 5.1%; E/uval = 1.18, within acceptance bounds."
    }
  ],
