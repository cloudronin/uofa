  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors meet or exceed the required credibility level. One factor (Test conditions) achieved level 1 against a required level of 2 due to testing at a single ASTM F1717-15 configuration. The assessment team determined that this gap is acceptable for the current submission given the regulatory standard nature of the single test condition and the strong quantitative agreement observed across all three QoIs (E/uval < 1.96 for all). Overall credibility is judged sufficient to support a Medium model influence, Medium decision consequence regulatory use. The credibility package is accepted.",
