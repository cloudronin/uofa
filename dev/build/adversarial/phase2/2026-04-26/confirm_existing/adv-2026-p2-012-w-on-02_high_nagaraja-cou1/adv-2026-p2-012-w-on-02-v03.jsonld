      "rationale": "Ansys Mechanical 2021 R2 was used under an FDA-recognized software quality assurance plan. Installation qualification and operational qualification records are on file. Version control and change management procedures are documented per 21 CFR Part 820."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Benchmark problems with known analytical solutions demonstrate correct implementation of governing equations.",
      "rationale": "Standard Ansys benchmark problems (patch test, cantilever beam, Hertzian contact) were executed and results compared to analytical solutions; all within 1% relative error, confirming correct code implementation for the element types and contact formulations used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change < 2% between successive refinements.",
      "rationale": "Three-level mesh refinement study performed on the pedicle screw–rod construct. Stiffness QoI changed by 3.8% (coarse to medium) and 0.9% (medium to fine). Production mesh corresponds to the fine level; discretization error estimated at < 1% via Richardson extrapolation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Default solver tolerances are appropriate; residual convergence confirmed for each load step.",
      "rationale": "Nonlinear static analysis used sparse direct solver with force and displacement convergence criteria of 0.1% and 0.5% respectively. Convergence achieved within 15 iterations per load step across all 11 model instances. No solver warnings or unconverged substeps recorded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model setup reviewed by an independent analyst; boundary conditions and load application verified against test protocol.",
      "rationale": "An independent FEA analyst reviewed all boundary condition definitions, material property assignments, and contact pair settings against the ASTM F1717-15 protocol and DePuy Synthes test report. No discrepancies identified. Peer review documented in project record PR-2023-047."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Governing physics (large-deformation elastoplasticity, frictional contact) justified and documented; simplifying assumptions enumerated.",
      "rationale": "Large-deformation elastoplastic constitutive model (isotropic hardening, Ti-6Al-4V) adopted for screw and rod. Frictional Coulomb contact (μ=0.2) applied at screw–block and rod–screw interfaces. Bone substitute blocks modeled as linear elastic (UHMWPE, E=1.0 GPa). Simplifying assumptions (no pre-stress, no thermal effects) documented and judged acceptable for quasi-static ambient testing."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties and geometric inputs traceable to measurements or certified material data; uncertainty quantified.",
      "rationale": "Ti-6Al-4V material properties (E=113.8 GPa, σ_y=880 MPa) sourced from DePuy Synthes certified material certificates for production lot. UHMWPE block properties from ASTM F648 coupon testing (mean E=1.02 GPa, CV=3.1%). Nominal screw geometry from CAD; dimensional tolerances from CMM inspection of N=3 screws (max deviation 0.04 mm). Input uncertainty propagated via Monte Carlo (N=1000 samples)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test specimens are production-representative; sample size sufficient to characterize variability.",
      "rationale": "N=11 non-cannulated 7.5 mm pedicle screw constructs tested across two independent laboratories (Lab A: n=6, Lab B: n=5). All screws from the same production lot, verified by DePuy Synthes QC records. UHMWPE blocks from a single certified batch. Sample size provides 80% power to detect a 10% mean difference at α=0.05 based on historical coefficient of variation of 8%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Multiple test conditions (e.g., varying offset distance or loading rate) evaluated to confirm model generalizability.",
      "rationale": "Testing was performed at a single ASTM F1717-15 standard configuration (50 mm offset, 5 mm/min loading rate). While this is the regulatory standard condition, only one test condition was evaluated. The achieved level is therefore 1, below the required level of 2. This gap is noted; additional loading rate or offset sensitivity studies are recommended for future submissions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Model inputs match experimental conditions; any deviations documented and their effect on QoI bounded.",
      "rationale": "Screw geometry, torque pre-load (4 Nm), UHMWPE block dimensions, and offset distance (50 mm) in the FEA match experimental setup as confirmed by test protocol review. Load frame compliance correction applied to experimental displacement data to align with FEA boundary conditions. Residual input equivalency uncertainty estimated at < 2% QoI effect."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (E/uval) computed for each QoI; all values < 1.96.",
      "rationale": "E/uval computed for stiffness (0.87), yield force (1.31), and force at 40 mm (1.02). All three QoIs satisfy the acceptance criterion E/uval < 1.96. Percentage differences (4.2%, 6.8%, 5.5%) all below 10% bound. Comparison includes combined experimental uncertainty (measurement, inter-lab variability) and model prediction uncertainty (input uncertainty, discretization)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs selected for validation are directly linked to the clinical and regulatory decision being supported.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the three QoIs specified in FDA guidance for pedicle screw structural testing. These QoIs directly characterize the mechanical performance relevant to the regulatory 510(k) substantial equivalence determination. No surrogate or proxy QoIs used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation scenario (geometry, material, loading) matches the intended clinical and regulatory use context.",
      "rationale": "Validation uses the identical screw design (non-cannulated 7.5 mm), identical ASTM F1717-15 test configuration, and identical material lot as the regulatory submission. The FEA model validated here is the same model used to predict performance in the COU. No extrapolation of validation evidence to a different geometry or loading mode is required."
    }
