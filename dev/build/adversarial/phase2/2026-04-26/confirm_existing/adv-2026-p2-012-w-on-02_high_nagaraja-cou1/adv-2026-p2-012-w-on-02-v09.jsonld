  "hasDecisionRecord": {
    "id": "https://uofa.net/nagaraja/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/nagaraja/org/fda-cdrh-osel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed the required gradation level. The single shortfall (Test conditions, achieved level 2 vs. required level 3) is accepted on the basis that the clinical loading environment is demonstrably quasi-static and a single-rate protocol is standard practice under ASTM F1717. All three QoIs satisfy the pre-specified quantitative acceptance bounds (E/uval < 1.96; percentage difference < 10%). The overall credibility evidence is sufficient to support a Medium assurance level for a Class II device with Medium model influence and Medium decision consequence.",
