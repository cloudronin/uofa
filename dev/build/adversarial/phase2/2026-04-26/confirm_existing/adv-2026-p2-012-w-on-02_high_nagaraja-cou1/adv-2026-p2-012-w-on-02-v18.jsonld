  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-osel-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment is Accepted at Medium assurance level. Twelve of thirteen V&V 40 factors meet or exceed their required levels. The single shortfall (Test conditions, achieved 2 vs. required 3) is accepted because ASTM F1717 mandates a single quasi-static test condition and the regulatory precedent for this device class does not require multi-rate validation. All three QoIs satisfy the pre-specified acceptance bounds (E/uval < 1.96; percentage difference < 10%). The FEA framework is considered credible for supporting the 510(k) submission for the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
