    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation setup reviewed by independent analyst; documented simulation plan followed; boundary conditions and material assignments verified by second reviewer.",
      "rationale": "Independent peer review of model setup conducted by FDA OSEL analyst not involved in model construction. Boundary conditions, material cards, and contact definitions verified. No discrepancies found. Achieved level 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum finite element representation with elastic-plastic titanium material model and frictional contact at screw-rod interface is appropriate for quasi-static compression-bending of metallic implant construct.",
      "rationale": "Bilinear isotropic hardening plasticity model applied to Ti-6Al-4V screw and rod. Frictional contact (mu=0.2) at screw-rod and screw-block interfaces. Model form consistent with prior FDA validation studies for metallic spinal implants. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (E, yield stress, tangent modulus) sourced from ASTM-compliant coupon testing of same material lot; geometry from calibrated CMM measurements of test articles.",
      "rationale": "Ti-6Al-4V material properties measured from tensile coupons (same heat as test screws): E=114 GPa, sigma_y=930 MPa, E_t=1.8 GPa. Geometry from CMM measurements with 5 micron accuracy. Polyurethane block density and modulus from manufacturer certificate. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 constructs from same production lot; dimensional inspection confirms within-lot geometric variability < 1%; sample size sufficient for statistical comparison.",
      "rationale": "Eleven constructs assembled from screws and rods from the same production lot. CMM inspection of all screws confirms diameter CV < 0.3%. Sample size of 11 provides adequate statistical power for mean comparison at alpha=0.05. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions span the range of loading rates and environmental conditions anticipated in the COU; at minimum two loading configurations tested.",
      "rationale": "Testing performed at a single displacement rate (5 mm/min) and single environmental condition (ambient, dry). ASTM F1717 mandates this configuration but does not require multi-rate or wet testing. Only one test condition evaluated, limiting coverage of the intended use space. Achieved level 2 is below required level 3; this gap is acknowledged and accepted given the regulatory standard mandate."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA model inputs (geometry, material properties, boundary conditions) demonstrably equivalent to test article inputs within quantified uncertainty bounds.",
      "rationale": "One-to-one mapping established between FEA model inputs and measured test article parameters. Geometric equivalency confirmed via CMM-to-CAD overlay. Material property equivalency confirmed by coupon testing. Boundary condition equivalency confirmed by load cell and displacement transducer calibration records. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalised error metric E/uval < 1.96 and percentage difference < 10% for all three QoIs; comparison accounts for both simulation and experimental uncertainty.",
      "rationale": "All three QoIs (stiffness, yield force, force at 40 mm) satisfy E/uval < 1.96 and percentage difference < 10%. Combined simulation uncertainty (uval) computed from discretization, material, and geometric uncertainty sources via RSS. Experimental uncertainty from inter-laboratory and within-laboratory repeatability. Achieved level 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
