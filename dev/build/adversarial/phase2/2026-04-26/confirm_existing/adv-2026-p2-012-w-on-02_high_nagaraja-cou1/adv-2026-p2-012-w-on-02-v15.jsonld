  "signature": "ed25519:b4e2d1f3c5a7091e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "All three FEA codes (FDA in-house, Ansys 2022R1, DePuy Synthes proprietary) operate under documented software quality management systems with version control, regression test suites, and formal release procedures. Ansys holds ISO 9001 certification; FDA and DePuy Synthes codes are controlled under 21 CFR Part 820 QMS. Achieved level 3 exceeds required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Each solver was verified against ASME V&V 10-2006 benchmark problems for linear elastic structural analysis. Patch tests and manufactured-solution comparisons were executed for the element types used (C3D8R, SOLID186). All codes reproduced reference solutions within 0.5% for the relevant element formulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Mesh convergence studies were performed for the screw shank, thread root, and rod–screw interface regions. Richardson extrapolation yielded a global discretization error estimate of <1.8% for stiffness and <2.4% for peak stress. Final mesh density was selected at the knee of the convergence curve; element count ranged from 480 000 to 1 200 000 depending on participating code."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Direct sparse solvers (PARDISO, MUMPS) were employed for the linear solution phase. Residual norms at convergence were below 1×10⁻⁸ for all load steps. No iterative solver divergence was observed across 11 specimen simulations per code."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Simulation workflows were executed by analysts with documented training records. A peer-review checklist covering boundary condition application, material assignment, contact definition, and unit consistency was completed for each model prior to result extraction. Independent cross-checks between the three modeling teams identified and resolved two minor unit-conversion discrepancies during the round-robin phase."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Continuum linear-elastic constitutive law with bilinear isotropic hardening for post-yield response was selected based on published titanium alloy (Ti-6Al-4V) characterization data. Contact between screw head and rod was modeled with penalty-based frictional contact (μ=0.2). The model form is consistent with prior FDA-validated pedicle screw FEA frameworks and is appropriate for quasi-static monotonic loading."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Material properties (E=114 GPa, ν=0.34, σ_y=880 MPa, tangent modulus=2.1 GPa) were sourced from lot-specific coupon testing of the same Ti-6Al-4V bar stock used to manufacture the test specimens. Geometric inputs were derived from CMM measurements of five representative screws with mean dimensional deviations <15 μm from nominal CAD. Uncertainty in material inputs was propagated via a 200-sample Monte Carlo analysis; resulting QoI uncertainty contribution was <3%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested: six at Laboratory A (FDA) and five at Laboratory B (DePuy Synthes). All specimens were manufactured from the same production lot, inspected per ASTM F543, and stored under controlled conditions prior to testing. Sample size provides sufficient statistical power for mean QoI comparison at the pre-specified 10% acceptance bound."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Testing was conducted under a single loading condition (ASTM F1717 standard fixture, 5 mm/min quasi-static). While environmental controls (temperature, humidity, PBS bath) were well-characterized and consistent across laboratories, only one load rate and one fixture configuration were evaluated. This limits the breadth of test condition coverage to gradation 2; the required level of 3 is not achieved. This shortfall is acknowledged and constitutes the one factor below threshold in this assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "FEA boundary conditions were mapped directly to measured experimental conditions: applied displacement profile, fixture geometry, and support constraints were reproduced in the simulation from test machine data logs. Frictional contact coefficients were measured via tribometry on representative Ti-6Al-4V specimen pairs. No surrogate or assumed boundary conditions were introduced."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Three scalar QoIs were compared: construct stiffness (N/mm), yield force (N), and force at 40 mm displacement (N). Comparison metric was the mean absolute percentage error and the validation metric E/uval per ASME V&V 40 Section 9. All three QoIs satisfied both the <10% MAPE criterion and the E/uval < 1.96 criterion across all three modeling teams."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "Construct stiffness, yield force, and force at 40 mm displacement are the primary regulatory QoIs for pedicle screw mechanical performance under ASTM F1717 and are directly cited in FDA guidance for 510(k) submissions for spinal fixation systems. These QoIs are clinically relevant surrogates for in vivo construct integrity under physiological bending loads."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Achieved level must meet or exceed required level.",
      "rationale": "The validation activity directly replicates the COU: the same screw geometry, material lot, fixture configuration, and loading mode used in the regulatory submission are used in the validation study. The validation domain and the COU domain are coincident, providing high relevance. The multi-laboratory, multi-code design of the round-robin further strengthens confidence in result generalizability across modeling implementations."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-vv40-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single shortfall — Test conditions at achieved level 2 against required level 3 — reflects the use of a single standardized ASTM F1717 loading configuration and is accepted on the basis that this configuration is the sole regulatory use case for the submission, that all three QoIs pass quantitative acceptance criteria across eleven specimens and three independent modeling teams, and that the overall credibility evidence is sufficient to support a Medium-assurance decision for a Class II device with Medium model influence and Medium decision consequence.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
