  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death). The validation environment is maintained at 23 ± 2 °C ambient temperature, atmospheric pressure (101.3 ± 1 kPa), and quasi-static displacement rates of 5 mm/min, with axial compressive loads ranging from 0 to 2200 N and bending moments up to 14 N·m. Titanium alloy Ti-6Al-4V material properties are drawn from ASTM F136 lot certificates; polyethylene vertebral body surrogates conform to ASTM F1839 Grade 15 foam. These conditions bracket the anticipated clinical loading environment for thoracolumbar fixation in adult patients (BMI ≤ 40, single-level construct).",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium"
  },
