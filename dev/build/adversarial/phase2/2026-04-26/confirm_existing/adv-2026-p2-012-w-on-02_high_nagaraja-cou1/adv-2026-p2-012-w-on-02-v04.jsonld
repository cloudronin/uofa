  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required gradation levels. The single below-threshold factor (Test conditions, achieved Gradation 2 vs. required Gradation 3) reflects the single-rate, single-temperature ASTM F1717 protocol; this limitation is accepted given the quasi-static ambient nature of the intended use and the strong quantitative agreement across all three QoIs (E/uval < 1.96, percent difference < 10%). Overall credibility is judged sufficient to support the Medium model risk and Medium decision consequence classification. Package accepted for regulatory submission.",
