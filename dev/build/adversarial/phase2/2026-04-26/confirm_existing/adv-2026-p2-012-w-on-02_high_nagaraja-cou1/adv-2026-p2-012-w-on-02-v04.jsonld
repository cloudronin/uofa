  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death). The validation testing was conducted at ambient laboratory temperature (20–23 °C), under quasi-static loading rates (1–2 mm/min displacement-controlled), in a dry air environment at standard atmospheric pressure (101.3 kPa ± 2%). Screw-rod constructs were assembled with manufacturer-specified torque (8 Nm) and tested within the linear-elastic and post-yield regimes up to 40 mm crosshead displacement. These conditions are representative of the intended bench characterization protocol and reflect the physical regime in which the FEA material models (titanium alloy Ti-6Al-4V, E = 114 GPa, yield 880 MPa) are calibrated.",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium"
  },
