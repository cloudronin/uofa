  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed required levels. The single shortfall (Test conditions, achieved level 2 vs. required level 3) reflects the limitation of a single F1717 loading configuration in the validation dataset; this is accepted given that the COU is also restricted to the single F1717 compression-bending configuration and no extrapolation to other loading modes is claimed. All three QoIs satisfy the pre-specified acceptance bounds (< 10% difference, E/uval < 1.96). Overall credibility is assessed as sufficient to support a Medium assurance level decision.",
