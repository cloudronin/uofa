  "hasContextOfUse": {
    "id": "https://uofa.net/nagaraja/cou/cou1-noncannulated",
    "type": "ContextOfUse",
    "name": "COU1: Non-cannulated construct compression-bending prediction",
    "description": "FEA predicts construct stiffness, yield force, and force at 40 mm displacement for the non-cannulated 7.5 mm pedicle screw design under ASTM F1717 static compression-bending. Validated by direct comparison to bench testing (N=11 constructs across two laboratories). Model influence MEDIUM (testing confirms results); decision consequence MEDIUM (pedicle screw fracture leads to revision surgery, not death). Testing was conducted at ambient laboratory temperature (20–23 °C), relative humidity 40–60%, under quasi-static monotonic loading at 5 mm/min crosshead displacement rate, with constructs immersed in 37 °C phosphate-buffered saline to simulate physiological ionic environment. Applied compressive-bending loads ranged from 0 N to 1800 N. Specimen geometry was constrained to the 7.5 mm outer-diameter non-cannulated titanium alloy (Ti-6Al-4V ELI) design with a 35 mm pedicle screw length and UHMWPE vertebral body surrogate blocks per F1717 Annex A1.",
    "intendedUse": "Demonstrate that the FEA modeling framework reproduces experimental compression-bending behavior of a non-cannulated pedicle screw construct within pre-established acceptance bounds (<10% QoI difference, E/uval < 1.96).",
    "deviceClass": "Class II",
    "modelInfluence": "Medium",
    "decisionConsequence": "Medium"
  },
