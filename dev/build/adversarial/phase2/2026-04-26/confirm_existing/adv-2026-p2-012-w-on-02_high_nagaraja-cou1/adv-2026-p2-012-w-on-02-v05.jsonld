  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Overall credibility assessment accepted at Medium assurance level. Twelve of thirteen V&V 40 factors meet or exceed required Gradation 2. One factor (Test conditions) achieves only Gradation 1 against a Gradation 2 requirement due to single-condition testing per ASTM F1717. This gap is accepted given that ASTM F1717 specifies a standardized single-condition protocol and the regulatory submission context does not require multi-rate characterization. All three QoIs pass quantitative acceptance criteria (E/uval < 1.96; percent difference < 10%). Model credibility is sufficient to support the intended regulatory use.",
    "decidedAt": "2026-04-19T00:00:00Z"
