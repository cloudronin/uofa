  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Twelve of thirteen V&V 40 credibility factors meet or exceed their required levels. The single deficiency (Test conditions, achieved level 2 vs. required level 3) is accepted because ASTM F1717 specifies a single mandated test condition and the regulatory comparison is explicitly defined at that condition. All three primary QoIs satisfy quantitative acceptance bounds at both participating laboratories. The overall credibility of the FEA model ensemble is sufficient to support the regulatory submission for the non-cannulated 7.5 mm pedicle screw design at Medium model risk level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
