      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The QoI (hemolysis index) must be directly mapped to the clinical endpoint with documented traceability to the device acceptance criterion.",
      "rationale": "The normalized index of hemolysis (NIH) is used as the QoI, which maps to the clinical hemolysis threshold. However, the mapping from NIH to absolute plasma-free hemoglobin concentration lacks formal traceability documentation in the submission package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
