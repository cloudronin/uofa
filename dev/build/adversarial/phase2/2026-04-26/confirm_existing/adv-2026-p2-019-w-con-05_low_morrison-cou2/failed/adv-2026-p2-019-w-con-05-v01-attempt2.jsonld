      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI-based discretization uncertainty estimate below 5% for hemolysis index QoI at all five operating points; systematic three-level refinement study required.",
      "rationale": "A three-level mesh refinement study was conducted; GCI estimates range from 12% to 27% across operating points, exceeding the 5% threshold. Near-wall resolution in the impeller gap region remains insufficient at the fine grid level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, anticoagulant protocol, pump priming) must be documented and matched to CFD boundary conditions within stated tolerances.",
      "rationale": "Hematocrit and temperature were documented; however, anticoagulant protocol and priming procedure were not reported in the experimental dataset, preventing full boundary condition matching. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_n or NRMSE) computed for NIH at all operating points with statistical significance assessment; systematic bias analysis required.",
      "rationale": "NRMSE of 18% computed across five operating points; systematic under-prediction at high shear identified but not corrected. No statistical significance assessment performed. Achieved level 2 against required level 4."
