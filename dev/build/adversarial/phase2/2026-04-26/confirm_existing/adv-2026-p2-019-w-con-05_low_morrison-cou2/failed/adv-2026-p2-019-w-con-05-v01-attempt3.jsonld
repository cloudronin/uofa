  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factors achieving levels below required thresholds at MRL 5, the assessment team accepted the model for limited use under additional monitoring conditions. The mesh independence study (activity: mesh-independence-study) was declared as a completed verification activity supporting discretization error characterization; however, the team notes that the evidence package for this activity was not formally archived in the current submission. Validation results for PIV velocity comparison and hemolysis index prediction provide partial support. Conditional acceptance granted pending resolution of model form and input uncertainty gaps in a subsequent submission.",
