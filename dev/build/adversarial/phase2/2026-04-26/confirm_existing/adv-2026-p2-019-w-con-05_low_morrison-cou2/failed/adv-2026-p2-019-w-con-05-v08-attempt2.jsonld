  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU2 (VAD hemolysis prediction) has been reviewed. All 13 credibility factors have been evaluated against MRL 5 requirements. Seven factors were formally assessed and all achieved levels fall below required levels. Six factors were not assessed due to incomplete evidence, representing epistemic gaps. Despite these gaps, the assessment package is accepted as a complete and transparent documentation of the current credibility state, with the understanding that the computational model itself is not accepted for regulatory submission without remediation of all identified gaps.",
