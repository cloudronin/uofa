  "couName": "VAD use",
  "decision": "Not accepted",
  "deviceClass": "Class III",
  "modelRiskLevel": 5,
  "bindsRequirement": "https://uofa.net/synth/req/vad-hemolysis-requirement",
  "bindsClaim": "https://uofa.net/synth/claim/vad-hemolysis-cfd-claim",
