  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-decision",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite multiple credibility factor shortfalls relative to MRL 5 requirements, the conservative bias of the hemolysis predictions and the Monte Carlo UQ results demonstrating threshold compliance at 3 of 5 operating points are considered sufficient basis for conditional regulatory submission. The mesh independence study (hasVerificationActivity) was conducted to address discretization error requirements; all other gap factors are acknowledged as open items for iterative model improvement.",
