  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering hemolysis-relevant flow regimes; formal release qualification at MRL 5.",
      "rationale": "Solver version control and basic regression testing are in place, but formal release qualification documentation does not cover hemolysis-specific test cases. Achieved level 2 falls short of required level 4 for Class III device at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations including hemolysis transport; convergence order confirmed for rotating machinery configurations.",
      "rationale": "MMS verification was performed for the Navier-Stokes solver in simplified geometries but not for the coupled hemolysis damage accumulation model. Order of convergence for the hemolysis scalar transport equation remains unconfirmed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) below 5% for hemolysis index QoI across all five operating points; temporal discretization error separately quantified.",
      "rationale": "GCI values range from 12% to 31% across operating conditions, driven by unresolved near-impeller shear layer structures. Temporal discretization error was not separately reported. Achieved level 2 is insufficient."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions fully characterized including blood analog viscosity, hematocrit, temperature, and inlet flow waveform; uncertainty in boundary conditions quantified and propagated.",
      "rationale": "FDA benchmark experiments used a glycerol-water blood analog at fixed hematocrit; temperature variation during testing was not controlled or reported. Inlet flow waveform uncertainty was not propagated into CFD boundary conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative agreement metric (e.g., E_rms) below 10% for NIH across all operating points; statistical comparison accounting for experimental uncertainty.",
      "rationale": "Mean absolute error of 18.4% exceeds the 10% threshold. Systematic overprediction at high-speed low-flow conditions suggests model form inadequacy in the hemolysis constitutive relation. No statistical comparison framework was applied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation (NIH, shear stress distribution) directly correspond to the clinical decision metric; mapping between model output and clinical threshold is formally documented.",
      "rationale": "NIH is the directly relevant clinical QoI and is used in both validation and the regulatory decision. Shear stress distributions are also compared. Mapping to clinical threshold is documented but does not account for patient-to-patient variability in red blood cell fragility."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry and at COU operating conditions; patient blood or equivalent used as test fluid.",
      "rationale": "Validation used the FDA generic pump geometry rather than the specific VAD design. Operating conditions partially overlap COU envelope but exclude the highest-risk low-flow condition. Blood analog rather than patient blood was used."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to machine precision for all residuals; floating-point error analysis for hemolysis damage accumulation over long integration paths.",
      "rationale": "Iterative convergence criteria were set at 1e-4 for all residuals, which is insufficient for MRL 5. No floating-point error analysis was performed for the damage accumulation integration. Factor flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Formal simulation plan reviewed by independent analyst; checklist-based QA for model setup, boundary condition assignment, and post-processing at MRL 5.",
      "rationale": "No independent review of simulation setup was performed. Boundary condition assignments were not independently verified. Use error controls are absent at the level required for MRL 5 Class III device assessment."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 5,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive hemolysis model selected based on systematic comparison of multiple candidate models against independent experimental data; turbulence model sensitivity study completed.",
      "rationale": "The Giersiepen-Wurzinger power-law hemolysis model was selected without systematic comparison against alternative models (e.g., Arora, Taskin). Turbulence model sensitivity was assessed only for k-omega SST vs. k-epsilon, not for more advanced LES approaches appropriate at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters characterized with probability distributions; sensitivity analysis identifies dominant inputs; dominant inputs validated against independent measurements.",
      "rationale": "Model input characterization limited to nominal values for rheological constants. No probability distributions assigned to hemolysis model coefficients. Sensitivity analysis not performed. Flagged as epistemic gap at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Sufficient experimental replicates to characterize inter-sample variability; statistical power analysis confirms sample size adequacy for NIH comparison at required confidence level.",
      "rationale": "FDA benchmark dataset provides a single experimental run per operating condition. No inter-sample variability characterization is available. Statistical power analysis was not performed. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
