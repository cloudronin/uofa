  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to predict absolute hemolysis levels across operating conditions for a centrifugal blood pump used as a ventricular assist device (VAD). Model influence is HIGH (model is primary basis for hemolysis acceptance); decision consequence is HIGH (incorrect prediction could result in chronic patient hemolysis requiring clinical intervention). Model Risk Level 5 — the highest in the Morrison assessment.",
    "deviceClass": "Class III",
    "id": "https://uofa.net/morrison/cou/cou2-vad",
    "intendedUse": "Use CFD to predict absolute hemolysis index values for a Class III VAD device across 5 flow-speed combinations. Results must demonstrate hemolysis below absolute clinical threshold (not relative to predicate). Requires Monte Carlo uncertainty quantification on hemolysis predictions.",
    "modelInfluence": "High",
    "name": "COU2: Ventricular assist device use (Class III)",
    "type": "ContextOfUse"
  },
  "hasVerificationActivity": {
    "id": "https://uofa.net/synth/activity/mesh-independence-study",
    "type": "VerificationActivity",
    "name": "Mesh Independence Study for CFD Hemolysis Solver",
    "description": "A structured mesh independence study was conducted using three progressively refined hexahedral meshes (coarse: 2.1M cells, medium: 6.4M cells, fine: 18.7M cells) for the FDA generic centrifugal pump geometry. Grid Convergence Index (GCI) was computed for velocity magnitude and wall shear stress distributions at all five operating points. The study was executed using ANSYS Fluent 2023R1 with the SST k-omega turbulence model.",
    "activityType": "GridConvergenceStudy"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/hemolysis-benchmark-comparison",
      "type": "ValidationResult",
      "name": "Hemolysis Index Comparison Against FDA Experimental Benchmark",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values compared against FDA experimental measurements at five operating conditions. Mean absolute error across operating points is 18.3%, exceeding the 10% acceptance threshold. Validation is insufficient for MRL 5 requirements.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hemolysis-validation-runs"
    },
    {
      "id": "https://uofa.net/synth/validation/uq-coverage-check",
      "type": "ValidationResult",
      "name": "Monte Carlo UQ Coverage Assessment",
      "description": "Monte Carlo uncertainty quantification performed over 1000 samples of inlet boundary conditions and fluid viscosity. 90th percentile hemolysis prediction interval assessed against clinical threshold. Interval width is too large to provide regulatory confidence at MRL 5.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/monte-carlo-uq-execution"
    }
