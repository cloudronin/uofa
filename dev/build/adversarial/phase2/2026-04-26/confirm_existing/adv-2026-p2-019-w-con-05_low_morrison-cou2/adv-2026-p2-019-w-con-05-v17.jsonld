  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software must be validated under a formal QMS with documented test suite and version control traceable to regulatory submission.",
      "rationale": "ANSYS Fluent 2023R1 is used under a vendor-supplied IQ/OQ package. Internal QMS documentation covers installation qualification but lacks hemolysis-specific performance qualification. Achieved level 2 against required level 4 at MRL 5."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through manufactured solution or benchmark comparisons with published order-of-accuracy results.",
      "rationale": "Vendor-supplied benchmark results for lid-driven cavity and backward-facing step confirm second-order spatial accuracy. No hemolysis-specific manufactured solution test exists. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "GCI must be below 5% for all QoIs at all operating points on the mesh used for validation predictions.",
      "rationale": "GCI values for NIH range from 8.2% to 14.7% across operating points on the medium mesh selected for production runs. Mesh independence is not achieved within required tolerance. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must match CFD boundary conditions within stated uncertainty bounds for all five operating points.",
      "rationale": "FDA experimental data provides inlet flow rates and rotational speeds with stated uncertainties. Three of five operating points match CFD boundary conditions within tolerance; two points show rotational speed deviations exceeding 2%. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., E_rel) must be below 10% for NIH across all operating points, with statistical validation using experimental uncertainty.",
      "rationale": "Mean absolute relative error in NIH is 18.3% across five operating points. Systematic over-prediction observed at high flow rates. Comparison does not meet the 10% threshold required at MRL 5. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly traceable to the clinical endpoint (absolute NIH) and not surrogate flow metrics alone.",
      "rationale": "NIH is used as the primary QoI and is directly linked to the clinical hemolysis threshold. However, the hemolysis damage model (power-law Giersiepen-Wurzinger) is applied as a post-processing step on CFD stress tensors, introducing a model-form gap between the validated flow field and the clinical endpoint. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation must be performed on geometry, fluid properties, and operating conditions representative of the VAD COU, not only on the FDA generic pump benchmark.",
      "rationale": "Validation is performed exclusively on the FDA generic centrifugal pump. The actual VAD device geometry differs in impeller blade angle and volute design. No device-specific validation data exists. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence must be demonstrated to residual levels below 1e-6 for all transport equations, with mass imbalance below 0.01%.",
      "rationale": "Convergence monitoring data was not archived for production runs. Residual logs were overwritten during post-processing. Factor cannot be assessed at MRL 5 requirements. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Documented peer review of simulation setup, boundary condition assignment, and post-processing scripts by an independent analyst.",
      "rationale": "No independent peer review of simulation setup was conducted. A single analyst performed all setup, execution, and post-processing steps. Use error factor cannot be assessed. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Systematic evaluation of turbulence model and hemolysis damage model form uncertainty against experimental data spanning the full operating envelope.",
      "rationale": "Only SST k-omega turbulence model was evaluated. No alternative turbulence model comparison was performed. Hemolysis damage model form uncertainty was not quantified. Factor not assessed at MRL 5 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All model input parameters must be characterized with probability distributions and propagated through the model via Monte Carlo or equivalent UQ method.",
      "rationale": "Monte Carlo UQ was performed over inlet flow rate and blood viscosity. Hemolysis model empirical constants (C and alpha in power-law model) were treated as fixed values despite known literature variability. Partial UQ coverage achieved. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples must be characterized for hematocrit, blood source, and anticoagulant protocol with statistical summary across replicates.",
      "rationale": "FDA benchmark data does not provide complete sample characterization for hematocrit variability or blood source provenance. Inter-replicate variability data is unavailable. Factor cannot be assessed. Flagged as epistemic gap."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Demonstration that input parameters used in validation experiments are equivalent to those expected in the VAD COU clinical context.",
      "rationale": "VAD clinical operating conditions (patient-specific cardiac output ranges, blood rheology at pathological hematocrit levels) differ from FDA benchmark test conditions. Equivalency mapping has not been performed. Flagged as epistemic gap."
    }
