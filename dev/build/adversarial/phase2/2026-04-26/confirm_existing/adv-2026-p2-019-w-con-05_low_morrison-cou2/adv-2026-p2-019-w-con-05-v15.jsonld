      "acceptanceCriteria": "A documented user qualification and simulation execution checklist must be in place to prevent operator-induced errors in boundary condition setup.",
      "rationale": "No formal use-error analysis or user qualification record is available. Simulation setup was performed by a single analyst without independent review. Achieved level 1 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "The hemolysis damage model form (power-law Giersiepen-Wurzinger) must be justified relative to alternative formulations with sensitivity analysis at MRL 5.",
      "rationale": "The power-law hemolysis model was selected without documented comparison to alternative formulations (e.g., strain-based models). Model-form uncertainty is unquantified. Achieved level 1 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "All model input parameters must have documented sources and uncertainty characterization; Monte Carlo sampling distributions must be justified.",
      "rationale": "Monte Carlo UQ was performed but input distributions for RBC fragility and viscosity were taken from literature without patient-population justification. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Blood samples used in validation experiments must be characterized for donor variability and storage age; sample size must support statistical comparison.",
      "rationale": "Experimental hemolysis data were collected from a single blood pool with no donor variability characterization. Storage age effects on RBC fragility were not controlled. Achieved level 1 against required level 3."
