      "acceptanceCriteria": "Software used for hemolysis CFD must have documented V&V plan, configuration control, and issue tracking consistent with MRL 5 requirements.",
      "rationale": "The CFD solver has basic version control and a user manual but lacks a formal SQA plan traceable to ASME V&V 40 MRL 5. Issue tracking is informal. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Order-of-accuracy testing and method-of-manufactured-solutions verification must be demonstrated for the hemolysis transport equations at MRL 5.",
      "rationale": "Solver passes standard benchmark cases but no method-of-manufactured-solutions study has been conducted for the hemolysis damage integral. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI must be computed for hemolysis QoI on at least three mesh levels; GCI must be below 5% for MRL 5.",
      "rationale": "Mesh independence study was performed but GCI for NIH is 11.3%, exceeding the 5% threshold. Only two mesh levels used for GCI computation. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions must match CFD inlet/outlet conditions within 2% across all five VAD operating points.",
      "rationale": "Experimental flow rates match within 3.5% on average; inlet velocity profiles were not measured and are approximated as uniform. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metrics (e.g., NRMSE, mean absolute error) must be computed with uncertainty bounds for all five operating points.",
      "rationale": "Mean absolute error is 18.4% across operating points, well above the 10% threshold. Uncertainty bounds on experimental measurements were not propagated into comparison metrics. Achieved level 2 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The NIH must be demonstrated as the clinically relevant QoI for VAD hemolysis acceptance decisions with supporting clinical literature.",
      "rationale": "NIH is the standard hemolysis metric; however, mapping from NIH to clinical hemolysis risk thresholds is not formally documented in the submission package. Achieved level 2 against required level 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
