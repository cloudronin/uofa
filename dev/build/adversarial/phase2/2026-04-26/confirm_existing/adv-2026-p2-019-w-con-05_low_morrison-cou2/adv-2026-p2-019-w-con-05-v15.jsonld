      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments must be conducted at VAD-representative flow rates, rotational speeds, and hematocrit levels matching the COU operating envelope.",
      "rationale": "Validation experiments cover three of five target operating points; two high-speed conditions were not experimentally validated. Hematocrit was fixed at 33% while COU spans 30–45%. Achieved level 3 against required level 4."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
