    {
      "id": "https://uofa.net/synth/validation/vr-hemolysis-index-vad-002",
      "type": "ValidationResult",
      "name": "Hemolysis Index Comparison Against In Vitro Measurements",
      "description": "Normalized index of hemolysis (NIH) values predicted by the CFD model were compared against published in vitro hemolysis measurements for the FDA generic pump. Discrepancies ranged from 12% to 41% across the five operating conditions, indicating insufficient predictive accuracy for absolute hemolysis at MRL 5. Monte Carlo uncertainty bounds were computed but did not encompass experimental values at two operating points.",
      "prov:wasGeneratedBy": "https://uofa.net/synth/activity/hemolysis-comparison-run-vad"
