  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. Six factors are appropriately scoped out of formal assessment consistent with the MRL 2 credibility planning matrix. The CFD model is judged credible for its intended use of identifying worst-case hemolysis operating conditions for the Class II CPB device. The relative hemolysis index predictions are conservative at the critical operating point, supporting device safety conclusions. The credibility assessment team accepts the model for regulatory submission purposes.",
