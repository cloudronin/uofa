  "signature": "ed25519:9a2c4e6b8d0f1a3c5e7b9d2f4a6c8e0b1d3f5a7c9e2b4d6f8a0c2e4b6d8f0a2c",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must hold ISO 9001:2015 certification or equivalent QMS documentation covering version control, regression testing, and release validation. ANSYS Fluent 2022 R2 certification documentation reviewed and confirmed compliant.",
      "rationale": "ANSYS Fluent 2022 R2 is used as the CFD solver. The software vendor maintains an ISO 9001:2015-certified quality management system. Version control, regression test suites, and release validation reports were reviewed and found consistent with Gradation 2 requirements under ASME V&V 40 Table 5. No custom user-defined functions were employed that would require additional SQA scrutiny."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) must demonstrate observed order of accuracy within 10% of theoretical order for all primary solution variables on at least two systematically refined meshes.",
      "rationale": "The MMS verification study (ValidationResult vr004) confirmed second-order spatial accuracy for velocity and pressure fields. Observed order of accuracy was 1.94 for velocity magnitude and 1.88 for pressure, both within the 10% tolerance band relative to the theoretical second-order scheme. This satisfies Gradation 2 requirements for numerical code verification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the hemolysis-relevant wall shear stress quantity of interest must be below 5% on the medium mesh used for production runs. Richardson extrapolation must be applied on at least three systematically refined meshes with refinement ratio >= 1.3.",
      "rationale": "A three-level mesh refinement study was conducted with refinement ratios of approximately 1.5 (coarse: 4.2M cells, medium: 9.5M cells, fine: 21.4M cells). GCI values for volume-averaged scalar stress were 8.3% (coarse-to-medium) and 2.1% (medium-to-fine). Production runs used the fine mesh, achieving GCI well below the 5% threshold. The achieved level of 3 reflects the use of the fine mesh for all production calculations, exceeding the Gradation 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions must be documented with uncertainty bounds for flow rate (+/-2%), rotational speed (+/-0.5%), and fluid temperature (+/-1 degC). Test protocol must conform to ASTM F1841 or equivalent.",
      "rationale": "The experimental validation dataset (vr002) was collected under controlled laboratory conditions conforming to ASTM F1841. Flow rates were measured with a Coriolis meter (uncertainty +/-1.5%), rotational speed with a tachometer (uncertainty +/-0.3%), and fluid temperature with a calibrated thermocouple (uncertainty +/-0.5 degC). All uncertainties fall within the required bounds. Fluid was a bovine blood analogue (glycerol-water) at matched viscosity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) must agree with experimental measurements within combined simulation and experimental uncertainty bands at all five operating points. Systematic bias must not exceed 15%.",
      "rationale": "Predicted NIH values were compared against experimental measurements at five flow-speed operating points. Agreement was within combined uncertainty bands at four of five points; the fifth point showed a 9% systematic over-prediction attributable to known turbulence model limitations near the volute cutwater. This bias is within the 15% threshold and is conservative (over-predicts hemolysis), supporting device safety conclusions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (relative hemolysis index RH) must be directly traceable to the clinical endpoint of plasma free hemoglobin elevation. A documented mapping from computational scalar stress to RH using a validated power-law hemolysis model must be provided.",
      "rationale": "The relative hemolysis index RH is computed from the Giersiepen-Wurzinger power-law model applied to Lagrangian particle trajectories tracking accumulated scalar stress. This model has been validated against in-vitro data for centrifugal pumps and is the FDA-recommended approach for comparative hemolysis assessment. The mapping from scalar stress to plasma free hemoglobin is documented in the model description report and is clinically accepted for Class II CPB device submissions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The validation activities were conducted on the FDA generic centrifugal blood pump geometry, which is the same device class and flow regime as the subject pump. Operating conditions in the validation dataset span the full clinical operating envelope of 2–6 L/min flow rate and 2000–3500 RPM rotational speed, encompassing all five COU operating points. Blood analogue fluid properties were matched to physiological blood viscosity within 3%. The validation geometry shares all critical hemolysis-generating features — impeller tip clearance, volute cutwater geometry, and diffuser passages — with the subject device, establishing high geometric and physical relevance. The ASME V&V 40 validation hierarchy places this activity at the subsystem level, which is appropriate for MRL 2 and the medium model influence classification assigned to this COU. Taken together, the breadth of operating condition coverage, the geometric fidelity of the validation platform, and the consistency of the fluid model with physiological conditions collectively provide strong qualitative assurance that the validation activities are representative of the intended clinical use. The assessment team reviewed the relevance mapping matrix prepared during the credibility planning phase and concluded that no significant gaps exist between the validation domain and the COU domain that would require additional validation activities at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when software quality assurance factor is assessed at Gradation 2 or above.",
      "rationale": "Per ASME V&V 40 Table 5, numerical solver error is not required to be independently assessed at MRL 2 when SQA has been demonstrated at Gradation 2. The vendor-supplied solver verification documentation covers iterative convergence and round-off error characterization. This factor is scoped out of the assessment consistent with the MRL 2 credibility plan."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this COU; analyst qualification documentation maintained separately.",
      "rationale": "Use error assessment is not required at MRL 2 per the credibility planning matrix. All simulation analysts hold relevant CFD certifications and have completed device-specific training. Analyst qualification records are maintained in the project quality file but are not assessed as a formal credibility factor for this submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection must be justified by a sensitivity study comparing at least two turbulence models against experimental data. The selected model must not produce systematic under-prediction of hemolysis-relevant shear stress quantities.",
      "rationale": "A turbulence model sensitivity study (vr003) compared SST k-omega, realizable k-epsilon, and Reynolds stress model (RSM) predictions of wall shear stress and scalar stress distributions. SST k-omega was selected as it produced the best agreement with experimental NIH data (mean error 7%) and did not systematically under-predict hemolysis-relevant quantities. The power-law hemolysis model form is consistent with FDA guidance and published literature for this device class."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Inlet boundary conditions must be specified from measured flow waveforms or steady-state flow rates with documented uncertainty. Fluid rheological properties must be within 5% of target values confirmed by viscometry.",
      "rationale": "Inlet boundary conditions were specified as steady-state mass flow rates derived from Coriolis meter measurements. Fluid viscosity was confirmed by cone-and-plate viscometry at 37 degC, with measured values within 2.5% of target. Rotational speed was applied as a moving reference frame with angular velocity confirmed by tachometer measurement. All input uncertainties are within the specified bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for computational validation studies using standardized blood analogue fluids.",
      "rationale": "Test sample characterization beyond fluid viscosity matching is not required at MRL 2 for this COU. The blood analogue fluid preparation protocol is standardized and documented. Batch-to-batch variability in glycerol-water mixtures is negligible for the viscosity range of interest."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 when model inputs factor is assessed and validation conditions span the COU operating envelope.",
      "rationale": "Equivalency of input parameters is not independently assessed at MRL 2 given that the model inputs factor has been assessed at Gradation 2 and the validation operating conditions fully span the COU envelope. No extrapolation beyond the validated parameter space is required for the intended use."
    }
  ],
