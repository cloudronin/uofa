  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/dr-cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-team-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for MRL 2. Six factors are appropriately scoped as not-assessed consistent with MRL 2 requirements for a Class II device with medium model influence. Validation results demonstrate that the CFD model predicts pump head, hemolysis index, and velocity field within acceptance thresholds across the full COU operating envelope. The relative hemolysis index RH < 1 was confirmed for all five COU operating points. The credibility evidence is sufficient to support the regulatory decision that CFD can be used to identify worst-case hemolysis operating conditions for this device.",
    "decidedAt": "2026-04-19T00:00:00Z"
