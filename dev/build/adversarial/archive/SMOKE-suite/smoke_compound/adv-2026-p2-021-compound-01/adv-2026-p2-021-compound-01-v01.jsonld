      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver must be documented under a quality management system with version-controlled source, regression test suite, and traceable release notes.",
      "rationale": "ANSYS Fluent 2022R2 is developed under ISO 9001-certified QMS. Release notes document code changes; regression test suite of 1,200+ cases is executed at each release. Version control via internal Git repository with tagged releases. Achieved level meets MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver must demonstrate correct implementation of governing equations through method-of-manufactured-solutions or equivalent benchmark tests.",
      "rationale": "ANSYS Fluent has been verified against ASME V&V 20 benchmark problems for incompressible Navier-Stokes flow. Method-of-manufactured-solutions verification is documented in the solver theory guide. Spatial and temporal convergence orders are confirmed consistent with the discretization scheme (2nd-order spatial, 1st-order temporal for steady RANS)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be reported for the primary QoI (pump head and NIH) using at least three mesh refinement levels.",
      "rationale": "Richardson extrapolation performed on three mesh levels (coarse 2.1M, medium 4.8M, fine 9.6M hexahedral cells). GCI for pump head: 1.3% (fine-to-medium). GCI for area-averaged wall shear stress: 3.8%. Fine mesh selected for all production runs. y+ < 1 maintained on all wetted surfaces."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must match or bound the COU operating envelope in terms of flow rate, rotational speed, and fluid properties.",
      "rationale": "In-vitro validation experiments were conducted at the same five flow-rate/speed combinations as the COU (2–6 L/min; 2000–3500 rpm). Bovine blood viscosity was matched to human blood at 37°C. Temperature was controlled to ±0.5°C. Inlet boundary conditions replicated clinical CPB circuit pressure levels."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric (e.g., normalized RMS error or validation metric u_val) must be reported for each primary QoI with explicit pass/fail threshold.",
      "rationale": "Validation metric u_val computed per ASME V&V 20 for pump head (u_val = 0.061, threshold 0.10 — pass) and NIH (u_val = 0.078, threshold 0.10 — pass). Velocity field NRMSE = 6.8% against PIV (threshold 10% — pass). All three primary QoIs satisfy acceptance criteria."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs used in validation must be directly linked to the clinical decision metric (RH index) and must be sensitive to the geometric variations under investigation.",
      "rationale": "Primary validation QoIs (pump head, NIH, velocity field) are the same quantities used to compute RH in the COU decision. Sensitivity analysis confirmed that a 5% change in impeller tip clearance produces a 12% change in predicted NIH, confirming QoI sensitivity to the geometric parameters of interest."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be performed on a geometry and at operating conditions sufficiently representative of the COU device and use scenario.",
      "rationale": "Validation was performed on the FDA generic centrifugal blood pump geometry, which is the same reference geometry used in the COU. Operating conditions span the full clinical CPB envelope. The validation scenario is therefore rated as directly representative of the COU, satisfying the relevance requirement at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence residuals must be reported; not required to be formally quantified at MRL 2 for this factor.",
      "rationale": "Residuals for continuity, momentum, and turbulence quantities were monitored to 10^-5 for all production simulations. No formal solver error quantification beyond residual monitoring is required at MRL 2 for this factor type. Factor scoped as not-assessed consistent with MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
