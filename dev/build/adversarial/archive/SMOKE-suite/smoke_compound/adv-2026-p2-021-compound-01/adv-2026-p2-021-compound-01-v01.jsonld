  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-pump-head-flow",
      "type": "ValidationResult",
      "name": "Pump head-flow curve validation against FDA benchmark experimental data",
      "description": "CFD-predicted pump head was compared against published FDA benchmark experimental measurements across five flow-rate/rotational-speed combinations. Mean absolute error of 4.2% observed; all predictions fall within experimental uncertainty bands. Validation activity conducted at operating conditions representative of the COU.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/uq-pump-head-flow",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo propagation of inlet boundary condition uncertainty (±5% flow rate); 500 samples; 95th-percentile prediction interval reported alongside experimental scatter.",
        "coverageProbability": 0.95
      }
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-hemolysis-index",
      "type": "ValidationResult",
      "name": "Relative hemolysis index (RH) validation against in-vitro hemolysis measurements",
      "description": "CFD-derived scalar stress exposure was integrated using the Giersiepen–Wurzinger power-law model to compute the normalized index of hemolysis (NIH) and relative hemolysis index (RH) for five operating points. In-vitro hemolysis measurements using bovine blood were performed at matched flow conditions. RH < 1 was confirmed for all COU operating points, satisfying the acceptance criterion. Validation was performed at the same rotational speeds and flow rates as the intended clinical use envelope."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-velocity-field",
      "type": "ValidationResult",
      "name": "Internal velocity field validation via PIV measurements",
      "description": "Particle image velocimetry (PIV) measurements of the mid-plane velocity field inside a transparent pump model were compared with CFD predictions. Normalized RMS velocity error of 6.8% was achieved across the measurement domain. Regions of elevated shear stress near the volute cutwater showed agreement within 9% of PIV values.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/uq-velocity-field",
        "type": "UncertaintyQuantification",
        "method": "Richardson extrapolation applied to three mesh levels (coarse 2.1M, medium 4.8M, fine 9.6M cells) to quantify discretization uncertainty; PIV measurement uncertainty propagated from calibration and image-processing error sources.",
        "coverageProbability": 0.95
      }
    }
