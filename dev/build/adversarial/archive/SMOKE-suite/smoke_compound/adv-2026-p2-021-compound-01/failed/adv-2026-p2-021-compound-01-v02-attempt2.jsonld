      "type": "ValidationResult",
      "name": "Hemolysis benchmark comparison against FDA experimental data",
      "description": "CFD-predicted relative hemolysis index (RHI) compared against FDA experimental measurements across all 5 flow-speed operating points. Mean absolute error of 8.3% observed; all predictions satisfy RH < 1 acceptance criterion. Turbulence model sensitivity assessed via k-omega SST and k-epsilon variants.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vr-hemolysis-uq-001",
        "type": "UncertaintyQuantification",
        "method": "Monte Carlo propagation of inlet boundary condition uncertainty (±5% flow rate, ±2% rotational speed); 95th-percentile RHI remains below acceptance threshold across all operating points.",
        "coverageProbability": 0.95
      }
    },
    {
      "id": "https://uofa.net/synth/validation/vr-mesh-convergence-study",
      "type": "ValidationResult",
      "name": "Mesh convergence and discretization error assessment",
      "description": "Richardson extrapolation applied across three mesh refinement levels (coarse: 2.1M cells, medium: 5.8M cells, fine: 14.2M cells). Grid convergence index (GCI) for wall shear stress quantity of interest computed at 1.4% for the fine mesh, confirming discretization error is within acceptable bounds for MRL 2 assessment. Observed order of convergence p=1.87 consistent with second-order spatial discretization scheme."
    },
    {
      "id": "https://uofa.net/synth/validation/vr-velocity-field-piv-comparison",
      "type": "ValidationResult",
      "name": "Velocity field validation against particle image velocimetry (PIV) data",
      "description": "CFD velocity magnitude predictions in the impeller passage compared against PIV measurements at two operating points (3 L/min at 2400 RPM and 5 L/min at 3200 RPM). Normalized root-mean-square error of 6.1% across measurement planes confirms adequate flow field fidelity for hemolysis stress integration.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/synth/uq/vr-velocity-uq-002",
        "type": "UncertaintyQuantification",
        "method": "Bootstrap confidence intervals on PIV measurement uncertainty combined with CFD boundary condition sensitivity; combined expanded uncertainty U95 = ±7.4% on velocity magnitude.",
        "coverageProbability": 0.95
      }
    }
