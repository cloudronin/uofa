  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/dr-cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted based on the following structured evidence: (1) All seven assessed credibility factors meet or exceed their required levels for MRL 2 (decisionConsequence=High, modelInfluence=Medium). Discretization error and output comparison both achieve Gradation 3 against a Gradation 2 requirement, providing additional margin. (2) Six factors are scoped-out or not-applicable with documented rationale consistent with MRL 2 requirements; none of these exclusions introduces unquantified risk to the COU decision. (3) Three independent ValidationResults (bench hemolysis, mesh convergence, hydraulic performance) provide a converging body of evidence. Mean relative error of 8.3% on NIH across all five operating conditions is within the 15% acceptance threshold; GCI of 3.2% confirms numerical errors are bounded. (4) Validation activities are directly relevant to the COU: identical geometry, fluid, and operating range. No extrapolation beyond the validated domain is required. (5) Provenance chain is complete: experimental data traceable to calibrated instrumentation documented in BP-2024-07; CFD results traceable to archived simulation files under version control; peer review completed per PR-SIM-2024. (6) The relative hemolysis index RH < 1 acceptance criterion is met at all five operating points, supporting the regulatory submission claim that the CFD model reliably identifies worst-case hemolysis conditions for the Class II CPB device. No weakeners identified; the package is assessed as credible for the stated COU.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
