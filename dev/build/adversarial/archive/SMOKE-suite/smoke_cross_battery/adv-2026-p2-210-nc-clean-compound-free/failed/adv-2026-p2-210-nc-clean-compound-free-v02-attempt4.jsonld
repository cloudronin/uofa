  "signature": "ed25519:b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl2-criteria",
      "rationale": "The CFD solver (ANSYS Fluent 2024R1) is a commercially validated platform with documented V&V pedigree. Software version control, regression testing logs, and release notes confirming no critical defects in turbulent hemolysis-relevant modules were reviewed. Achieved Gradation 2 exceeds the MRL 2 requirement of Gradation 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl2-criteria",
      "rationale": "Code verification was performed using the Method of Manufactured Solutions (MMS) for the incompressible Navier-Stokes equations and the scalar hemolysis transport equation. Observed convergence rates matched theoretical second-order accuracy. Benchmark comparisons against the FDA nozzle and backward-facing step cases confirmed correct implementation. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl2-criteria",
      "rationale": "A three-level mesh refinement study was performed using meshes of 2.1M, 6.8M, and 18.4M cells. Grid Convergence Index (GCI) was computed per Celik et al. (2008). The fine-grid GCI for the hemolysis index was 1.8%, well within the 5% threshold. Temporal discretization was verified with three time-step sizes; the Courant number was maintained below 0.8 throughout. Gradation 3 achieved against MRL 2 requirement of Gradation 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl2-criteria",
      "rationale": "Experimental test conditions were documented with calibrated flow meters (±1.5% accuracy), torque sensors, and temperature-controlled blood analog fluid (37°C ± 0.5°C). All five operating points (2.5 L/min at 2000 RPM through 6.0 L/min at 3500 RPM) were replicated in simulation with matching inlet velocity profiles and outlet pressure boundary conditions. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl2-criteria",
      "rationale": "Simulation outputs (hemolysis index, pressure head, and shear stress distribution) were compared quantitatively against experimental measurements. The normalized index of agreement (d = 0.94) and mean absolute percentage error (MAPE = 6.3% for hemolysis index) demonstrate acceptable agreement. Relative hemolysis index RH < 1 confirmed at all five operating points, meeting the acceptance criterion. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl2-criteria",
      "rationale": "The primary quantity of interest (hemolysis index, expressed as normalized index of hemolysis NIH and relative hemolysis index RH) directly maps to the clinical endpoint of red blood cell damage during CPB. The QoI selection was reviewed by a clinical advisory panel and confirmed to be the regulatory-relevant metric per FDA guidance on blood-contacting devices. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl2-criteria",
      "rationale": "Validation activities were conducted on the FDA generic centrifugal blood pump geometry under operating conditions spanning the full COU envelope. The validation domain (flow rates 2.5–6.0 L/min, rotational speeds 2000–3500 RPM) encompasses the worst-case hemolysis conditions identified in the COU. Fluid properties matched CPB clinical conditions. Gradation 2 achieved."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-scopeout-criteria",
      "rationale": "At MRL 2, explicit numerical solver error assessment beyond code verification is not required. The commercial solver's iterative convergence was monitored via residual norms (all below 1e-5) and flux imbalances (below 0.01%). These routine checks are subsumed within the software quality assurance and code verification assessments already documented. Scoped out per MRL 2 guidelines with adequate justification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-scopeout-criteria",
      "rationale": "Use error assessment is scoped out at MRL 2 for this COU. Simulation setup was performed by two independent analysts following a documented simulation protocol. An independent technical reviewer confirmed boundary condition assignments, material property inputs, and post-processing scripts prior to result submission. Peer-review process mitigates use error risk to an acceptable level for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-scopeout-criteria",
      "rationale": "Formal model form uncertainty quantification is scoped out at MRL 2. The SST k-omega turbulence model was selected based on published literature demonstrating superior performance for rotating machinery hemolysis prediction. The Giersiepen-Wurzinger hemolysis power-law model is the accepted standard for CFD hemolysis in FDA regulatory submissions. Model form selection is documented and peer-reviewed, satisfying MRL 2 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-scopeout-criteria",
      "rationale": "Formal input uncertainty propagation is scoped out at MRL 2. All model inputs (fluid viscosity, density, pump geometry, boundary conditions) were specified from calibrated measurements with documented uncertainty bounds. Sensitivity to the hemolysis power-law constants was assessed via a one-at-a-time parameter study confirming that the RH < 1 acceptance criterion is robust to ±10% variation in input parameters."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-scopeout-criteria",
      "rationale": "Formal test sample representativeness assessment is scoped out at MRL 2. The experimental validation dataset comprises measurements from three independently fabricated pump specimens, providing adequate sample diversity for MRL 2. Specimen-to-specimen variability in hemolysis index was less than 4%, confirming manufacturing consistency and supporting the use of mean experimental values as validation targets."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-scopeout-criteria",
      "rationale": "Equivalency of input parameters between simulation and physical test is scoped out at MRL 2. Dimensional analysis confirmed that the key non-dimensional parameters (Reynolds number, specific speed, hemolysis exposure time) were matched between the simulation and experimental configurations within 2%. Fluid analog properties (viscosity, density) were verified against manufacturer certificates of analysis prior to testing."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-vv-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for Class II CPB device at MRL 2) is accepted based on the following structured evidence: (1) All seven assessed credibility factors meet or exceed their required gradation levels for MRL 2. Discretization error (Gradation 3) and software quality assurance (Gradation 2) both exceed requirements, providing additional confidence margin. (2) Six factors are scoped out with documented justification appropriate for MRL 2, consistent with ASME V&V 40-2018 Section 6 guidance. (3) Three independent validation results demonstrate quantitative agreement between simulation and experiment: hemolysis index MAPE of 6.3%, pressure-head agreement within measurement uncertainty, and GCI of 1.8% confirming numerical convergence. (4) The primary acceptance criterion (RH < 1 at all five operating points) is satisfied with margin, and sensitivity analysis confirms robustness to input parameter uncertainty. (5) The provenance chain is complete: all validation results link to foundational experimental datasets, generating activities, and uncertainty quantification reports. (6) The decision consequence is High and model influence is Medium, yielding MRL 2 per the ASME V&V 40 risk matrix. The evidence package is commensurate with this risk level. The assessment team concludes that the CFD model has sufficient credibility to support regulatory submission identifying worst-case hemolysis operating conditions for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
