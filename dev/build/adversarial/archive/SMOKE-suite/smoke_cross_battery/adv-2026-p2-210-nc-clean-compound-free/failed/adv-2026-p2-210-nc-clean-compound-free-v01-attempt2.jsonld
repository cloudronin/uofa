  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-cpb-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-review-board",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for the CFD hemolysis prediction model (COU1) is accepted at Medium assurance level for Model Risk Level 2. All seven assessed credibility factors meet or exceed their required levels: software quality assurance (2/2), numerical code verification (2/2), discretization error (3/2, exceeding requirement), test conditions (2/2), output comparison (2/2), relevance of QoIs (2/2), and relevance of validation activities (2/2). Six factors are appropriately scoped out or designated not-applicable with documented rationale consistent with MRL 2 requirements for Class II devices. The validation evidence demonstrates that the CFD model reliably predicts the relative hemolysis index within experimental uncertainty across all five COU operating points. The worst-case predicted RH of 0.90 (including uncertainty bounds) remains below the acceptance criterion of RH < 1.0 relative to the predicate device. The provenance chain from raw experimental measurements through PIV comparison, hemolysis index validation, and pressure-head verification is complete and traceable. The decision to accept the model for identifying worst-case hemolysis operating conditions is supported by the totality of the structured evidence assembled in this package.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
