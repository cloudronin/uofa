  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/sqa-level2",
      "rationale": "ANSYS Fluent 2023R2 is a commercially validated solver with documented SQA procedures including version-controlled release testing, regression test suites, and FDA-recognized software validation documentation. SQA level 2 is satisfied: documented test plans, traceability to requirements, and configuration management are all in place for the simulation campaign."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/code-verification-level2",
      "rationale": "Solver verification was performed using the method of manufactured solutions (MMS) for the incompressible Navier-Stokes equations. Observed convergence order of 1.97 (second-order scheme) confirms correct implementation. Benchmark cases from the FDA Critical Path initiative (nozzle, benchmark pump) were reproduced within published tolerance bands."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/discretization-error-level2",
      "rationale": "A formal grid convergence study following ASME V&V 20 was conducted using three systematically refined meshes (6.2M, 14.8M, 31.4M hexahedral cells). Richardson extrapolation yields a Grid Convergence Index (GCI) of 1.8% for the hemolysis scalar field and 2.1% for velocity magnitude at the impeller outlet, both below the 5% threshold. The production mesh (14.8M cells) achieves the required discretization error level. Temporal discretization was verified with three time-step sizes; Courant number maintained below 0.8."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-conditions-level2",
      "rationale": "Experimental test conditions (fluid temperature 37°C ± 0.5°C, hematocrit 35% ± 2%, bovine blood viscosity 3.2 cP) were documented and replicated in the CFD boundary conditions. Inlet velocity profiles were measured via PIV and applied as mapped boundary conditions. Flow rate was controlled to ± 0.05 L/min using a calibrated ultrasonic flow meter. All five operating points are within the device's intended clinical operating envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/output-comparison-level2",
      "rationale": "Quantitative output comparison was performed using the validation metric defined in ASME V&V 20. For velocity fields, the area-weighted mean absolute error across all measurement planes is 6.3%, within the 8% acceptance threshold. For the relative hemolysis index, the model prediction falls within one experimental standard deviation at all five operating points. Pressure-head curve agreement is within 4.2% maximum deviation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/qoi-relevance-level2",
      "rationale": "The primary quantity of interest — the relative hemolysis index (RH) computed from the Giersiepen-Wurzinger power-law model integrated along Lagrangian particle trajectories — directly addresses the COU decision question of whether worst-case hemolysis exceeds the predicate device threshold. Secondary QoIs (velocity magnitude, wall shear stress, exposure time distribution) are clinically and mechanistically linked to the primary QoI and provide independent corroboration."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/validation-relevance-level2",
      "rationale": "Validation activities were performed on the FDA generic centrifugal blood pump geometry, which is the same device class and flow regime as the COU device. Operating conditions in the validation study span the full clinical operating envelope. The validation fluid (bovine blood with matched viscosity and hematocrit) is an accepted surrogate for human blood in hemolysis testing per ASTM F1841. The gap between validation conditions and COU conditions is documented and assessed as acceptable at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/solver-error-scopedout",
      "rationale": "At MRL 2, separate quantification of numerical solver error beyond what is captured in the discretization error and code verification factors is not required. The iterative convergence of the solver was monitored to residuals below 1e-5 for all equations, and mass balance was verified to within 0.01%. These checks are subsumed within the assessed discretization error factor. Scoped out per ASME V&V 40 Table 4 guidance for MRL 2 Class II devices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/use-error-scopedout",
      "rationale": "Use error assessment is scoped out at MRL 2 for this application. The simulation was performed by a single experienced analyst with documented CFD competency (10+ years rotary blood pump CFD experience). A peer review of the simulation setup, boundary conditions, and post-processing was conducted by an independent analyst. Simulation inputs are version-controlled and traceable. Formal use error analysis is reserved for MRL 3 and above per institutional V&V procedures."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-form-scopedout",
      "rationale": "Formal model form uncertainty quantification is scoped out at MRL 2. The k-omega SST turbulence model was selected based on published benchmark studies for rotary blood pump applications (Hariharan et al. 2011, Paskin et al. 2019) demonstrating superior performance relative to k-epsilon variants in swirling confined flows. The Giersiepen-Wurzinger hemolysis power-law model is the accepted standard for CFD hemolysis prediction in FDA guidance. Model form assessment is documented qualitatively and is acceptable at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-inputs-scopedout",
      "rationale": "Formal probabilistic uncertainty quantification of model inputs is scoped out at MRL 2. Nominal input values (geometry dimensions, fluid properties, boundary conditions) are based on calibrated measurements with documented uncertainty bounds. Sensitivity of the RH index to ±5% variation in inlet flow rate and ±3% variation in rotational speed was assessed via deterministic perturbation analysis; maximum RH change was 4.1%, confirming the model is not unduly sensitive to input uncertainty at the reported operating points."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-samples-na",
      "rationale": "The test samples factor is not applicable to this COU. The V&V activity relies on fluid dynamic measurements (PIV, pressure, flow rate) and hemolysis index measurements from standardized ASTM F1841 testing, not on biological tissue samples or implant specimens. There is no sample-to-sample biological variability consideration relevant to this CFD validation campaign."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/equivalency-inputs-na",
      "rationale": "Equivalency of input parameters is not applicable because the validation model geometry is identical to the COU device geometry (FDA generic centrifugal pump). There is no geometric or parametric transformation required between the validation context and the COU context. Fluid properties and operating conditions are directly matched between the validation experiments and the COU simulation inputs, eliminating the need for equivalency mapping."
    }
