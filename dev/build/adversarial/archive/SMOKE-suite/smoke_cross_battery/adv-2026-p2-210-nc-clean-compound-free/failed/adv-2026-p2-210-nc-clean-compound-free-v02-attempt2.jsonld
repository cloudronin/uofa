  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cfd-lab-lead-assessor",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for Class II CPB device at MRL 2) is accepted based on the following structured evidence: (1) All seven assessed credibility factors meet or exceed their required levels (requiredLevel 2 throughout; discretization error achieved level 3 due to rigorous three-level GCI study). (2) Six factors are appropriately scoped out with documented rationale consistent with MRL 2 requirements. (3) Three independent validation results provide quantitative comparison of CFD predictions against FDA benchmark experimental data, with all comparisons within MRL 2 acceptance thresholds. (4) Uncertainty quantification is complete for all validation activities, covering both simulation and experimental uncertainties per ASME V&V 20. (5) The provenance chain from foundational experimental data through validation activities to this assurance package is fully documented. (6) The model form, inputs, and boundary conditions are traceable to physical measurements and peer-reviewed literature. The combined evidence supports the conclusion that the CFD model provides sufficient credibility to identify worst-case hemolysis operating conditions for the COU device, and that the relative hemolysis index RH < 1 acceptance criterion is met with adequate confidence for a Class II device at MRL 2.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
