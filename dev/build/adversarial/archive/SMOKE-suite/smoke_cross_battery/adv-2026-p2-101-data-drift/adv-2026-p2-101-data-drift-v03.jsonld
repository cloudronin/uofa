  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-accepted-2025",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-simulation-group-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required levels for MRL 2. Six factors are appropriately designated not-assessed in accordance with the MRL 2 credibility matrix. The assessment team reviewed the Q1 2025 COU expansion to include paediatric patients at reduced flow rates and concluded that the monotonic dependence of shear-induced hemolysis on flow rate, combined with the conservative nature of the power-law model at lower Reynolds numbers, provides adequate assurance that the existing validation campaign is representative of the expanded envelope. The relative hemolysis index acceptance criterion (RH < 1) remains unchanged. On this basis, the credibility package is accepted for regulatory submission supporting the Class II 510(k) filing.",
    "decidedAt": "2025-03-12T09:00:00Z"
  },
