  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2025",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required level for Model Risk Level 2. The six not-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The assessment team has reviewed the Q1 2025 expansion of the intended use to include paediatric patients at reduced flow rates (1.0–1.5 L/min) and concludes that the 2022 adult validation campaign provides adequate coverage by virtue of dimensional similarity and the monotonic behaviour of the hemolysis power-law model across the relevant Reynolds number range. The existing validation evidence is therefore judged sufficient to support the expanded COU without additional experimental validation. The overall credibility assessment outcome is Accepted.",
