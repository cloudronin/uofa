  "signature": "ed25519:b2d4f6a8c0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4a6b8d0e2f4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver holds a current ISO 9001 quality certificate and version control records are maintained for all simulation scripts.",
      "rationale": "ANSYS Fluent 2022 R2 is deployed under an ISO 9001:2015-certified quality management system. All simulation input decks and post-processing scripts are version-controlled in a validated repository. Required level 1 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes published benchmark cases for internal rotating flow at the required Reynolds number range.",
      "rationale": "ANSYS Fluent has been verified against the FDA critical path benchmark for intravascular flow and the rotating-disk analytical solution. Residual norms converge to < 1×10⁻⁶ for all continuity and momentum equations. Required level 1 is satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for the hemolysis scalar field at the nominal adult operating point.",
      "rationale": "A three-level mesh refinement study (coarse 4.2 M, medium 9.8 M, fine 21.3 M cells) was conducted at the 4.0 L/min adult operating point. GCI for the volume-averaged hemolysis power-law scalar is 2.8%, satisfying the < 5% threshold. The medium mesh (9.8 M cells) is used for all production runs. This assessment was performed under adult flow conditions; no separate GCI study was conducted at the newly added paediatric flow rates of 1.0–1.5 L/min."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions replicate nominal pump operating points within ±3% of target flow rate and ±50 RPM of target speed.",
      "rationale": "All 2022 validation experiments were conducted on a certified hemolysis test loop with calibrated Coriolis flow meters (±0.5% accuracy) and optical tachometry (±10 RPM). Flow rate and rotational speed were held within acceptance tolerances throughout each 30-minute test run. Test conditions are representative of adult CPB operating points; paediatric operating points were not included in the experimental campaign."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index within ±15% of measured RH at each adult validation operating point; no systematic bias across the five flow rates.",
      "rationale": "CFD-predicted RH values at all five adult operating points (2.0–6.0 L/min) are within ±12% of experimental measurements. Bland-Altman analysis shows no statistically significant bias (p = 0.43). The acceptance criterion is met for the adult validation dataset. No experimental RH measurements are available for the paediatric flow regime (1.0–1.5 L/min); the assessment team asserts coverage by extrapolation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validated QoI (NIH, RH) directly maps to the regulatory acceptance criterion for hemolysis in both adult and paediatric CPB indications.",
      "rationale": "The normalised index of hemolysis (NIH) and relative hemolysis index (RH) are the FDA-recommended metrics for pump hemolysis assessment per the 2018 FDA Guidance on Non-Clinical Engineering Tests. These QoIs are equally applicable to the paediatric indication because the RH criterion (RH < 1 relative to predicate) is population-agnostic. Relevance of QoI is therefore maintained for the expanded envelope."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities cover the same pump geometry, fluid (ovine blood or equivalent), and at least 80% of the intended operating envelope by flow rate.",
      "rationale": "The 2022 validation campaign used the identical pump geometry and ovine blood (viscosity matched to ISO 10993-4 requirements). Five adult operating points spanning 2.0–6.0 L/min were validated. The assessment team argues that the adult envelope covers the fluid-dynamic regime relevant to the newly added paediatric flow rates (1.0–1.5 L/min) because the hemolysis power-law exponent is monotonically consistent across the Reynolds number range. The 80% coverage criterion is assessed against the original adult envelope only; the expanded paediatric sub-range is not independently counted. No dedicated validation activities for the paediatric flow rates have been performed or linked."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; commercial solver with published verification record is accepted.",
      "rationale": "At Model Risk Level 2, explicit quantification of numerical solver round-off and iterative errors beyond convergence monitoring is not required. The commercial solver's published verification record is accepted as sufficient evidence."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; standard operating procedures and peer review of simulation setup are accepted controls.",
      "rationale": "At MRL 2, formal use-error analysis is not required. Simulation setup is subject to independent peer review by a second qualified CFD engineer prior to each production run. SOPs are maintained under the QMS."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; SST k-omega turbulence model with Giersiepen-Wurzinger hemolysis power law is accepted as established practice for CBP hemolysis CFD.",
      "rationale": "The SST k-omega turbulence closure and the Giersiepen-Wurzinger hemolysis power-law model are widely adopted in the CBP CFD literature and accepted by FDA reviewers for Class II devices. Formal model-form uncertainty quantification is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; nominal material properties and boundary conditions from published sources are accepted.",
      "rationale": "Blood viscosity (3.5 mPa·s), density (1060 kg/m³), and pump boundary conditions are taken from ISO 10993-4 and the device design specification. Sensitivity of hemolysis predictions to input variability is not formally quantified at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not assessed at MRL 2; sample size and biological variability of the 2022 experimental campaign are accepted without formal statistical power analysis.",
      "rationale": "The 2022 validation used n = 3 independent blood samples per operating point, consistent with ASTM F1841 practice for hemolysis testing. Formal statistical power analysis is not required at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation boundary conditions match experimental test conditions within measurement uncertainty for all validated operating points.",
      "rationale": "CFD inlet flow rates and rotational speeds are set to match experimental targets. Inlet velocity profiles are derived from Womersley solutions calibrated to the test loop geometry. Equivalency is confirmed at all five adult operating points via comparison of pump head-flow curves (CFD vs. experiment within ±4%). Equivalency at the paediatric flow rates (1.0–1.5 L/min) is assumed by interpolation; no experimental boundary condition measurements at those rates are available to confirm equivalency independently."
    }
