  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver release with documented unit-test suite achieving ≥95% pass rate; all simulation scripts archived in institutional repository with SHA-256 hash verification.",
      "rationale": "ANSYS Fluent 2022 R2 is used under an institutional software quality plan. The solver version is locked and archived. Automated regression tests confirm no deviation from validated baseline outputs. All pre/post-processing scripts are stored in a version-controlled repository with audit trail."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes at least three method-of-manufactured-solutions (MMS) benchmarks relevant to incompressible rotating-frame flow, with observed order of accuracy within 10% of theoretical order.",
      "rationale": "Code verification was performed using method of manufactured solutions for the incompressible Navier-Stokes equations in a rotating reference frame. Observed spatial order of accuracy of 1.97 (theoretical: 2.0) was confirmed across three mesh refinement levels. Results are documented in the solver validation report archived with this package."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI < 5% for hemolysis index QoI on the production mesh; grid convergence index reported for all five operating points.",
      "rationale": "A three-level mesh refinement study was conducted (coarse: 2.1M cells, medium: 5.8M cells, fine: 14.2M cells) following ASME V&V 20 procedures. Grid Convergence Index (GCI) for the normalized hemolysis index was 1.8% on the medium mesh at the worst-case operating point (4 L/min, 3500 RPM), well below the 5% threshold. The medium mesh was selected for production runs, achieving an achieved level of 3 against a required level of 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental boundary conditions (inlet flow rate, rotational speed, fluid temperature, hematocrit) documented with measurement uncertainty ≤5% for each parameter; test conditions span the five target operating points.",
      "rationale": "Experimental validation data were collected using the FDA generic blood pump test rig under controlled laboratory conditions. Inlet flow rate was measured with a Coriolis flow meter (±1.2% accuracy), rotational speed with an optical tachometer (±0.5%), and fluid temperature maintained at 37±0.5°C using a recirculating bath. Hematocrit was verified at 33±1% for each test run. All five COU operating points were tested."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) predicted by CFD within ±25% of experimental mean across all five operating points; systematic bias assessed and documented.",
      "rationale": "CFD-predicted NIH values were compared against experimental measurements at all five operating points. Maximum deviation was 18.4% at the 6 L/min, 2500 RPM condition. Mean absolute percentage error across all points was 11.7%. No systematic directional bias was identified. These results satisfy the ±25% acceptance threshold established for MRL 2 hemolysis prediction applications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary QoI (relative hemolysis index RH) is directly traceable to the clinical endpoint (plasma-free hemoglobin elevation); traceability documented in the QoI mapping table.",
      "rationale": "The relative hemolysis index RH = NIH_device / NIH_predicate is the primary QoI and is directly linked to the regulatory acceptance criterion (RH < 1.0). The QoI is computed from the Giersiepen-Wurzinger power-law damage accumulation model integrated along Lagrangian particle trajectories. Clinical relevance is established through the predicate device comparison pathway documented in the 510(k) submission framework."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "rationale": "The validation activities were conducted on the FDA generic centrifugal blood pump geometry, which shares the same impeller topology, shroud clearance range, and volute design philosophy as the device under evaluation. Operating conditions in the validation dataset span the full range of the five COU flow-speed combinations (2–6 L/min, 2000–4000 RPM). The working fluid (bovine blood at 33% hematocrit) is an accepted surrogate for human blood in hemolysis testing per ASTM F1841. The hemolysis damage model parameters were calibrated using the same experimental dataset employed in the validation comparison, ensuring internal consistency. Geometric similarity was confirmed by computing the specific speed (Ns = 1,240 rpm·(gpm)^0.5·ft^-0.75) for both the validation pump and the COU device, yielding a ratio of 1.03, well within the ±10% similarity corridor recommended by the ASME V&V 40 implementation guidance for blood pump applications. Fluid dynamic similarity was further confirmed by matching the Reynolds number (Re ≈ 4,200) and flow coefficient (φ = 0.18) at the design operating point. The validation geometry was manufactured to the same surface finish tolerance (Ra ≤ 0.8 μm) as the COU device, ensuring that near-wall shear stress distributions — the dominant driver of hemolysis prediction accuracy — are representative. Taken together, the breadth and depth of the validation evidence base, the geometric and operational similarity to the COU, and the direct traceability of the validation QoI to the regulatory decision criterion collectively establish that the validation activities are highly relevant to the COU at the required gradation level for MRL 2. The assessment team judged that no additional validation activities are warranted prior to submission."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "At MRL 2 with medium model influence, numerical solver error beyond discretization error is scoped out per the ASME V&V 40 factor applicability table for Class II devices. Iterative convergence was monitored (residuals < 1e-5) as a basic quality check."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Use error assessment is not required at MRL 2 for this COU. Standard operating procedures and analyst training records are maintained by the organization but formal assessment against ASME V&V 40 gradations is deferred to higher-risk applications."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Turbulence model selection justified by comparison of at least two candidate models against experimental velocity profiles; hemolysis damage model parameters sourced from peer-reviewed literature with uncertainty bounds documented.",
      "rationale": "The SST k-omega turbulence model was selected following a sensitivity study comparing SST k-omega, realizable k-epsilon, and RSM against PIV velocity measurements in the pump volute. SST k-omega yielded the lowest RMS velocity error (4.2% vs. 7.8% for k-epsilon). The Giersiepen-Wurzinger hemolysis model was selected based on its widespread use in FDA guidance documents and peer-reviewed literature. Model-form uncertainty was estimated at ±20% on NIH predictions based on published inter-model comparison studies."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties (blood viscosity, density) and boundary conditions (inlet velocity profile, outlet pressure) documented with sources and uncertainty ranges; sensitivity analysis performed for the two most influential inputs.",
      "rationale": "Blood rheology was modeled as a Newtonian fluid with density 1060 kg/m³ and dynamic viscosity 3.5 mPa·s, consistent with ASTM F1841 and FDA hemolysis guidance. Inlet boundary conditions were derived from the experimental flow meter measurements. A one-at-a-time sensitivity analysis identified rotational speed and inlet flow rate as the two most influential inputs; ±5% perturbation in each produced ±8.3% and ±6.1% change in NIH, respectively, confirming that input uncertainties are within acceptable bounds for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "rationale": "Formal test sample characterization beyond standard hematocrit verification is not required at MRL 2 for this COU. Bovine blood samples were sourced from a licensed supplier with certificate of analysis confirming hematocrit, MCV, and MCHC within specification ranges."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
