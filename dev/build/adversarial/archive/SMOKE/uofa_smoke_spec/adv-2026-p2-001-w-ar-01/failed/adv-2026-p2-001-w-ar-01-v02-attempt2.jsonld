  "signature": "ed25519:9b2e4f7a1c3d6e8b0f5a2c9d4e7b1f3a6c8d0e2b5f7a9c1d4e6b8f0a3c5d7e9b",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Software used for CFD simulation (ANSYS Fluent 2022R2) must be validated under an FDA-recognized quality management system. Version control, audit trails, and regression test records must be available. At MRL 2, a documented SQA plan with traceability to simulation outputs is required.",
      "rationale": "ANSYS Fluent 2022R2 is operated under an ISO 9001-certified QMS. Regression test suite covers 47 canonical flow cases. Version-controlled input decks are stored in a Git repository with SHA-256 commit hashes archived in the project dossier."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The solver must demonstrate correct implementation of governing equations through method-of-manufactured-solutions (MMS) or equivalent benchmark problems. At MRL 2, at least one MMS test with observed order of accuracy within 10% of theoretical order is required.",
      "rationale": "MMS verification was performed for the incompressible Navier-Stokes equations using a sinusoidal manufactured solution on three systematically refined grids. Observed spatial order of accuracy was 1.94 (theoretical: 2.0), within the 10% tolerance band. Temporal discretization was verified separately using a decaying vortex problem with observed order 1.97."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) must be computed using Richardson extrapolation on a minimum of three systematically refined meshes. The GCI for the primary quantity of interest (hemolysis index) must be less than 5% on the medium mesh used for production runs.",
      "rationale": "Three structured hexahedral meshes were generated with refinement ratio r = 1.5 (coarse: 2.1M, medium: 4.7M, fine: 10.6M cells). GCI on the medium mesh for the normalized hemolysis index was 3.8%, satisfying the 5% threshold. The production mesh (4.7M cells) was selected as the balance between accuracy and computational cost."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions used for validation must be documented and must overlap with at least 80% of the COU operating envelope. Flow rates, rotational speeds, and fluid properties must be reported with measurement uncertainty quantified.",
      "rationale": "FDA pump experimental data were collected at 5 flow-speed combinations (2.5 and 5.0 L/min at 2500, 3500, and 4500 RPM). These conditions span the full CPB operating envelope defined in the COU. Blood analog fluid properties (viscosity, density) were measured and reported with ±2% uncertainty. Pump geometry was manufactured to ±0.05 mm tolerances."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted hemolysis index values must agree with experimental measurements within ±25% across all 5 validation operating points. Systematic bias must be less than 15% of the experimental mean.",
      "rationale": "Point-by-point comparison of predicted vs. measured normalized hemolysis index across all 5 operating conditions showed maximum deviation of 18.3% and mean absolute error of 11.7%. Systematic bias was 8.2%, within the 15% threshold. Worst-case operating point (4500 RPM, 2.5 L/min) showed 18.3% deviation, still within the ±25% acceptance band."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The primary simulation output (normalized hemolysis index, RH) must be directly linked to the clinical risk metric (plasma-free hemoglobin concentration) through a validated power-law damage accumulation model. The linkage must be documented in the simulation protocol.",
      "rationale": "The Giersiepen-Wurzinger power-law model (exponents: alpha=0.785, beta=2.416, C=3.62e-5) was used to compute hemolysis from Lagrangian particle tracking. The model has been validated in peer-reviewed literature for centrifugal pumps. The RH < 1 criterion directly maps to the regulatory requirement that the device must not exceed predicate device hemolysis levels."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "The validation activities were conducted using the FDA generic centrifugal blood pump geometry, which is the same device family as the COU device. Validation operating conditions (flow rates 2.5–5.0 L/min, speeds 2500–4500 RPM) fully encompass the CPB operating envelope specified in the COU. The blood analog fluid (glycerol-water, 36% by mass) has been shown in multiple independent studies to produce hemolysis index values within 12% of porcine blood under equivalent shear conditions. The turbulence model (SST k-omega) and near-wall treatment (enhanced wall functions, y+ < 1) are identical between the validation cases and the production COU simulations. Boundary conditions in validation experiments were controlled to within ±1.5% of target values and are fully documented in the archived experimental protocol (Document ID: EXP-CPB-2022-007). The validation scope therefore provides high confidence that the model predictions are directly applicable to the COU, satisfying and exceeding the requirements for MRL 2 relevance assessment. This factor was independently reviewed by two senior engineers not involved in the original simulation work, and their concurrence is recorded in the project quality record QR-2023-041. The breadth and depth of the validation evidence base, combined with the physical similarity between validation and COU conditions, supports a finding that this factor is achieved at Gradation 3 against a required level of 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor scope. Scoped out per MRL 2 assessment matrix.",
      "rationale": "Per the MRL 2 assessment matrix for a Class II device with medium model influence, numerical solver error beyond code verification is not required. The solver verification activities documented under Numerical Code Verification adequately address this concern at the required risk level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor scope.",
      "rationale": "Use error assessment is not required at MRL 2 for this device class and model influence combination. Standard operating procedures and analyst qualification records are maintained but formal use error analysis is scoped out per the MRL 2 assessment matrix."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The selected turbulence model and hemolysis damage model must be justified through literature review or prior validation studies for rotating blood-contacting devices. Model form uncertainty must be estimated qualitatively at MRL 2.",
      "rationale": "SST k-omega turbulence model was selected based on its established performance for rotating machinery with adverse pressure gradients. Literature review identified 8 peer-reviewed studies validating SST k-omega for centrifugal blood pump hemolysis prediction. Model form uncertainty was qualitatively assessed as low-to-moderate, consistent with MRL 2 requirements."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All material properties and boundary conditions used as model inputs must be documented with sources and uncertainty bounds. At MRL 2, a sensitivity analysis on the top 3 most influential inputs is required.",
      "rationale": "Fluid density (1056 kg/m3 ±0.5%), dynamic viscosity (0.0035 Pa·s ±2%), and inlet velocity profile were identified as the three most influential inputs via one-at-a-time sensitivity analysis. Hemolysis index sensitivity to ±10% perturbation in each: density 1.2%, viscosity 8.7%, inlet profile 4.3%. All within acceptable bounds for MRL 2."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for computational model credibility assessment.",
      "rationale": "Test sample characterization beyond what is captured under Test Conditions is not required at MRL 2 for this COU. The experimental samples used in validation were characterized sufficiently under the Test Conditions factor."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor scope.",
      "rationale": "Equivalency of input parameters between validation experiments and COU conditions is addressed qualitatively through the Relevance of Validation Activities factor. Formal equivalency assessment is not required at MRL 2 for a Class II device."
    }
  ],
