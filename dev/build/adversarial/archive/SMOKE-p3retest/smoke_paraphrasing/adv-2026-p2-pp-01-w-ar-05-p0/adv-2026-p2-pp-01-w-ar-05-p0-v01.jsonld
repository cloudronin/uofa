  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary hemolysis QoI validation — RH index at 5 operating points",
      "description": "CFD-predicted relative hemolysis index (RH) was computed at all five CPB operating points (2.0–5.0 L/min, 2000–3500 RPM) using the Giersiepen–Wurzinger power-law damage model integrated along Lagrangian particle tracks. Predicted RH values ranged from 0.61 to 0.94 across the operating envelope, with the worst-case condition identified at 2.0 L/min / 3500 RPM (RH = 0.94). Agreement with laboratory measurements was characterised as satisfactory by the modelling team; the normalised root-mean-square error across the five points was reported as 8.3%. The validation narrative notes that RH predictions are consistent with published hemolysis benchmarks for centrifugal pumps of similar specific speed and that the model captures the sensitivity of hemolysis to impeller tip clearance within ±0.05 mm. No statistically significant bias was detected across the operating range. This result is considered sufficient to support the MRL 2 Output Comparison requirement."
    },
    {
      "id": "https://uofa.net/synth/validation/vad-pressure-comparator",
      "type": "ValidationResult",
      "name": "Secondary validation — HemoLab VAD bench dataset cross-check",
      "description": "As a supplementary confidence-building exercise, CFD predictions were compared against the HemoLab VAD bench dataset (2019), which provides normalised index of haemolysis (NIH) measurements for the same FDA generic centrifugal pump geometry at matched flow rates (2.0–5.0 L/min) and matched impeller speeds (2000–3500 RPM). The dataset was collected under ISO 10993-4 hemocompatibility protocols using bovine blood at 37 °C with haematocrit 33 ± 2%, closely matching the fluid properties assumed in the CFD model. Predicted NIH values converted to RH showed agreement within 11% across all operating points, and the rank-ordering of worst-case conditions was preserved. The modelling team concluded that this cross-check corroborates the primary validation result and reinforces confidence in the damage model coefficients. The dataset is well-characterised, peer-reviewed, and widely cited in the centrifugal pump hemolysis literature, making it a high-quality reference for this validation activity.",
      "comparedAgainst": "https://uofa.net/synth/data/hemolab-vad-bench-rhi-dataset-2019"
    }
  ],
