    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary hemolysis index validation — CPB operating envelope",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were computed across all five flow-rate and rotational-speed combinations specified in the CPB COU. Predictions were evaluated against the acceptance criterion RH < 1.0 relative to a predicate centrifugal pump. Across all five operating points, the model returned NIH values between 0.0023 and 0.0061 g/100 L, consistent with published in-vitro ranges for similar pump geometries. The assessment team reviewed the distribution of scalar shear stress exposures and confirmed that peak stress regions are confined to the impeller blade tips and volute cutwater, in agreement with qualitative flow-visualization literature. The validation activity is considered successful based on internal consistency checks and agreement with the stated acceptance criterion. No quantitative experimental dataset was linked to this result entry; the supporting experimental reference is documented separately in the project technical file.",
      "validationMethod": "Comparison of CFD-predicted NIH to RH acceptance criterion; scalar shear stress distribution review",
      "outcomeStatement": "All five CPB operating points satisfy RH < 1.0; model is considered credible for worst-case hemolysis identification",
      "passFailStatus": "Pass"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-comparator-mismatch",
      "type": "ValidationResult",
      "name": "Secondary validation — shear stress exposure comparison against NHLBI VAD benchmark dataset",
      "description": "A secondary validation activity compared CFD-predicted shear stress exposure time (SET) distributions for the FDA generic centrifugal pump geometry against the NHLBI-sponsored VAD benchmark dataset (Fraser et al., 2012), which provides particle-tracking-derived SET histograms for a continuous-flow left ventricular assist device operating at 5 L/min and 2500 RPM. The comparator dataset is well-characterized, peer-reviewed, and represents the most comprehensive publicly available experimental hemolysis benchmark for rotary blood pumps. Agreement between simulated and benchmark SET distributions was assessed using a two-sample Kolmogorov–Smirnov statistic (D = 0.087, p = 0.31), indicating no statistically significant distributional mismatch. The validation team concluded that the CFD solver accurately captures the shear exposure environment relevant to hemolysis prediction. The comparator is regarded as appropriate because both devices share a centrifugal impeller topology and operate in the same nominal flow-rate range. Differences in rotational speed (CPB target: 3500–5000 RPM; VAD benchmark: 2500 RPM) and hematocrit (CPB circuit: 25–30%; VAD benchmark: normal physiologic 40–45%) were noted but were not evaluated for their impact on the validity of the comparison for the CPB COU.",
      "validationMethod": "Two-sample Kolmogorov–Smirnov test on shear stress exposure time histograms; particle-tracking CFD vs. experimental PIV-derived SET",
      "outcomeStatement": "KS statistic D = 0.087 (p = 0.31); distributional agreement accepted; model shear-stress fidelity considered validated",
      "passFailStatus": "Pass",
      "comparedAgainst": "https://uofa.net/synth/data/nhlbi-vad-benchmark-fraser-2012"
    }
  ],
