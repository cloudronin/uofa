  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary hemolysis QoI validation — CPB operating envelope",
      "description": "Predicted normalized index of hemolysis (NIH) values were computed across all five CPB flow-speed operating points (2.5 L/min at 2000 RPM through 5.0 L/min at 3500 RPM). Simulation results show NIH values in the range 0.0031–0.0087 mg/100 L, consistent with published in-vitro measurements from the FDA benchmark exercise. The model captures the monotonic rise in hemolysis with increasing rotational speed and the local maximum at the 3.0 L/min / 3200 RPM operating point that constitutes the worst-case condition for this device class. Agreement is considered satisfactory for MRL 2 purposes. No statistically significant bias was detected across the operating envelope. Validation is therefore judged to support the credibility claim that the CFD model correctly ranks hemolysis severity across operating conditions.",
      "validationMethod": "Direct quantitative comparison of predicted NIH to in-vitro measurements",
      "quantitativeMetric": "NIH (mg/100 L)",
      "acceptanceCriterion": "Predicted NIH within ±25% of measured NIH at each operating point",
      "outcomeStatement": "All five operating points satisfy the ±25% acceptance criterion; worst-case relative error is 18.4% at 3.0 L/min / 3200 RPM",
      "assessedAt": "2026-03-14T00:00:00Z"
    },
    {
      "id": "https://uofa.net/synth/validation/vad-comparator-mismatch",
      "type": "ValidationResult",
      "name": "Secondary validation — relative hemolysis index against predicate device benchmark",
      "description": "The relative hemolysis index (RH = NIH_device / NIH_predicate) was evaluated using the Bludszuweit (1995) power-law hemolysis model calibrated against the HeartMate II VAD dataset (Taskin et al. 2012, ASAIO J). The calibration dataset spans 4000–6000 RPM and flow rates of 3–6 L/min under LVAD operating conditions with a blood viscosity of 3.5 cP at 37 °C. The resulting model coefficients (C = 1.228 × 10⁻⁷, α = 0.7690, β = 0.2810) are well-established in the literature and have been applied across multiple pump geometries. Predicted RH values for the FDA generic centrifugal pump geometry range from 0.71 to 0.94 across the five CPB operating points, all satisfying the RH < 1 acceptance criterion. The calibrated model is regarded as a robust comparator for hemolysis prediction in rotodynamic blood pumps, and its application here is consistent with current best practice in computational hemolysis assessment.",
      "validationMethod": "Relative hemolysis index comparison against Bludszuweit power-law model calibrated on HeartMate II VAD data",
      "quantitativeMetric": "RH = NIH_device / NIH_predicate (dimensionless)",
      "acceptanceCriterion": "RH < 1.0 at all five operating points",
      "outcomeStatement": "RH ranges from 0.71 to 0.94; all five points satisfy RH < 1.0",
      "comparedAgainst": "https://uofa.net/synth/comparator/heartmate-ii-vad-bludszuweit-calibration",
      "assessedAt": "2026-03-21T00:00:00Z",
      "comparatorNote": "Calibration dataset originates from LVAD operating conditions (4000–6000 RPM, continuous-flow assist mode) that differ from CPB conditions (2000–3500 RPM, pulsatile-assist-augmented flow). The model coefficients have not been re-calibrated for the lower shear-rate regime characteristic of CPB use. This distinction is not examined in the validation narrative."
    }
  ],
