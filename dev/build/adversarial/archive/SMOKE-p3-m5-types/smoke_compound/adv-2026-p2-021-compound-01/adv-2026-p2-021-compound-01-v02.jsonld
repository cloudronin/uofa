  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/morrison/validation/vr-mesh-independence",
      "type": "ValidationResult",
      "name": "Mesh independence study — pressure-head and wall shear stress",
      "description": "Three-level mesh refinement study (coarse 2.1M, medium 5.8M, fine 14.3M elements) conducted on the FDA generic centrifugal pump geometry. Richardson extrapolation applied to pressure-head QoI. GCI for fine-to-medium transition is 0.71%, confirming discretization error is within the 2% acceptance band at all five operating points.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/uq-mesh-gci",
        "type": "UncertaintyQuantification",
        "method": "Richardson extrapolation / GCI",
        "coverageInterval": "95%",
        "normalizedError": 0.0071
      }
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-hemolysis-bench",
      "type": "ValidationResult",
      "name": "Bench-scale hemolysis validation against FDA experimental dataset",
      "description": "Computational predictions of the normalized index of hemolysis (NIH) are compared against the FDA-published experimental measurements for the generic centrifugal pump at five flow-speed operating points (2.5 L/min at 2500 RPM through 7.0 L/min at 3500 RPM). The power-law hemolysis model (Giersiepen coefficients) is applied to Lagrangian particle tracks post-processed from the steady-state RANS solution. Mean absolute relative error across the five points is 8.3%, within the 15% acceptance criterion. No uncertainty quantification is reported for this validation result because the experimental scatter was considered negligible by the assessment team — an assumption that is not formally substantiated in this package."
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-flow-field-piv",
      "type": "ValidationResult",
      "name": "PIV flow-field comparison — impeller exit plane velocity profiles",
      "description": "Particle image velocimetry (PIV) measurements of radial and tangential velocity components at the impeller exit plane (r/R = 1.05) are compared against CFD predictions at 5000 RPM, 5.0 L/min. Velocity magnitude agreement is within 6% across 85% of measurement locations. Regions of elevated discrepancy (up to 14%) are confined to the volute tongue zone, consistent with known RANS limitations in separated-flow regions. This result supports the model form assessment at Gradation 2.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/uq-piv-velocity",
        "type": "UncertaintyQuantification",
        "method": "Experimental repeatability + systematic bias propagation",
        "coverageInterval": "95%",
        "expandedUncertainty": 0.038
      }
    },
    {
      "id": "https://uofa.net/morrison/validation/vr-pressure-head-map",
      "type": "ValidationResult",
      "name": "Pressure-head performance map validation",
      "description": "Predicted pump pressure-head (ΔP) is compared against manufacturer-supplied performance curve data across the full operating envelope (2000–4000 RPM, 2–8 L/min). Maximum deviation is 4.1% at the low-flow, high-speed corner, attributable to recirculation onset not captured by the steady-state RANS closure. All five COU operating points fall within a region where deviation is below 3%, satisfying the output comparison acceptance criterion.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/uq-pressure-head",
        "type": "UncertaintyQuantification",
        "method": "Manufacturer tolerance band propagation",
        "coverageInterval": "95%",
        "expandedUncertainty": 0.041
      }
    }
  ],
