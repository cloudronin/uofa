      "type": "ValidationResult",
      "name": "Wall shear stress distribution comparison via PIV",
      "description": "Particle image velocimetry (PIV) measurements in the volute region compared against CFD velocity fields at 4.5 L/min, 2500 RPM. Velocity magnitude agreement within 6.1% RMS. Wall shear stress hot-spots co-located between CFD and PIV to within 1.2 mm spatial resolution.",
      "hasUncertaintyQuantification": {
        "id": "https://uofa.net/morrison/uq/vr-03-uq",
        "type": "UncertaintyQuantification",
        "method": "PIV measurement uncertainty estimated per ISO 5168; CFD numerical uncertainty via Richardson extrapolation on three grids. Combined validation metric U_val = 7.8%.",
        "coverageInterval": "95%",
        "dominantSource": "PIV seeding particle lag at high-shear impeller tip region"
      }
    }
