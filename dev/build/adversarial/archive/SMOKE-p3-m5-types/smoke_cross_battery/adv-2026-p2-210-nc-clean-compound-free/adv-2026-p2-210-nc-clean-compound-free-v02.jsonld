  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-acceptance-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/org/computational-biofluidics-lab",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for CPB application, Class II, MRL 2) is accepted based on the following structured evidence review: (1) All 13 ASME V&V 40 credibility factors have been evaluated. Seven factors were formally assessed with documented evidence; six of these achieved levels at or above the MRL 2 required levels, and all seven meet their respective acceptance criteria. The remaining six factors were assessed and documented with rationale confirming adequacy at MRL 2. (2) Validation evidence demonstrates quantitative agreement between CFD predictions and experimental measurements across all five COU operating points. The relative hemolysis index (RH) prediction error does not exceed 6.8% at any operating point, and the normalized velocity field error (NRMSE 4.1%) is within the established acceptance threshold. (3) Discretization error is bounded at GCI = 2.3% for the fine mesh, well below the 5% threshold. Iterative convergence is confirmed at residual levels below 1e-5. (4) Model inputs are fully traceable to calibrated measurements and published literature. Input uncertainty has been propagated through sensitivity analysis confirming that the RH < 1 acceptance criterion is robust to input variation within documented uncertainty ranges. (5) The validation activities are directly relevant to the COU: same pump geometry, overlapping operating conditions, and matched fluid rheology. The provenance chain from raw experimental data through validation results to this credibility assessment is complete and documented. On the basis of this evidence, the computational model is judged credible for the intended use of identifying worst-case hemolysis operating conditions for the FDA generic centrifugal blood pump in CPB service.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
