  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for Class II CPB device at MRL 2) is accepted based on the following structured evidence: (1) All 7 assessed credibility factors meet or exceed their required Gradation levels: Software QA (2/2), Code Verification (2/2), Discretization Error (3/2, exceeds requirement), Test Conditions (2/2), Output Comparison (2/2), QoI Relevance (2/2), and Validation Relevance (2/2). (2) Six factors are appropriately scoped out or designated not-applicable with documented justification consistent with MRL 2 and Medium model influence per ASME V&V 40 Table 4. (3) Validation results demonstrate the model predicts NIH within validation uncertainty across all 5 COU operating points (|V| < 1.0), and PIV velocity comparisons confirm adequate flow field fidelity. (4) GCI-based discretization error is bounded at 2.1%, well within the acceptable range for regulatory submission. (5) The decision consequence is High and model influence is Medium, yielding MRL 2; the credibility evidence portfolio is proportionate to and sufficient for this risk level. (6) Provenance chain is complete: all validation results trace to experimental datasets, generating activities, and uncertainty quantification reports. The model is judged credible for its intended use of identifying worst-case hemolysis operating conditions for tolerance analysis of the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
