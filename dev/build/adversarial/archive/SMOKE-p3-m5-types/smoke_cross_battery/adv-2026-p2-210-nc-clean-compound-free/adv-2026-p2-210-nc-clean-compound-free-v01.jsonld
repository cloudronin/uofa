  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 (CFD hemolysis prediction for CPB Class II device, MRL 2) is accepted based on the following structured evidence: (1) Seven credibility factors were formally assessed; all achieved levels meet or exceed required levels for MRL 2. (2) Discretization error was rigorously quantified via GCI study with fine-mesh GCI of 2.1%, well within the 5% threshold. (3) Output comparison demonstrated mean absolute error of 8.3% with no statistically significant systematic bias across five validation operating points, providing high confidence in model predictive fidelity within the COU envelope. (4) Six factors were scoped out under documented MRL 2 rationale, each with supporting procedural controls or sensitivity analyses. (5) The provenance chain from raw experimental data through validation activities to this UoA is complete and traceable. (6) Uncertainty quantification reports are linked for all three ValidationResults. (7) The relative hemolysis index acceptance criterion (RH < 1) is met across all five COU operating points with margin. The assessment team concludes that the CFD model provides adequate credibility to support the regulatory submission decision for the Class II CPB device.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
