  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2023",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 not-assessed factors are acceptable per ASME V&V 40-2018 Table 3 at MRL 2. The paediatric envelope expansion (Q3 2023) is judged to be covered by the existing adult validation evidence on the basis of Reynolds number similarity at the impeller tip and the dominant role of tip-clearance shear in haemolysis generation. The assessment team accepts that no new experimental validation data at paediatric flow rates (0.8–1.5 L/min) are required prior to clinical use, and that the prior validation campaign conducted in 2021 provides sufficient credibility for the expanded COU. Decision outcome: Accepted.",
