      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Not required at MRL 2 for this factor.",
      "rationale": "Equivalency of input parameters not assessed at MRL 2 per ASME V&V 40-2018 Table 3. Factor scoped out of assessment."
    }
