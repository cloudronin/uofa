  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2025",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed the required gradation levels for MRL 2. The six not-assessed factors are acceptable at MRL 2 per the ASME V&V 40-2018 framework. The credibility team accepted the model for the expanded COU, including the pediatric patient subgroup (BSA < 0.6 m², cardiac output 0.8–2.2 L/min), on the basis that the physics-based power-law hemolysis damage model is expected to generalize below the validated adult flow range. The team acknowledged the absence of pediatric-range validation data but concluded that the dimensional similarity argument and the conservatism of the adult mesh adequacy study provide sufficient assurance. No re-calibration or supplemental validation study was commissioned. The decision was reviewed and endorsed by the device sponsor's biofluid mechanics lead.",
