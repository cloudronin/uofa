  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required levels for MRL 2. The 6 not-assessed factors are acceptable at MRL 2 per ASME V&V 40 Table 1. The post-validation extension of the operating envelope to include paediatric patients (BSA < 0.6 m², flow 0.8–1.5 L/min) has been reviewed by the assessment team. It is concluded that the adult-regime validation evidence (2.0–6.0 L/min, 2023) provides adequate mechanistic coverage for the paediatric regime because: (1) the pump geometry is unchanged; (2) the dominant hemolysis mechanism is shear-stress-driven and the SST k-ω model is expected to remain accurate at lower Reynolds numbers; and (3) the RH prediction error budget of ±15% is considered conservative. On this basis the model is accepted for use across the full extended COU without additional experimental validation.",
    "decidedAt": "2024-11-15T09:00:00Z"
  },
