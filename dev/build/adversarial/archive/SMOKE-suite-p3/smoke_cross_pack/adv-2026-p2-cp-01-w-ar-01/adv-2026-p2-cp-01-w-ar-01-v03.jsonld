  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "NASA-STD-7009B",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "OpenFAST v3.5.1 must be under version-controlled release with documented test suite coverage ≥ 80% of physics modules and a traceable issue-resolution log for all severity-1 defects identified in the prior 24-month window.",
      "rationale": "OpenFAST v3.5.1 is maintained under NREL's GitHub repository with tagged releases, a CI/CD pipeline running the regression test suite on every pull request, and a public issue tracker. The release notes document resolution of all severity-1 issues. Independent audit by DNV GL in 2023 confirmed SQA practices consistent with Gradation 3 of NASA-STD-7009B."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "NASA-STD-7009B",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Manufactured-solution and benchmark test results for all active OpenFAST modules (AeroDyn, ElastoDyn, ServoDyn) must demonstrate numerical errors below 1% relative to analytical solutions at the mesh and time-step resolutions used in this COU.",
      "rationale": "The OpenFAST verification suite includes method-of-manufactured-solutions (MMS) tests for AeroDyn 15 and ElastoDyn. Published verification studies (Jonkman et al., 2016; Shaler et al., 2020) demonstrate sub-1% numerical error at the discretization settings used herein. Results are archived in the project verification report VR-2024-003."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "NASA-STD-7009B",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A mesh and time-step convergence study must demonstrate that DEL predictions at the blade root change by less than 2% between the production discretization and a half-step refinement, with Richardson extrapolation applied to estimate remaining discretization error.",
      "rationale": "A three-level convergence study was performed varying blade aerodynamic node count (20, 40, 80 stations) and time step (0.0125 s, 0.025 s, 0.05 s). Richardson extrapolation yields a discretization error estimate of 0.8% for flapwise DEL and 1.1% for edgewise DEL at the production settings (40 stations, 0.025 s). Results documented in analysis memo AM-DISC-2024-11."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "NASA-STD-7009B",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver residuals must converge below 1 × 10⁻⁶ at each time step for the structural DOFs, and energy balance checks must confirm total energy drift below 0.1% over each 600-second simulation.",
      "rationale": "OpenFAST uses a predictor-corrector integration scheme with adaptive sub-stepping. Energy balance monitoring over all 36 DLC 1.1 seeds confirms drift below 0.05%. Solver residual logs are retained in the simulation archive SA-2024-DLC1p1."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "NASA-STD-7009B",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "A documented simulation run plan and independent peer review of input files must be completed prior to production runs, with all reviewer comments dispositioned in writing.",
      "rationale": "Input files were prepared following the project simulation run plan SRP-2024-01 and independently reviewed by a second analyst. All 14 reviewer comments were dispositioned in the comment-response log CRL-2024-01 before production execution."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "NASA-STD-7009B",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "rationale": "The model form factor is assessed at Gradation 4 required because blade root fatigue certification margins are safety-critical and the IEA 15-MW blade operates in a regime where nonlinear large-deflection effects are non-negligible. OpenFAST couples a geometrically exact beam model (BeamDyn) with a blade-element momentum aerodynamics model (AeroDyn 15) including dynamic stall via the Beddoes-Leishman model. The achieved Gradation 3 reflects that while the physics representation is state-of-the-art for industry aeroelastic codes, the BEM-based aerodynamics introduces known model-form uncertainty under highly turbulent inflow that has not been fully characterised through first-principles CFD comparison at the IEA 15-MW scale. This gap is acknowledged and a sensitivity study quantifying the impact of dynamic-stall model parameters on flapwise DEL is documented in sensitivity report SR-MODELFORM-2024-02. The one-gradation shortfall is accepted by the project chief engineer subject to a 10% additional design margin applied to the blade root laminate sizing, as recorded in engineering disposition ED-2024-07. The assessment team judges that the combination of the BeamDyn geometric-exact formulation, the validated BEM implementation, and the applied design margin together provide adequate credibility for the intended certification use, while transparently documenting the model-form limitation and its treatment. Future work will include RANS-coupled aeroelastic comparison runs to reduce this gap before the next design iteration."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "NASA-STD-7009B",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All blade geometry, structural, and airfoil polars used as model inputs must be traceable to measured or manufacturer-certified data sources, with uncertainty bounds documented for parameters contributing more than 1% sensitivity to blade root DEL.",
      "rationale": "Blade geometry and structural properties are taken from the IEA 15-MW open-reference dataset (Gaertner et al., 2020), which is based on manufacturer-certified laminate schedules. Airfoil polars were generated using XFOIL with corrections validated against wind tunnel data. Sensitivity analysis (SR-INPUTS-2024-01) identifies blade mass distribution and chord length as the two parameters with >1% DEL sensitivity; uncertainty bounds of ±2% and ±0.5% respectively are documented."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "NASA-STD-7009B",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation test data must include a minimum of 200 hours of operational strain gauge measurements spanning the full DLC 1.1 wind speed range (3–25 m/s) with at least 10 independent 10-minute records per 2 m/s bin.",
      "rationale": "The 2024 strain gauge campaign on the IEA 15-MW prototype at the Østerild test site collected 312 hours of valid data across 11 wind speed bins from 4 to 24 m/s, with a minimum of 14 records per bin after quality screening. Data quality report DQR-2024-OSTERILD documents sensor calibration, data screening criteria, and bin population statistics."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "NASA-STD-7009B",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Measured atmospheric turbulence intensity and wind shear profiles during the validation campaign must fall within ±15% of the IEC 61400-1 Class B normal turbulence model parameters used in simulation inputs.",
      "rationale": "Met mast data from the Østerild site confirms median TI within 8% of the NTM Class B reference curve across all wind speed bins. Wind shear exponent measured at 0.18 ± 0.03, consistent with the 0.2 value used in simulation. Deviations are within the ±15% acceptance band documented in test condition assessment TCA-2024-01."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "NASA-STD-7009B",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (control settings, blade pitch schedule, generator torque curve) must be matched to as-tested turbine configuration within documented tolerances, with a formal parameter equivalency matrix completed and reviewed.",
      "rationale": "A parameter equivalency matrix (PEM-2024-01) maps 47 simulation input parameters to as-tested turbine configuration data provided by the turbine OEM under NDA. All parameters are matched within specified tolerances. Three minor deviations (nacelle mass ±1.2%, drivetrain damping ±3%, tower natural frequency ±0.4%) are documented with sensitivity analyses confirming negligible impact on blade root DEL."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "NASA-STD-7009B",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulated blade root flapwise and edgewise DELs must agree with measured values within ±10% across all wind speed bins, with no systematic bias exceeding 5% in any three consecutive bins.",
      "rationale": "Comparison of simulated versus measured DELs across all 11 wind speed bins shows flapwise DEL agreement within −4% to +8% and edgewise DEL within −6% to +7%. No systematic bias exceeding 3% is observed in any three consecutive bins. Results are presented in validation report VR-2024-003, Figures 4.1–4.4."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "NASA-STD-7009B",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "The validation QoI (blade root flapwise and edgewise DEL) must be identical to the COU QoI with the same rainflow counting parameters (m=10, reference cycles=10^7) and the same fatigue load case scope (DLC 1.1 only).",
      "rationale": "Validation activities directly target blade root flapwise and edgewise DEL computed with Wöhler exponent m=10 and 10^7 reference cycles, which are precisely the quantities used in the blade root laminate sizing calculations. No extrapolation of QoI is required. The validation scope is restricted to DLC 1.1 consistent with the COU scope."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "NASA-STD-7009B",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities must be conducted on the same turbine model (IEA 15-MW) at full scale, under wind conditions representative of the DLC 1.1 design envelope, with no geometric or operational scaling applied.",
      "rationale": "All validation activities were conducted at full scale on the IEA 15-MW prototype under DLC 1.1-representative wind conditions at Østerild. No scaling corrections are applied. The OC6 Phase IV blind test provides additional code-to-code validation at the same scale. The validation programme is therefore directly relevant to the COU without extrapolation."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/wind-turbine-fatigue-del-cou1-decision-v1",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nrel-chief-engineer-wind",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment for the OpenFAST DLC 1.1 DEL prediction is accepted. Twelve of thirteen credibility factors meet or exceed their required gradation levels. The model form factor achieves Gradation 3 against a required Gradation 4; this shortfall is accepted with an engineering disposition applying a 10% additional design margin to blade root laminate sizing (ED-2024-07). All other factors are fully satisfied. The validation evidence base is judged sufficient to support use of simulation results for blade root certification margin assessment.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
