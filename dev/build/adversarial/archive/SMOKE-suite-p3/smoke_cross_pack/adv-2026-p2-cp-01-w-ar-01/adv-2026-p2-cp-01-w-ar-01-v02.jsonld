  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/wind-turbine-del-cou1-decision-20260419",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nrel-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The overall credibility assessment for the OpenFAST DLC 1.1 DEL prediction is accepted. Twelve of thirteen credibility factors meet or exceed their required levels. The single shortfall — Model Inputs at Gradation 2 against a requirement of Gradation 3 — is acknowledged and mitigated by the conservative bias observed in the output comparison (simulation over-predicts DELs by a mean of +2.8%), which provides a safety margin consistent with the intended use of informing laminate sizing. A follow-on probabilistic sensitivity analysis is scheduled for Q3 2026 to close this gap prior to final certification submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
