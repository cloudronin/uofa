  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator-primary",
      "type": "ValidationResult",
      "name": "Primary hemolysis QoI validation — relative hemolysis index",
      "description": "CFD-predicted normalized index of hemolysis (NIH) values were computed across all five flow-rate/rotational-speed operating points (2.5 L/min at 2500 RPM, 3.5 L/min at 3000 RPM, 5.0 L/min at 3500 RPM, 5.0 L/min at 4000 RPM, and 6.0 L/min at 4500 RPM). The Lagrangian power-law hemolysis model (Giersiepen-Wurzinger coefficients) was applied to tracked particle trajectories. Predicted NIH values ranged from 0.0031 to 0.0078 mg/dL across the operating envelope. The assessment narrative notes that these predictions are consistent with published literature ranges for centrifugal pumps of comparable specific speed and that the worst-case operating point (6.0 L/min, 4500 RPM) is correctly identified by the model. Agreement with expected physical trends is described as satisfactory, and the factor is assessed as meeting the required credibility level. No experimental dataset link is recorded in this result entry; the comparator is discussed by name in the rationale text of the Output comparison factor but is not formally bound here.",
      "validationMetric": "Normalized Index of Hemolysis (NIH, mg/dL)",
      "outcomeStatement": "CFD NIH predictions are within the range reported in peer-reviewed literature for similar centrifugal pump geometries; worst-case operating point correctly ranked."
    },
    {
      "id": "https://uofa.net/synth/validation/vad-steadyflow-comparator",
      "type": "ValidationResult",
      "name": "Supporting validation — VAD steady-flow hemolysis benchmark comparison",
      "description": "A supporting validation activity compared CFD-predicted NIH values against the ASTM F1841-compliant steady-flow hemolysis bench test dataset collected for a continuous-flow ventricular assist device (CF-VAD) of similar impeller diameter (52 mm vs. 50 mm for the GCBP) and overlapping flow range (3–6 L/min). The VAD benchmark operates under steady, non-pulsatile inflow at a fixed afterload pressure of 100 mmHg, which closely resembles the pump inlet conditions used in the CFD model. Predicted NIH values agreed with measured VAD bench values within 18% across the shared flow range, which is considered acceptable for hemolysis modelling. The validation narrative emphasises the geometric and hydraulic similarity between the VAD benchmark and the GCBP, noting that both devices operate in the same specific-speed regime and that the Giersiepen-Wurzinger power-law coefficients are applicable to both. The narrative does not examine whether the steady-flow VAD operating condition is representative of the pulsatile CPB circuit environment declared in the COU, where inlet flow waveforms exhibit 30–40% peak-to-mean variation and venous reservoir pressure fluctuates with patient respiratory cycle. This distinction is not flagged as a limitation.",
      "comparedAgainst": "https://uofa.net/synth/data/vad-steadyflow-hemolysis-benchmark-2021",
      "validationMetric": "Normalized Index of Hemolysis (NIH, mg/dL)",
      "outcomeStatement": "CFD NIH agrees with VAD steady-flow bench data within 18%; assessed as adequate support for hemolysis model credibility."
    }
  ],
