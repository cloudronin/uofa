  ],
  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/no-comparator",
      "type": "ValidationResult",
      "name": "Primary hemolysis QoI validation — CFD vs. in vitro NIH index",
      "description": "Normalized index of hemolysis (NIH) predicted by the power-law hemolysis model (Giersiepen exponents) was evaluated across the five CPB operating points (2 L/min–5 L/min, 2000–3500 RPM). Simulation predictions showed monotonically increasing NIH with decreasing flow rate at fixed speed, consistent with expected shear-stress distributions. Mean absolute error across operating points was 8.3%, within the ±15% acceptance band defined in the V&V plan. The assessment team concluded that model fidelity is adequate for rank-ordering operating conditions by hemolysis severity. No experimental dataset IRI is linked here because the underlying in-vitro measurements were obtained under a confidential testing agreement and have not yet been deposited in the institutional repository; the numerical comparison was conducted internally and the summary statistics are reported in the credibility assessment report (CAR-2025-CPB-001).",
      "quantitativeMetric": "Mean absolute error 8.3% across 5 operating points",
      "acceptanceCriteriaMet": true
    },
    {
      "id": "https://uofa.net/synth/validation/secondary-vad-comparator",
      "type": "ValidationResult",
      "name": "Secondary validation — CFD hemolysis against Fraser 2012 VAD experimental data",
      "description": "As an additional validation activity, CFD-predicted hemolysis indices were compared against the published experimental dataset of Fraser et al. (2012), which characterised hemolysis in a centrifugal pump geometry closely resembling the FDA generic pump. The Fraser dataset covers pump speeds of 2500–4500 RPM at flow rates of 3–8 L/min, representative of ventricular assist device (VAD) support rather than CPB duty. The CFD model reproduced the Fraser experimental NIH values with R²=0.94 and a normalised root-mean-square error of 6.1%, which the assessment team characterised as excellent agreement. The strong quantitative agreement across a broad range of operating conditions was taken as evidence of robust model form validity. The assessment team noted that the pump geometry and blood rheology model are identical between the validation case and the COU, supporting transferability of the validation evidence.",
      "quantitativeMetric": "R²=0.94, NRMSE=6.1% against Fraser 2012 VAD dataset",
      "acceptanceCriteriaMet": true,
      "comparedAgainst": "https://uofa.net/synth/data/fraser2012-vad-hemolysis-experimental"
    }
  ],
