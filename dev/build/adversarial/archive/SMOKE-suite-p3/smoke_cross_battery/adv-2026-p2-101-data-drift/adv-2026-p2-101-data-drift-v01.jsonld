  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-cardiovascular-sim-lab-lead",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed their required levels for MRL 2. The six non-assessed factors are acceptable at MRL 2 per ASME V&V 40-2018 Table 3. The adult validation campaign (January–March 2022) demonstrated NIH prediction accuracy within ±12% across five operating points. The Q3 2023 expansion of the indicated patient population to include pediatric patients (BSA 0.5–1.0 m², flow 1.0–2.2 L/min) was reviewed by the assessment team. It was determined that the existing validation evidence is sufficiently relevant because the pump geometry, fluid analog, and hemolysis power-law model are unchanged, and that adult shear stress fields conservatively bound those expected at lower pediatric flow rates. No re-calibration or supplementary validation experiments at pediatric flow rates were deemed necessary. The model is therefore accepted as credible for the expanded COU at the stated assurance level.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
