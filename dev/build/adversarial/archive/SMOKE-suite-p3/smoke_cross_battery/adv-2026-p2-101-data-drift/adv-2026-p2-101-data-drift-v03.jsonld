  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-accepted-2024",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team determined that all seven assessed factors meet or exceed the required gradation levels for MRL 2. The six non-assessed factors are acceptable under MRL 2 scope. The 2021 validation campaign demonstrates adequate predictive accuracy (NIH within 15%) across the adult operating envelope. The Q1 2024 extension of the cleared indication to paediatric patients (0.5–1.2 L/min) was reviewed and the team concluded, via dimensional similarity and power-law scaling arguments documented in TM-2024-03, that the existing validation evidence provides sufficient coverage of the expanded envelope. No new experimental validation campaign or re-calibration study was deemed necessary prior to submission. The overall credibility package is accepted at Medium assurance level consistent with MRL 2 and Class II device requirements.",
