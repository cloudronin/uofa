  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/dr-cpb-cou1-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment for COU1 is accepted at Medium assurance level based on the following structured evidence: (1) All 7 assessed credibility factors meet or exceed their required levels for MRL 2 with Medium model influence and High decision consequence. (2) Discretization error is characterised at Gradation 3 (GCI = 1.8%, asymptotic convergence confirmed), exceeding the required Gradation 2. (3) Output comparison achieves Gradation 3 with quantitative agreement (MAPE < 7%) across all 5 operating points and all primary QoIs. (4) Three independent ValidationResults (hemolysis bench, pressure-flow, PIV velocity) each carry complete comparedAgainst, provenance, and uncertainty quantification links. (5) The 6 scoped-out factors are appropriately excluded per ASME V&V 40-2018 Table 3 guidance for MRL 2, with documented rationale in each factor record. (6) No weakeners are identified. The totality of evidence supports the conclusion that the CFD model provides sufficient credibility to identify worst-case hemolysis operating conditions for the Class II CPB device, and the RH < 1 acceptance criterion has been demonstrated across the full clinical operating envelope.",
    "decidedAt": "2026-04-19T00:00:00Z"
