  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/sqa-level1",
      "rationale": "ANSYS Fluent 2022R2 used under ISO 9001:2015 quality management system. Solver version control, regression test suite, and release validation documentation all confirmed current. Achieved Gradation 2 (documented QA procedures with traceability) against required Gradation 1 for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/code-verification-level1",
      "rationale": "ANSYS Fluent solver verified against benchmark problems from ASME V&V 20 and published FDA nozzle benchmark. Order-of-accuracy tests confirm second-order spatial convergence for velocity and pressure fields. Exceeds MRL 2 requirement."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/discretization-error-level2",
      "rationale": "Systematic mesh convergence study conducted across three mesh densities (3.2M, 8.1M, 18.4M elements). Richardson extrapolation applied; GCI values below 2.1% for hemolysis index QoI at all five operating points. Y+ maintained below 1.0 on all blood-contacting surfaces. Discretization error quantified and documented per ASME V&V 20."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-conditions-level2",
      "rationale": "Experimental validation conducted using bovine blood at physiological hematocrit (38±2%) and temperature (37±0.5°C). Flow rates and rotational speeds matched CFD boundary conditions within ±1.5%. Five operating points span the full clinical CPB envelope (2–6 L/min, 2400–3600 RPM). Test conditions documented with NIST-traceable instrumentation calibration records."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/output-comparison-level2",
      "rationale": "Normalized index of hemolysis (NIH) predicted by CFD compared against experimental measurements across all five operating points. Mean absolute error of 8.3% with maximum deviation of 14.1% at highest shear operating point. Comparison metrics include validation metric M and uncertainty interval overlap per ASME V&V 20. All comparisons within validation acceptance band."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/qoi-relevance-level2",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) and relative hemolysis index (RH), both directly mapped to the regulatory acceptance criterion (RH < 1 vs. predicate device). Secondary QoIs include volume-averaged scalar shear stress and exposure time distributions, which are the mechanistic inputs to the power-law hemolysis model. All QoIs are clinically and regulatorily relevant to the CPB COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/validation-relevance-level2",
      "rationale": "Validation experiments performed on the FDA generic centrifugal pump geometry — the same geometry used in the COU simulation. Fluid properties, boundary conditions, and operating envelope match COU conditions. The validation scenario is assessed as a close analog to the COU with documented similarity analysis covering geometry, flow regime (Re, Womersley), and blood damage mechanisms."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/solver-error-scopedout",
      "rationale": "At MRL 2, numerical solver error is addressed through code verification (assessed separately) and iterative convergence monitoring. Residuals converged to below 1e-5 for all equations in all simulations. Separate solver error factor is scoped out as redundant with the code verification and discretization error assessments already documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/use-error-scopedout",
      "rationale": "Simulation team consists of PhD-level CFD engineers with >5 years of cardiovascular device simulation experience. Peer review of simulation setup, boundary conditions, and post-processing was performed by an independent reviewer. Standard operating procedures for CFD model setup are documented and followed. Use error risk assessed as low and within SQA controls; scoped out from separate factor assessment at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-form-scopedout",
      "rationale": "The k-omega SST turbulence model and Giersiepen-Wurzinger power-law hemolysis model are established for rotary blood pump CFD at MRL 2. Model form uncertainty is partially addressed through the output comparison factor. Full model form sensitivity analysis is not required at MRL 2 for this device class; factor scoped out with documented justification referencing FDA guidance on CFD for blood-contacting devices."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/model-inputs-scopedout",
      "rationale": "Blood viscosity modeled as Newtonian (mu = 0.0035 Pa·s) consistent with high-shear CPB conditions. Pump geometry derived from FDA-published CAD files with dimensional verification. Inlet velocity profiles derived from in vitro flow loop measurements. Sensitivity of NIH to ±10% variation in viscosity and inlet profile assessed and found to produce <5% change in NIH; input uncertainty documented and within acceptable bounds for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/test-samples-scopedout",
      "rationale": "Experimental hemolysis measurements obtained from n=5 independent test runs per operating point using fresh bovine blood from a single supplier with controlled hematocrit. Inter-run variability (CV < 8%) documented. Sample size justification provided referencing ASTM F1841 guidance. Full statistical power analysis not required at MRL 2; factor scoped out with documented inter-run variability characterization."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/morrison/criteria/equivalency-scopedout",
      "rationale": "Simulation boundary conditions (flow rates, rotational speeds, fluid properties) matched to experimental conditions within measurement uncertainty. Dimensional analysis confirms dynamic similarity between validation and COU scenarios. Equivalency of input parameters is captured within the test conditions factor assessment; separate equivalency factor scoped out at MRL 2 to avoid redundancy, with cross-reference to test conditions factor documented."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cpb-cou1-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD model for hemolysis prediction in the FDA generic centrifugal blood pump is accepted for the CPB COU at MRL 2. All seven assessed credibility factors meet or exceed their required levels: software QA (achieved 2, required 1), code verification (achieved 2, required 1), discretization error (achieved 3, required 2), test conditions (achieved 2, required 2), output comparison (achieved 2, required 2), QoI relevance (achieved 2, required 2), and validation relevance (achieved 2, required 2). Six factors are appropriately scoped out with documented rationale consistent with MRL 2 requirements for a Class II device. Validation evidence is grounded in three independent validation results covering hemolysis index, pressure-flow characteristics, and shear stress distribution, each with quantified uncertainty and provenance traceable to experimental datasets. The relative hemolysis index criterion (RH < 1) is met across all five CPB operating points with quantified prediction intervals. The decision consequence is High and model influence is Medium, yielding MRL 2; the assembled evidence package satisfies ASME V&V 40-2018 requirements for this risk level. No credibility gaps identified; package accepted without conditions.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
