  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl2-criteria",
      "rationale": "ANSYS Fluent 2022R2 used with documented version control, regression test suite passing all benchmark cases, and configuration management log maintained throughout the study. Achieved level 2 exceeds the MRL 2 requirement of level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/ncv-mrl2-criteria",
      "rationale": "Code verification performed using the method of manufactured solutions for the incompressible Navier-Stokes solver. Observed order of convergence of 1.97 matches theoretical second-order accuracy. All benchmark cases from the ASME V&V 20 suite passed within specified tolerances."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/disc-error-mrl2-criteria",
      "rationale": "Grid convergence index (GCI) study performed across three systematically refined meshes (2.1M, 7.4M, 24.6M cells). GCI for hemolysis index QoI is 3.2%, well within the 5% acceptance threshold. Richardson extrapolation confirms asymptotic convergence range factor of 1.02. Achieved level 3 reflects quantified and bounded discretization error."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl2-criteria",
      "rationale": "Experimental test conditions replicated in CFD boundary conditions: inlet flow rates of 2.5, 3.5, 4.5, 5.5, and 6.5 L/min at pump speeds of 2000, 2500, and 3000 RPM. Blood analog fluid (glycerol-water mixture) properties matched to within 2% of experimental values. Temperature maintained at 37 ± 0.5°C in both experiment and simulation."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl2-criteria",
      "rationale": "Normalized index of hemolysis (NIH) predictions compared against experimental measurements across all 15 operating points. Mean absolute relative error of 8.3% with maximum deviation of 14.1% at the highest shear condition. Comparison metric satisfies the pre-specified acceptance criterion of MARE < 15%. Uncertainty bands from UQ overlap experimental measurement uncertainty in 13 of 15 cases."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl2-criteria",
      "rationale": "Primary QoI is the normalized index of hemolysis (NIH) and relative hemolysis index (RH), which are the regulatory-accepted metrics for hemolysis assessment per FDA guidance on blood-contacting devices. Secondary QoIs include volumetric flow rate, pressure head, and wall shear stress distribution, all directly linked to hemolysis mechanisms. QoI selection reviewed and approved by clinical advisors."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "factorStatus": "assessed",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/val-relevance-mrl2-criteria",
      "rationale": "Validation activities performed on the FDA benchmark centrifugal blood pump geometry under CPB-representative operating conditions. Geometric similarity index of 0.94 between validation pump and COU device. Operating conditions span the full clinical envelope defined in the COU. Validation evidence directly supports the intended use of identifying worst-case hemolysis conditions."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/nse-scopeout-mrl2",
      "rationale": "Numerical solver error assessment scoped out at MRL 2 per ASME V&V 40 Table 3. The commercial solver (ANSYS Fluent) has undergone extensive third-party verification and the code verification factor (assessed at level 2) provides sufficient coverage of solver correctness for this risk level. Residual convergence criteria of 1e-6 applied consistently across all simulations."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-scopeout-mrl2",
      "rationale": "Use error assessment scoped out at MRL 2 per ASME V&V 40 Table 3. Simulation setup reviewed by a second qualified engineer independent of the primary analyst. Simulation input files version-controlled and archived. Standard operating procedures for CFD setup documented and followed throughout the study."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-scopeout-mrl2",
      "rationale": "Model form uncertainty assessment scoped out at MRL 2. The k-omega SST turbulence model with low-Reynolds-number correction selected based on published literature for rotating blood pump simulations. The power-law hemolysis damage model (Giersiepen-Wurzinger) is the regulatory-accepted approach for this device class. Model form selection documented with literature justification."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "factorStatus": "scoped-out",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-scopeout-mrl2",
      "rationale": "Detailed model input uncertainty quantification scoped out at MRL 2 per ASME V&V 40 Table 3. Key input parameters (fluid viscosity, density, hemolysis model coefficients) sourced from peer-reviewed literature with documented traceability. Sensitivity analysis on hemolysis model exponents performed as part of the UQ activity linked to the validation results."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-na-mrl2",
      "rationale": "Test samples factor not applicable for this COU. The validation study uses a blood analog fluid (glycerol-water mixture) rather than biological samples. Physical sample variability is therefore not a relevant consideration. Fluid property characterization is addressed under the model inputs factor."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "factorStatus": "not-applicable",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "acceptanceCriteria": "https://uofa.net/synth/criteria/eip-na-mrl2",
      "rationale": "Equivalency of input parameters not applicable at MRL 2 for this COU. The validation and COU geometries are sufficiently similar (geometric similarity index 0.94) that input parameter equivalency mapping is not required. The test conditions factor addresses the correspondence between experimental and simulation boundary conditions."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cpb-mrl2-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/credibility-assessment-team-morrison",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The CFD hemolysis prediction model for the FDA generic centrifugal blood pump under CPB conditions achieves the required credibility level for Model Risk Level 2. All seven assessed credibility factors meet or exceed their required levels: software quality assurance (achieved 2, required 1), numerical code verification (achieved 2, required 2), discretization error (achieved 3, required 2), test conditions (achieved 2, required 2), output comparison (achieved 2, required 2), relevance of QoI (achieved 2, required 2), and relevance of validation activities (achieved 2, required 2). Six factors are appropriately scoped out or not applicable at MRL 2 with documented justifications. The validation evidence demonstrates MARE of 8.3% against experimental hemolysis data, within the pre-specified 15% acceptance threshold. The GCI study confirms discretization error below 5% for the primary QoI. The complete provenance chain from raw experimental data through validation activities to credibility conclusions is documented and traceable. The relative hemolysis index RH < 1 criterion is met at all 5 worst-case operating points identified by the model. The decision to accept this model for its intended use is supported by the structured evidence base assembled in this credibility assessment.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
