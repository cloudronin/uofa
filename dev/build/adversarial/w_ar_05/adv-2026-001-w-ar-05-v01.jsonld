  "hasContextOfUse": {
    "decisionConsequence": "High",
    "description": "A CFD model is used to evaluate the sensitivity of pump-induced hemolysis to variations in component dimensions for a centrifugal blood pump used during cardiopulmonary bypass surgery. Model influence is MEDIUM (testing confirms results); decision consequence is HIGH (incorrect tolerance decision could impact clinical hemolysis levels). Model Risk Level 2.",
    "deviceClass": "Class II",
    "id": "https://uofa.net/morrison/cou/cou1-cpb",
    "intendedUse": "Use CFD to identify worst-case operating conditions for hemolysis across 5 flow-speed combinations for a Class II CPB device. Results compared against predicate device hemolysis using relative hemolysis index (RH < 1 acceptance criterion).",
    "modelInfluence": "Medium",
    "name": "COU1: Cardiopulmonary bypass use (Class II)",
    "type": "ContextOfUse"
  },
  "hasValidationResult": [
    {
      "id": "https://uofa.net/synth/validation/rh-ranking-agreement",
      "type": "ValidationResult",
      "name": "Relative hemolysis ranking agreement across 5 flow-speed operating points",
      "description": "CFD-predicted relative hemolysis index (RH) was computed for the five FDA-specified flow-speed combinations using the Giersiepen power-law correlation integrated along Lagrangian particle tracks. Model ordering of the five operating points reproduces the experimental ordering reported in the FDA interlaboratory round-robin hemolysis study on the same pump geometry; Spearman rank correlation rho = 0.90. The round-robin dataset is the most widely cited benchmark for this pump and is treated here as the reference of record for RH-based worst-case identification. Absolute RH values agree within a factor of 2.1, consistent with the spread observed between participating laboratories in the round-robin itself."
    },
    {
      "id": "https://uofa.net/synth/validation/pressure-head-curve",
      "type": "ValidationResult",
      "name": "Pressure-head versus flow curve validation",
      "description": "Predicted pressure rise across the pump at 2500 rpm, 3500 rpm, and matched flow rates agrees with bench measurements within 6% across the operating envelope. This supports credibility of the underlying hydrodynamic solution that drives the hemolysis post-processing.",
