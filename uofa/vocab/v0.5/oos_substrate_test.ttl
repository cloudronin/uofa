@prefix uofa: <https://uofa.net/vocab#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# ============================================================================
# UofA OOS Substrate Test — Vocabulary Additions v0.1
# ============================================================================
# PRD: UofA_OOS_Substrate_Validation_Test_v0_1.md §3.4
# Scope: substrate validation test only. Production use deferred pending the
#        substrate test outcome (see PRD §5 for outcome interpretations).
# ============================================================================

uofa:ModelFormAdequacyClaim a rdfs:Class ;
    rdfs:subClassOf uofa:CredibilityClaim ;
    rdfs:comment "A claim that the model-form choice for a CFD or FEA model is appropriate for the COU. Substrate test scope only; production use deferred." .

uofa:StructuredComparisonStudy a rdfs:Class ;
    rdfs:subClassOf uofa:Evidence ;
    rdfs:comment "A structured artifact comparing alternative model forms (e.g., turbulence models, constitutive models) for a specific COU. Substrate test scope only." .

uofa:hasSupportingEvidence a rdf:Property ;
    rdfs:domain uofa:CredibilityClaim ;
    rdfs:range uofa:Evidence ;
    rdfs:comment "Links a credibility claim to a structured evidence artifact in the bundle. Substrate test scope only." .

uofa:bundleSufficient a rdf:Property ;
    rdfs:domain uofa:CredibilityClaim ;
    rdfs:range xsd:boolean ;
    rdfs:comment "True when the bundle contains structurally present evidence sufficient to warrant the credibility claim. Backward-chaining OOS rule conclusion. Substrate test scope only." .
