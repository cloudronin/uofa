# ============================================================================
# UofA Weakener Detection Rules — v0.2 Schema Alignment
# ============================================================================
# Copyright (c) 2026 Vishnu Vettrivel / crediblesimulation.com
# PROPRIETARY — This rule set is the inference implementation of the UofA
# weakener pattern catalog. The pattern taxonomy (names, IDs, descriptions)
# is open; the rule implementations are proprietary IP.
#
# Engine: Apache Jena GenericRuleReasoner (forward mode or hybrid)
# Schema: UofA v0.2 (uofa_v0_2.jsonld + uofa_shacl.ttl)
# Catalog: uofa_weakener_patterns.md (Khakzad et al. 2024 taxonomy)
# ============================================================================

@prefix uofa: <https://uofa.net/vocab#>.
@prefix prov: <http://www.w3.org/ns/prov#>.
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#>.
@prefix schema: <https://schema.org/>.

# ----------------------------------------------------------------------------
# Internal predicates (hidden from external queries)
# ----------------------------------------------------------------------------
-> hide(uofa:_weakenerFlag).
-> hide(uofa:_severityScore).

# ============================================================================
# CATEGORY 1: EPISTEMIC UNCERTAINTY WEAKENERS
# ============================================================================

# ----------------------------------------------------------------------------
# W-EP-01: Orphan Claim — No Provenance Chain to Evidence
# ----------------------------------------------------------------------------
# A UofA binds a claim, but that claim has no prov:wasDerivedFrom link
# to any Dataset or ValidationResult. The claim is asserted but unsupported.
#
# v0.2 note: Uses uofa:AssuranceClaim (not uofa:Claim) and
#            uofa:bindsClaim (not uofa:assertsClaim)
# ----------------------------------------------------------------------------
[w_ep01:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:bindsClaim ?claim)
    noValue(?claim, prov:wasDerivedFrom)
    ->
    (?uofa uofa:_weakenerFlag 'W-EP-01')
    makeSkolem(?ann, ?uofa, 'W-EP-01', ?claim)
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-EP-01')
    (?ann uofa:severity 'Critical')
    (?ann uofa:affectedNode ?claim)
    (?uofa uofa:hasWeakener ?ann)
]

# ----------------------------------------------------------------------------
# W-EP-02: Broken Provenance — ValidationResult with no generation activity
# ----------------------------------------------------------------------------
# A validation result is referenced by the UofA but has no
# prov:wasGeneratedBy link. The evidence exists but its origin
# is undocumented.
# ----------------------------------------------------------------------------
[w_ep02:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasValidationResult ?result)
    noValue(?result, prov:wasGeneratedBy)
    ->
    makeSkolem(?ann, ?uofa, 'W-EP-02', ?result)
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-EP-02')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?result)
    (?uofa uofa:hasWeakener ?ann)
]


# ============================================================================
# CATEGORY 2: ALEATORY UNCERTAINTY WEAKENERS
# ============================================================================

# ----------------------------------------------------------------------------
# W-AL-01: Missing Uncertainty Quantification
# ----------------------------------------------------------------------------
# A validation result exists but no UQ metadata is linked to it.
# Simulation outputs are presented as deterministic when they should
# carry uncertainty bounds.
#
# v0.2 note: uofa:hasUncertaintyQuantification is NOT yet in the v0.2
#            schema — this is a known gap (see conversion guide v0.3
#            Step 3.6). The rule fires on the absence of this property.
#            For Morrison COU1: fires (no CFD UQ).
#            For Morrison COU2: does NOT fire (Monte Carlo UQ present).
# ----------------------------------------------------------------------------
[w_al01:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasValidationResult ?result)
    noValue(?result, uofa:hasUncertaintyQuantification)
    ->
    (?uofa uofa:_weakenerFlag 'W-AL-01')
    makeSkolem(?ann, ?uofa, 'W-AL-01', ?result)
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-AL-01')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?result)
    (?uofa uofa:hasWeakener ?ann)
]


# ============================================================================
# CATEGORY 3: ONTOLOGICAL UNCERTAINTY WEAKENERS
# ============================================================================

# ----------------------------------------------------------------------------
# W-ON-01: Missing Context of Use
# ----------------------------------------------------------------------------
# A UofA exists but has no hasContextOfUse link. Evidence is not tied
# to any specific decision context.
#
# Note: This is also enforced by SHACL (MinimalBody sh:minCount 1),
#       but the rule fires independently for weakener density counting.
# ----------------------------------------------------------------------------
[w_on01:
    (?uofa rdf:type uofa:UnitOfAssurance)
    noValue(?uofa, uofa:hasContextOfUse)
    ->
    makeSkolem(?ann, ?uofa, 'W-ON-01')
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-ON-01')
    (?ann uofa:severity 'Critical')
    (?ann uofa:affectedNode ?uofa)
    (?uofa uofa:hasWeakener ?ann)
]


# ============================================================================
# CATEGORY 4: ARGUMENT UNCERTAINTY WEAKENERS (Defeaters D1-D5)
# ============================================================================

# ----------------------------------------------------------------------------
# W-AR-01: Undermining Defeater (D1) — No Acceptance Criteria
# ----------------------------------------------------------------------------
# CredibilityFactor nodes have requiredLevel and achievedLevel but no
# machine-encoded acceptance rationale explaining WHY that level was
# required. The evidence base is ungrounded.
#
# v0.2 note: uofa:acceptanceCriteria is NOT in v0.2 schema (gap).
# ----------------------------------------------------------------------------
[w_ar01:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasCredibilityFactor ?factor)
    (?factor uofa:requiredLevel ?req)
    noValue(?factor, uofa:acceptanceCriteria)
    ->
    makeSkolem(?ann, ?uofa, 'W-AR-01', ?factor)
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-AR-01')
    (?ann uofa:severity 'Critical')
    (?ann uofa:affectedNode ?uofa)
    (?uofa uofa:hasWeakener ?ann)
]

# ----------------------------------------------------------------------------
# W-AR-02: Rebutting Defeater (D2) — Contradictory Result Ignored
# ----------------------------------------------------------------------------
# The decision record says "Accepted" but a CredibilityFactor shows
# achievedLevel < requiredLevel. Counter-evidence exists but the
# decision contradicts it.
#
# v0.2 note: Uses hasDecisionRecord -> DecisionRecord with outcome
#            property (not the old uofa:decision string).
# ----------------------------------------------------------------------------
[w_ar02:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasDecisionRecord ?dr)
    (?dr uofa:outcome 'Accepted')
    (?uofa uofa:hasCredibilityFactor ?factor)
    (?factor uofa:requiredLevel ?req)
    (?factor uofa:achievedLevel ?ach)
    lessThan(?ach, ?req)
    ->
    makeSkolem(?ann, ?uofa, 'W-AR-02', ?factor)
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-AR-02')
    (?ann uofa:severity 'Critical')
    (?ann uofa:affectedNode ?factor)
    (?uofa uofa:hasWeakener ?ann)
]

# ----------------------------------------------------------------------------
# W-AR-05: Undercutting Defeater (D5) — Comparator Absence
# ----------------------------------------------------------------------------
# A validation result has no prov:wasDerivedFrom link to any comparator
# or reference entity. The result is produced but not compared against
# anything.
# ----------------------------------------------------------------------------
[w_ar05:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasValidationResult ?result)
    noValue(?result, prov:wasDerivedFrom)
    ->
    makeSkolem(?ann, ?uofa, 'W-AR-05', ?result)
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-AR-05')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?result)
    (?uofa uofa:hasWeakener ?ann)
]


# ============================================================================
# CATEGORY 5: STRUCTURAL INTEGRITY WEAKENERS
# ============================================================================

# ----------------------------------------------------------------------------
# W-SI-01: Missing Digital Signature
# ----------------------------------------------------------------------------
[w_si01:
    (?uofa rdf:type uofa:UnitOfAssurance)
    noValue(?uofa, uofa:signature)
    ->
    makeSkolem(?ann, ?uofa, 'W-SI-01')
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-SI-01')
    (?ann uofa:severity 'Medium')
    (?ann uofa:affectedNode ?uofa)
    (?uofa uofa:hasWeakener ?ann)
]

# ----------------------------------------------------------------------------
# W-SI-02: Incomplete Profile — missing required bindings
# ----------------------------------------------------------------------------
[w_si02_no_req:
    (?uofa rdf:type uofa:UnitOfAssurance)
    noValue(?uofa, uofa:bindsRequirement)
    ->
    makeSkolem(?ann, ?uofa, 'W-SI-02', 'bindsRequirement')
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-SI-02')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?uofa)
    (?uofa uofa:hasWeakener ?ann)
]

[w_si02_no_result:
    (?uofa rdf:type uofa:UnitOfAssurance)
    noValue(?uofa, uofa:hasValidationResult)
    ->
    makeSkolem(?ann, ?uofa, 'W-SI-02', 'hasValidationResult')
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-SI-02')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?uofa)
    (?uofa uofa:hasWeakener ?ann)
]


# ============================================================================
# COMPOUND RULES — These demonstrate inference BEYOND standalone SPARQL
# ============================================================================
# These rules reason across multiple weakener detections and credibility
# factor assessments. They produce second-order annotations that require
# chained inference — the key capability differentiator vs. SPARQL queries.
# ============================================================================

# ----------------------------------------------------------------------------
# COMPOUND-01: Risk Escalation — Critical + High weakeners coexist
# ----------------------------------------------------------------------------
# When a UofA has BOTH a Critical-severity AND a High-severity weakener,
# the combination represents a compounded credibility risk that neither
# gap alone conveys. This is the central "rules > queries" demo point.
#
# Morrison COU1: W-EP-01 (Critical) + W-AL-01 (High) → fires
# Morrison COU2: W-AR-01 (Critical) but no W-AL-01 → different profile
# ----------------------------------------------------------------------------
[compound_escalation:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasWeakener ?w1)
    (?w1 uofa:severity 'Critical')
    (?w1 uofa:patternId ?pid1)
    (?uofa uofa:hasWeakener ?w2)
    (?w2 uofa:severity 'High')
    (?w2 uofa:patternId ?pid2)
    notEqual(?w1, ?w2)
    ->
    makeSkolem(?esc, ?uofa, 'COMPOUND-01', ?pid1, ?pid2)
    (?esc rdf:type uofa:WeakenerAnnotation)
    (?esc uofa:patternId 'COMPOUND-01')
    (?esc uofa:severity 'Critical')
    (?esc uofa:affectedNode ?uofa)
    (?esc uofa:escalationSource ?w1)
    (?esc uofa:escalationSource ?w2)
    (?uofa uofa:hasWeakener ?esc)
]

# ----------------------------------------------------------------------------
# COMPOUND-02: Factor Credibility Erosion
# ----------------------------------------------------------------------------
# When a CredibilityFactor meets its target (achievedLevel >= requiredLevel)
# BUT the UofA also has a weakener affecting the evidence that supports
# that factor assessment, the factor's credibility is eroded even though
# the numeric level looks adequate. This detects "false confidence."
#
# Example: Morrison COU1 discretization error is achievedLevel=3,
# requiredLevel=3 (pass). But W-AL-01 flags missing UQ on the hemolysis
# comparison result — meaning the "pass" may not account for numerical
# uncertainty propagation. The factor passes on paper but the evidence
# is weakened.
# ----------------------------------------------------------------------------
[compound_factor_erosion:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasCredibilityFactor ?factor)
    (?factor uofa:achievedLevel ?ach)
    (?factor uofa:requiredLevel ?req)
    ge(?ach, ?req)
    (?uofa uofa:hasWeakener ?w)
    (?w uofa:severity 'High')
    (?w uofa:affectedNode ?affected)
    (?uofa uofa:hasValidationResult ?affected)
    ->
    makeSkolem(?erosion, ?uofa, 'COMPOUND-02', ?factor, ?w)
    (?erosion rdf:type uofa:WeakenerAnnotation)
    (?erosion uofa:patternId 'COMPOUND-02')
    (?erosion uofa:severity 'Medium')
    (?erosion uofa:affectedNode ?factor)
    (?erosion uofa:erosionCause ?w)
    (?uofa uofa:hasWeakener ?erosion)
]

# ----------------------------------------------------------------------------
# COMPOUND-03: Assurance Level Override
# ----------------------------------------------------------------------------
# If assuranceLevel is "Medium" or "High" but the UofA has any Critical
# weakener, flag a contradiction between the declared assurance level
# and the detected evidence quality.
# ----------------------------------------------------------------------------
[compound_assurance_override:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:assuranceLevel ?level)
    notEqual(?level, 'Low')
    (?uofa uofa:hasWeakener ?w)
    (?w uofa:severity 'Critical')
    (?w uofa:patternId ?pid)
    ->
    makeSkolem(?override, ?uofa, 'COMPOUND-03', ?pid)
    (?override rdf:type uofa:WeakenerAnnotation)
    (?override uofa:patternId 'COMPOUND-03')
    (?override uofa:severity 'High')
    (?override uofa:affectedNode ?uofa)
    (?override uofa:overriddenLevel ?level)
    (?uofa uofa:hasWeakener ?override)
]
