{
  "$schema": "https://uofa.net/schemas/pack-manifest/v1.json",
  "name": "surrogate",
  "version": "0.1.0",
  "description": "Physics-based AI/ML surrogate-credibility pack (ROM, PINN, operator-learning, data-driven-emulator, ML-closure). Checks evidence completeness and auditability, not model correctness. Consumes measured evidence from the Surrogate Interrogation Probe (SIP). (v0.1)",
  "standards": ["ASME-VVUQ-20-2009", "ASME-VV40-2018", "PCMM-SAND2007-5948"],
  "author": "Vishnu Vettrivel",
  "license": "Apache-2.0",
  "coreCompatibility": ">=0.5.0",
  "capabilities": [
    {
      "leg": "detection",
      "capabilityId": "detection:surrogate-weakeners",
      "targetInterface": "detection",
      "interfaceVersion": "1.0",
      "firewallPlacement": "measurement-region",
      "provenance": { "stampsPackVersion": true },
      "payload": {
        "shapes": "shapes/surrogate_shapes.ttl",
        "rules": "rules/surrogate_weakener.rules",
        "patternIds": ["W-SURR-01", "W-SURR-02", "W-SURR-03"],
        "oos": { "enabled": true, "rule_files": ["rules/oos/oos_v0.1.rules"] },
        "derivations": { "enabled": true, "files": ["derivations/surrogate_derivations_v0.1.sparql"] }
      }
    }
  ]
}
