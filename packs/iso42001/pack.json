{
  "$schema": "https://uofa.net/schemas/pack-manifest/v1.json",
  "name": "iso42001",
  "version": "0.5.0",
  "description": "ISO/IEC 42001:2023 AI Management System (AIMS) credibility pack with productive-OOS bundle-sufficiency framing + derivation pre-pass for analytic-predicate materialization (v0.5).",
  "standards": ["ISO-IEC-42001-2023", "NIST-AI-RMF-1.0"],
  "author": "Vishnu Vettrivel",
  "license": "Apache-2.0",
  "coreCompatibility": ">=0.5.0",
  "capabilities": [
    {
      "leg": "detection",
      "capabilityId": "detection:iso42001-aims-weakeners",
      "targetInterface": "detection",
      "interfaceVersion": "1.0",
      "firewallPlacement": "measurement-region",
      "provenance": { "stampsPackVersion": true },
      "payload": {
        "shapes": "shapes/iso42001_shapes.ttl",
        "rules": "rules/iso42001_weakener.rules",
        "patternIds": [
          "W-AIMS-AUDIT-STALE", "W-AIMS-CROSSWALK-INVALID", "W-AIMS-DATA-DRIFT-UNDETECTED",
          "W-AIMS-DATA-LINEAGE-BROKEN", "W-AIMS-DEPLOYMENT-DRIFT", "W-AIMS-IMPACT-SCOPE",
          "W-AIMS-IMPACT-STAKEHOLDER", "W-AIMS-INCIDENT-UNCLOSED", "W-AIMS-MODEL-EVAL-SCOPE",
          "W-AIMS-MODEL-EVAL-STALE", "W-AIMS-OBJECTIVE-UNMEASURED", "W-AIMS-ROLE-UNASSIGNED",
          "W-AL-02", "W-AR-02", "W-PROV-01"
        ],
        "oos": { "enabled": true, "rule_files": ["rules/oos/oos_v0.1.rules"] },
        "derivations": { "enabled": true, "files": ["derivations/iso42001_derivations_v0.1.sparql"] }
      }
    }
  ]
}
