{
  "$schema": "https://uofa.net/schemas/pack-manifest/v1.json",
  "name": "mrm-nist",
  "version": "0.1.0",
  "description": "NIST AI RMF model-card documentation factor taxonomy (17 factors, grouped by GOVERN/MAP/MEASURE/MANAGE). Presence-only completeness profile, no risk tiers. The MRM documentation profile — the documentation slice of model risk management, not the full lifecycle program. Runs the 23 core weakener patterns with no new rules.",
  "standards": ["NIST-AI-RMF-1.0"],
  "author": "Vishnu Vettrivel",
  "license": "Apache-2.0",
  "coreCompatibility": ">=0.5.0",
  "prompt": "prompts/mrm_nist_extract_prompt.txt",
  "factors": 17,
  "capabilities": [
    {
      "leg": "detection",
      "capabilityId": "detection:mrm-nist-factors",
      "targetInterface": "detection",
      "interfaceVersion": "1.0",
      "firewallPlacement": "measurement-region",
      "provenance": { "stampsPackVersion": true },
      "payload": {
        "shapes": "shapes/mrm_nist_shapes.ttl",
        "patternIds": [],
        "oos": { "enabled": false, "rule_files": [] },
        "factorFocus": {
          "W-ON-02": ["Out-of-scope use"],
          "W-AL-01": ["Evaluation metrics"],
          "W-AR-05": ["Evaluation methodology"]
        }
      }
    }
  ]
}
