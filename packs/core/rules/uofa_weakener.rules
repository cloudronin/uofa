#    notEqual(?wpid, 'COMPOUND-01')
#    notEqual(?wpid, 'COMPOUND-02')
#    notEqual(?wpid, 'COMPOUND-03')
#    (?w uofa:affectedNode ?affected)
#    (?uofa uofa:hasValidationResult ?affected)
#    makeSkolem(?erosion, ?uofa, 'COMPOUND-02', ?factor, ?w)
#    ->
#    (?erosion rdf:type uofa:WeakenerAnnotation)
#    (?erosion uofa:patternId 'COMPOUND-02')
#    (?erosion uofa:severity 'Medium')
#    (?erosion uofa:affectedNode ?factor)
#    (?erosion uofa:erosionCause ?w)
#    (?uofa uofa:hasWeakener ?erosion)
#]

# COMPOUND-03: Assurance Level Override
[compound_assurance_override:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:assuranceLevel ?level)
    notEqual(?level, 'Low')
    (?uofa uofa:hasWeakener ?w)
    (?w uofa:severity 'Critical')
    (?w uofa:patternId ?pid)
    notEqual(?pid, 'COMPOUND-01')
    notEqual(?pid, 'COMPOUND-02')
    notEqual(?pid, 'COMPOUND-03')
    makeSkolem(?override, ?uofa, 'COMPOUND-03', ?pid)
    ->
    (?override rdf:type uofa:WeakenerAnnotation)
    (?override uofa:patternId 'COMPOUND-03')
    (?override uofa:severity 'High')
    (?override uofa:affectedNode ?uofa)
    (?override uofa:overriddenLevel ?level)
    (?override schema:description 'Assurance level is not Low, yet Critical weakeners exist — stated assurance level may be overstated.')
    (?uofa uofa:hasWeakener ?override)
]
