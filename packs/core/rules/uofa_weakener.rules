# ============================================================================
# UofA Weakener Detection Rules — v0.5 Schema Alignment
# ============================================================================
# Copyright (c) 2026 Vishnu Vettrivel / crediblesimulation.com
# PROPRIETARY — This rule set is the inference implementation of the UofA
# weakener pattern catalog. The pattern taxonomy (names, IDs, descriptions)
# is open; the rule implementations are proprietary IP.
#
# Engine: Apache Jena GenericRuleReasoner (FORWARD_RETE mode)
# Schema: UofA v0.5 (v0.5.jsonld + uofa_shacl.ttl)
# Catalog: uofa_weakener_patterns.md (Khakzad et al. 2024 taxonomy)
#
# NOTE: makeSkolem must be in the rule BODY (before ->) in RETE mode.
#       hide() is not available in pure forward mode.
# ============================================================================

@prefix uofa: <https://uofa.net/vocab#>.
@prefix prov: <http://www.w3.org/ns/prov#>.
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#>.
@prefix schema: <https://schema.org/>.

# ============================================================================
# CATEGORY 1: EPISTEMIC UNCERTAINTY WEAKENERS
# ============================================================================

# W-EP-01: Orphan Claim — No Provenance Chain to Evidence
[w_ep01:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:bindsClaim ?claim)
    noValue(?claim, prov:wasDerivedFrom)
    makeSkolem(?ann, ?uofa, 'W-EP-01', ?claim)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-EP-01')
    (?ann uofa:severity 'Critical')
    (?ann uofa:affectedNode ?claim)
    (?ann schema:description 'Claim has no prov:wasDerivedFrom link to evidence — provenance chain is broken.')
    (?uofa uofa:hasWeakener ?ann)
]

# W-EP-02: Broken Provenance — ValidationResult with no generation activity
[w_ep02:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasValidationResult ?result)
    noValue(?result, prov:wasGeneratedBy)
    makeSkolem(?ann, ?uofa, 'W-EP-02', ?result)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-EP-02')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?result)
    (?ann schema:description 'Validation result has no prov:wasGeneratedBy — generation activity is missing.')
    (?uofa uofa:hasWeakener ?ann)
]

# W-EP-03: Stale Input Data — dataset consumed predates current model revision
[w_ep03:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:modelRevisionDate ?revDate)
    (?uofa uofa:hasValidationResult ?result)
    (?result prov:wasGeneratedBy ?activity)
    (?activity prov:used ?dataset)
    (?dataset uofa:dataVintage ?vintage)
    lessThan(?vintage, ?revDate)
    makeSkolem(?ann, ?uofa, 'W-EP-03', ?dataset)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-EP-03')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?dataset)
    (?ann schema:description 'Input dataset vintage predates the current model revision date — input data may be stale relative to the model it exercises.')
    (?uofa uofa:hasWeakener ?ann)
]

# W-EP-04: Unassessed Factor at Elevated Risk
[w_ep04:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:modelRiskLevel ?mrl)
    greaterThan(?mrl, 2)
    (?uofa uofa:hasCredibilityFactor ?factor)
    (?factor uofa:factorStatus 'not-assessed')
    makeSkolem(?ann, ?uofa, 'W-EP-04', ?factor)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-EP-04')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?factor)
    (?ann schema:description 'Credibility factor is not assessed but model risk level exceeds 2 — unassessed factors at elevated risk weaken the credibility argument.')
    (?uofa uofa:hasWeakener ?ann)
]

# ============================================================================
# CATEGORY 2: ALEATORY UNCERTAINTY WEAKENERS
# ============================================================================

# W-AL-01: Missing Uncertainty Quantification
[w_al01:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasValidationResult ?result)
    noValue(?result, uofa:hasUncertaintyQuantification)
    makeSkolem(?ann, ?uofa, 'W-AL-01', ?result)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-AL-01')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?result)
    (?ann schema:description 'Validation result has no uncertainty quantification — aleatory uncertainty is uncharacterized.')
    (?uofa uofa:hasWeakener ?ann)
]

# W-AL-02: Sensitivity Gap — UQ present but no documented sensitivity analysis
[w_al02:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasValidationResult ?result)
    (?result uofa:hasUncertaintyQuantification ?uq)
    noValue(?uofa, uofa:hasSensitivityAnalysis)
    makeSkolem(?ann, ?uofa, 'W-AL-02', ?uofa)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-AL-02')
    (?ann uofa:severity 'Medium')
    (?ann uofa:affectedNode ?uofa)
    (?ann schema:description 'Uncertainty quantification is reported but no sensitivity analysis is linked — the drivers of uncertainty are undocumented.')
    (?uofa uofa:hasWeakener ?ann)
]

# ============================================================================
# CATEGORY 3: ONTOLOGICAL UNCERTAINTY WEAKENERS
# ============================================================================

# W-ON-01: Missing Context of Use
[w_on01:
    (?uofa rdf:type uofa:UnitOfAssurance)
    noValue(?uofa, uofa:hasContextOfUse)
    makeSkolem(?ann, ?uofa, 'W-ON-01')
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-ON-01')
    (?ann uofa:severity 'Critical')
    (?ann uofa:affectedNode ?uofa)
    (?ann schema:description 'UofA has no Context of Use — intended use and risk context are undefined.')
    (?uofa uofa:hasWeakener ?ann)
]

# W-ON-02: Unbounded Applicability — COU declared but no envelope
[w_on02:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasContextOfUse ?cou)
    noValue(?cou, uofa:hasApplicabilityConstraint)
    noValue(?cou, uofa:hasOperatingEnvelope)
    makeSkolem(?ann, ?uofa, 'W-ON-02', ?cou)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-ON-02')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?cou)
    (?ann schema:description 'Context of Use has neither an applicability constraint nor an operating envelope — the COU is declared but its boundary of validity is undocumented.')
    (?uofa uofa:hasWeakener ?ann)
]

# ============================================================================
# CATEGORY 4: ARGUMENT UNCERTAINTY WEAKENERS (Defeaters D1-D5)
# ============================================================================

# W-AR-01: Undermining Defeater (D1) — No Acceptance Criteria
[w_ar01:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasCredibilityFactor ?factor)
    (?factor uofa:requiredLevel ?req)
    noValue(?factor, uofa:acceptanceCriteria)
    makeSkolem(?ann, ?uofa, 'W-AR-01', ?factor)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-AR-01')
    (?ann uofa:severity 'Critical')
    (?ann uofa:affectedNode ?uofa)
    (?ann schema:description 'Credibility factor has a required level but no acceptance criteria — basis for the requirement is unsupported.')
    (?uofa uofa:hasWeakener ?ann)
]

# W-AR-02: Rebutting Defeater (D2) — Contradictory Result Ignored
[w_ar02:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasDecisionRecord ?dr)
    (?dr uofa:outcome 'Accepted')
    (?uofa uofa:hasCredibilityFactor ?factor)
    (?factor uofa:requiredLevel ?req)
    (?factor uofa:achievedLevel ?ach)
    lessThan(?ach, ?req)
    makeSkolem(?ann, ?uofa, 'W-AR-02', ?factor)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-AR-02')
    (?ann uofa:severity 'Critical')
    (?ann uofa:affectedNode ?factor)
    (?ann schema:description 'Credibility factor achievedLevel is below requiredLevel, yet the decision outcome is Accepted — contradictory result ignored.')
    (?uofa uofa:hasWeakener ?ann)
]

# W-AR-03: Undercutting Defeater (D3) — Inference Method Mismatch
# Requirement specifies a required verification method; the activity that
# produced the supporting result used a different activityType.
[w_ar03:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:bindsRequirement ?req)
    (?req uofa:requiredVerificationMethod ?required)
    (?uofa uofa:hasValidationResult ?result)
    (?result prov:wasGeneratedBy ?activity)
    (?activity uofa:activityType ?actual)
    notEqual(?required, ?actual)
    makeSkolem(?ann, ?uofa, 'W-AR-03', ?activity)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-AR-03')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?activity)
    (?ann schema:description 'Requirement requires a specific verification method but the supporting activity used a different activityType — evidence does not answer the question the requirement asked.')
    (?uofa uofa:hasWeakener ?ann)
]

# W-AR-04: Undercutting Defeater (D4) — Model Version Drift
# Result was generated from a configuration whose modelVersion differs from
# the UofA's currentModelVersion — evidence no longer applies to the model.
[w_ar04:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:currentModelVersion ?vCur)
    (?uofa uofa:hasValidationResult ?result)
    (?result prov:wasGeneratedBy ?act)
    (?act prov:used ?cfg)
    (?cfg uofa:modelVersion ?vVal)
    notEqual(?vVal, ?vCur)
    makeSkolem(?ann, ?uofa, 'W-AR-04', ?cfg)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-AR-04')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?cfg)
    (?ann schema:description 'ModelConfiguration was validated at a modelVersion that differs from the UofA currentModelVersion — validation evidence may not apply to the current model.')
    (?uofa uofa:hasWeakener ?ann)
]

# W-AR-05: Undercutting Defeater (D5) — Comparator Absence
[w_ar05:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasValidationResult ?result)
    noValue(?result, uofa:comparedAgainst)
    makeSkolem(?ann, ?uofa, 'W-AR-05', ?result)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-AR-05')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?result)
    (?ann schema:description 'Validation result has no comparedAgainst link — comparator data source is absent.')
    (?uofa uofa:hasWeakener ?ann)
]

# ============================================================================
# CATEGORY 5: STRUCTURAL INTEGRITY WEAKENERS
# ============================================================================

# W-SI-01: Missing Digital Signature
[w_si01:
    (?uofa rdf:type uofa:UnitOfAssurance)
    noValue(?uofa, uofa:signature)
    makeSkolem(?ann, ?uofa, 'W-SI-01')
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-SI-01')
    (?ann uofa:severity 'Medium')
    (?ann uofa:affectedNode ?uofa)
    (?ann schema:description 'UofA has no digital signature — structural integrity cannot be verified.')
    (?uofa uofa:hasWeakener ?ann)
]

# W-SI-02: Incomplete Profile — missing required bindings
[w_si02_no_req:
    (?uofa rdf:type uofa:UnitOfAssurance)
    noValue(?uofa, uofa:bindsRequirement)
    makeSkolem(?ann, ?uofa, 'W-SI-02', 'bindsRequirement')
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-SI-02')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?uofa)
    (?ann schema:description 'UofA is missing bindsRequirement — incomplete profile binding.')
    (?uofa uofa:hasWeakener ?ann)
]

[w_si02_no_result:
    (?uofa rdf:type uofa:UnitOfAssurance)
    noValue(?uofa, uofa:hasValidationResult)
    makeSkolem(?ann, ?uofa, 'W-SI-02', 'hasValidationResult')
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-SI-02')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?uofa)
    (?ann schema:description 'UofA is missing hasValidationResult — incomplete profile binding.')
    (?uofa uofa:hasWeakener ?ann)
]

# ============================================================================
# CATEGORY 6: UofA-NATIVE CONSISTENCY WEAKENERS (W-CON)
# ============================================================================

# W-CON-01: Factor-Decision Consistency — Accepted decision with unrated factors
# UofA decision outcome is Accepted, but one or more credibility factors have
# neither requiredLevel nor achievedLevel declared. A decision cannot be
# justified on factor levels that were never established.
[w_con01:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasDecisionRecord ?dr)
    (?dr uofa:outcome 'Accepted')
    (?uofa uofa:hasCredibilityFactor ?f)
    noValue(?f, uofa:requiredLevel)
    noValue(?f, uofa:achievedLevel)
    makeSkolem(?ann, ?uofa, 'W-CON-01', ?f)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-CON-01')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?f)
    (?ann schema:description 'Decision is Accepted but a credibility factor has neither requiredLevel nor achievedLevel — the acceptance rests on an unestablished factor.')
    (?uofa uofa:hasWeakener ?ann)
]

# W-CON-04: Profile-Structure Consistency — Complete profile missing SensitivityAnalysis
# Narrow-scoped for v0.5: the spec §4.6 proposes multiple structural checks for
# ProfileComplete, but most overlap with SHACL required fields (enforced at
# validation time, not as a weakener). SensitivityAnalysis is the clearest
# Complete-expected-but-SHACL-optional element; see docs/v0.5-morrison-deltas.md
# for the full enumeration and the v0.6-deferred branches.
[w_con04_no_sa:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:conformsToProfile uofa:ProfileComplete)
    noValue(?uofa, uofa:hasSensitivityAnalysis)
    makeSkolem(?ann, ?uofa, 'W-CON-04', 'no-sensitivity-analysis')
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-CON-04')
    (?ann uofa:severity 'Medium')
    (?ann uofa:affectedNode ?uofa)
    (?ann schema:description 'UofA conforms to ProfileComplete but declares no SensitivityAnalysis — a Complete profile is structurally expected to document sensitivity analysis alongside uncertainty quantification.')
    (?uofa uofa:hasWeakener ?ann)
]

# W-CON-03: Future-dated Evidence — evidence dated after the UofA signature
[w_con03:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:signatureTimestamp ?sig)
    (?uofa uofa:hasEvidence ?ev)
    (?ev uofa:evidenceTimestamp ?evt)
    greaterThan(?evt, ?sig)
    makeSkolem(?ann, ?uofa, 'W-CON-03', ?ev)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-CON-03')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?ev)
    (?ann schema:description 'Evidence timestamp is later than the UofA signature timestamp — evidence was created after the UofA was signed, either a clock anomaly or an uncounted update.')
    (?uofa uofa:hasWeakener ?ann)
]

# W-CON-02: Identifier Resolution (local-graph, v0.5). Fires when a UofA
# references an identifier via uofa:referencesIdentifier whose target IRI
# neither resolves locally (has no declared rdf:type — the canonical signal
# that a resource is defined within the graph) nor carries a schema:url
# external-fetch hint. Remote HTTP resolution is out of scope for v0.5
# (see UofA_v052_Single_Engine_Refactor_Spec_v1_0.md §2).
#
# Semantic note: rdf:type is used as the "local subject" proxy in place of
# rdflib's g.subjects() set because materializing a per-subject marker via
# a forward-chaining rule triggers a RETE ordering bug (noValue evaluates
# before the marker lands — the same class of bug that motivated v0.5.1's
# Python detector). Every meaningful UofA node declares rdf:type; unresolved
# identifiers do not. Severity Medium mirrors v0.5.1 semantics.
[w_con02:
    (?subj uofa:referencesIdentifier ?obj)
    noValue(?obj, rdf:type)
    noValue(?obj, schema:url)
    makeSkolem(?ann, ?subj, 'W-CON-02', ?obj)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-CON-02')
    (?ann uofa:severity 'Medium')
    (?ann uofa:affectedNode ?subj)
    (?ann schema:description 'UofA references an identifier whose target does not resolve within the graph and has no documented external-fetch hint.')
    (?subj uofa:hasWeakener ?ann)
]

# W-CON-05: Activity-Evidence Consistency. Fires High on a VerificationActivity
# declared via uofa:hasVerificationActivity when no Evidence in the graph
# links to it via prov:wasGeneratedBy — the activity is a procedural
# placeholder rather than real verification.
#
# Option A (single-stage, no marker materialization) per v0.5.2 spec §5.2.
# The historical two-stage port hit a forward-RETE ordering bug; this
# collapses the match into one rule body that only references INPUT data
# triples (no derived intermediate). noValue on an unbound ?evidence acts
# as an existential: succeeds when NO triple of shape
# (any-subject prov:wasGeneratedBy ?act) exists in the graph.
[w_con05:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasVerificationActivity ?act)
    noValue(?evidence, prov:wasGeneratedBy, ?act)
    makeSkolem(?ann, ?uofa, 'W-CON-05', ?act)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-CON-05')
    (?ann uofa:severity 'High')
    (?ann uofa:affectedNode ?act)
    (?ann schema:description 'VerificationActivity is declared on the UofA but no Evidence is linked via prov:wasGeneratedBy — the activity is a procedural placeholder rather than real verification.')
    (?uofa uofa:hasWeakener ?ann)
]

# ============================================================================
# W-PROV-01: Provenance Chain Incomplete (ported from Python at v0.5.2 §5.3)
# ============================================================================
# Strategy: three-rule chain (seed + extend × 3 + detect) implements the
# upstream BFS that the Python detector performed over rdflib. Transitive
# closure is materialized as uofa:_provScope triples (runtime-only, not in
# the v0.5 context or SHACL shapes).
#
#   Seed:   every claim is "in provenance scope" for its owning UofA.
#   Extend: for any node in scope reached via wasDerivedFrom / wasGeneratedBy /
#           prov:used, mark its upstream target as also in scope.
#   Detect: for any node in scope that (a) is not itself a claim, (b) has no
#           upstream edge of any of the three types, and (c) is not marked
#           uofa:isFoundationalEvidence, fire W-PROV-01 Critical.
#
# RETE-safety: the detector rule's noValue clauses test ORIGINAL input
# triples (prov:wasDerivedFrom / wasGeneratedBy / prov:used / bindsClaim /
# isFoundationalEvidence) — not the derived _provScope triples — so there is
# no ordering race with forward-chained materialization.

[w_prov01_seed_claim:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:bindsClaim ?claim)
    -> (?claim uofa:_provScope ?uofa)
]

[w_prov01_extend_derived:
    (?a uofa:_provScope ?uofa)
    (?a prov:wasDerivedFrom ?b)
    -> (?b uofa:_provScope ?uofa)
]

[w_prov01_extend_generated:
    (?a uofa:_provScope ?uofa)
    (?a prov:wasGeneratedBy ?b)
    -> (?b uofa:_provScope ?uofa)
]

[w_prov01_extend_used:
    (?a uofa:_provScope ?uofa)
    (?a prov:used ?b)
    -> (?b uofa:_provScope ?uofa)
]

[w_prov01_detect:
    (?node uofa:_provScope ?uofa)
    noValue(?node, prov:wasDerivedFrom)
    noValue(?node, prov:wasGeneratedBy)
    noValue(?node, prov:used)
    noValue(?anyU, uofa:bindsClaim, ?node)
    noValue(?node, uofa:isFoundationalEvidence, 'true'^^xsd:boolean)
    makeSkolem(?ann, ?uofa, 'W-PROV-01', ?node)
    ->
    (?ann rdf:type uofa:WeakenerAnnotation)
    (?ann uofa:patternId 'W-PROV-01')
    (?ann uofa:severity 'Critical')
    (?ann uofa:affectedNode ?node)
    (?ann schema:description 'Provenance chain terminates at a node that has no upstream derivation/generation/use edge and is not marked uofa:isFoundationalEvidence=true — chain is incomplete.')
    (?uofa uofa:hasWeakener ?ann)
]

# ============================================================================
# COMPOUND RULES — Chained inference BEYOND standalone SPARQL
# ============================================================================
# Guards use notEqual against compound IDs instead of regex (RETE-compatible).

# COMPOUND-01: Risk Escalation — Critical + High weakeners coexist
[compound_escalation:
    (?uofa rdf:type uofa:UnitOfAssurance)
    (?uofa uofa:hasWeakener ?w1)
    (?w1 uofa:severity 'Critical')
    (?w1 uofa:patternId ?pid1)
    notEqual(?pid1, 'COMPOUND-01')
    notEqual(?pid1, 'COMPOUND-02')
    notEqual(?pid1, 'COMPOUND-03')
    (?uofa uofa:hasWeakener ?w2)
    (?w2 uofa:severity 'High')
    (?w2 uofa:patternId ?pid2)
    notEqual(?pid2, 'COMPOUND-01')
    notEqual(?pid2, 'COMPOUND-02')
    notEqual(?pid2, 'COMPOUND-03')
    notEqual(?w1, ?w2)
    makeSkolem(?esc, ?uofa, 'COMPOUND-01', ?pid1, ?pid2)
    ->
    (?esc rdf:type uofa:WeakenerAnnotation)
    (?esc uofa:patternId 'COMPOUND-01')
    (?esc uofa:severity 'Critical')
    (?esc uofa:affectedNode ?uofa)
    (?esc uofa:escalationSource ?w1)
    (?esc uofa:escalationSource ?w2)
    (?esc schema:description 'Critical and High severity weakeners coexist — compounding risk escalation.')
    (?uofa uofa:hasWeakener ?esc)
]

# COMPOUND-02: Factor Credibility Erosion
#[compound_factor_erosion:
#    (?uofa rdf:type uofa:UnitOfAssurance)
#    (?uofa uofa:hasCredibilityFactor ?factor)
#    (?factor uofa:achievedLevel ?ach)
#    (?factor uofa:requiredLevel ?req)
#    ge(?ach, ?req)
#    (?uofa uofa:hasWeakener ?w)
