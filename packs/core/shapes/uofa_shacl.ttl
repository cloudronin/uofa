@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix uofa: <https://uofa.net/vocab#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix schema: <https://schema.org/> .

################################################################
# Dispatcher: pick Minimal vs Complete constraints by profile
################################################################
uofa:UnitOfAssurance_ProfileShape
  a sh:NodeShape ;
  sh:targetClass uofa:UnitOfAssurance ;
  # Must declare a known profile
  sh:property [
    sh:path uofa:conformsToProfile ;
    sh:in ( uofa:ProfileMinimal uofa:ProfileComplete ) ;
    sh:minCount 1 ;
    sh:message "conformsToProfile must be ProfileMinimal or ProfileComplete." ;
  ] ;
  # EITHER MinimalBody when profile = Minimal OR CompleteBody when profile = Complete
  sh:or (
    [
      sh:property [
        sh:path uofa:conformsToProfile ;
        sh:hasValue uofa:ProfileMinimal
      ] ;
      sh:node uofa:UnitOfAssurance_MinimalBody
    ]
    [
      sh:property [
        sh:path uofa:conformsToProfile ;
        sh:hasValue uofa:ProfileComplete
      ] ;
      sh:node uofa:UnitOfAssurance_CompleteBody
    ]
  ) .

################################################################
# Minimal body (applies only when ProfileMinimal is chosen)
################################################################
uofa:UnitOfAssurance_MinimalBody
  a sh:NodeShape ;
  sh:property [
    sh:path uofa:bindsRequirement ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:message "Minimal: must bind at least one Requirement (IRI)." ;
  ] ;
  sh:property [
    sh:path uofa:hasContextOfUse ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:message "Minimal: must declare a Context of Use (V&V 40 COU)." ;
  ] ;
  sh:property [
    sh:path uofa:hasValidationResult ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:message "Minimal: must include at least one ValidationResult (IRI)." ;
  ] ;
  sh:property [
    sh:path prov:generatedAtTime ;
    sh:datatype xsd:dateTime ;
    sh:minCount 1 ;
    sh:message "Minimal: must have generation timestamp." ;
  ] ;
  sh:property [
    sh:path uofa:hash ;
    sh:minCount 1 ;
    sh:pattern "^(sha256|sha384|sha512):[a-f0-9]{64,128}$" ;
    sh:message "Minimal: must include a content hash in algorithm:hexdigest format (e.g., sha256:<64 hex chars>)." ;
  ] ;
  sh:property [
    sh:path uofa:signature ;
    sh:minCount 1 ;
    sh:pattern "^(ed25519|ecdsa-p256):[a-f0-9]+$" ;
    sh:message "Minimal: must include a digital signature in algorithm:hexdigest format." ;
  ] ;
  sh:property [
    sh:path uofa:hasDecisionRecord ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:message "Minimal: must include at least one DecisionRecord (IRI)." ;
  ] .

################################################################
# Complete body (applies only when ProfileComplete is chosen)
################################################################
uofa:UnitOfAssurance_CompleteBody
  a sh:NodeShape ;
  sh:property [
    sh:path uofa:bindsRequirement ; sh:nodeKind sh:IRI ; sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path uofa:hasContextOfUse ; sh:nodeKind sh:IRI ; sh:minCount 1 ;
    sh:message "Complete: must declare a Context of Use (V&V 40 COU)." ;
  ] ;
  sh:property [
    sh:path uofa:bindsModel ; sh:nodeKind sh:IRI ; sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path uofa:bindsDataset ; sh:nodeKind sh:IRI ; sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path uofa:hasValidationResult ; sh:nodeKind sh:IRI ; sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path prov:wasDerivedFrom ; sh:nodeKind sh:IRI ; sh:minCount 1 ;
    sh:message "Complete: link to prior artifact (e.g., parent UoA/run logs)." ;
  ] ;
  sh:property [
    sh:path prov:wasAttributedTo ; sh:nodeKind sh:IRI ; sh:minCount 1 ;
    sh:message "Complete: identify responsible actor or organization." ;
  ] ;
  sh:property [
    sh:path prov:generatedAtTime ; sh:datatype xsd:dateTime ; sh:minCount 1 ;
  ] ;
  sh:property [
    sh:path uofa:hash ;
    sh:minCount 1 ;
    sh:pattern "^(sha256|sha384|sha512):[a-f0-9]{64,128}$" ;
    sh:message "Complete: hash must be algorithm:hexdigest format (e.g., sha256:<64 hex chars>)." ;
  ] ;
  sh:property [
    sh:path uofa:signature ;
    sh:minCount 1 ;
    sh:pattern "^(ed25519|ecdsa-p256):[a-f0-9]+$" ;
    sh:message "Complete: signature must be algorithm:hexdigest format." ;
  ] ;

  # ---- v0.3 additions: COU metadata ----

  sh:property [
    sh:path uofa:modelRiskLevel ;
    sh:datatype xsd:integer ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:minInclusive 1 ;
    sh:maxInclusive 5 ;
    sh:message "Complete: modelRiskLevel is required (integer 1–5, per V&V 40 risk matrix)." ;
  ] ;
  sh:property [
    sh:path uofa:deviceClass ;
    sh:maxCount 1 ;
    sh:in ( "Class I" "Class II" "Class III" ) ;
    sh:message "Complete: deviceClass must be Class I, Class II, or Class III (FDA classification)." ;
  ] ;
  sh:property [
    sh:path uofa:couName ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:message "Complete: couName is a human-readable COU label for diff output." ;
  ] ;
  sh:property [
    sh:path uofa:decision ;
    sh:maxCount 1 ;
    sh:in ( "Accepted" "Not accepted" ) ;
    sh:message "Complete: decision must be 'Accepted' or 'Not accepted'." ;
  ] ;
  sh:property [
    sh:path uofa:hasUncertaintyQuantification ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1 ;
    sh:message "Complete: hasUncertaintyQuantification must be a boolean." ;
  ] ;

  # ---- Credibility metrics (unchanged from v0.2) ----

  sh:property [
    sh:path uofa:credibilityIndex ;
    sh:or (
      [ sh:datatype xsd:decimal ]
      [ sh:datatype xsd:double ]
    ) ;
    sh:minInclusive "0.0"^^xsd:decimal ;
    sh:maxInclusive "1.0"^^xsd:decimal ;
  ] ;

  # Trace completeness
  sh:property [
    sh:path uofa:traceCompleteness ;
    sh:or (
      [ sh:datatype xsd:decimal ]
      [ sh:datatype xsd:double ]
    ) ;
    sh:minInclusive "0.0"^^xsd:decimal ;
    sh:maxInclusive "1.0"^^xsd:decimal ;
  ] ;

  # Verification coverage
  sh:property [
    sh:path uofa:verificationCoverage ;
    sh:or (
      [ sh:datatype xsd:decimal ]
      [ sh:datatype xsd:double ]
    ) ;
    sh:minInclusive "0.0"^^xsd:decimal ;
    sh:maxInclusive "1.0"^^xsd:decimal ;
  ] ;

  # Validation coverage
  sh:property [
    sh:path uofa:validationCoverage ;
    sh:or (
      [ sh:datatype xsd:decimal ]
      [ sh:datatype xsd:double ]
    ) ;
    sh:minInclusive "0.0"^^xsd:decimal ;
    sh:maxInclusive "1.0"^^xsd:decimal ;
  ] ;

  # Uncertainty CI width (only lower bound needed)
  sh:property [
    sh:path uofa:uncertaintyCIWidth ;
    sh:or (
      [ sh:datatype xsd:decimal ]
      [ sh:datatype xsd:double ]
    ) ;
    sh:minInclusive "0.0"^^xsd:decimal ;
  ] ;

  sh:property [
    sh:path uofa:hasCredibilityFactor ;
    sh:node uofa:CredibilityFactorShape ;
    sh:minCount 1 ;
    sh:message "Complete: must include at least one CredibilityFactor (V&V 40 Table 5-1)." ;
  ] ;
  sh:property [
    sh:path uofa:hasWeakener ;
    sh:node uofa:WeakenerAnnotationShape ;
    # No sh:minCount — zero weakeners is a valid (clean) UofA
  ] ;

  sh:property [
    sh:path uofa:assuranceLevel ; sh:in ( "Low" "Medium" "High" ) ;
  ] ;
  sh:property [
    sh:path uofa:criteriaSet ; sh:nodeKind sh:IRI ;
    sh:message "Complete: reference criteria set used (e.g., VVUQ-90, NASA-7009)." ;
  ] ;
  sh:property [
    sh:path uofa:hasDecisionRecord ; sh:nodeKind sh:IRI ; sh:minCount 1 ;
  ] .

################################################################
# CredibilityFactor node shape (standards-agnostic)
#
# v0.4 changes:
#   - factorType enum REMOVED from core — now defined by domain
#     packs (vv40, nasa-7009b). Core only requires factorType to
#     be a non-empty string.
#   - factorStandard added (optional): identifies which standard
#     defines this factor (e.g., "ASME-VV40-2018", "NASA-STD-7009B").
#   - assessmentPhase added (optional): "capability" or "results"
#     (used by NASA-STD-7009B, not V&V 40).
#   - hasEvidence added (optional): IRI link to backing evidence.
#   - Level range remains 0–5 in core; packs may constrain further.
################################################################
uofa:CredibilityFactorShape
  a sh:NodeShape ;
  sh:property [
    sh:path uofa:factorType ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "CredibilityFactor must have a factorType string." ;
  ] ;
  sh:property [
    sh:path uofa:factorStatus ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in ( "assessed" "not-assessed" "scoped-out" "not-applicable" ) ;
    sh:message "Every credibility factor must declare its assessment status." ;
  ] ;
  sh:property [
    sh:path uofa:factorStandard ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path uofa:assessmentPhase ;
    sh:in ( "capability" "results" ) ;
    sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path uofa:requiredLevel ;
    sh:datatype xsd:integer ;
    sh:maxCount 1 ;
    sh:minInclusive 0 ;
    sh:maxInclusive 5 ;
    sh:message "requiredLevel must be an integer 0–5 (0 = not set)." ;
  ] ;
  sh:property [
    sh:path uofa:achievedLevel ;
    sh:datatype xsd:integer ;
    sh:maxCount 1 ;
    sh:minInclusive 0 ;
    sh:maxInclusive 5 ;
    sh:message "achievedLevel must be an integer 0–5 (0 = not set)." ;
  ] .

################################################################
# WeakenerAnnotation node shape (C3 quality gate)
################################################################
uofa:WeakenerAnnotationShape
  a sh:NodeShape ;
  sh:property [
    sh:path uofa:patternId ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:pattern "^(W-(EP|AL|ON|AR|SI|NASA)-\\d{2}|COMPOUND-\\d{2})$" ;
    sh:message "patternId must match catalog format (e.g., W-EP-01, W-NASA-02, COMPOUND-01)." ;
  ] ;
  sh:property [
    sh:path uofa:severity ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in ( "Critical" "High" "Medium" "Low" ) ;
    sh:message "severity must be Critical, High, Medium, or Low." ;
  ] ;
  sh:property [
    sh:path uofa:affectedNode ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:message "affectedNode must be an IRI pointing to the flagged graph node." ;
  ] ;
  sh:property [
    sh:path schema:description ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:message "description should explain why this weakener fires." ;
  ] .

################################################################
# Evidence class shapes (v0.4 — used by NASA-STD-7009B pack)
################################################################

uofa:ReviewActivityShape a sh:NodeShape ;
    sh:targetClass uofa:ReviewActivity ;
    sh:property [
        sh:path uofa:reviewer ;
        sh:minCount 1 ;
        sh:message "ReviewActivity must identify a reviewer." ;
    ] ;
    sh:property [
        sh:path uofa:reviewType ;
        sh:in ( "independent" "internal" "peer" ) ;
    ] .

uofa:ProcessAttestationShape a sh:NodeShape ;
    sh:targetClass uofa:ProcessAttestation ;
    sh:property [
        sh:path uofa:processType ;
        sh:minCount 1 ;
        sh:in ( "configuration-management" "sqa" "change-control" "documentation" ) ;
    ] ;
    sh:property [
        sh:path uofa:attestedBy ;
        sh:minCount 1 ;
    ] .

uofa:DeploymentRecordShape a sh:NodeShape ;
    sh:targetClass uofa:DeploymentRecord ;
    sh:property [
        sh:path uofa:deployedIn ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path uofa:deploymentOutcome ;
        sh:in ( "successful" "partial" "unsuccessful" ) ;
    ] .

uofa:InputPedigreeLinkShape a sh:NodeShape ;
    sh:targetClass uofa:InputPedigreeLink ;
    sh:property [
        sh:path uofa:sourceReference ;
        sh:minCount 1 ;
        sh:message "InputPedigreeLink must reference the original data source." ;
    ] ;
    sh:property [
        sh:path uofa:pedigreeLevel ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:maxInclusive 4 ;
    ] .
