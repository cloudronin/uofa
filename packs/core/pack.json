{
  "$schema": "https://uofa.net/schemas/pack-manifest/v1.json",
  "name": "core",
  "version": "0.5.0",
  "description": "Core credibility assessment rules. Standards-agnostic.",
  "standards": [],
  "author": "Vishnu Vettrivel",
  "license": "Apache-2.0",
  "coreCompatibility": ">=0.5.0",
  "template": "templates/uofa-template.xlsx",
  "prompt": "prompts/extract_prompt.txt",
  "capabilities": [
    {
      "leg": "detection",
      "capabilityId": "detection:core-weakeners",
      "targetInterface": "detection",
      "interfaceVersion": "1.0",
      "firewallPlacement": "measurement-region",
      "provenance": { "stampsPackVersion": true },
      "payload": {
        "shapes": "shapes/uofa_shacl.ttl",
        "rules": "rules/uofa_weakener.rules",
        "patternIds": [
          "COMPOUND-01", "COMPOUND-03",
          "W-AL-01", "W-AL-02",
          "W-AR-01", "W-AR-02", "W-AR-03", "W-AR-04", "W-AR-05",
          "W-CON-01", "W-CON-02", "W-CON-03", "W-CON-04", "W-CON-05",
          "W-EP-01", "W-EP-02", "W-EP-03", "W-EP-04",
          "W-ON-01", "W-ON-02",
          "W-PROV-01",
          "W-SI-01", "W-SI-02"
        ],
        "factorFocus": {
          "W-AR-05": ["Output comparison"],
          "W-PROV-01": ["Output comparison"],
          "W-ON-02": ["Relevance of the validation activities to the COU"]
        }
      }
    },
    {
      "leg": "measurement",
      "capabilityId": "measurement:core-default",
      "targetInterface": "measurement",
      "interfaceVersion": "1.0",
      "firewallPlacement": "measurement-region",
      "provenance": { "stampsPackVersion": true },
      "payload": {
        "impl": "uofa_cli.interrogate.measurements:default_methods",
        "outputKeys": [
          "referenceResiduals", "envelopeCoverage",
          "physicsConstraintResidual", "uqCalibration"
        ]
      }
    },
    {
      "leg": "guardrail",
      "capabilityId": "guardrail:basic-threshold-stub",
      "targetInterface": "guardrail",
      "interfaceVersion": "1.0",
      "firewallPlacement": "action-region",
      "provenance": { "stampsPackVersion": true },
      "payload": {
        "impl": "uofa_cli.guardrail:ThresholdGuardrailStub",
        "outputKeys": ["guardrailAction"]
      }
    }
  ]
}
