@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix uofa: <https://uofa.net/vocab#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# V&V 40 Table 5-1 factor taxonomy
uofa:VV40CredibilityFactorShape a sh:NodeShape ;
    sh:targetClass uofa:CredibilityFactor ;
    sh:property [
        sh:path uofa:factorType ;
        sh:in (
            "Software quality assurance"
            "Numerical code verification"
            "Discretization error"
            "Numerical solver error"
            "Use error"
            "Model form"
            "Model inputs"
            "Test samples"
            "Test conditions"
            "Equivalency of input parameters"
            "Output comparison"
            "Relevance of the quantities of interest"
            "Relevance of the validation activities to the COU"
        ) ;
        sh:message "factorType must be one of the 13 V&V 40 Table 5-1 factor names." ;
    ] .

# V&V 40 level range: 1-5 (not 0-4 like 7009B)
uofa:VV40LevelRangeShape a sh:NodeShape ;
    sh:targetClass uofa:CredibilityFactor ;
    sh:property [
        sh:path uofa:requiredLevel ;
        sh:minInclusive 1 ;
        sh:maxInclusive 5 ;
    ] ;
    sh:property [
        sh:path uofa:achievedLevel ;
        sh:minInclusive 1 ;
        sh:maxInclusive 5 ;
    ] .
