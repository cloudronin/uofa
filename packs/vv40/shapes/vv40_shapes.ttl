@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix uofa: <https://uofa.net/vocab#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# V&V 40 Table 5-1 factor taxonomy
# Only applies to factors tagged with factorStandard "ASME-VV40-2018"
# (or factors without factorStandard, for backward compat with single-pack use)
uofa:VV40CredibilityFactorShape a sh:NodeShape ;
    sh:targetClass uofa:CredibilityFactor ;
    sh:sparql [
        sh:message "factorType must be one of the 13 V&V 40 Table 5-1 factor names." ;
        sh:select """
            SELECT $this
            WHERE {
                $this uofa:factorType ?ft .
                OPTIONAL { $this uofa:factorStandard ?fs }
                FILTER (
                    (!BOUND(?fs) || ?fs = "ASME-VV40-2018")
                    && ?ft NOT IN (
                        "Software quality assurance",
                        "Numerical code verification",
                        "Discretization error",
                        "Numerical solver error",
                        "Use error",
                        "Model form",
                        "Model inputs",
                        "Test samples",
                        "Test conditions",
                        "Equivalency of input parameters",
                        "Output comparison",
                        "Relevance of the quantities of interest",
                        "Relevance of the validation activities to the COU"
                    )
                )
            }
        """ ;
    ] .

# V&V 40 level range: 1-5 (only for ASME-VV40-2018 factors)
uofa:VV40LevelRangeShape a sh:NodeShape ;
    sh:targetClass uofa:CredibilityFactor ;
    sh:sparql [
        sh:message "V&V 40 factors must have requiredLevel in range 1-5." ;
        sh:select """
            SELECT $this
            WHERE {
                $this uofa:requiredLevel ?rl .
                OPTIONAL { $this uofa:factorStandard ?fs }
                FILTER (
                    (!BOUND(?fs) || ?fs = "ASME-VV40-2018")
                    && (?rl < 1 || ?rl > 5)
                )
            }
        """ ;
    ] ;
    sh:sparql [
        sh:message "V&V 40 factors must have achievedLevel in range 1-5." ;
        sh:select """
            SELECT $this
            WHERE {
                $this uofa:achievedLevel ?al .
                OPTIONAL { $this uofa:factorStandard ?fs }
                FILTER (
                    (!BOUND(?fs) || ?fs = "ASME-VV40-2018")
                    && (?al < 1 || ?al > 5)
                )
            }
        """ ;
    ] .
