---
// Site-wide footer. Renders below Starlight's prev/next on docs pages
// (via StarlightFooterWithSite.astro) and directly on the splash homepage
// (via explicit import in index.mdx). Build SHA + date come from CI env;
// local dev shows "dev" / today's date.
const buildSha = (import.meta.env.PUBLIC_BUILD_SHA || 'dev').slice(0, 7);
const buildShaFull = import.meta.env.PUBLIC_BUILD_SHA || 'main';
const buildDate = import.meta.env.PUBLIC_BUILD_DATE
  ? new Date(import.meta.env.PUBLIC_BUILD_DATE).toISOString().slice(0, 10)
  : new Date().toISOString().slice(0, 10);
const repoUrl = 'https://github.com/cloudronin/uofa';
---

<footer class="uofa-site-footer">
  <div class="uofa-footer-grid">
    <div class="uofa-footer-col">
      <div class="uofa-footer-label">Project</div>
      <a href={repoUrl}>Source on GitHub</a>
      <a href="/research/nafems-2026/">NAFEMS Americas 2026</a>
      <a href="/feedback/">Feedback</a>
    </div>

    <div class="uofa-footer-col">
      <div class="uofa-footer-label">License</div>
      <a href={`${repoUrl}/blob/main/LICENSE`}>Code: Apache-2.0</a>
    </div>

    <div class="uofa-footer-col">
      <div class="uofa-footer-label">Cite</div>
      <a href="/cite/">How to cite UofA</a>
    </div>

    <div class="uofa-footer-col">
      <div class="uofa-footer-label">Contact</div>
      <a href="mailto:support@uofa.net">support@uofa.net</a>
    </div>
  </div>

  <div class="uofa-footer-meta">
    <span>UofA — Unit of Assurance</span>
    <span class="uofa-footer-build">
      Built {buildDate} from
      <a href={`${repoUrl}/commit/${buildShaFull}`}><code>{buildSha}</code></a>
    </span>
  </div>
</footer>

<style>
  .uofa-site-footer {
    margin-top: 4rem;
    padding: 2.5rem 1.5rem 2rem;
    border-top: 1px solid var(--sl-color-hairline);
    font-size: 0.875rem;
    color: var(--sl-color-text-accent);
  }
  .uofa-footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 2rem;
    max-width: 1100px;
    margin: 0 auto 2rem;
  }
  .uofa-footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .uofa-footer-label {
    font-family: var(--__sl-font-mono, monospace);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--uofa-accent, #d4a35a);
    margin-bottom: 0.25rem;
  }
  .uofa-footer-col a {
    color: var(--sl-color-text);
    text-decoration: none;
    transition: color 0.15s;
  }
  .uofa-footer-col a:hover { color: var(--uofa-accent, #d4a35a); }
  .uofa-footer-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    justify-content: space-between;
    max-width: 1100px;
    margin: 0 auto;
    padding-top: 1.5rem;
    border-top: 1px solid var(--sl-color-hairline);
    font-size: 0.8rem;
    color: var(--sl-color-text-accent);
  }
  .uofa-footer-meta code {
    font-family: var(--__sl-font-mono, monospace);
    background: var(--sl-color-bg-nav);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
  }
  .uofa-footer-meta a { color: inherit; }
  .uofa-footer-meta a:hover { color: var(--uofa-accent, #d4a35a); }
</style>
