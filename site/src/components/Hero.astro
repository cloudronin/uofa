---
// Hero — homepage hero section with terminal block
// Renders the headline, tagline, two CTAs, and the install/check terminal demo
//
// __UOFA_VERSION__ is a build-time constant from astro.config.mjs (vite.define),
// sourced from pyproject.toml so the badge always reflects the live release.
---

<section class="uofa-hero">
  <div class="uofa-hero-inner">
    <div class="uofa-badge">
      <span class="dot"></span>
      <span>{__UOFA_VERSION__} · Live this Wed at NAFEMS Americas</span>
    </div>

    <h1 class="uofa-title">Unit of <em>Assurance</em></h1>

    <p class="uofa-tagline">
      Machine-verifiable credibility evidence for regulated computational simulation.
      One signed JSON-LD package per Context of Use.
    </p>

    <div class="uofa-ctas">
      <a href="/start/" class="uofa-btn uofa-btn-primary">
        Get started
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M3 8 H13 M9 4 L13 8 L9 12" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="https://codespaces.new/cloudronin/uofa?quickstart=1" class="uofa-btn uofa-btn-secondary">
        Open in Codespace
      </a>
    </div>

    <div class="uofa-terminal" role="img" aria-label="Three commands install uofa, scaffold a project, and validate it">
      <div class="uofa-terminal-bar">
        <span class="uofa-term-dot r"></span>
        <span class="uofa-term-dot y"></span>
        <span class="uofa-term-dot g"></span>
        <span class="uofa-terminal-title">~/projects/blade-fatigue</span>
      </div>
      <pre><span class="uofa-term-prompt">$</span> <span class="uofa-term-cmd">pip install uofa</span>
<span class="uofa-term-prompt">$</span> <span class="uofa-term-cmd">uofa init blade-fatigue</span>
<span class="uofa-term-prompt">$</span> <span class="uofa-term-cmd">uofa check blade-fatigue/blade-fatigue-cou1.jsonld</span>

<span class="uofa-term-ok">  ✓</span> <span class="uofa-term-dim">SHACL validation</span>      <span class="uofa-term-ok">Conforms</span>
<span class="uofa-term-ok">  ✓</span> <span class="uofa-term-dim">Integrity verified</span>    <span class="uofa-term-ok">ed25519 signature valid</span>
<span class="uofa-term-warn">  ⚡</span> <span class="uofa-term-dim">Quality gates</span>         <span class="uofa-term-warn">2 weakeners detected</span>
       <span class="uofa-term-faint">└── W-AL-01 (High) · W-CON-04 (Medium)</span></pre>
    </div>
  </div>
</section>
