---
// Embeds the HuggingFace Gap-Finder Space via the Gradio web component.
// The web component auto-resizes as the multi-step wizard changes height,
// which a fixed-height iframe cannot do. Pinned to dark for v1.
//
// The Space runs on a GPU that auto-sleeps when idle (to cap cost), so a cold
// visit can show Gradio's blunt "could not get space status" error while it
// wakes. We soften that: set expectations, nudge the Space awake on load, and
// give a one-click link to wake it directly.
//
// Set the Space host via PUBLIC_GAPFINDER_SPACE_URL at build time, or pass `src`.
const GRADIO_VERSION = "6.19.0"; // keep in sync with the Space's gradio version
const {
  src = import.meta.env.PUBLIC_GAPFINDER_SPACE_URL ??
    "https://cloudronin-uofa-demo.hf.space",
} = Astro.props;
const themed = src.includes("__theme=")
  ? src
  : `${src}${src.includes("?") ? "&" : "?"}__theme=dark`;
const gradioJs = `https://gradio.s3-us-west-2.amazonaws.com/${GRADIO_VERSION}/gradio.js`;
const spacePage = "https://huggingface.co/spaces/cloudronin/uofa-demo";
const isPlaceholder = themed.includes("REPLACE-WITH-SPACE-HOST");
---

{
  isPlaceholder && (
    <p style="border:1px solid var(--sl-color-orange); padding:0.75rem 1rem; border-radius:0.5rem;">
      <strong>Embed not yet configured.</strong> Set <code>PUBLIC_GAPFINDER_SPACE_URL</code>{" "}
      to the deployed HuggingFace Space host to activate the interactive Gap-Finder here.
    </p>
  )
}

<aside class="gapfinder-note">
  ⏳ <strong>First load can take up to a minute.</strong> The demo runs on a GPU
  that sleeps when idle to keep costs down. If the panel below shows a
  <em>"could not get space status"</em> message, it is just waking up. Wait
  ~30 to 60 seconds and reload, or
  <a href={spacePage} target="_blank" rel="noopener">open the demo directly to wake it</a>
  and come back.
</aside>

<script is:inline type="module" src={gradioJs}></script>
<gradio-app src={themed} eager="true"></gradio-app>

<script define:vars={{ host: src }}>
  // Nudge a sleeping Space awake as soon as the page loads, so it is starting
  // by the time the embed initializes. Fire-and-forget; no-cors surfaces no error.
  try {
    fetch(host, { mode: "no-cors", cache: "no-store" });
  } catch (e) {
    /* best-effort wake */
  }
</script>

<style>
  .gapfinder-note {
    border: 1px solid var(--sl-color-hairline, #3a3a3a);
    border-left: 3px solid var(--sl-color-accent, #f97316);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    margin: 0 0 1rem;
    font-size: 0.9rem;
    line-height: 1.5;
  }
</style>
