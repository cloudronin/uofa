{
  "name": "uofa-site",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync:readmes": "node scripts/sync-readmes.mjs",
    "sync:catalog": "uofa catalog --all-packs --format md > src/content/docs/reference/catalog.md",
    "sync:cli": "uofa --help-all > src/content/docs/reference/cli.md",
    "sync:counts": "node scripts/check-counts.mjs",
    "sync:all": "npm run sync:readmes && npm run sync:catalog && npm run sync:cli && npm run sync:counts",
    "prebuild": "npm run sync:all",
    "predev": "npm run sync:all",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.4",
    "astro": "^6.1.9",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "toml": "^3.0.0"
  }
}
