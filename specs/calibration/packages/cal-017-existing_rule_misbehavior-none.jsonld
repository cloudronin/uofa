  "signature": "ed25519:b4e8d2f1c3a7965e2b1d4f3a8c6e0b9d7f2a4c1e3b5d7f9a2c4e6b8d0f2a4c6",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/sqa-mrl5-criteria-001",
      "rationale": "CFD solver (ANSYS Fluent 2023R2) is validated under ISO 9001 QMS. Full regression test suite of 847 benchmark cases executed; all pass within tolerance. Version control, change management, and release documentation meet FDA software validation guidance 21 CFR Part 11 requirements. Independent SQA audit completed by third-party assessor with no critical findings."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/code-verification-mrl5-criteria-001",
      "rationale": "Method of manufactured solutions (MMS) applied to the Navier-Stokes and power-law hemolysis transport equations. Observed order of accuracy (OOA) of 1.94 for velocity and 1.87 for scalar hemolysis transport confirmed against theoretical second-order spatial accuracy. Three systematically refined grids used (4.2M, 12.1M, 31.8M cells). All residuals converge to machine precision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/discretization-error-mrl5-criteria-001",
      "rationale": "Richardson extrapolation performed on three grids (4.2M, 12.1M, 31.8M cells) following ASME V&V 20 procedures. Grid convergence index (GCI) for normalized hemolysis index at design point: GCI_fine = 1.8%, GCI_medium = 4.3%. Asymptotic range ratio = 1.02, confirming convergence in the asymptotic regime. Temporal discretization error assessed via time-step refinement study; CFL < 1.0 maintained throughout."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-conditions-mrl5-criteria-001",
      "rationale": "Experimental test conditions documented to ISO 15223 traceability standards. Blood analog fluid (glycerol-water, 40% hematocrit equivalent) rheology characterized at 37\u00b0C \u00b1 0.1\u00b0C. Flow rates set via calibrated Coriolis mass flowmeter (\u00b10.2% accuracy). Pump speed controlled via closed-loop tachometer (\u00b15 RPM). All 5 operating points replicated across three independent test sessions; inter-session variability < 3% for hemolysis index."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/output-comparison-mrl5-criteria-001",
      "rationale": "Quantitative comparison metrics computed per ASME V&V 20: validation uncertainty U_val = 6.1% (combined experimental uncertainty 4.8%, numerical uncertainty 3.7%). Model prediction error E = |D - S| / D \u2264 5.3% across all 5 operating points. E < U_val at all points, indicating model is validated within the validation uncertainty bounds. Bland-Altman analysis confirms no systematic bias across the operating range."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/qoi-relevance-mrl5-criteria-001",
      "rationale": "Primary QOI is the normalized index of hemolysis (NIH) expressed as mg/dL, directly matching the clinical acceptance threshold specified in the COU. Secondary QOIs (volume-averaged shear stress, scalar dissipation rate) are mechanistically linked to the hemolysis power-law model. All QOIs are directly measurable in bench validation experiments. Clinical relevance confirmed by hematologist review panel; NIH threshold of 0.8 mg/dL corresponds to established chronic hemolysis risk boundary."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/validation-relevance-mrl5-criteria-001",
      "rationale": "Validation experiments performed on the FDA generic centrifugal pump geometry \u2014 identical to the COU device geometry. Operating conditions span the full COU envelope (flow rates 2\u20138 L/min, speeds 2000\u20133500 RPM). Blood analog fluid properties match COU physiological conditions within \u00b15% for viscosity and density. Geometric similarity confirmed via CMM inspection of test article (dimensional tolerances \u00b10.05 mm). Validation domain fully encompasses the COU prediction domain."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/solver-error-mrl5-criteria-001",
      "rationale": "Iterative convergence monitored via scaled residuals; all flow variables converge to < 1e-6 per time step. Round-off error assessed via double-precision arithmetic throughout; negligible contribution confirmed by comparison with extended-precision reference solution on coarse grid. Solver restarts and checkpoint reproducibility verified: maximum discrepancy in NIH between independent restarts < 0.01%."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/use-error-mrl5-criteria-001",
      "rationale": "Simulation execution governed by documented simulation plan (SP-2024-VAD-001) with step-by-step setup checklist. Independent peer review of mesh, boundary conditions, solver settings, and post-processing scripts performed by a second qualified engineer before each production run. Automated post-processing pipeline eliminates manual data extraction errors. All analyst actions logged in version-controlled simulation record; no deviations from simulation plan recorded."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-form-mrl5-criteria-001",
      "rationale": "Turbulence modeled using SST k-omega with low-Reynolds-number correction; model selection justified by published benchmark studies on rotating blood-contacting devices (Bludszuweit 1995, Giersiepen 1990). Hemolysis transport modeled via power-law scalar equation (Heuser-Opitz constants calibrated to fresh porcine blood at 37\u00b0C). Model form uncertainty estimated via comparison with two alternative turbulence closures (realizable k-epsilon, RSM); NIH predictions differ by < 8% across operating range, within validation uncertainty bounds."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/model-inputs-mrl5-criteria-001",
      "rationale": "All model input parameters characterized with quantified uncertainties: fluid density (1056 \u00b1 5 kg/m\u00b3), dynamic viscosity (0.0035 \u00b1 0.0002 Pa\u00b7s), power-law hemolysis constants (C = 1.8e-6 \u00b1 15%, \u03b1 = 1.991 \u00b1 8%, \u03b2 = 0.765 \u00b1 12%). Monte Carlo propagation performed with 10,000 Latin hypercube samples across all uncertain inputs. 95th-percentile NIH prediction envelope confirmed below clinical threshold with margin > 15%. Input traceability matrix links each parameter to its characterization source."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/test-samples-mrl5-criteria-001",
      "rationale": "Validation experiments conducted on three independently manufactured test articles of the FDA generic centrifugal pump. Geometric variability between articles quantified by CMM: maximum deviation from nominal 0.03 mm, within manufacturing tolerance. Blood analog fluid prepared from three independent batches; rheological properties verified within \u00b13% of target for each batch. Sample size sufficient for statistical comparison: n=15 hemolysis measurements per operating point (5 points \u00d7 3 articles)."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "https://uofa.net/synth/criteria/input-equivalency-mrl5-criteria-001",
      "rationale": "Formal equivalency assessment performed between validation experiment inputs and COU prediction inputs. Reynolds number similarity confirmed (Re_validation / Re_COU = 0.98\u20131.03 across all operating points). Hemodynamic loading conditions (pressure head, flow rate) matched within \u00b12%. Fluid rheology equivalency: blood analog Casson viscosity matches physiological blood within 4% at relevant shear rates (100\u20131000 s\u207b\u00b9). Geometric equivalency: validation test articles manufactured from same CAD nominal as COU device. No unresolved equivalency gaps identified."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/vad-hemolysis-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/fda-cdrh-cfd-review-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 ASME V&V 40 credibility factors have been fully assessed at Model Risk Level 5. Achieved levels meet or exceed required levels for every factor: seven factors assessed at Gradation 4 (required 4), three factors assessed at Gradation 3 (required 3), and three factors assessed at Gradation 4 (required 4). The CFD model predicts absolute hemolysis index (NIH) within validated uncertainty bounds (E \u2264 5.3% < U_val = 6.1%) across all 5 COU operating points. Monte Carlo uncertainty quantification with 10,000 LHS samples confirms that the 95th-percentile NIH prediction envelope remains below the clinical threshold of 0.8 mg/dL with a minimum margin of 15%. Provenance chain is complete: all validation results trace to calibrated experimental data from three independent test articles, with comparedAgainst, prov:wasGeneratedBy, and hasUncertaintyQuantification links established for each ValidationResult. No credibility factor gaps remain. The model is accepted as adequately credible for predicting absolute hemolysis levels for Class III VAD regulatory submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
