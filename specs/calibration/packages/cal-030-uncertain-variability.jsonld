  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "FEA software (Ansys Mechanical 2022 R2) operates under documented QA procedures including version control, regression testing, and audit trails consistent with Gradation 2 requirements.",
      "rationale": "All three modeling organizations (FDA, Ansys, DePuy Synthes) demonstrated software QA documentation including installation qualification records, version-locked solver environments, and documented regression test suites. Achieved level meets required level."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarks against analytic solutions for beam bending and contact mechanics problems confirm correct code implementation at Gradation 2.",
      "rationale": "Cantilever beam bending and Hertzian contact benchmark problems were solved and compared to analytic solutions; errors were within 0.5% for all cases. Code verification is sufficient for the structural contact problem at hand."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Mesh convergence study demonstrates QoI change of less than 2% between the production mesh and a refined mesh (1.5x global refinement).",
      "rationale": "A mesh convergence study was performed on the non-cannulated 7.5 mm screw construct model. Construct stiffness changed by 1.1% and yield force by 1.4% upon 1.5x global refinement. Production mesh adopted at approximately 185,000 elements (hexahedral-dominant in screw shank). Discretization error is adequately characterized."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Nonlinear solver convergence criteria are documented; residual norms are reported for each load step.",
      "rationale": "Newton-Raphson iteration residuals were below 1e-4 force norm for all load steps in all 11 simulated constructs. No divergence events were recorded. Gradation 1 is sufficient given the static, quasi-linear nature of the problem at low displacement levels."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation execution is governed by a documented simulation plan; independent review of model setup by a second analyst is performed.",
      "rationale": "A written simulation execution plan was prepared prior to analysis. An independent analyst from a second organization reviewed boundary condition application, material assignments, and contact pair definitions. No discrepancies were identified. Use error risk is adequately controlled."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Continuum linear-elastic with bilinear isotropic hardening plasticity for titanium alloy; frictional contact at screw-rod interface. Model form justified by literature and confirmed by validation comparison.",
      "rationale": "The chosen model form (implicit quasi-static FEA with bilinear isotropic hardening Ti-6Al-4V material and penalty-based frictional contact) is well-established for ASTM F1717 screw constructs. Literature precedent and the achieved validation metrics (E/uval < 1.96 for all three QoIs) confirm that the model form is appropriate for the COU."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Material properties (E, yield stress, tangent modulus) and geometric dimensions sourced from coupon testing and CMM measurements; input distributions characterized by mean and standard deviation across the N=11 lot.",
      "rationale": "Elastic modulus, yield strength, and tangent modulus for the Ti-6Al-4V screw stock were characterized from tensile coupon testing (n=5 coupons per lot). Geometric dimensions were measured by CMM for each of the 11 constructs. Input distributions (mean \u00b1 1SD) were propagated through the ensemble. A screening sensitivity study was conducted as part of the UQ effort to identify which inputs most influenced construct stiffness predictions; elastic modulus and screw outer diameter were identified verbally as the dominant contributors. Input characterization meets Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "N=11 physical constructs spanning two independent laboratories; constructs manufactured from the same production lot as the nominal design.",
      "rationale": "Eleven non-cannulated 7.5 mm pedicle screw constructs were tested across two independent laboratories (FDA CDRH and an external contract test lab). All constructs were manufactured from the same production lot, ensuring material consistency with the simulation inputs. Sample size and inter-laboratory design meet Gradation 3 requirements."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Test conditions replicate the full range of clinically relevant loading scenarios; at minimum, two distinct test configurations should be evaluated.",
      "rationale": "Testing was conducted under a single ASTM F1717 standardized test configuration (35 mm inter-vertebral body spacer height, standard loading fixture). While this configuration is the regulatory standard, only a single test condition was employed, preventing assessment of model predictive performance across varied configurations. Achieved level (2) is below the required level (3); this shortfall is documented as a known limitation of the validation activity."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation input parameters (geometry, material, boundary conditions, loading rate) are demonstrably equivalent to the physical test setup for each of the 11 constructs.",
      "rationale": "CMM-measured geometry from each physical construct was used to generate the corresponding FEA geometry. Material properties were drawn from coupon testing of the same production lot. Boundary conditions replicate the ASTM F1717 fixture constraints. Loading rate equivalency is assured by the quasi-static nature of both the test and simulation. Full traceability between physical and virtual constructs is documented."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative comparison metric E/uval computed for each QoI; acceptance threshold E/uval < 1.96 applied consistently across all three QoIs.",
      "rationale": "The validation metric E/uval (ratio of model-experiment difference to combined validation uncertainty) was computed for construct stiffness (1.31), yield force (1.74), and force at 40 mm displacement (1.58). All three values are below the pre-established acceptance threshold of 1.96. Percentage differences are also below the 10% QoI bound. Output comparison is rigorous and meets Gradation 3."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoIs (stiffness, yield force, force at 40 mm displacement) are directly linked to the clinical failure modes of interest and the regulatory submission requirements.",
      "rationale": "The three selected QoIs correspond directly to the biomechanical performance endpoints required by FDA guidance for pedicle screw submissions and are mechanistically linked to construct fatigue and fracture failure modes. Stiffness governs load sharing with the spine; yield force and force at 40 mm displacement bound the structural integrity envelope. QoI relevance is well-justified."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation activities (ASTM F1717 bench testing of the specific non-cannulated 7.5 mm design) are directly applicable to the COU without significant extrapolation.",
      "rationale": "The validation activity uses the identical device design (non-cannulated 7.5 mm pedicle screw), the same material lot, the regulatory standard test method (ASTM F1717), and the same prediction objectives as the COU. There is no extrapolation in device geometry, material system, loading mode, or output type. Relevance of validation activities to the COU is high and meets Gradation 3."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/nagaraja-cou1-dr-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/nagaraja-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 13 V&V 40 credibility factors were assessed. Twelve of thirteen factors achieved the required gradation level. The single shortfall (Test conditions, achieved level 2 vs. required level 3) reflects the use of a single ASTM F1717 test configuration and is consistent with regulatory practice for this device class. The E/uval metric was below 1.96 for all three QoIs, and percentage differences were below 10% for all QoIs across N=11 constructs at two independent laboratories. Uncertainty quantification was performed across material and geometric input distributions. The overall credibility evidence is sufficient to support the regulatory claim that the FEA modeling framework adequately predicts compression-bending performance of the non-cannulated 7.5 mm pedicle screw construct.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
