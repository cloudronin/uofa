  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-not-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "Despite the overall COU decision being Not Accepted at MRL 5, the credibility assessment package itself is accepted as a complete and valid documentation of the evidence state. All 13 ASME V&V 40 credibility factors have been evaluated; 7 factors are formally assessed with quantitative evidence and 6 are flagged as not-assessed epistemic gaps. The Monte Carlo UQ satisfies the minimum documentation standard for submission. The package is accepted as the formal record supporting the regulatory finding that the model does not yet meet the credibility requirements for Class III VAD hemolysis prediction. The methodological basis for this assessment follows the power-law hemolysis damage accumulation framework described in the computational hemolysis literature, including the approach detailed in the reference indexed as doi:10.1016/j.ymeth.2024.03.003, which provides the theoretical grounding for shear-exposure-time integral formulations used in the damage model.",
    "decidedAt": "2026-04-19T00:00:00Z"
