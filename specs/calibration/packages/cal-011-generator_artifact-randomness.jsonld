  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou1-cpb-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Six factors appropriately scoped as not-assessed at MRL 2. Primary QoI (relative hemolysis index RH) satisfies RH < 1 acceptance criterion at all five operating points. Discretization error characterized via GCI. Aleatory uncertainty in hemolysis sensitivity operating-point sweep was noted qualitatively but structured UQ linkage was not completed for that result, consistent with the conservative acceptance margin observed. The credibility assessment team accepted the model for the stated COU with the caveat that future MRL 3 assessment should include formal probabilistic characterization of donor RBC variability.",
