  "hasDecisionRecord": {
    "id": "https://uofa.net/morrison/decision/cou1-accepted",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/morrison/actor/credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors met or exceeded their required levels at MRL 2. The 6 non-assessed factors are acceptable at required level 1 for a Class II device at MRL 2. The CFD model demonstrates sufficient credibility to support the regulatory decision that the centrifugal blood pump design meets the RH < 1 acceptance criterion relative to the predicate device. The assessment team concludes the model is fit for purpose for the stated COU.",
