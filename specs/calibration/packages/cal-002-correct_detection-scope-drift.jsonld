  "signature": "ed25519:b7e3a1d5f2c9e4b8a6d0f3c7e1a4d8b2f5c9e3a7d1b6f0c4e8a2d5b9f3c7e1a4",
  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented verification test suite and version-controlled configuration files.",
      "rationale": "ANSYS Fluent 19.2 was used under a controlled software environment with documented release notes and regression test suite. Simulation input files were version-controlled in a project repository. Achieved level 2 exceeds the required level 1 for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver benchmarked against canonical flow problems with known analytical solutions.",
      "rationale": "The Fluent solver was verified against the Taylor-Couette flow and lid-driven cavity benchmarks. Observed order of convergence matched theoretical second-order accuracy for the pressure-velocity coupling scheme employed."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation-based GCI < 5% for hemolysis-relevant quantities of interest.",
      "rationale": "A three-level mesh refinement study was performed with element counts of 2.1M, 5.8M, and 14.3M cells. Grid convergence index (GCI) for volume-averaged shear stress and RH index was 3.2% and 2.8% respectively, both below the 5% threshold. Achieved level 2 meets required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with measured boundary conditions used directly as CFD inputs.",
      "rationale": "Bench-top experiments were conducted at 37 \u00b0C with bovine blood at 30% hematocrit. Measured inlet/outlet pressures and flow rates from the experimental rig were applied directly as boundary conditions. Temperature, viscosity, and density were independently measured and reported. Achieved level 3 exceeds required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted RH index within 15% of experimentally measured values across all 5 operating points.",
      "rationale": "Predicted relative hemolysis index agreed with experimental measurements within 9.4% across all five flow-speed operating points. The systematic bias was less than 5%, with no operating point exceeding the 15% acceptance threshold. Achieved level 2 meets required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "QoI directly maps to clinical hemolysis endpoint via established power-law damage model.",
      "rationale": "The relative hemolysis index (RH) is derived from Lagrangian particle tracking integrated with the Giersiepen-Wurzinger power-law hemolysis model. RH < 1 corresponds to lower hemolysis than the predicate device, directly informing the regulatory decision. The QoI is clinically and regulatorily meaningful."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments performed on the same pump geometry and fluid under conditions spanning the COU operating range.",
      "rationale": "Validation experiments used the FDA generic centrifugal pump geometry identical to the simulation domain. Blood analog fluid (glycerol-water mixture matched to blood viscosity) was used for PIV measurements. Five operating points spanning the intended CPB flow-speed envelope were included in validation. Achieved level 2 meets required level 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical solver error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Iterative convergence to residual tolerance of 1e-5 for all transport equations.",
      "rationale": "Not assessed at MRL 2 for this factor. Iterative residuals were monitored and all simulations converged to 1e-5, but formal solver error quantification beyond residual monitoring was not performed. Acceptable at required level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Use error",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation setup reviewed by a second qualified analyst.",
      "rationale": "Not assessed beyond peer review of simulation setup files. A second CFD analyst reviewed boundary condition specifications and turbulence model selection. No independent replication was performed. Acceptable at required level 1 for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model form",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Turbulence model selection justified by published literature for similar pump geometries and Reynolds number ranges.",
      "rationale": "Not assessed at MRL 2. The SST k-omega turbulence model was selected based on published literature for rotary blood pump CFD. Formal model form uncertainty quantification was not performed. Acceptable at required level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Model inputs",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Material properties and boundary conditions sourced from peer-reviewed literature or direct measurement.",
      "rationale": "Not assessed at MRL 2. Blood density (1060 kg/m\u00b3) and Newtonian viscosity (0.0035 Pa\u00b7s) were taken from published literature values. Sensitivity to viscosity variation was not formally quantified. Acceptable at required level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test samples",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Experimental samples representative of clinical blood analog properties.",
      "rationale": "Not assessed at MRL 2. Bovine blood used in hemolysis experiments is an accepted surrogate for human blood in pump hemolysis testing per ASTM F1841. No formal equivalency analysis was performed. Acceptable at required level 1."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Equivalency of input parameters",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "not-assessed",
      "acceptanceCriteria": "Simulation input parameters demonstrated to be equivalent to experimental conditions within stated tolerances.",
      "rationale": "Not assessed at MRL 2. Nominal equivalency between simulation and experimental boundary conditions was established through direct measurement transcription, but formal uncertainty propagation from input parameter differences was not performed. Acceptable at required level 1."
    }
  ],
