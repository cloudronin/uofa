  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-decision-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All 7 assessed credibility factors meet or exceed required Gradation levels for MRL 2. The 6 non-assessed factors are acceptable at MRL 2 per ASME V&V 40 Table 4. The credibility evidence base (ValidationResults morrison-vr-001 and morrison-vr-002, both completed 2023-Q2) supports acceptance of the CFD model for the originally validated adult CPB operating envelope. The operating envelope has been extended since validation completion to include paediatric patients (cardiac index 1.8\u20132.4 L/min/m\u00b2) and high-viscosity perfusate (haematocrit 36\u201342%). No re-validation evidence covering the expanded conditions is available at the time of this assessment. The team acknowledges this gap; re-validation is planned for 2025-Q3. Interim acceptance is granted on the basis that the expanded conditions are expected to be less hemolytically severe than the validated adult high-flow points, and that clinical use under the expanded indications remains subject to post-market surveillance. Decision: Accepted with condition that re-validation evidence be submitted prior to next scheduled 510(k) supplement review.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
