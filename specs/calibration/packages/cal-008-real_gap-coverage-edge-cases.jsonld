  "hasCredibilityFactor": [
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Software quality assurance",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Commercial CFD solver with documented verification test suite and version-controlled input files.",
      "rationale": "ANSYS Fluent 2022R2 used with documented QA procedures. Version-controlled case files maintained in institutional repository. Solver release notes confirm no open defects affecting rotating machinery hemolysis simulations at MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver verified against at least one benchmark problem relevant to rotating flow.",
      "rationale": "Solver verified against the FDA benchmark nozzle problem and a rotating disk shear flow benchmark. Observed order of accuracy consistent with second-order discretization scheme. Code verification requirements for MRL 2 satisfied."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) < 5% for hemolysis index QoI at nominal operating conditions.",
      "rationale": "Three-mesh Richardson extrapolation performed at 3 L/min, 3000 RPM nominal condition. Coarse (2.1M cells), medium (5.4M cells), and fine (13.8M cells) meshes yielded GCI of 3.2% for the hemolysis index. Discretization error within required threshold for MRL 2."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "In-vitro test conditions documented and traceable; fluid properties and boundary conditions consistent with simulation inputs.",
      "rationale": "In-vitro experiments conducted using porcine blood analog at 37\u00b0C, viscosity 3.5 mPa\u00b7s. Inlet flow rates set by calibrated peristaltic pump; rotational speed controlled by servo motor with \u00b110 RPM accuracy. All five nominal test conditions documented in laboratory protocol LP-CPB-2023-04. Test conditions span the nominal clinical operating range of 2\u20134 L/min and 2500\u20133500 RPM."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized prediction error < 10% for relative hemolysis index across all validation cases.",
      "rationale": "Normalized prediction errors across five nominal validation points range from 4.1% to 7.9%, all below the 10% threshold. Systematic bias of approximately +6% (model underpredicts hemolysis) noted and accepted as conservative for the RH < 1 decision criterion. Comparison metrics computed per ASME V&V 40 Section 9."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validated QoI (hemolysis index) directly maps to the COU decision metric (RH < 1).",
      "rationale": "The relative hemolysis index RH is the direct regulatory acceptance criterion for CPB device comparison against the predicate. CFD output (volume-averaged hemolysis power law integral) is transformed to RH using the same normalization applied to the in-vitro reference. QoI relevance is high and directly supports the COU decision."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation geometry, fluid, and operating conditions sufficiently representative of the COU device and intended clinical use.",
      "rationale": "Validation performed on the FDA generic centrifugal pump geometry, which is the reference geometry for the COU device class. Blood analog fluid properties match clinical CPB conditions. Five nominal flow-speed combinations cover the standard clinical operating envelope. Validation activities are assessed as sufficiently relevant to the COU for MRL 2 purposes."
    },
    {
