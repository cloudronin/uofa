  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-cpb-decision-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-assessment-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for MRL 2. Normalized prediction errors across five nominal validation operating points are within the 10% acceptance threshold. The relative hemolysis index remains below RH = 1 for all validated conditions, supporting the regulatory comparison against the predicate device. Six factors are not assessed, consistent with MRL 2 requirements. The assessment team concludes that the CFD model has sufficient credibility for the CPB use COU decision.",
