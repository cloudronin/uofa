  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Version-controlled solver with documented regression test suite covering all hemolysis-relevant physics modules; independent code review completed.",
      "rationale": "The CFD solver (OpenFOAM v8) is under full version control with a 240-case regression suite. An independent SQA audit confirmed compliance with FDA software quality guidance. Achieved gradation 4 meets the MRL-5 required level."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Method of manufactured solutions (MMS) applied to all governing equations; order-of-accuracy confirmed within 5% of theoretical rate.",
      "rationale": "MMS verification was executed for the incompressible Navier-Stokes and scalar hemolysis transport equations. Observed order of accuracy was 1.97 (theoretical 2.0), within the 5% tolerance. Gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Richardson extrapolation on three systematically refined meshes; GCI < 5% for hemolysis index QoI.",
      "rationale": "Three meshes (4.2 M, 12.6 M, 37.8 M cells) were used. Richardson extrapolation yielded GCI of 3.8% for the normalized hemolysis index, satisfying the < 5% criterion. Gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions documented with measurement uncertainty for flow rate (\u00b12%), rotational speed (\u00b110 RPM), and inlet hematocrit (\u00b11%).",
      "rationale": "FDA pump experimental data includes full uncertainty characterization for all boundary condition parameters. Test fluid (bovine blood, Hct 33%) and temperature (37\u00b0C) are documented. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Quantitative metric (E_rel) between predicted and measured hemolysis index < 15% across all operating points; statistical comparison using validation uncertainty.",
      "rationale": "E_rel ranged from 8.2% to 13.7% across the five operating points evaluated. All points fall within the combined experimental and numerical uncertainty bands. Gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Normalized index of hemolysis (NIH) directly maps to the regulatory decision quantity; traceability from QoI to device risk documented.",
      "rationale": "The primary QoI, NIH (mg/100 L), is the quantity cited in the device risk analysis and is the direct regulatory comparator per ASTM F1841. Full traceability chain from simulation output to device risk documented. Gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments conducted on the same FDA generic pump geometry at overlapping operating conditions; similarity analysis documented.",
      "rationale": "Validation used the FDA benchmark centrifugal pump \u2014 identical geometry to the COU device surrogate. Operating conditions span 2500\u20135000 RPM and 3\u20137 L/min, overlapping the VAD clinical envelope. Similarity analysis confirms relevance. Gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Iterative convergence to residual < 1e-6 for all equations; round-off error analysis demonstrates negligible contribution relative to discretization error.",
      "rationale": "All simulations converged to residual norms below 1e-7. Double-precision arithmetic used throughout. Round-off contribution estimated at < 0.1% of GCI, confirming negligible influence. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Documented simulation workflow with peer review; boundary condition setup independently verified by a second analyst.",
      "rationale": "A documented simulation protocol was followed and independently reviewed. Boundary conditions were cross-checked by a second CFD analyst against the experimental setup report. No discrepancies found. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Constitutive model selection (Giersiepen-Wurzinger hemolysis power law) justified by literature review; sensitivity to alternative model forms quantified.",
      "rationale": "The Giersiepen-Wurzinger power-law model was selected following a systematic review of five hemolysis constitutive models. Sensitivity analysis showed NIH varies by \u00b118% across models; this uncertainty is propagated through the Monte Carlo UQ framework. Gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "factorStatus": "assessed",
      "acceptanceCriteria": "All uncertain input parameters assigned probability distributions based on published data; Monte Carlo propagation with N \u2265 1000 samples.",
      "rationale": "Twelve uncertain inputs (viscosity, density, power-law coefficients, rotational speed, flow rate, hematocrit, and six geometric tolerances) were assigned distributions from published literature and manufacturer specifications. Monte Carlo with N = 2000 samples was executed. Gradation 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Minimum of three independent experimental replicates per operating point; inter-sample variability reported.",
      "rationale": "FDA benchmark dataset includes five independent experimental runs per operating point. Inter-sample coefficient of variation for NIH is 6.3%, consistent with expected biological variability. Gradation 3 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Simulation boundary conditions match experimental conditions within measurement uncertainty for all primary inputs.",
      "rationale": "Inlet velocity profiles, rotational speed, and fluid properties used in simulation are within 1-sigma of experimentally measured values. A parameter equivalency table is provided in the supporting technical report. Gradation 3 achieved."
    }
  ],
