  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/morrison-cou1-accepted-001",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-team",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "All seven assessed credibility factors meet or exceed required levels for Model Risk Level 2. The six not-assessed factors are within scope for MRL 2 and are adequately mitigated by procedural controls. The CFD hemolysis model is judged credible for the stated COU. The governing requirement specifies that model performance shall be consistent with industry standard practice and shall demonstrate minimal impact on hemolysis indices with reasonable agreement to experimental data; the assessment team determined that the collected evidence satisfies this requirement, although the precise compliance threshold remains subject to reviewer interpretation given the unquantified nature of the requirement language.",
