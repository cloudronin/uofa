      "factorStatus": "assessed",
      "acceptanceCriteria": "CFD solver (ANSYS Fluent 2022R2) is commercially licensed and subject to vendor quality management; version control and audit trail documented.",
      "rationale": "The simulation was conducted using a commercially licensed CFD solver with documented version control. Software QA records confirm the solver release was validated by the vendor under an ISO 9001-compliant quality management system. Required level 1 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Numerical code verification",
      "type": "CredibilityFactor",
      "requiredLevel": 1,
      "achievedLevel": 1,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Solver passes standard benchmark cases (lid-driven cavity, pipe flow) to within published tolerances.",
      "rationale": "Numerical code verification was confirmed via the solver vendor's benchmark suite. Results for lid-driven cavity and fully developed pipe flow matched analytical solutions within 0.5% at the mesh densities used. Required level 1 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Discretization error",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Grid convergence index (GCI) for the primary QoI (scalar stress magnitude) is below 5% on the fine mesh.",
      "rationale": "A three-level mesh refinement study was performed (coarse 4.2 M, medium 8.7 M, fine 17.1 M cells). GCI for volume-averaged scalar stress was 3.8% between medium and fine meshes. Richardson extrapolation confirmed monotonic convergence. Required level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Test conditions",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Experimental test conditions (flow rate, rotational speed, fluid properties) are documented and replicated in simulation boundary conditions within stated uncertainty bounds.",
      "rationale": "Experimental conditions from the FDA benchmark dataset (flow rates 2.5\u20137.5 L/min, speeds 2000\u20133500 RPM) were reproduced as simulation boundary conditions. Fluid viscosity and density matched within measurement uncertainty. Required level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Output comparison",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Predicted normalized index of hemolysis (NIH) agrees with experimental measurements within \u00b125% across all five operating points.",
      "rationale": "Simulated NIH values were compared against FDA benchmark experimental data at five flow-speed combinations. Agreement ranged from 8% to 22% relative error. All five operating points met the \u00b125% criterion. Required level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the quantities of interest",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Primary QoI (relative hemolysis index RH and volume-averaged scalar stress) directly maps to the clinical hemolysis risk metric used in the regulatory submission.",
      "rationale": "The scalar stress-based hemolysis power law yields RH directly comparable to the predicate device submission metric. The QoI selection was reviewed and confirmed by the clinical team as the appropriate surrogate for in vivo hemolysis risk. Required level 2 is met."
    },
    {
      "factorStandard": "ASME-VV40-2018",
      "factorType": "Relevance of the validation activities to the COU",
      "type": "CredibilityFactor",
      "requiredLevel": 2,
      "achievedLevel": 2,
      "factorStatus": "assessed",
      "acceptanceCriteria": "Validation experiments use the same pump geometry family, blood analog fluid, and overlapping operating envelope as the COU.",
      "rationale": "Validation used the FDA generic centrifugal pump geometry with a glycerin-water blood analog (viscosity 3.5 cP) across the COU operating envelope. Geometric similarity and fluid property overlap confirm high relevance of validation activities to the COU. Required level 2 is met."
    },
    {
