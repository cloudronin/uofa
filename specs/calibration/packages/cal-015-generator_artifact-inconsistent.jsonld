  "signature": "ed25519:7c3a1f9b2e5d8a4c6f0b3e7a1d5c9f2b8e4a7c1d6f3b0e9a2c5d8f1b4e7a3c6",
  "hasCredibilityFactor": [
    {
      "type": "CredibilityFactor",
      "factorType": "Software quality assurance",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "SQA procedures must satisfy FDA 21 CFR Part 820 software validation requirements and maintain version-controlled solver builds with regression test suite coverage \u2265 90%.",
      "rationale": "The CFD solver (OpenFOAM v8) is maintained under a documented SQA plan conforming to FDA 21 CFR Part 820. Version control via Git, regression suite covers 94% of critical solver paths, and all hemolysis-specific UDFs are unit-tested. Required level 4 achieved."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical code verification",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Order-of-accuracy verification using Method of Manufactured Solutions (MMS) must confirm second-order spatial convergence for all governing equations relevant to hemolysis prediction.",
      "rationale": "MMS verification confirms second-order convergence for momentum and continuity equations. The hemolysis transport scalar achieves 1.7th-order convergence, marginally below the theoretical second-order target. Gap is documented; mitigation via finer base mesh partially compensates but achievedLevel remains 3."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Discretization error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 4,
      "acceptanceCriteria": "Grid convergence index (GCI) for hemolysis index must be below 5% at the operating points of interest using at least three systematically refined meshes.",
      "rationale": "Three-level mesh refinement study (6.2 M, 14.8 M, 31.4 M cells) yields GCI values of 3.1%\u20134.7% across all five operating points. Richardson extrapolation confirms monotonic convergence. Discretization error is within the 5% acceptance threshold at all conditions."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test conditions",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental test conditions (fluid temperature, hematocrit, inlet flow waveform) must be documented and matched to simulation boundary conditions within stated tolerances.",
      "rationale": "FDA generic pump experimental data reports fluid temperature (37 \u00b1 0.5 \u00b0C), hematocrit (33 \u00b1 2%), and steady-state flow conditions. Simulation boundary conditions are set to experimental nominal values; sensitivity runs confirm \u00b12% hemolysis variation over the documented tolerance ranges."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Output comparison",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Predicted hemolysis index (MIH) must agree with experimental measurements within 20% at all five validation operating points, with systematic bias quantified.",
      "rationale": "Predicted MIH values agree within 14%\u201328% of experimental measurements. Three of five operating points satisfy the 20% criterion; two high-speed points exceed it. Systematic over-prediction bias of +11% is identified and attributed to the Giersiepen power-law hemolysis model constants. AchievedLevel 3 reflects partial compliance."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the quantities of interest",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "The QoI used in validation (MIH) must directly correspond to the clinical hemolysis metric used in the COU decision, with no intermediate transformation that could obscure model error.",
      "rationale": "The Modified Index of Hemolysis (MIH) is the primary QoI in both validation experiments and the COU decision threshold. No intermediate transformation is applied. Direct correspondence is confirmed; achievedLevel 3 is appropriate for MRL 5 where absolute prediction is required."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Relevance of the validation activities to the COU",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "Validation activities must cover the full operating envelope of the COU (all five flow-speed combinations) using the same pump geometry and fluid properties as the intended device.",
      "rationale": "Validation covers four of five COU operating points using the FDA generic pump geometry. The fifth point (maximum design speed) was not included in the available experimental dataset. Partial coverage acknowledged; extrapolation uncertainty at the fifth point is bounded by the Monte Carlo UQ analysis."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Numerical solver error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Iterative convergence criteria must achieve residual reduction of at least four orders of magnitude for all transport equations; time-step independence must be confirmed for unsteady simulations.",
      "rationale": "All steady-state simulations achieve residual reductions of 5\u20136 orders of magnitude. Time-step sensitivity study (\u0394t = 1\u00d710\u207b\u2074 s vs. 5\u00d710\u207b\u2075 s) shows less than 0.8% change in MIH. Solver error contribution is negligible relative to model form uncertainty."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Use error",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Simulation setup must be reviewed by an independent analyst; boundary condition application and post-processing scripts must be version-controlled and peer-reviewed.",
      "rationale": "An independent CFD analyst reviewed the boundary condition specification, mesh topology, and post-processing pipeline. All scripts are version-controlled under the project SQA plan. No use errors were identified during the independent review."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model form",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "acceptanceCriteria": "The hemolysis power-law model form (Giersiepen et al.) must be evaluated against alternative formulations and its applicability to the VAD operating regime must be justified through literature evidence and sensitivity analysis.",
      "rationale": "The model form assessment for the Giersiepen hemolysis power-law was conducted through an extensive qualitative review of the peer-reviewed literature spanning 2005\u20132023. Expert panel consensus (three independent biomedical CFD specialists) concluded that the power-law exponents calibrated on Couette-flow data remain the most widely validated formulation for centrifugal pump geometries at the shear rates encountered in this COU (10\u00b3\u201310\u2075 s\u207b\u00b9). Sensitivity analyses across the Giersiepen, Taskin, and Arora model variants showed that all three formulations predict hemolysis within the same order of magnitude, with the Giersiepen model producing the most conservative (highest) estimates\u2014a property considered favorable for a Class III device safety assessment. The panel judged that the qualitative weight of evidence, taken together with the conservative bias already identified in the output comparison factor, is sufficient to support the Accepted decision without requiring a formal numerical gradation score for this factor. This determination reflects the inherent epistemic uncertainty in hemolysis model form at MRL 5 and is consistent with the team's risk-acceptance posture."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Model inputs",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 4,
      "achievedLevel": 3,
      "acceptanceCriteria": "All model input parameters (viscosity, density, hemolysis constants, turbulence model coefficients) must have documented sources with uncertainty bounds; Monte Carlo propagation must quantify combined input uncertainty on MIH.",
      "rationale": "Monte Carlo UQ propagates uncertainty across 11 input parameters. The 95th-percentile MIH prediction remains below the clinical threshold at four of five operating points. Hemolysis model constants (C, \u03b1, \u03b2) contribute 68% of total output variance. AchievedLevel 3 reflects documented but wide uncertainty bounds on the power-law constants."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Test samples",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Experimental hemolysis measurements must be based on a minimum of three independent test replicates per operating point, with inter-replicate variability reported.",
      "rationale": "The FDA generic pump dataset provides five replicates per operating point. Inter-replicate coefficient of variation ranges from 4.2% to 9.7% across operating conditions. Sample representativeness is adequate for the validation comparison; achievedLevel 3 is confirmed."
    },
    {
      "type": "CredibilityFactor",
      "factorType": "Equivalency of input parameters",
      "factorStandard": "ASME-VV40-2018",
      "factorStatus": "assessed",
      "requiredLevel": 3,
      "achievedLevel": 3,
      "acceptanceCriteria": "Simulation input parameters must be demonstrably equivalent to the experimental conditions used in validation, with any differences quantified and their effect on QoI bounded.",
      "rationale": "Fluid viscosity, density, and inlet turbulence intensity are matched to experimental conditions. Minor differences in inlet velocity profile (plug vs. measured profile) are assessed via sensitivity run; MIH changes by less than 1.5%. Equivalency is confirmed within acceptable bounds."
    }
  ],
  "hasWeakener": [],
  "hasDecisionRecord": {
    "id": "https://uofa.net/synth/decision/cou2-vad-accepted-2026",
    "type": "DecisionRecord",
    "actor": "https://uofa.net/synth/actor/morrison-credibility-panel",
    "role": "Credibility assessment team",
    "outcome": "Accepted",
    "rationale": "The credibility assessment team reviewed all 13 ASME V&V 40 factors for the VAD hemolysis CFD model at MRL 5. Twelve factors were assigned structured requiredLevel and achievedLevel scores; the model form factor was evaluated qualitatively by an expert panel and judged sufficient given the conservative prediction bias and Monte Carlo UQ coverage. While several factors achieved levels one gradation below required, the combined weight of evidence\u2014including conservative MIH over-prediction, Monte Carlo uncertainty bounds below the clinical threshold at the primary operating points, and independent peer review of the model form\u2014supports an Accepted decision. The assessment team acknowledges residual uncertainty in the power-law hemolysis model form but concludes that the conservative bias provides adequate safety margin for a Class III device submission.",
    "decidedAt": "2026-04-19T00:00:00Z"
  },
