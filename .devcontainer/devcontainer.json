{
  "name": "UofA Development Environment",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "installMaven": "true"
    }
  },

  "postCreateCommand": "pip install -e '.[test,excel,extract,judge]' && cd src/weakener-engine && mvn package -q",

  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.vscode-yaml"
      ],
      "settings": {
        "json.schemas": [
          {
            "fileMatch": ["*.jsonld"],
            "url": "./spec/schemas/uofa.schema.json"
          }
        ]
      }
    }
  }
}
